async function loadDashboardStat() {

    try {

        const token = localStorage.getItem("token");

        const res = await fetch("/api/laporan-pembayaran", {

            headers: {

                Authorization: `Bearer ${token}`,
                Accept: "application/json"

            }

        });

        const json = await res.json();

        const data = Array.isArray(json.data)
            ? json.data
            : [];

        let total = 0;

        data.forEach(item => {

            total += Number(
                item.total || item.amount || 0
            );

        });

        const income =
            document.getElementById("todayIncome");

        if (income) {

            income.innerHTML =
                "Rp " +
                total.toLocaleString("id-ID");

        }

        const trx =
            document.getElementById("totalTrx");

        if (trx) {

            trx.innerHTML = data.length;

        }

    } catch (e) {

        console.log(e);

    }

}

async function showDetailTransaksi() {

    try {

        const token = localStorage.getItem("token");

        const res = await fetch("/api/laporan-pembayaran", {
            headers: {
                Authorization: `Bearer ${token}`,
                Accept: "application/json"
            }
        });

        const json = await res.json();

        const start = document.getElementById("filterStart")?.value || "";
        const end = document.getElementById("filterEnd")?.value || "";
        const status = document.getElementById("filterStatus")?.value || "";
        const nama = (document.getElementById("filterNama")?.value || "").toLowerCase();

        let data = json.data || [];

        if (start) {
            data = data.filter(item =>
                item.createdAt.substring(0, 10) >= start
            );
        }

        if (end) {
            data = data.filter(item =>
                item.createdAt.substring(0, 10) <= end
            );
        }

        if (status) {
            data = data.filter(item =>
                item.status === status
            );
        }

        if (nama) {
            data = data.filter(item =>
                (item.customer?.name || "")
                .toLowerCase()
                .includes(nama)
            );
        }

        let total = 0;
        let html = "";

        data.forEach((item, index) => {

            total += Number(item.total || 0);

            html += `
                <tr>
                    <td style="padding:8px;border:1px solid #ddd;text-align:center;">
                        ${index + 1}
                    </td>

                    <td style="padding:8px;border:1px solid #ddd;">
                        ${item.invoice_number || "-"}
                    </td>

                    <td style="padding:8px;border:1px solid #ddd;">
                        ${item.customer?.customer_id || "-"}
                    </td>

                    <td style="padding:8px;border:1px solid #ddd;">
                        ${item.customer?.name || "-"}
                    </td>

                    <td style="padding:8px;border:1px solid #ddd;text-align:right;">
                        Rp ${Number(item.total || 0).toLocaleString("id-ID")}
                    </td>

                    <td style="padding:8px;border:1px solid #ddd;text-align:center;">
                        ${item.status || "-"}
                    </td>

                    <td style="padding:8px;border:1px solid #ddd;text-align:center;">
                        ${new Date(item.createdAt).toLocaleDateString("id-ID")}
                    </td>
                </tr>
            `;

        });

        if (data.length === 0) {

            html = `
                <tr>
                    <td colspan="7" style="padding:15px;text-align:center;">
                        Tidak ada data
                    </td>
                </tr>
            `;

        }

        document.getElementById("detailTransaksiBody").innerHTML = html;

        document.getElementById("totalPemasukan").innerHTML =
            "Rp " + total.toLocaleString("id-ID");

        showView("detail-transaksi-view");

    } catch (err) {

        console.error(err);
        alert("Gagal memuat data transaksi.");

    }
}

function resetFilter(){

    document.getElementById("filterStart").value="";
    document.getElementById("filterEnd").value="";
    document.getElementById("filterStatus").value="";
    document.getElementById("filterNama").value="";

    showDetailTransaksi();

}

let currentUser = null;

async function loadDataUser() {

    try {

        const res = await fetch("/api/agen/profile", {
            method: "GET",
            credentials: "include"
        });

        const result = await res.json();

        console.log(result);

        if (!result.success) {
            alert(result.message);
            return;
        }

        currentUser = result.data;

        document.getElementById("userTableBody").innerHTML = `
            <tr>
                <td>
                    <button
                        onclick="editProfile()"
                        style="
                            background:#0891b2;
                            color:white;
                            border:none;
                            padding:5px 10px;
                            border-radius:5px;
                            cursor:pointer;
                        ">
                        ✏ Edit
                    </button>
                </td>

                <td>${currentUser.name || "-"}</td>
                <td>${currentUser.email || "-"}</td>
                <td>${currentUser.role?.name || "-"}</td>
                <td>Aktif</td>
            </tr>
        `;

    } catch (err) {

