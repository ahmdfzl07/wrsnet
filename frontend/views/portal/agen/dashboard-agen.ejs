async function simpanPembayaran() {

    

    const customer = customerData[currentCustomerIndex];

    if (!customer) {
        return alert("Pilih pelanggan!");
    }

    const nominal = document.getElementById("inputNominal").value;
    const keterangan = document.getElementById("inputKeterangan").value;
    const fileInput = document.getElementById("inputBukti");

    const formData = new FormData();

    formData.append("customer_id", customer.id);
    formData.append("amount", nominal);
    formData.append("total", nominal);
    formData.append("keterangan", keterangan);
    formData.append("period_month", new Date().getMonth() + 1);
    formData.append("period_year", new Date().getFullYear());

    if (fileInput.files.length > 0) {
        formData.append("bukti_foto", fileInput.files[0]);
    }

    try {

        const token = localStorage.getItem("token");

        const response = await fetch("/api/pembayaran", {
            method: "POST",
            headers: {
                Authorization: `Bearer ${token}`
            },
            body: formData
        });

        const result = await response.json();

        console.log("STATUS =", response.status);
        console.log("RESULT =", result);

        if (result.success) {

            alert("Pembayaran berhasil");

            await cariCustomer();
            await loadLaporan();
            await loadDashboardStat();

            showView("dashboard-target");

        } else {

            alert(result.message);

        }

    } catch (err) {

        console.log(err);
        alert(err.message);

    }

}
function populateForm(customer) {
    document.getElementById('inputCustomerId').value = customer.id;
    
    const selectPaket = document.getElementById('select-paket');
    selectPaket.innerHTML = `
        <option value="${customer.package.id}">
            ${customer.package.name} - Rp ${Number(customer.package.price).toLocaleString('id-ID')}
        </option>
    `;
        document.getElementById('inputNominal').value = customer.package.price;
}

async function loadLaporan() {

    try {

        const token = localStorage.getItem("token");

        const res = await fetch("/api/laporan-pembayaran", {
            method: "GET",
            headers: {
                Authorization: `Bearer ${token}`,
                Accept: "application/json"
            }
        });

        const result = await res.json();

        const tbody = document.getElementById("tabelLaporanBody");

        let total = 0;

        if (
            result.success &&
            Array.isArray(result.data) &&
            result.data.length > 0
        ) {

            tbody.innerHTML = result.data.map((item, index) => {

                const nominal = Number(
                    item.total || item.amount || 0
                );

                total += nominal;

                return `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${item.customer?.customer_id || "-"}</td>
                        <td>${item.customer?.name || "-"}</td>
                        <td>
                            Rp ${nominal.toLocaleString("id-ID")}
                        </td>
                        <td>${item.status || "-"}</td>
                        <td>
                            ${
                                item.createdAt
                                    ? new Date(item.createdAt)
                                          .toLocaleDateString("id-ID")
                                    : "-"
                            }
                        </td>
                    </tr>
                `;

            }).join("");

        } else {

            tbody.innerHTML = `
                <tr>
                    <td colspan="6" style="text-align:center">
                        Data tidak ditemukan
                    </td>
                </tr>
            `;

        }

        const totalElement =
            document.getElementById("totalPemasukan");

        if (totalElement) {

            totalElement.innerHTML =
                "Rp " +
                total.toLocaleString("id-ID");

        }

        const card =
            document.getElementById("totalTransaksiNominal");

        if (card) {

            card.innerHTML =
                "Rp " +
                total.toLocaleString("id-ID");

        }

    } catch (err) {

        console.error(err);

        document.getElementById(
            "tabelLaporanBody"
        ).innerHTML = `
            <tr>
                <td colspan="6" style="text-align:center">
                    Gagal memuat data
                </td>
            </tr>
        `;

    }

}

async function loadDashboardTotal() {

    try {

        const token = localStorage.getItem("token");

        const res = await fetch("/api/dashboard-total", {

            headers: {

                Authorization: `Bearer ${token}`,
