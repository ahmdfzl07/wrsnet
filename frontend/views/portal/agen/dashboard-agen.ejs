<script>
  let customerData = [];
 function showView(viewId){

    const views=[
        'main-content',
        'dashboard-target',
        'dashboard-agen-view',
        'view-data-user',
        'form-entry-pelanggan',
        'detail-customer-view',
        'form-pembayaran',
        'laporan-pembayaran',
        'detail-transaksi-view',
         'form-topup'
    ];

    views.forEach(function(v){

        const el=document.getElementById(v);

        if(el){
            el.classList.add('hidden');
        }

    });

    const target=document.getElementById(viewId);

    if(target){
        target.classList.remove('hidden');
    }

}
  function backToHome() { showView('main-content'); }
  async function cariCustomer() {
    const keyword = document.getElementById('keywordCustomer').value;
    try {
        const response = await fetch(
        `/api/agen/customers?search=${encodeURIComponent(keyword)}`
        );      const result = await response.json();
      customerData = Array.isArray(result.data) ? result.data : [result.data];
      let html = customerData.map((item, index) => `<tr><td>${index+1}</td><td><button class="btn-view" onclick="lihatCustomer(${index})">👁️</button></td><td>${item.customer_id}</td><td>${item.name}</td></tr>`).join('');
      document.getElementById('tableCustomerBody').innerHTML = html;
      document.getElementById('modalCustomer').style.display = 'block';
    } catch(err) { console.error(err); alert('Gagal mengambil data'); }
  }
  function closeCustomerModal() { document.getElementById('modalCustomer').style.display = 'none'; }
  let currentCustomerIndex = null;
  function lihatCustomer(index) {
    currentCustomerIndex = index;
  const c = customerData[index];
  const selectPaket = document.getElementById('select-paket');
  
  if (c.package) {
    const hargaFormat = Number(c.package.price).toLocaleString('id-ID');
    const optionText = `${c.name} - ${c.package.name} - Rp ${hargaFormat}`;
    
    selectPaket.innerHTML = `<option value="${c.package.id}">${optionText}</option>`;
  }
  if (!c) {
    alert('Data customer tidak ditemukan');
    return;
  }

  document.getElementById('customerDetailContent').innerHTML = `
    <div style="background:white; color:black; padding:20px; border-radius:10px; margin-top:15px; border: 1px solid #ccc; font-size: 14px;">
      <h3 style="margin-bottom:10px; color:#0891b2;">Detail Pelanggan</h3>
      <p><b>ID Pelanggan:</b> ${c.customer_id || '-'}</p>
      <p><b>Nama:</b> ${c.name || '-'}</p>
      <p><b>NIK:</b> ${c.nik || '-'}</p>
      <p><b>Alamat:</b> ${c.address || 'Tidak ada alamat'}</p>
      <p><b>No Tlp:</b> ${c.phone || '-'}</p>
      <p><b>Status:</b> ${c.status || '-'}</p>
      <hr style="margin: 10px 0;">
      <h4 style="margin-bottom:5px;">Info Paket</h4>
      <p><b>Paket:</b> ${c.package?.name || '-'}</p>
      <p><b>Harga:</b> Rp ${Number(c.package?.price || 0).toLocaleString('id-ID')}</p>
      <p><b>Jatuh Tempo:</b> ${c.latest_due_date || '-'}</p>
      <p><b>Status Tagihan:</b> <span style="color: ${c.latest_invoice_status === 'overdue' ? 'red' : 'green'}; font-weight:bold;">
        ${c.latest_invoice_status || '-'}
      </span></p>
      
      <div style="margin-top: 15px; display:flex; gap: 10px;">
        <button class="btn-view" style="background:#3b82f6;" onclick="lihatRiwayat(${index})">Riwayat</button>
      <button class="btn-view" style="background:#16a34a;" onclick="showView('form-pembayaran')">Bayar</button>
      </div>
    </div>
  `;

  closeCustomerModal();
  showView('detail-customer-view');
}
function lihatRiwayat(index) {
    const c = customerData[index];
    if (!c || !c.invoices) {
        alert('Data riwayat tidak tersedia');
        return;
    }

    let rows = c.invoices.map(inv => `
        <tr style="border-bottom: 1px solid #dee2e6;">
            <td style="padding:12px;">${inv.invoice_number}</td>
            <td style="padding:12px;">${c.package_id || '-'}</td>
            <td style="padding:12px;">${c.package?.name || '-'}</td>
            <td style="padding:12px;">Rp ${Number(c.package?.price || 0).toLocaleString('id-ID')}</td>
            <td style="padding:12px;">Rp ${Number(c.package?.price || 0).toLocaleString('id-ID')}</td>
            <td style="padding:12px;">${inv.period_month}/${inv.period_year}</td>
            <td style="padding:12px; font-weight:bold; color: ${inv.status === 'overdue' ? 'red' : 'inherit'};">
                ${inv.status === 'overdue' ? 'Belum Lunas' : 'Lunas'}
            </td>
            <td style="padding:12px;">${inv.paid_date || ''}</td>
            <td style="padding:12px;">-</td>
            <td style="padding:12px;">-</td>
            <td style="padding:12px;">
                ${inv.status !== 'overdue' ? `
                    <button class="btn-view" style="font-size:10px; background:#007bff; border:none; color:white; padding:5px; margin-right:2px;">Download bukti</button>
                    <button class="act-btn act-inv" onclick="openInvoiceByInvId(${inv.id})">
                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>Invoice
                    </button>
                    <button class="btn-view" style="font-size:10px; background:#17a2b8; border:none; color:white; padding:5px;">➤ Kirim</button>
                ` : ''}
            </td>
        </tr>
    `).join('');

    document.getElementById('customerDetailContent').innerHTML = `
        <div style="background:white; color:black; padding:20px; overflow-x: auto;">
            <h3>Histori Pembayaran</h3>
            <table style="width:100%; border-collapse:collapse; margin-top:15px; font-size:12px;">
                <thead>
                    <tr style="background:#f8f9fa; border-bottom:2px solid #dee2e6;">
                        <th style="padding:12px; text-align:left;">No Invoice</th>
                        <th style="padding:12px; text-align:left;">ID Paket</th>
                        <th style="padding:12px; text-align:left;">Nama Paket</th>
                        <th style="padding:12px; text-align:left;">Harga</th>
                        <th style="padding:12px; text-align:left;">Jumlah Bayar</th>
                        <th style="padding:12px; text-align:left;">Periode</th>
                        <th style="padding:12px; text-align:left;">Status</th>
                        <th style="padding:12px; text-align:left;">Waktu Pembayaran</th>
                        <th style="padding:12px; text-align:left;">Metode</th>
                        <th style="padding:12px; text-align:left;">Keterangan</th>
                        <th style="padding:12px; text-align:left;">Aksi</th>
                    </tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>
        </div>
    `;
    showView('detail-customer-view');
}

