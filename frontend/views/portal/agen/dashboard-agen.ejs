    }

}

window.saveProfile = async function () {

    const body = {
        name: document.getElementById("editName").value,
        username: document.getElementById("editUsername").value,
        password: document.getElementById("editPassword").value
    };

    const res = await fetch("/api/profile", {
        method: "PUT",
        headers: {
            "Content-Type": "application/json",
            Authorization: "Bearer " + localStorage.getItem("token")
        },
        body: JSON.stringify(body)
    });

    const result = await res.json();

    if (result.success) {

        alert("Profile berhasil diupdate");

        currentUser.name = body.name;
        currentUser.email = body.username;

        loadDataUser();

        document.getElementById("modalEditProfile").classList.add("hidden");

    } else {
        alert(result.message);
    }
};

window.editProfile = function () {

    if (!currentUser) {
        alert("User belum dimuat");
        return;
    }

    document.getElementById("editName").value = currentUser.name || "";
    document.getElementById("editUsername").value = currentUser.email || "";
    document.getElementById("editPassword").value = "";

    document.getElementById("modalEditProfile").classList.remove("hidden");
};

async function loadDashboardAgen() {
  try {

    const token = localStorage.getItem("token");
    const date = document.getElementById("filterDate")?.value || "2026-06-01";

    const res = await fetch(`/api/agen/dashboard?date=${date}`, {
      headers: {
        Authorization: `Bearer ${token}`,
        Accept: "application/json"
      }
    });

    const result = await res.json();

    if (!result.success) return;

    const data = result.data.list;

    const tbody = document.getElementById("agenTableBody");

    tbody.innerHTML = data.map((item, i) => `
      <tr>
        <td>
          <button>👁️</button>
          <button>💵</button>
        </td>
        <td>${i + 1}</td>
        <td>${item.nama_sales}</td>
        <td>${item.alamat}</td>

        <td>${item.jumlah_pelanggan}</td>
        <td>${item.pelanggan_lunas}</td>
        <td>${item.pelanggan_belum_lunas}</td>

        <td>Rp ${num(item.pemasukan)}</td>
        <td>Rp ${num(item.pengeluaran)}</td>
        <td>Rp ${num(item.insentif)}</td>
        <td>Rp ${num(item.balance)}</td>

        <td>Rp ${num(item.cash)}</td>
        <td>Rp ${num(item.transfer)}</td>
        <td>Rp ${num(item.cash_disetor)}</td>
        <td>Rp ${num(item.cash_belum_setor)}</td>

        <td>Rp ${num(item.est_pemasukan)}</td>
        <td>Rp ${num(item.est_insentif)}</td>
        <td>Rp ${num(item.est_bersih)}</td>
      </tr>
    `).join('');

    // SUMMARY
    document.getElementById("totalPelanggan").innerText = result.data.total_pelanggan;
    document.getElementById("totalIncome").innerText = rupiah(result.data.total_income);
    document.getElementById("totalInsentif").innerText = rupiah(result.data.total_insentif);
    document.getElementById("totalSetor").innerText = rupiah(result.data.total_setor);

    document.getElementById("agenHeader").innerText =
      `ℹ️ Dashboard Sales Bulan ${result.data.month_text}`;

  } catch (err) {
    console.log(err);
  }
}

function num(val) {
  return new Intl.NumberFormat('id-ID').format(val || 0);
}

function rupiah(val) {
  return "Rp " + new Intl.NumberFormat('id-ID').format(val || 0);
}

function renderAgenTable(data) {
  const tbody = document.getElementById("agenTableBody");

  if (!data || data.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6">Tidak ada data</td></tr>`;
    return;
  }

  tbody.innerHTML = data.map((item, index) => `
    <tr>
      <td>
        <button onclick="viewAgen(${item.id})">👁️</button>
        <button onclick="topupAgen(${item.id})">💵</button>
      </td>
      <td>${index + 1}</td>
      <td>${item.name}</td>
      <td>${item.address || '-'}</td>
      <td>${item.total_customer}</td>
      <td>Rp ${new Intl.NumberFormat('id-ID').format(item.total_income)}</td>
    </tr>
  `).join('');
}


async function submitTopup() {

    if (!currentUser) {
        alert("User belum dimuat, silakan refresh halaman.");
        return;
    }

    const amount =
        document.getElementById("topupAmount").value;

    const payment_method =
        document.getElementById("topupMethod").value;

    const description =
        document.getElementById("topupNote").value;

    const proof =
        document.getElementById("topupProof").files[0];

    if (!amount || Number(amount) <= 0) {
        alert("Masukkan nominal yang benar.");
        return;
    }

    const formData = new FormData();

    formData.append("user_id", currentUser.id);
    formData.append("amount", amount);
    formData.append("payment_method", payment_method);
    formData.append("description", description);

    if (proof) {
        formData.append("proof", proof);
    }

    console.log({
        user_id: currentUser.id,
        amount,
        payment_method,
        description
    });

    try {

        const res = await fetch("/api/topup", {
            method: "POST",
            body: formData,
            credentials: "include"
        });

        const result = await res.json();

        console.log(result);

        if (result.success) {

            alert(result.message);

            document.getElementById("topupAmount").value = "";
            document.getElementById("topupNote").value = "";
            document.getElementById("topupProof").value = "";

        } else {

            alert(result.message);

        }

    } catch (err) {

        console.log(err);

        alert("Terjadi kesalahan server");

    }

}

