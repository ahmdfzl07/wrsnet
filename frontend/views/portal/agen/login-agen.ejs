<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login Agen</title>

  <style>

    body{
      font-family:Arial;
      background:#0f172a;
      display:flex;
      justify-content:center;
      align-items:center;
      height:100vh;
      margin:0;
    }

    .card{
      width:350px;
      background:#fff;
      padding:30px;
      border-radius:16px;
    }

    input{
      width:100%;
      padding:12px;
      margin-bottom:15px;
      border:1px solid #ccc;
      border-radius:8px;
      box-sizing:border-box;
    }

    button{
      width:100%;
      padding:12px;
      border:none;
      background:#2563eb;
      color:#fff;
      border-radius:8px;
      cursor:pointer;
      font-size:16px;
    }

  </style>

</head>
<body>

<div class="card">

  <h2>Login Agen</h2>

  <form id="loginForm">

    <input
      type="text"
      id="username"
      placeholder="Username"
      required
    />

    <input
      type="password"
      id="password"
      placeholder="Password"
      required
    />

    <button type="submit">
      Login
    </button>

  </form>

</div>

<script>

document
  .getElementById('loginForm')
  .addEventListener('submit', async function(e){

    e.preventDefault();

    const username =
      document.getElementById('username').value.trim();

    const password =
      document.getElementById('password').value.trim();

    console.log(username);
    console.log(password);

    try {

      const response = await fetch(
        '/portal/api/agen/login',
        {
          method:'POST',
          headers:{
            'Content-Type':'application/json'
          },
          body:JSON.stringify({
            username: username,
            password: password
          })
        }
      );

      const result = await response.json();

      console.log(result);

      if(!result.success){

        alert(result.message);

        return;

      }

     if(result.success){

  window.location.href =
    '/portal/agen/dashboard-agen';

}

      window.location.href =
        '/portal/agen/dashboard-agen';

    } catch(err){

      console.log(err);

      alert('Server error');

    }

});

</script>

</body>
</html>