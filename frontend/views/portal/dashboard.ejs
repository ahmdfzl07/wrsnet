// ── Submit: buka WhatsApp dengan pesan konfirmasi pembayaran ──

async function confirmPayment() {
  if (!PAY_CONTEXT.invoice_id) return;

  var btn = document.getElementById('btnConfirmPay');
  btn.disabled = true;

  try {
    var r = await fetch('/portal/api/pay', {
      method: 'POST', headers: authH(),
      body: JSON.stringify({ invoice_id: PAY_CONTEXT.invoice_id, mode: 'manual' })
    });
    var j = await r.json();

    if (!j.success) {
      toast(j.message || 'Gagal membuat konfirmasi', true);
      btn.disabled = false;
      return;
    }

    if (j.mode === 'manual' && j.wa_url) {
      closeModal('modalPay');
      window.open(j.wa_url, '_blank');
      toast('WhatsApp dibuka, kirim bukti transfer ya');
    } else if (j.wa_url) {
      closeModal('modalPay');
      window.open(j.wa_url, '_blank');
    } else {
      toast(j.message || 'Silakan hubungi admin', true);
    }
  } catch(e) {
    toast('Error: ' + e.message, true);
  } finally {
    btn.disabled = false;
  }
}


