async function _loadTaxCfg() {
  if (_TAX_CFG_CACHE) return _TAX_CFG_CACHE;
  try {
    var res = await fetch('/api/app-settings/tax');
    var d = await res.json();
    _TAX_CFG_CACHE = (d && d.success) ? d.data : null;
  } catch(e) { _TAX_CFG_CACHE = null; }
  return _TAX_CFG_CACHE;
}

