            <div style="font-size:11px;color:#4ade80;margin-top:1px" id="pushDeviceCount">— perangkat terdaftar</div>
          </div>
        </div>
        <button class="btn-reboot" style="background:linear-gradient(135deg,#64748b,#475569)" id="btnDisablePush" onclick="disablePush()">
          Nonaktifkan Notifikasi
        </button>
      </div>
    </div>
  </div>

