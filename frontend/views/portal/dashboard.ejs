      <div>
        <div class="pkg-label">Package Detail</div>
        <div class="pkg-name">
          <div class="pkg-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>
          </div>
          <span id="inetPkgName">Internet</span>
