function fmtBytes(b){
  b = parseInt(b)||0;
  if(b>=1073741824) return (b/1073741824).toFixed(2)+' GB';
  if(b>=1048576) return (b/1048576).toFixed(1)+' MB';
  if(b>=1024) return Math.round(b/1024)+' KB';
  return b+' B';
}

var _chartRange = '1d';
var _chartLoading = false;
var _chartLiveTimer = null;
var _chartLiveData  = [];
var _chartMode = 'live';

async function fetchLiveMikrotik() {
  try {
    var portalCustomer = JSON.parse(localStorage.getItem('portal_customer') || '{}');
    var custId = portalCustomer.customer_id;

    if (!custId) return null;

    var r = await fetch('/portal/mikrotik/customer-traffic', {
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'Authorization': 'Bearer ' + (localStorage.getItem('token') || ''),
        'X-Customer-Id': custId
      }
    });

    var j = await r.json();
    if (!j || !j.success || !j.data) return null;

    return {
      rx_mbps: (j.data.rateDown || 0) / 1e6,
      tx_mbps: (j.data.rateUp || 0) / 1e6
    };

  } catch (e) {
    console.log('live error', e);
    return null;
  }
}

function startLiveChart() {
  stopLiveChart();

  _chartLiveData = [];

  _chartLiveTimer = setInterval(async function () {
    if (_chartMode !== 'live') return;

    var d = await fetchLiveMikrotik();
    if (!d) return;

    _chartLiveData.push(d);

    if (_chartLiveData.length > 60) {
      _chartLiveData.shift();
    }

    drawTrafficChart(document.getElementById('usageChartSvg'), _chartLiveData);
    updateChartStats(_chartLiveData);

  }, 3000);
}

async function pushLiveSample() {
  var d = await fetchLiveMikrotik();
  if (!d) return;

  _chartLiveData.push(d);

  if (_chartLiveData.length > 60) {
    _chartLiveData.shift();
  }

  drawTrafficChart(document.getElementById('usageChartSvg'), _chartLiveData);
  updateChartStats(_chartLiveData);
}

function stopLiveChart() {
  if (_chartLiveTimer) {
    clearInterval(_chartLiveTimer);
    _chartLiveTimer = null;
  }
}

async function loadTraffic() {
  try {
    var r = await fetch('/portal/api/traffic?range=3d', { headers: authH() });
    var j = await r.json();
    if (j.success) {
      var cur   = j.data.current;
      var usage = j.usage || {};
      // var rxBytes = usage.total_rx_bytes || (cur && cur.bytesDown) || 0;
      // var txBytes = usage.total_tx_bytes || (cur && cur.bytesUp)   || 0;
      var rxBytes = cur?.bytesDown || 0;
      var txBytes = cur?.bytesUp   || 0;

      function splitBytes(b) {
        b = parseFloat(b) || 0;
        if (b >= 1e12) return { val: (b/1e12).toFixed(2), unit: 'TB' };
        if (b >= 1e9)  return { val: (b/1e9).toFixed(2),  unit: 'GB' };
        if (b >= 1e6)  return { val: (b/1e6).toFixed(1),  unit: 'MB' };
        if (b >= 1e3)  return { val: (b/1e3).toFixed(0),  unit: 'KB' };
        return { val: b, unit: 'B' };
      }
      var dl = splitBytes(rxBytes), ul = splitBytes(txBytes);
      document.getElementById('usageDlVal').innerHTML = dl.val + ' <span style="font-size:13px;font-weight:600;opacity:.8">' + dl.unit + '</span>';
      document.getElementById('usageUlVal').innerHTML = ul.val + ' <span style="font-size:13px;font-weight:600;opacity:.8">' + ul.unit + '</span>';

      var rateDown = cur ? parseFloat(cur.rateDown || 0) : 0;
      var rateUp   = cur ? parseFloat(cur.rateUp   || 0) : 0;
      document.getElementById('usageDlRate').textContent = rateDown > 0 ? '↓ ' + fmtBps(rateDown) + ' real-time' : '3 hari terakhir';
      document.getElementById('usageUlRate').textContent = rateUp   > 0 ? '↑ ' + fmtBps(rateUp)   + ' real-time' : '';
    }
  } catch(e) { console.error('Traffic totals:', e); }

  initChartTabs();
  loadTrafficChart(_chartRange);
}

function initChartTabs() {
  var tabs = document.getElementById('usageChartTabs');
  if (!tabs || tabs._bound) return;
  tabs._bound = true;
  tabs.querySelectorAll('.ct-tab').forEach(function(b) {
    b.addEventListener('click', function() {
      var range = b.getAttribute('data-range');
      if (range === _chartRange) return;
      _chartRange = range;
      tabs.querySelectorAll('.ct-tab').forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      loadTrafficChart(range);
    });
  });
}

async function loadTrafficChart(range) {
  if (_chartLoading) return;
  _chartLoading = true;

  stopLiveChart();

  var empty = document.getElementById('chartEmpty');
  var svg   = document.getElementById('usageChartSvg');

  empty.style.display = 'flex';
  empty.innerHTML = '<div class="uc-spinner"></div><span>Memuat data…</span>';
  svg.style.display = 'none';

  try {

    if (range === 'live') {
      startLiveChart();
      empty.style.display = 'none';
      svg.style.display = 'block';
      _chartLoading = false;
      return;
    }

    var data = await buildHistoryFromMikrotik(range);

    if (!data || data.length < 2) {
      empty.innerHTML = 'Belum ada data live buffer';
      _chartLoading = false;
      return;
    }

    drawTrafficChart(svg, data);
    updateChartStats(data);

    empty.style.display = 'none';
    svg.style.display = 'block';

  } catch (e) {
    console.error(e);
    empty.innerHTML = 'Error load chart';
  } finally {
    _chartLoading = false;
  }
}

async function buildHistoryFromMikrotik(range) {
  return new Promise(async function(resolve) {
    var maxPoints =
      range === '1h' ? 20 :
      range === '1d' ? 40 :
      range === '3d' ? 80 : 40;

    var arr = [];

    for (let i = 0; i < maxPoints; i++) {
      var d = await fetchLiveMikrotik();
      if (d) arr.push(d);

      await new Promise(r => setTimeout(r, 1500));
    }

    resolve(arr);
  });
}

function _rangeLabel(r) {
  return { '1h':'1 jam', '1d':'1 hari', '3d':'3 hari', '30d':'30 hari' }[r] || r;
}

function updateChartStats(hist) {
  var sumRx=0, sumTx=0, maxRx=0, maxTx=0;
  hist.forEach(function(p){
    var rx = p.rx_mbps || 0, tx = p.tx_mbps || 0;
    var mrx = p.max_rx_mbps || rx, mtx = p.max_tx_mbps || tx;
    sumRx += rx; sumTx += tx;
    if (mrx > maxRx) maxRx = mrx;
    if (mtx > maxTx) maxTx = mtx;
  });
  var avgRx = sumRx / hist.length, avgTx = sumTx / hist.length;
  function fmtMbps(v) {
    if (v >= 1) return v.toFixed(2) + ' Mbps';
    return (v * 1000).toFixed(0) + ' Kbps';
  }
  document.getElementById('chartAvgDl').textContent  = fmtMbps(avgRx);
  document.getElementById('chartPeakDl').textContent = fmtMbps(maxRx);
  document.getElementById('chartAvgUl').textContent  = fmtMbps(avgTx);
  document.getElementById('chartPeakUl').textContent = fmtMbps(maxTx);
}

// Render SVG dual-area chart
function drawTrafficChart(svg, hist) {
  var W = 400, H = 140, padL = 4, padR = 4, padT = 8, padB = 16;
  var innerW = W - padL - padR, innerH = H - padT - padB;
  var n = hist.length;

  // Normalize values
  var maxVal = 0.1; // minimum supaya chart kelihatan walau semua 0
  hist.forEach(function(p){
    if ((p.rx_mbps||0) > maxVal) maxVal = p.rx_mbps;
    if ((p.tx_mbps||0) > maxVal) maxVal = p.tx_mbps;
  });
  maxVal = maxVal * 1.15; // headroom 15%

  function xPos(i) { return padL + (n === 1 ? innerW/2 : (i / (n - 1)) * innerW); }
  function yPos(v) { return padT + innerH - ((v || 0) / maxVal) * innerH; }

  // Build SVG paths (smoothed via simple catmull-rom-ish bezier)
  function buildPath(accessor) {
    var pts = hist.map(function(p, i){ return [xPos(i), yPos(accessor(p))]; });
    if (pts.length === 1) return 'M ' + pts[0][0] + ' ' + pts[0][1];
    var d = 'M ' + pts[0][0].toFixed(2) + ' ' + pts[0][1].toFixed(2);
    for (var i = 1; i < pts.length; i++) {
      var p0 = pts[i-1], p1 = pts[i];
      var cx = (p0[0] + p1[0]) / 2;
      d += ' C ' + cx.toFixed(2) + ' ' + p0[1].toFixed(2) +
           ', ' + cx.toFixed(2) + ' ' + p1[1].toFixed(2) +
           ', ' + p1[0].toFixed(2) + ' ' + p1[1].toFixed(2);
    }
    return d;
  }
  function buildAreaPath(accessor) {
    var line = buildPath(accessor);
    var lastX = xPos(n - 1), firstX = xPos(0);
    return line + ' L ' + lastX.toFixed(2) + ' ' + (padT + innerH) +
                ' L ' + firstX.toFixed(2) + ' ' + (padT + innerH) + ' Z';
  }

  var dlLine = buildPath(function(p){ return p.rx_mbps || 0; });
  var ulLine = buildPath(function(p){ return p.tx_mbps || 0; });
  var dlArea = buildAreaPath(function(p){ return p.rx_mbps || 0; });
  var ulArea = buildAreaPath(function(p){ return p.tx_mbps || 0; });

  // Gridlines (3 horizontal)
  var grid = '';
  for (var g = 0; g <= 3; g++) {
    var gy = padT + (innerH * g / 3);
    grid += '<line x1="' + padL + '" y1="' + gy + '" x2="' + (W - padR) + '" y2="' + gy + '" stroke="#e2e8f0" stroke-width="0.5" stroke-dasharray="2,3"/>';
  }

  // Time labels (first, middle, last)
  function fmtTime(ts) {
    if (!ts) return '';
    var d = new Date(ts);
    var r = _chartRange;
    if (r === '1h' || r === '1d') return d.toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit' });
    if (r === '3d') return d.toLocaleDateString('id-ID', { day:'2-digit', month:'short' }) + ' ' + d.getHours() + ':00';
    return d.toLocaleDateString('id-ID', { day:'2-digit', month:'short' });
  }
  var labels = '';
  var firstT = fmtTime(hist[0].time);
  var midT   = fmtTime(hist[Math.floor(n/2)].time);
  var lastT  = fmtTime(hist[n-1].time);
  labels += '<text x="' + (padL + 2) + '" y="' + (H - 3) + '" font-size="9" fill="#94a3b8">' + firstT + '</text>';
  labels += '<text x="' + (W/2) + '" y="' + (H - 3) + '" font-size="9" fill="#94a3b8" text-anchor="middle">' + midT + '</text>';
  labels += '<text x="' + (W - padR - 2) + '" y="' + (H - 3) + '" font-size="9" fill="#94a3b8" text-anchor="end">' + lastT + '</text>';

  // Scale indicator
  var scaleTop = maxVal >= 1 ? maxVal.toFixed(1) + ' Mbps' : (maxVal * 1000).toFixed(0) + ' Kbps';

  svg.innerHTML =
    '<defs>' +
      '<linearGradient id="gradDl" x1="0" y1="0" x2="0" y2="1">' +
        '<stop offset="0%" stop-color="#2563eb" stop-opacity="0.35"/>' +
        '<stop offset="100%" stop-color="#2563eb" stop-opacity="0"/>' +
      '</linearGradient>' +
      '<linearGradient id="gradUl" x1="0" y1="0" x2="0" y2="1">' +
        '<stop offset="0%" stop-color="#10b981" stop-opacity="0.35"/>' +
        '<stop offset="100%" stop-color="#10b981" stop-opacity="0"/>' +
      '</linearGradient>' +
    '</defs>' +
    grid +
    '<path d="' + dlArea + '" fill="url(#gradDl)"/>' +
    '<path d="' + ulArea + '" fill="url(#gradUl)"/>' +
    '<path d="' + dlLine + '" fill="none" stroke="#2563eb" stroke-width="1.5" stroke-linejoin="round"/>' +
    '<path d="' + ulLine + '" fill="none" stroke="#10b981" stroke-width="1.5" stroke-linejoin="round"/>' +
    labels +
    '<text x="' + (W - padR - 2) + '" y="' + (padT + 8) + '" font-size="8.5" fill="#94a3b8" text-anchor="end">' + scaleTop + '</text>';

  // Bind hover tooltip (pakai pointerMove, cari titik terdekat)
  _bindChartTooltip(svg, hist, xPos, yPos, W, H);
}

function _bindChartTooltip(svg, hist, xPos, yPos, W, H) {
  var area = svg.parentElement;
  var tt = document.getElementById('chartTooltip');
  function onMove(ev) {
    var rect = svg.getBoundingClientRect();
    var clientX = (ev.touches && ev.touches[0]) ? ev.touches[0].clientX : ev.clientX;
    var px = ((clientX - rect.left) / rect.width) * W;
    // Cari index terdekat
    var bestI = 0, bestD = Infinity;
    for (var i = 0; i < hist.length; i++) {
      var d = Math.abs(xPos(i) - px);
      if (d < bestD) { bestD = d; bestI = i; }
    }
    var p = hist[bestI];
    var t = p.time ? new Date(p.time).toLocaleString('id-ID', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) : '';
    tt.innerHTML =
      '<b>' + t + '</b><br>' +
      '<span class="tt-dl">↓ ' + ((p.rx_mbps||0) >= 1 ? (p.rx_mbps).toFixed(2) + ' Mbps' : ((p.rx_mbps||0)*1000).toFixed(0) + ' Kbps') + '</span><br>' +
      '<span class="tt-ul">↑ ' + ((p.tx_mbps||0) >= 1 ? (p.tx_mbps).toFixed(2) + ' Mbps' : ((p.tx_mbps||0)*1000).toFixed(0) + ' Kbps') + '</span>';
    var xPx = (xPos(bestI) / W) * rect.width;
    var yPx = (yPos(Math.max(p.rx_mbps||0, p.tx_mbps||0)) / H) * rect.height;
    tt.style.left = xPx + 'px';
    tt.style.top  = yPx + 'px';
    tt.classList.add('show');
  }
  function onLeave() { tt.classList.remove('show'); }
  svg.addEventListener('pointermove', onMove);
  svg.addEventListener('pointerleave', onLeave);
  svg.addEventListener('touchmove', onMove, { passive: true });
  svg.addEventListener('touchend',  onLeave);
}

