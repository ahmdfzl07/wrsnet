let paymentController = null;

function closeLoading() {
  document.getElementById("paymentLoading").style.display = "none";
}

async function payAuto() {
  try {

    document.getElementById("paymentLoading").style.display = "flex";

    const response = await fetch("/api/payment/create", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        invoice_id: PAY_CONTEXT.invoice_id,
        method: selectedPaymentMethod
      }),
    });

    const res = await response.json();

    if (!res.success) {
      document.getElementById("paymentLoading").style.display = "none";
      alert(res.message);
      return;
    }

    setTimeout(() => {
      window.location.href = res.payment_url;
    }, 500);

  } catch (err) {
    console.error(err);

    document.getElementById("paymentLoading").style.display = "none";
    alert("Gagal pembayaran");
  }
}

async function payOnline(provider, method, fee = 0) {
  try {

    const response = await fetch("/api/payment/create", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        provider: provider,
        invoice_id: PAY_CONTEXT.invoice_id,
        method: method,
        admin_fee: fee
      }),
    });

    const res = await response.json();

    if (!res.success) {
      alert(res.message || "Gagal");
      return;
    }

    if (res.payment_url) {
      window.location.href = res.payment_url;
    }

  } catch (err) {
    console.error(err);
    alert("Error pembayaran");
  }
}

