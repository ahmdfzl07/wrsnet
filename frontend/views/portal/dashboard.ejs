<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#2563eb">
  <title>Customer Portal</title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root{
      --font:'Plus Jakarta Sans',sans-serif;
      --blue:#2563eb;--blue2:#1d4ed8;--blue3:#1e40af;
      --teal:#06b6d4;--green:#10b981;--red:#ef4444;--amber:#f59e0b;--orange:#f97316;
      --bg:#f1f5f9;--card:#fff;--border:#e2e8f0;
      --text:#0f172a;--muted:#64748b;--radius:18px;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100dvh;overflow-x:hidden;max-width:480px;margin:0 auto;}

    /* ═══ HERO ═══ */
    .hero{background: #020e2e; padding:22px 20px 68px;position:relative;overflow:hidden;}
    .hero-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;position:relative;z-index:1;}
    .hero-user{display:flex;align-items:center;gap:11px;}
    .hu-avatar{width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:16px;flex-shrink:0;}
    .hu-name{font-size:15px;font-weight:700;color:#fff;line-height:1.2;}
    .hu-sub{font-size:11px;color:rgba(255,255,255,.65);margin-top:2px;display:flex;align-items:center;gap:6px;}
    .hu-badge{padding:1px 7px;border-radius:20px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;}
    .badge-active{background:rgba(16,185,129,.25);color:#6ee7b7;}
    .badge-isolated{background:rgba(239,68,68,.25);color:#fca5a5;}
    .badge-inactive{background:rgba(100,116,139,.25);color:#cbd5e1;}
    .hero-btns{display:flex;gap:6px;}
    .hbtn{width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,.1);border:none;display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.75);cursor:pointer;transition:all .2s;}
    .hbtn:hover{background:rgba(255,255,255,.2);color:#fff;}
    .credit-row{position:relative;z-index:1;display:flex;align-items:flex-end;justify-content:space-between;}
    .cr-lbl{font-size:11px;color:rgba(255,255,255,.55);font-weight:600;text-transform:uppercase;letter-spacing:.5px;}
    .cr-amount{font-size:28px;font-weight:800;color:#fff;letter-spacing:-1px;line-height:1.1;margin-top:3px;}
    .cr-sub{font-size:10px;color:rgba(255,255,255,.5);margin-top:4px;font-weight:600;letter-spacing:.4px;}
    .btn-bayar{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.15);backdrop-filter:blur(8px);border:1.5px solid rgba(255,255,255,.25);color:#fff;padding:9px 16px;border-radius:12px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer;transition:all .2s;}
    .btn-bayar:hover{background:rgba(255,255,255,.25);}
    .btn-bayar.hidden{display:none;}

    /* ═══ PACKAGE DETAIL CARD ═══ */
    .inet-float{margin:-52px 16px 0;position:relative;z-index:10;}
    .inet-card{background:linear-gradient(145deg,#1e40af 0%,#2563eb 60%,#0284c7 100%);border-radius:var(--radius);padding:18px 20px 20px;box-shadow:0 12px 36px rgba(37,99,235,.35);position:relative;overflow:hidden;}
    /* Header row */
    .pkg-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;position:relative;z-index:1;}
    .pkg-label{font-size:10px;font-weight:700;color:rgba(255,255,255,.6);text-transform:uppercase;letter-spacing:.6px;}
    .pkg-name{font-size:15px;font-weight:800;color:#fff;margin-top:2px;display:flex;align-items:center;gap:8px;}
    .pkg-icon{width:28px;height:28px;border-radius:8px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;}
    /* Progress bar */
    .pkg-bar-wrap{position:relative;z-index:1;margin-bottom:6px;}
    .pkg-bar{height:6px;background:rgba(255,255,255,.2);border-radius:99px;overflow:hidden;}
    .pkg-bar-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,#fbbf24,#f59e0b);transition:width .7s;}
    .pkg-bar-labels{display:flex;justify-content:space-between;margin-top:5px;margin-bottom:14px;}
    .pkg-bar-labels span{font-size:10px;color:rgba(255,255,255,.55);font-weight:500;}
    .pkg-bar-labels span.right{text-align:right;}
    /* Stats row */
    .pkg-stats{display:flex;justify-content:space-between;padding-top:14px;border-top:1px solid rgba(255,255,255,.12);position:relative;z-index:1;}
    .ps-item{flex:1;text-align:center;position:relative;}
    .ps-item+.ps-item::before{content:'';position:absolute;left:0;top:10%;height:80%;width:1px;background:rgba(255,255,255,.15);}
    .ps-icon{width:32px;height:32px;border-radius:10px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;margin:0 auto 7px;color:#fff;}
    .ps-val{font-size:13px;font-weight:800;color:#fff;line-height:1;}
    .ps-lbl{font-size:9px;color:rgba(255,255,255,.55);font-weight:600;text-transform:uppercase;letter-spacing:.3px;margin-top:3px;}

    /* ═══ CONTENT ═══ */
    .content{padding:18px 16px 88px;}

    /* Notif banner */
    .notif-banner{display:none;background:linear-gradient(135deg,#fef3c7,#fffbeb);border:1.5px solid #fde68a;border-radius:14px;padding:14px 16px;margin-bottom:16px;cursor:pointer;}
    .notif-banner.overdue{background:linear-gradient(135deg,#fee2e2,#fff1f2);border-color:#fca5a5;}
    .notif-banner.isolated{background:linear-gradient(135deg,#fee2e2,#fff1f2);border-color:#fca5a5;}
    .nb-row{display:flex;align-items:center;gap:12px;}
    .nb-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .nb-icon.warn{background:#fde68a;color:#d97706;}
    .nb-icon.danger{background:#fca5a5;color:#dc2626;}
    .nb-text{flex:1;min-width:0;}
    .nb-title{font-size:13px;font-weight:700;}
    .nb-sub{font-size:11px;color:var(--muted);margin-top:1px;}

    /* ═══ ANNOUNCEMENT BANNERS ═══ */
    .ann-wrap{margin-bottom:14px;}
    .ann-item{border-radius:14px;padding:13px 14px;margin-bottom:8px;position:relative;cursor:default;animation:fadeUp .3s ease;}
    .ann-item:last-child{margin-bottom:0;}
    .ann-item.gangguan{background:linear-gradient(135deg,#fee2e2,#fff1f2);border:1.5px solid #fca5a5;}
    .ann-item.maintenance{background:linear-gradient(135deg,#fef3c7,#fffbeb);border:1.5px solid #fde68a;}
    .ann-item.info{background:linear-gradient(135deg,#eff6ff,#f0f9ff);border:1.5px solid #bfdbfe;}
    .ann-item.promo{background:linear-gradient(135deg,#f0fdf4,#ecfdf5);border:1.5px solid #86efac;}
    .ann-row{display:flex;align-items:flex-start;gap:11px;}
    .ann-icon{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .ann-item.gangguan .ann-icon{background:#fca5a5;color:#dc2626;}
    .ann-item.maintenance .ann-icon{background:#fde68a;color:#d97706;}
    .ann-item.info .ann-icon{background:#bfdbfe;color:#1d4ed8;}
    .ann-item.promo .ann-icon{background:#86efac;color:#15803d;}
    .ann-body{flex:1;min-width:0;}
    .ann-type{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.6px;margin-bottom:3px;}
    .ann-item.gangguan .ann-type{color:#dc2626;}
    .ann-item.maintenance .ann-type{color:#d97706;}
    .ann-item.info .ann-type{color:#1d4ed8;}
    .ann-item.promo .ann-type{color:#15803d;}
    .ann-title{font-size:13px;font-weight:700;color:var(--text);line-height:1.3;}
    .ann-content{font-size:11px;color:var(--muted);margin-top:4px;line-height:1.5;}
    .ann-until{font-size:10px;color:var(--muted);margin-top:5px;font-weight:500;}
    .ann-dismiss{position:absolute;top:10px;right:10px;background:none;border:none;color:var(--muted);cursor:pointer;padding:3px;opacity:.6;line-height:1;}
    .ann-dismiss:hover{opacity:1;}
    .nb-arrow{color:var(--muted);}

    /* Quick Menu */
    .section-label{font-size:13px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;}
    .quick-menu{display:grid;grid-template-columns:repeat(4,1fr);gap:8px 6px;margin-bottom:22px;}
    .qm-item{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;text-decoration:none;color:var(--text);-webkit-tap-highlight-color:transparent;padding:4px 2px;border-radius:12px;transition:background .15s;}
    .qm-item:active{background:rgba(0,0,0,.05);}
    .qm-circle{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;transition:all .2s;border:2px solid transparent;}
    .qm-circle.c-blue {background:#eff6ff;color:var(--blue);}
    .qm-circle.c-teal {background:#f0fdfa;color:#0d9488;}
    .qm-circle.c-navy {background:#eff6ff;color:var(--blue3);}
    .qm-circle.c-rose {background:#fff1f2;color:#e11d48;}
    .qm-circle.c-amber{background:#fffbeb;color:#d97706;}
    .qm-circle.c-violet{background:#f5f3ff;color:#7c3aed;}
    .qm-circle.c-green{background:#f0fdf4;color:#16a34a;}
    /* Upgrade paket card */
    .pkg-upgrade-card{background:#fff;border:1.5px solid var(--border);border-radius:14px;padding:14px 16px;margin-bottom:10px;transition:all .15s;display:flex;align-items:center;gap:14px;cursor:pointer;-webkit-tap-highlight-color:transparent;}
    .pkg-upgrade-card:hover{border-color:var(--blue);box-shadow:0 4px 16px rgba(37,99,235,.08);}
    .pkg-upgrade-card.current{border-color:var(--green);background:#f0fdf4;cursor:default;}
    .pkg-upgrade-card.selected{border-color:var(--blue);background:#eff6ff;box-shadow:0 0 0 3px rgba(37,99,235,.12);}
    /* Radio check di kanan */
    .puc-radio{width:20px;height:20px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s;}
    .pkg-upgrade-card.selected .puc-radio{border-color:var(--blue);background:var(--blue);}
    .pkg-upgrade-card.selected .puc-radio::after{content:'';width:8px;height:8px;border-radius:50%;background:#fff;}
    .pkg-upgrade-card.current .puc-radio{border-color:var(--green);background:var(--green);}
    .pkg-upgrade-card.current .puc-radio::after{content:'✓';font-size:10px;color:#fff;font-weight:800;line-height:1;}
    .puc-icon{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .puc-info{flex:1;min-width:0;}
    .puc-name{font-size:13px;font-weight:700;}
    .puc-speed{font-size:11px;color:var(--muted);margin-top:2px;}
    .puc-price{font-size:14px;font-weight:800;text-align:right;flex-shrink:0;}
    .puc-badge{font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;margin-top:3px;display:inline-block;}
    .puc-current{background:#dcfce7;color:#16a34a;}
    .puc-upgrade{background:#eff6ff;color:var(--blue);}
    .puc-downgrade{background:#f1f5f9;color:var(--muted);}
    .qm-item.active .qm-circle{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.12);}
    .qm-name{font-size:10px;font-weight:600;color:var(--muted);text-align:center;line-height:1.2;}
    .qm-item.active .qm-name{color:var(--blue);font-weight:700;}
    .qm-badge{position:relative;}
    .qm-dot{position:absolute;top:-2px;right:-2px;width:10px;height:10px;border-radius:50%;background:var(--red);border:1.5px solid #fff;font-size:7px;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;}

    /* ═══ PANELS ═══ */
    .panel{display:none;animation:fadeUp .25s ease;}
    .panel.active{display:block;}
    @keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

    /* Cards */
    .w-card{background:#fff;border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;}
    .w-card-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
    .w-card-title svg{width:16px;height:16px;color:var(--blue);flex-shrink:0;}
    .w-card-title .badge-count{margin-left:auto;background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:1px 7px;border-radius:20px;}

    /* Info grid */
    .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
    .info-item{background:#f8fafc;border-radius:10px;padding:10px 12px;}
    .ii-label{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.3px;}
    .ii-value{font-size:12px;font-weight:700;color:var(--text);margin-top:3px;word-break:break-all;}
    .info-item.full{grid-column:1/-1;}
    .status-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:5px;}
    .dot-green{background:var(--green);}.dot-red{background:var(--red);}.dot-amber{background:var(--amber);}

    /* Invoice items */
    .inv-item{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid #f1f5f9;gap:10px;}
    .inv-item:last-child{border-bottom:none;padding-bottom:0;}
    .inv-left{flex:1;min-width:0;}
    .inv-period{font-size:13px;font-weight:700;}
    .inv-due{font-size:10px;color:var(--muted);margin-top:1px;}
    .inv-right{text-align:right;flex-shrink:0;}
    .inv-amount{font-size:13px;font-weight:800;font-family:'Plus Jakarta Sans',monospace;}
    .inv-badge{display:inline-block;padding:2px 8px;border-radius:20px;font-size:9px;font-weight:700;margin-top:3px;text-transform:uppercase;}
    .inv-paid{background:#dcfce7;color:#16a34a;}
    .inv-unpaid{background:#fef3c7;color:#d97706;}
    .inv-overdue{background:#fee2e2;color:#dc2626;}
    .inv-cancelled{background:#f1f5f9;color:var(--muted);}
    .btn-pay{padding:6px 12px;border-radius:20px;background:var(--blue);color:#fff;font-size:10px;font-weight:700;border:none;cursor:pointer;font-family:inherit;margin-left:8px;transition:opacity .15s;}
    .btn-pay:hover{opacity:.85;}
    .btn-pay:disabled{opacity:.4;cursor:not-allowed;}

    /* Payment section */
    .pay-methods{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;}
    .pay-method{background:#f8fafc;border:1.5px solid transparent;border-radius:12px;padding:12px;cursor:pointer;text-align:center;transition:all .2s;}
    .pay-method.selected{border-color:var(--blue);background:#eff6ff;}
    .pay-method svg{display:block;margin:0 auto 5px;width:22px;height:22px;}
    .pay-method span{font-size:11px;font-weight:600;}

    /* Payment modal overlay */
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;display:none;align-items:flex-end;justify-content:center;}
    .modal-overlay.active{display:flex;}
    .modal-sheet{background:#fff;border-radius:24px 24px 0 0;padding:0 20px 32px;width:100%;max-width:480px;max-height:90dvh;overflow-y:auto;animation:slideUp .3s ease;}
    @keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
    .modal-handle{width:36px;height:4px;background:#e2e8f0;border-radius:2px;margin:14px auto 20px;}
    .modal-title{font-size:17px;font-weight:800;margin-bottom:20px;}
    .modal-close{position:absolute;top:16px;right:20px;background:none;border:none;color:var(--muted);cursor:pointer;padding:4px;}

    /* ONT / Signal */
    .signal-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px;}

    /* ═══ Usage History Chart ═══ */
    .usage-chart-wrap{background:#f8fafc;border-radius:14px;padding:14px;margin-top:2px;}
    .usage-chart-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;gap:10px;flex-wrap:wrap;}
    .usage-chart-title{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:800;color:var(--text);text-transform:uppercase;letter-spacing:.4px;}
    .usage-chart-title svg{color:var(--blue2);}
    .usage-chart-legend{display:flex;align-items:center;gap:4px;font-size:10.5px;color:var(--muted);font-weight:600;}
    .lg-dot{width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:4px;}

    .usage-chart-tabs{display:flex;gap:4px;background:#e2e8f0;border-radius:10px;padding:3px;margin-bottom:14px;}
    .ct-tab{flex:1;background:transparent;border:none;color:var(--muted);font-size:11.5px;font-weight:700;padding:7px 6px;border-radius:7px;cursor:pointer;font-family:inherit;transition:all .18s;}
    .ct-tab:hover:not(.active){color:var(--text);background:rgba(255,255,255,.5);}
    .ct-tab.active{background:#fff;color:var(--blue2);box-shadow:0 1px 3px rgba(15,23,42,.1),0 1px 2px rgba(15,23,42,.06);}

    .usage-chart-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px;}
    .ucs-item{background:#fff;border-radius:9px;padding:8px 7px;text-align:center;}
    .ucs-lbl{display:block;font-size:9.5px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.3px;margin-bottom:2px;}
    .ucs-val{display:block;font-size:11.5px;font-weight:800;color:var(--text);font-family:'DM Mono',monospace;line-height:1.2;}

    .usage-chart-area{position:relative;background:#fff;border-radius:10px;padding:10px;height:160px;overflow:hidden;}
    .uc-svg{width:100%;height:100%;display:block;}
    .uc-empty{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:8px;color:var(--muted);font-size:11.5px;font-weight:600;}
    .uc-spinner{width:16px;height:16px;border:2px solid #e2e8f0;border-top-color:var(--blue);border-radius:50%;animation:uc-spin .8s linear infinite;}
    @keyframes uc-spin{to{transform:rotate(360deg);}}
    .uc-tooltip{position:absolute;pointer-events:none;background:#0f172a;color:#fff;font-size:10.5px;padding:6px 9px;border-radius:6px;font-family:'DM Mono',monospace;line-height:1.5;white-space:nowrap;box-shadow:0 4px 14px rgba(15,23,42,.22);opacity:0;transform:translate(-50%,-110%);transition:opacity .12s;z-index:2;}
    .uc-tooltip.show{opacity:1;}
    .uc-tooltip b{font-weight:700;}
    .uc-tooltip .tt-dl{color:#60a5fa;}
    .uc-tooltip .tt-ul{color:#34d399;}

    .uc-empty-data{color:var(--muted);font-size:11.5px;font-weight:600;display:flex;flex-direction:column;align-items:center;gap:6px;}
    .uc-empty-data svg{color:#cbd5e1;}
    .sig-card{background:#f8fafc;border-radius:12px;padding:14px;text-align:center;}
    .sig-val{font-size:20px;font-weight:800;font-family:'DM Mono',monospace;}
    .sig-lbl{font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;margin-top:2px;}
    .sig-good{color:var(--green);}.sig-warn{color:var(--amber);}.sig-bad{color:var(--red);}
    .btn-reboot{width:100%;padding:12px;border:none;border-radius:12px;background:linear-gradient(135deg,#ef4444,#dc2626);color:#fff;font-size:13px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:14px;transition:all .15s;}
    .btn-reboot:hover{opacity:.9;}.btn-reboot:disabled{opacity:.45;cursor:not-allowed;}

    /* Traffic */
    .chart-wrap{position:relative;height:180px;margin-top:8px;}
    .period-btns{display:flex;gap:4px;background:#f1f5f9;border-radius:8px;padding:3px;width:fit-content;margin-bottom:12px;}
    .period-btns button{padding:5px 12px;border:none;border-radius:6px;font-size:11px;font-weight:600;font-family:inherit;background:none;color:var(--muted);cursor:pointer;transition:all .15s;}
    .period-btns button.active{background:#fff;color:var(--text);box-shadow:0 1px 3px rgba(0,0,0,.08);}
    .stat-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:12px;}
    .stat-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:14px;text-align:center;}
    .stat-val{font-size:19px;font-weight:800;font-family:'DM Mono',monospace;}
    .stat-lbl{font-size:9px;font-weight:600;color:var(--muted);margin-top:2px;text-transform:uppercase;}

    /* Tiket */
    .ticket-item{padding:13px 0;border-bottom:1px solid #f1f5f9;cursor:pointer;}
    .ticket-item:last-child{border-bottom:none;padding-bottom:0;}
    .tk-row{display:flex;align-items:flex-start;gap:12px;}
    .tk-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .tk-icon.open{background:#eff6ff;color:var(--blue);}
    .tk-icon.in_progress{background:#fef3c7;color:#d97706;}
    .tk-icon.resolved,.tk-icon.closed{background:#f0fdf4;color:var(--green);}
