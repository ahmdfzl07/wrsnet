// Copy ke clipboard
function copyAccount(btn, number) {
  var clean = String(number).replace(/\s+/g,'');
  var span  = btn.querySelector('span');
  var orig  = span ? span.textContent : 'Salin';

  function done() {
    btn.classList.add('copied');
    if (span) span.textContent = 'Tersalin!';
    setTimeout(function(){
      btn.classList.remove('copied');
      if (span) span.textContent = orig;
    }, 1800);
  }

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(clean).then(done).catch(function(){
      fallbackCopy(clean); done();
    });
  } else {
    fallbackCopy(clean); done();
  }
}
function fallbackCopy(text) {
  var ta = document.createElement('textarea');
  ta.value = text; ta.style.position='fixed'; ta.style.opacity='0';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); } catch(e){}
  document.body.removeChild(ta);
}

// JS-string escape helper (escapeHtml sudah ada di file, tidak perlu redeclare)
function jsEsc(s) { return String(s==null?'':s).replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

// ── Bayar Online (Midtrans Snap / Xendit) ──
var SNAP_LOADED = false;
function loadMidtransSnap(clientKey, env) {
  return new Promise(function(resolve, reject){
    if (window.snap) return resolve();
    if (SNAP_LOADED) {
      // Tunggu sampai window.snap siap
      var tries = 0;
      var iv = setInterval(function(){
        if (window.snap) { clearInterval(iv); resolve(); }
        else if (++tries > 50) { clearInterval(iv); reject(new Error('Snap.js timeout')); }
      }, 100);
      return;
    }
    SNAP_LOADED = true;
    var s = document.createElement('script');
    s.src = (env === 'production')
      ? 'https://app.midtrans.com/snap/snap.js'
      : 'https://app.sandbox.midtrans.com/snap/snap.js';
    s.setAttribute('data-client-key', clientKey || '');
    s.onload  = function(){ resolve(); };
    s.onerror = function(){ reject(new Error('Gagal load Snap.js')); };
    document.head.appendChild(s);
  });
}

