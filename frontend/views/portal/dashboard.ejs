    .btn-save:disabled{opacity:.45;cursor:not-allowed;}

    /* ═══ PAYMENT ACCORDION (Modal Bayar Manual) ═══ */
    .pm-info-box{background:#f8fafc;border-radius:14px;padding:14px 16px;margin-bottom:16px;}
    .pm-info-row{display:flex;justify-content:space-between;margin-bottom:8px;font-size:12px;}
    .pm-info-row:last-child{margin-bottom:0;}
