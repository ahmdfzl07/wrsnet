      <div class="ps-item">
        <div class="ps-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21V9"/><path d="M7 14l5-5 5 5"/><path d="M5 3h14"/></svg>
        </div>
        <div class="ps-val" id="iuUp">—</div>
        <div class="ps-lbl">Upload</div>
      </div>
    </div>
