<script src="/socket.io/socket.io.js"></script>
<script>
// const socket = io("https://admin.wrsnet.id/", {
//   auth: {
//     token: localStorage.getItem("token")
//   }
// });

function openTab(id, el){
  document.querySelectorAll('.panel').forEach(p=>{
    p.classList.remove('active');
  });

  document.querySelectorAll('.tab-btn').forEach(b=>{
    b.classList.remove('active');
  });

  document.getElementById(id).classList.add('active');
  el.classList.add('active');
}

const isLocal =
  window.location.hostname === "localhost" ||
  window.location.hostname === "127.0.0.1";

const socket = io(
  isLocal
    ? "http://localhost:3001"
    : "https://admin.wrsnet.id",
  {
    auth: {
      token: localStorage.getItem("token"),
    },
  }
);

const user = JSON.parse(localStorage.getItem("user"));
const customer = JSON.parse(localStorage.getItem("portal_customer"));

const USER_ID = user?.id ?? null;
const CUSTOMER_ID = customer?.customer_id ?? null;
const CUSTOMER_ID_KEY = customer?.id ?? null;
const CUSTOMER_NAME= customer?.name ?? null;

const ROOM = CUSTOMER_ID
  ? `customer_${CUSTOMER_ID}`
  : `user_${USER_ID}`;

const USER_ID_CHAT = CUSTOMER_ID_KEY
  ? `${CUSTOMER_ID_KEY}`
  : `${USER_ID}`;

const TYPE = "customer";

const ticketId =
  new URLSearchParams(window.location.search).get("ticket_id") || "1";

socket.on("connect", () => {
  socket.emit("chat:join", ROOM);

  loadChat();
});

document.addEventListener("DOMContentLoaded", function () {

  const chatBox = document.getElementById("chatBox");
  const btn = document.getElementById("scrollBottomBtn");

  if (!chatBox || !btn) return;

  chatBox.addEventListener("scroll", function () {
    const distance =
      chatBox.scrollHeight - chatBox.scrollTop - chatBox.clientHeight;

    if (distance > 80) {
      btn.style.display = "flex";
    } else {
      btn.style.display = "none";
    }
  });

});

function updateChatBadge(messages) {
  const badge = document.getElementById("chat-badge");

  const unread = messages.filter(msg =>
    msg.is_read == 0 &&
    msg.type === "admin" &&
    msg.room === ROOM
  );

  if (unread.length > 0) {
    badge.style.display = "inline-block";
    badge.innerText = unread.length;
  } else {
    badge.style.display = "none";
  }
}

function loadChat() {
  fetch(`/portal/api/chat/${ROOM}`)
    .then(res => res.json())
    .then(data => {
      const box = document.getElementById("chatBox");
      box.innerHTML = "";

      data.forEach(renderMessage);

      updateChatBadge(data);

      scrollBottom();
    });
}

socket.on("chat:receive", (data) => {
  if (data.room !== ROOM) return;

  renderMessage(data);
  scrollBottom();

  if (data.is_read == 0 && data.type === "admin") {
    const badge = document.getElementById("chat-badge");
    let count = parseInt(badge.innerText || "0");

    badge.style.display = "inline-block";
    badge.innerText = count + 1;
  }

  const box = document.getElementById("chatBox");
  const btn = document.getElementById("scrollBottomBtn");

  const distance =
    box.scrollHeight - box.scrollTop - box.clientHeight;
  if (distance < 80) {
    scrollBottom();
  } else {
    btn.style.display = "flex";
  }
});

socket.on("chat:read", (data) => {
  if (data.room !== ROOM) return;

  const badge = document.getElementById("chat-badge");
  badge.style.display = "none";
  badge.innerText = "0";
});

function markAsRead(room) {
  fetch(`/portal/api/chat/read-customer/${room}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    }
  });

  const badge = document.getElementById("chat-badge");
  if (badge) {
    badge.style.display = "none";
    badge.innerText = "0";
  }
}

function formatChatDate(dateString) {
  const date = new Date(dateString);
  const today = new Date();

  const yesterday = new Date();
  yesterday.setDate(today.getDate() - 1);

  const isToday =
    date.toDateString() === today.toDateString();

  const isYesterday =
    date.toDateString() === yesterday.toDateString();

  if (isToday) return "Hari ini";
  if (isYesterday) return "Kemarin";

  return date.toLocaleDateString("id-ID", {
    day: "2-digit",
    month: "long",
    year: "numeric"
  });
}

function renderDateSeparator(label) {
  const box = document.getElementById("chatBox");

  const existing = box.querySelector(`[data-date="${label}"]`);
  if (existing) return;

  const div = document.createElement("div");
  div.setAttribute("data-date", label);
  div.style.textAlign = "center";
  div.style.margin = "10px 0";
  div.style.fontSize = "12px";
  div.style.color = "#6b7280";

  div.innerHTML = `<span style="background:#f3f4f6;padding:4px 10px;border-radius:999px">${label}</span>`;

  box.appendChild(div);
}

function renderMessage(data) {
  const box = document.getElementById("chatBox");

  const dateLabel = formatChatDate(data.created_at);

  renderDateSeparator(dateLabel);

  const isMe =
    (String(data.user_id) === String(USER_ID) && data.type === "customer") ||
    (String(data.user_id) === String(CUSTOMER_ID_KEY) && data.type === "customer");

  const wrap = document.createElement("div");
  wrap.style.display = "flex";
  wrap.style.flexDirection = "column";
  wrap.style.alignItems = isMe ? "flex-end" : "flex-start";
  wrap.style.margin = "6px 0";

  const bubble = document.createElement("div");
  bubble.style.maxWidth = "70%";
  bubble.style.padding = "10px 14px";
  bubble.style.borderRadius = "14px";
  bubble.style.fontSize = "14px";
  bubble.style.wordBreak = "break-word";
  bubble.style.background = isMe ? "#4f46e5" : "#e5e7eb";
  bubble.style.color = isMe ? "white" : "#111";

  bubble.innerText = data.message;

  const meta = document.createElement("small");

  const time = new Date(data.created_at).toLocaleTimeString("id-ID", {
    hour: "2-digit",
    minute: "2-digit"
  });

  meta.style.fontSize = "11px";
  meta.style.opacity = "0.6";

  meta.innerText = isMe
    ? `You • ${time}`
    : `${data.name} • ${time}`;

  wrap.appendChild(bubble);
  wrap.appendChild(meta);

  box.appendChild(wrap);
}

function sendChat() {
  const input = document.getElementById("chatInput");
  const message = input.value.trim();

  if (!message) return;

  socket.emit("chat:send", {
    room: ROOM,
    name: CUSTOMER_NAME,
    user_id: USER_ID_CHAT,
    type: TYPE,
    message
  });

  input.value = "";
}

function scrollBottom() {
  const box = document.getElementById("chatBox");
  box.scrollTop = box.scrollHeight;

  const btn = document.getElementById("scrollBottomBtn");
  if (btn) btn.style.display = "none";
}
</script>

<script>
// ══════════════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════════════
var TOKEN     = localStorage.getItem('portal_token');
var CUST_DATA = null;
var META      = null;
var PAY_INV_ID = null;
var currentPanel = 'home';

// Fallback kontak CS — dipakai kalau settings company_* di DB masih kosong.
// Ganti nilainya sesuai kontak CS operasional Anda.
var DEFAULT_CS_WA    = '081292266620';
var DEFAULT_CS_PHONE = '';
var DEFAULT_CS_EMAIL = '';

if (!TOKEN) window.location.href = '/portal/login';

// ══════════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════════
function authH() { return { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + TOKEN }; }
function fmtRp(v)   { return 'Rp ' + (parseFloat(v)||0).toLocaleString('id-ID'); }
function fmtRpK(v)  { v=parseFloat(v)||0; if(v>=1e6) return 'Rp'+(v/1e6).toFixed(v%1e6===0?0:1)+'jt'; if(v>=1e3) return 'Rp'+Math.round(v/1e3)+'rb'; return 'Rp'+v; }
function fmtSpd(m)  { if(!m) return '—'; return m>=1000?(m/1000)+'Gbps':m+'Mbps'; }
function fmtBps(b)  { if(!b) return '0'; b=parseFloat(b); if(b>=1e9) return (b/1e9).toFixed(1)+'G'; if(b>=1e6) return (b/1e6).toFixed(1)+'M'; if(b>=1e3) return (b/1e3).toFixed(0)+'K'; return b+'b'; }
function fmtDate(d) { if(!d) return '—'; return new Date(d).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}); }
function mn(m)      { return ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'][m-1]||'?'; }

function toast(msg, isError, duration) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = isError ? '#ef4444' : '#0f172a';
  t.style.whiteSpace = 'pre-line';       // support \n
  t.style.maxWidth = '92vw';
  t.style.lineHeight = '1.45';
  t.style.display = 'block';
  var dur = duration || (isError ? 5000 : 3200);
  // Auto-extend kalau pesan panjang
  if (msg && msg.length > 80) dur = Math.max(dur, 6500);
  clearTimeout(t._hideTimer);
  t._hideTimer = setTimeout(function(){ t.style.display = 'none'; }, dur);
}

function openModal(id)  { document.getElementById(id).classList.add('active'); document.body.style.overflow='hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('active'); document.body.style.overflow=''; }

// ══════════════════════════════════════════════════════════════
// NAVIGATION — sinkron bottom nav + quick menu sekaligus
// ══════════════════════════════════════════════════════════════
var PANELS = ['chat','home','billing','traffic','ont','wifi','upgrade','profil','tickets'];
var BN_MAP  = { chat:'chat', home:'home', billing:'billing', traffic:'traffic', ont:'traffic', wifi:'wifi', upgrade:'wifi', profil:'profil', tickets:'profil' };

const APP_ENV = "<%= process.env.APP_ENV %>";

const ADMIN_URL = "https://admin.wrsnet.id/portal";
const PORTAL_URL = "https://portal.wrsnet.id/portal";

const CURRENT_HOST = window.location.origin;

console.log(APP_ENV);
let HAS_OPENED_CHAT = false;
function navTo(id) {
  const host = window.location.hostname;

  const isAdmin = host.includes("admin.wrsnet.id");
  const isPortal = host.includes("portal.wrsnet.id");

  if (id === "chat") {
    if (!isAdmin) {
      window.location.replace("https://admin.wrsnet.id/portal#chat");
      return;
    }

    showPanel("chat");
    return;
  }

  if (isAdmin && id !== "chat") {
    window.location.replace("https://portal.wrsnet.id/portal");
    return;
  }

  const wifiSection = document.getElementById("wifiSection");
  if (wifiSection) {
    wifiSection.style.display = "none";
  }

  if (id === "wifi") {
    if (wifiSection) {
      wifiSection.style.display = "block";
    }
  }

  showPanel(id);
}

function showPanel(id) {
  PANELS.forEach(function(p) {
    var el = document.getElementById('panel-' + p);
    if (el) el.classList.toggle('active', p === id);
  });

  ['chat','home','billing','traffic','wifi','upgrade','profil','tickets'].forEach(function(p) {
    var el = document.getElementById('qm-'+p);
    if (el) el.classList.toggle('active', p === id);
  });

  Object.keys(BN_MAP).forEach(function(panel) {
    var bnKey = BN_MAP[panel];
    var el = document.getElementById('bn-'+bnKey);
    if (el) el.classList.toggle('active', bnKey === BN_MAP[id]);
  });

  var c = document.querySelector('.content');
  if (c) window.scrollTo({ top: c.offsetTop - 10, behavior: 'smooth' });

  if (id === 'chat' && !HAS_OPENED_CHAT) {
    markAsRead(ROOM);
    HAS_OPENED_CHAT = true;
  }

  if (id === 'upgrade') loadUpgrade();
  if (id === 'traffic') loadTraffic();
  if (id === 'ont') loadSignal();
  if (id === 'billing') loadBilling();
  if (id === 'wifi') loadWifi();
  if (id === 'profil') fillProfil();
  if (id === 'tickets') loadTickets();
}

window.addEventListener('load', function () {
  const hash = window.location.hash.replace('#', '');

  if (hash === 'chat') {
    navTo('chat');
  } else if (hash) {
    navTo(hash);
  }
});

// ══════════════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════════════
async function loadDashboard() {
  try {
    var r = await fetch('/portal/api/dashboard', { headers: authH() });
    if (r.status === 401) { window.location.href = '/portal/login'; return; }
    var j = await r.json();
    if (!j.success) return;

    var d = j.data, c = d.customer, p = d.package;
    CUST_DATA = d;
    META = d.meta || {};

    // Hero
    document.getElementById('avatar').textContent = (c.name||'?').charAt(0).toUpperCase();
    document.getElementById('custName').textContent = c.name || '—';
    document.getElementById('custPhone').textContent = c.phone || c.customer_id;

    var badge = document.getElementById('custBadge');
    badge.className = 'hu-badge';
    if (c.isolir_status === 'isolated') {
      badge.classList.add('badge-isolated'); badge.textContent = 'TERISOLIR';
    } else if (c.status === 'active') {
      badge.classList.add('badge-active'); badge.textContent = 'AKTIF';
    } else {
      badge.classList.add('badge-inactive'); badge.textContent = c.status.toUpperCase();
    }

    // Credit
    document.getElementById('crAmount').textContent = fmtRp(d.total_unpaid || 0);
    if (d.total_unpaid > 0) {
      document.getElementById('crSub').textContent = 'BELUM LUNAS';
      document.getElementById('btnBayarHero').classList.remove('hidden');
    } else if (c.isolir_status === 'isolated') {
      document.getElementById('crSub').textContent = 'TERISOLIR';
    } else {
      document.getElementById('crSub').textContent = 'LUNAS';
    }

    // Package Detail card
    if (p) {
      var isActive = c.status === 'active' && c.isolir_status !== 'isolated';

      // Nama paket
      document.getElementById('inetPkgName').textContent = p.name;

      // Status
      document.getElementById('inetStatus').textContent = isActive ? '● Aktif' : '● Nonaktif';
      document.getElementById('inetStatus').style.color = isActive ? '#86efac' : '#fca5a5';

      // Bar: aktif = 100%, isolir = 10%
      document.getElementById('inetBar').style.width = isActive ? '100%' : '10%';

      // Label kiri: kecepatan paket
      document.getElementById('inetSpd').textContent = fmtSpd(p.speed_down) + ' / ' + fmtSpd(p.speed_up);

      // Label kanan: tanggal jatuh tempo
      var dueLabel = c.due_date ? 'Due: ' + fmtDate(c.due_date) : 'Tgl ' + (c.billing_date||1) + ' /bln';
      document.getElementById('inetBillingDate').textContent = dueLabel;

      // Masa aktif: hitung sisa hari dari due_date
      var daysEl = document.getElementById('inetDays');
      if (c.due_date) {
        var today = new Date(); today.setHours(0,0,0,0);
        var due   = new Date(c.due_date); due.setHours(0,0,0,0);
        var diff  = Math.ceil((due - today) / 86400000);
        if (diff > 0)      { daysEl.textContent = diff + ' Hari'; daysEl.style.color = diff <= 3 ? '#fbbf24' : '#fff'; }
        else if (diff === 0) { daysEl.textContent = 'Hari Ini'; daysEl.style.color = '#fca5a5'; }
        else                 { daysEl.textContent = 'Overdue';  daysEl.style.color = '#fca5a5'; }
      } else {
        daysEl.textContent = 'Aktif';
      }

      // Download / Upload speed
      document.getElementById('iuDown').textContent = fmtSpd(p.speed_down);
      document.getElementById('iuUp').textContent   = fmtSpd(p.speed_up);
    }

    // Notif banner
    var nb = document.getElementById('notifBanner');
    if (c.isolir_status === 'isolated') {
      nb.className = 'notif-banner isolated'; nb.style.display = 'block';
      document.getElementById('notifIcon').className = 'nb-icon danger';
      document.getElementById('notifTitle').textContent = 'Layanan anda sedang terisolir';
      document.getElementById('notifSub').textContent   = 'Lunasi tagihan untuk mengaktifkan kembali';
    } else if (d.total_unpaid > 0) {
      var isOverdue = d.invoices && d.invoices.some(function(i){ return i.status === 'overdue'; });
      nb.className = 'notif-banner' + (isOverdue ? ' overdue' : ''); nb.style.display = 'block';
      document.getElementById('notifIcon').className = isOverdue ? 'nb-icon danger' : 'nb-icon warn';
      document.getElementById('notifTitle').textContent = isOverdue ? 'Tagihan jatuh tempo!' : 'Ada tagihan belum lunas';
      document.getElementById('notifSub').textContent   = fmtRp(d.total_unpaid) + ' · Tap untuk bayar';
    }

    // Billing badge di quick menu
    if (d.total_unpaid > 0 || (d.invoices && d.invoices.length)) {
      var dot = document.createElement('div');
      dot.className = 'qm-dot'; dot.textContent = d.invoices ? d.invoices.length : '';
      var wrap = document.getElementById('qmBillingWrap');
      if (!wrap.querySelector('.qm-dot')) wrap.appendChild(dot);
    }

    // Tiket badge di quick menu
    if (d.open_tickets && d.open_tickets > 0) {
      var tkWrap = document.getElementById('qmTicketsWrap');
      if (tkWrap && !tkWrap.querySelector('.qm-dot')) {
        var tkDot = document.createElement('div');
        tkDot.className = 'qm-dot';
        tkDot.textContent = d.open_tickets > 9 ? '9+' : d.open_tickets;
        tkWrap.appendChild(tkDot);
      }
    }

    // Customer info grid (panel home)
    document.getElementById('custInfo').innerHTML =
      '<div class="info-item"><div class="ii-label">ID Pelanggan</div><div class="ii-value">' + c.customer_id + '</div></div>' +
      '<div class="info-item"><div class="ii-label">Paket</div><div class="ii-value">' + (p ? p.name : '—') + '</div></div>' +
      '<div class="info-item"><div class="ii-label">No. HP</div><div class="ii-value">' + (c.phone||'—') + '</div></div>' +
      '<div class="info-item"><div class="ii-label">PPPoE</div><div class="ii-value">' + (c.pppoe_username||'—') + '</div></div>' +
      '<div class="info-item full"><div class="ii-label">Alamat</div><div class="ii-value">' + (c.address||'—') + '</div></div>' +
      '<div class="info-item"><div class="ii-label">Tgl Pasang</div><div class="ii-value">' + fmtDate(c.installation_date) + '</div></div>' +
      '<div class="info-item"><div class="ii-label">Jatuh Tempo</div><div class="ii-value">Tgl ' + (c.billing_date||1) + ' /bln</div></div>';

    // Home: Tagihan aktif
    if (d.invoices && d.invoices.length) {
      document.getElementById('homeInvCard').style.display = '';
      var h = '';
      d.invoices.forEach(function(inv) {
        if (inv.amount > 0) {
          var sc = inv.status === 'overdue' ? 'overdue' : 'unpaid';
          var sl = inv.status === 'overdue' ? 'Jatuh Tempo' : 'Belum Bayar';
          h += '<div class="inv-item">' +
            '<div class="inv-left"><div class="inv-period">' + mn(inv.period_month) + ' ' + inv.period_year + '</div>' +
            '<div class="inv-due">Due: ' + fmtDate(inv.due_date) + '</div></div>' +
            '<div class="inv-right"><div class="inv-amount">' + fmtRp(inv.total || inv.amount) + '</div>' +
            '<div class="inv-badge inv-' + sc + '">' + sl + '</div></div>' +
            '<button class="btn-pay" onclick=\'openPayModal(' + JSON.stringify(inv).replace(/'/g, '&#39;') + ')\'>Bayar</button>' +
            '</div>';
        }
      });
      document.getElementById('homeInvList').innerHTML = h;
    }

    // Home: Riwayat bayar
    if (d.payments && d.payments.length) {
      document.getElementById('homePayCard').style.display = '';
      var hp = '';
      d.payments.slice(0, 3).forEach(function(pay) {
        hp += '<div class="inv-item">' +
          '<div class="inv-left"><div class="inv-period">' + mn(pay.period_month) + ' ' + pay.period_year + '</div>' +
          '<div class="inv-due">' + fmtDate(pay.payment_date) + ' · ' + (pay.payment_method||'').toUpperCase() + '</div></div>' +
          '<div class="inv-right"><div class="inv-amount" style="color:var(--green)">' + fmtRp(pay.amount) + '</div>' +
          '<div class="inv-badge inv-paid">Lunas</div></div>' +
          '</div>';
      });
      document.getElementById('homePayList').innerHTML = hp;
    }

    // Profil net info (optional — card Perangkat & Koneksi bisa dihilangkan)
    var profilNet = document.getElementById('profilNetInfo');
    if (profilNet) {
      profilNet.innerHTML =
        '<div class="info-item"><div class="ii-label">PPPoE</div><div class="ii-value">' + (c.pppoe_username||'—') + '</div></div>' +
        '<div class="info-item"><div class="ii-label">ONT SN</div><div class="ii-value">' + (c.ont_sn||'—') + '</div></div>' +
        '<div class="info-item"><div class="ii-label">Static IP</div><div class="ii-value">' + (c.static_ip||'DHCP') + '</div></div>' +
        '<div class="info-item"><div class="ii-label">Status</div><div class="ii-value"><span class="status-dot ' + (c.status==='active'?'dot-green':'dot-red') + '"></span>' + c.status + '</div></div>';
    }

  } catch(e) { console.error('loadDashboard:', e); }
}

