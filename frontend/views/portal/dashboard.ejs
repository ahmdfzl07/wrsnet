function buildAccordionGroup(opts) {
  var itemsHtml = '';
  opts.items.forEach(function(m){
    var label = (opts.labelMap && opts.labelMap[(m.provider||'').toLowerCase()]) || (m.provider||'').toUpperCase() || '—';
    var logo  = m.logo_url
      ? '<img src="'+escapeHtml(m.logo_url)+'" alt="'+escapeHtml(label)+'" onerror="this.outerHTML=\''+escapeHtml(label)+'\'">'
      : escapeHtml(label);
    var num   = m.account_number || '—';
    var owner = m.account_owner  || '';
    itemsHtml +=
      '<div class="pm-item">' +
        '<div class="pm-item-row">' +
          '<div class="pm-logo">'+logo+'</div>' +
          '<div class="pm-detail">' +
            '<div class="pm-name">'+escapeHtml(label)+'</div>' +
            '<div class="pm-number">'+escapeHtml(num)+'</div>' +
            (owner ? '<div class="pm-owner">a.n. '+escapeHtml(owner)+'</div>' : '') +
          '</div>' +
          '<button class="pm-copy-btn" onclick="copyAccount(this, \''+ jsEsc(num) +'\')">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>' +
            '<span>Salin</span>' +
          '</button>' +
        '</div>' +
      '</div>';
  });

  return '<div class="pm-group">' +
    '<div class="pm-group-head" data-key="'+opts.key+'">' +
      '<div class="pm-group-ico '+(opts.iconClass||'')+'">'+opts.icon+'</div>' +
      '<div class="pm-group-text">' +
        '<div class="pm-group-title">'+escapeHtml(opts.title)+'</div>' +
        '<div class="pm-group-sub">'+escapeHtml(opts.sub)+'</div>' +
      '</div>' +
      '<span class="pm-group-count">'+opts.items.length+'</span>' +
      '<svg class="pm-group-chev" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>' +
    '</div>' +
    '<div class="pm-group-body"><div class="pm-group-inner">'+itemsHtml+'</div></div>' +
  '</div>';
}

