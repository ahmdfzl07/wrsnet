</div>

<!-- ═══ CONTENT ═══ -->
<div class="content">

  <!-- Announcement banners (gangguan massal, maintenance, info) -->
  <div class="ann-wrap" id="annWrap" style="display:none"></div>

  <!-- Notif banner (tagihan) -->
  <div class="notif-banner" id="notifBanner" onclick="navTo('billing')">
    <div class="nb-row">
      <div class="nb-icon warn" id="notifIcon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
