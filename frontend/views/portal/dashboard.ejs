var billingLoaded = false;
async function loadBilling() {
  if (billingLoaded) return;
  billingLoaded = true;
  try {
    var r = await fetch('/portal/api/billing', { headers: authH() });
    var j = await r.json();
    if (!j.success) return;
    var invs = j.data.invoices || [];
    var pays = j.data.payments || [];

    if (!invs.length) {
      document.getElementById('billingList').innerHTML = '<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>Belum ada tagihan</div>';
    } else {
      var h = '';
      invs.forEach(function(inv) {
        if (inv.amount > 0) {
          var sc = inv.status === 'paid' ? 'paid' : inv.status === 'overdue' ? 'overdue' : inv.status === 'cancelled' ? 'cancelled' : 'unpaid';
          var sl = { paid:'Lunas', overdue:'Jatuh Tempo', unpaid:'Belum Bayar', cancelled:'Dibatalkan' }[sc] || sc;
          h += '<div class="inv-item">' +
            '<div class="inv-left"><div class="inv-period">' + mn(inv.period_month) + ' ' + inv.period_year + '</div>' +
            '<div class="inv-due">Due: ' + fmtDate(inv.due_date) + (inv.invoice_number ? ' · ' + inv.invoice_number : '') + '</div></div>' +
            '<div class="inv-right"><div class="inv-amount">' + fmtRp(inv.total||inv.amount) + '</div>' +
            '<div class="inv-badge inv-' + sc + '">' + sl + '</div></div>' +
            (sc !== 'paid' && sc !== 'cancelled'
              ? '<button class="btn-pay" onclick=\'openPayModal(' + JSON.stringify(inv).replace(/'/g, '&#39;') + ')\'>Bayar</button>'
              : '') +
            '</div>';
        }
      });
      document.getElementById('billingList').innerHTML = h;
    }

    if (pays.length) {
      document.getElementById('payHistCard').style.display = '';
      var hp = '';
      pays.forEach(function(pay) {
        hp += '<div class="inv-item">' +
          '<div class="inv-left"><div class="inv-period">' + mn(pay.period_month) + ' ' + pay.period_year + '</div>' +
          '<div class="inv-due">' + fmtDate(pay.payment_date) + ' · ' + (pay.payment_method||'').toUpperCase() + (pay.reference_number ? ' · ' + pay.reference_number : '') + '</div></div>' +
          '<div class="inv-right"><div class="inv-amount" style="color:var(--green)">' + fmtRp(pay.amount) + '</div>' +
          '<div class="inv-badge inv-paid">Lunas</div></div>' +
          '</div>';
      });
      document.getElementById('payHistList').innerHTML = hp;
    }
  } catch(e) { console.error('loadBilling:', e); }
}

