function openPayModal(arg1, invNum, period, total) {

  var inv;

  if (arg1 && typeof arg1 === 'object') {

    inv = arg1;

  } else {

    inv = {
      id: arg1,
      invoice_number: invNum,
      period_month: null,
      period_year: null,
      total: total
    };

    inv._period = period;
  }

  var periodTxt =
    inv._period ||
    (
      inv.period_month &&
      inv.period_year
    )
      ? mn(inv.period_month) + ' ' + inv.period_year
      : '—';

  var subtotal = Number(inv.amount || 0);

  var tax = Number(inv.tax || 0);

  var grandTotal =
    Number(
      inv.total ||
      (subtotal + tax) ||
      0
    );

  if (!subtotal && !tax) {
    subtotal = grandTotal;
    tax = 0;
  }

  PAY_CONTEXT = {
    invoice_id: inv.id,
    invoice_number:
      inv.invoice_number ||
      ('INV-' + inv.id),
    period: periodTxt,
    subtotal: subtotal,
    tax: tax,
    total: grandTotal
  };

  document.getElementById(
    'payInvNum'
  ).textContent =
    PAY_CONTEXT.invoice_number;

  document.getElementById(
    'payPeriod'
  ).textContent =
    periodTxt;

  document.getElementById(
    'payTotal'
  ).textContent =
    fmtRp(grandTotal);

  // ======================
  // SUBTOTAL & TAX
  // ======================

  var rowSub =
    document.getElementById(
      'payRowSubtotal'
    );

  var rowTax =
    document.getElementById(
      'payRowTax'
    );

  if (tax > 0) {

    if (rowSub) {

      rowSub.style.display = '';

      document.getElementById(
        'paySubtotal'
      ).textContent =
        fmtRp(subtotal);
    }

    if (rowTax) {

      rowTax.style.display = '';

      document.getElementById(
        'payTax'
      ).textContent =
        fmtRp(tax);

      _loadTaxCfg().then(function(cfg){

        var lbl =
          (cfg && cfg.label)
            ? cfg.label
            : 'PPN';

        var rate =
          subtotal > 0
            ? Math.round((tax / subtotal) * 1000) / 10
            : 0;

        var lblEl =
          document.getElementById(
            'payTaxLbl'
          );

        if (lblEl) {

          lblEl.textContent =
            lbl +
            (
              rate
                ? ' (' + rate + '%)'
                : ''
            );
        }
      });
    }

  } else {

    if (rowSub) {
      rowSub.style.display = 'none';
    }

    if (rowTax) {
      rowTax.style.display = 'none';
    }
  }

  // ======================
  // CUSTOMER
  // ======================

  var custName =
    (
      CUST_DATA &&
      CUST_DATA.customer &&
      CUST_DATA.customer.name
    )
      ? CUST_DATA.customer.name
      : '—';

  var pkgName =
    (
      CUST_DATA &&
      CUST_DATA.package &&
      CUST_DATA.package.name
    )
      ? CUST_DATA.package.name
      : '—';

  document.getElementById(
    'payCustomerName'
  ).textContent = custName;

  document.getElementById(
    'payServiceName'
  ).textContent = pkgName;

  renderPaymentAccordion();

  openModal('modalPay');
}

