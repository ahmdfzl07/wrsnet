function escHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function doLogout() {
  localStorage.removeItem('portal_token');
  localStorage.removeItem('portal_customer');
  document.cookie = 'portal_token=;path=/portal;max-age=0';
  window.location.href = '/portal/login';
}

// ══════════════════════════════════════════════════════════════
// UPGRADE PAKET
// ══════════════════════════════════════════════════════════════
var upgradeLoaded = false;

async function loadUpgrade() {
  if (upgradeLoaded) return;
  upgradeLoaded = true;
  try {
    var r = await fetch('/portal/api/packages', { headers: authH() });
    var j = await r.json();
    console.log('[Upgrade] packages response:', j);
    if (!j.success || !j.data || !j.data.length) {
      document.getElementById('upgradeList').innerHTML =
        '<div class="empty-state">Tidak ada paket tersedia</div>';
      return;
    }

    var currentPkgId = CUST_DATA && CUST_DATA.customer ? CUST_DATA.customer.package_id : null;
    var currentPrice = CUST_DATA && CUST_DATA.package ? parseFloat(CUST_DATA.package.price) : 0;

    var html = '';
    j.data.forEach(function(pkg) {
      if (!pkg.is_active) return;
      var isCurrent = pkg.id === currentPkgId;
      var price     = parseFloat(pkg.price) || 0;
      var isUpgrade = price > currentPrice;
      var badgeClass = isCurrent ? 'puc-current' : (isUpgrade ? 'puc-upgrade' : 'puc-downgrade');
      var badgeText  = isCurrent ? '✓ Paket Saat Ini' : (isUpgrade ? '↑ Upgrade' : '↓ Downgrade');
      var iconBg     = isCurrent ? '#f0fdf4' : (isUpgrade ? '#eff6ff' : '#f8fafc');
      var iconColor  = isCurrent ? '#16a34a' : (isUpgrade ? 'var(--blue)' : 'var(--muted)');
      var onclick    = isCurrent ? '' : 'selectUpgradePkg(' + pkg.id + ',\'' + escHtml(pkg.name) + '\')';

      html += '<div class="pkg-upgrade-card' + (isCurrent ? ' current' : '') + '" id="upg-card-' + pkg.id + '" onclick="' + onclick + '">' +
        '<div class="puc-icon" style="background:' + iconBg + ';color:' + iconColor + '">' +
          '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/></svg>' +
        '</div>' +
        '<div class="puc-info">' +
          '<div class="puc-name">' + escHtml(pkg.name) + '</div>' +
          '<div class="puc-speed">' + (pkg.speed_down||0) + ' Mbps / ' + (pkg.speed_up||0) + ' Mbps</div>' +
          '<span class="puc-badge ' + badgeClass + '">' + badgeText + '</span>' +
        '</div>' +
        '<div style="text-align:right;margin-right:8px;flex-shrink:0">' +
          '<div class="puc-price" style="color:' + iconColor + '">' + fmtRpK(price) + '</div>' +
          '<div style="font-size:9px;color:var(--muted);margin-top:2px">/bulan</div>' +
        '</div>' +
        '<div class="puc-radio"></div>' +
      '</div>';
    });
    document.getElementById('upgradeList').innerHTML = html || '<div class="empty-state">Tidak ada paket tersedia</div>';

    // Cek apakah ada permintaan upgrade aktif via endpoint dedicated
    try {
      var sr = await fetch('/portal/api/upgrade/status', { headers: authH() });
      var sj = await sr.json();
      if (sj.success && sj.blocked && sj.ticket) {
        showUpgradeBlockedBanner(sj.ticket);
      }
    } catch(e) { /* silent */ }
  } catch(e) {
    upgradeLoaded = false;
    console.error('[Upgrade] error:', e);
    document.getElementById('upgradeList').innerHTML = '<div class="empty-state">Gagal memuat paket. Coba lagi.</div>';
  }
}

var _upgradePkgId   = null;
var _upgradePkgName = null;

function showUpgradeBlockedBanner(ticket) {
  var statusLabel = { open:'Menunggu', in_progress:'Sedang Diproses', pending:'Ditunda', assigned:'Ditugaskan', on_hold:'Ditahan' };
  // Hapus banner lama jika ada
  var old = document.getElementById('upgradeActiveNotif');
  if (old) old.remove();
  var notifDiv = document.createElement('div');
  notifDiv.id = 'upgradeActiveNotif';
  notifDiv.innerHTML =
    '<div style="background:#fef3c7;border:1.5px solid #fde68a;border-radius:12px;padding:14px 16px;margin-top:4px">' +
      '<div style="display:flex;align-items:flex-start;gap:10px">' +
        '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5" style="flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' +
        '<div>' +
          '<div style="font-size:13px;font-weight:700;color:#92400e;margin-bottom:4px">Ada permintaan yang sedang diproses</div>' +
          '<div style="font-size:11px;color:#92400e;line-height:1.6">' +
            (ticket ? (ticket.ticket_number || '') + ' · ' + (statusLabel[ticket.status] || ticket.status) + '<br>' : '') +
            'Tunggu hingga permintaan sebelumnya selesai sebelum mengajukan yang baru.' +
          '</div>' +
        '</div>' +
      '</div>' +
    '</div>';
  var wrap = document.getElementById('upgradeBtnWrap');
  if (wrap) wrap.parentNode.insertBefore(notifDiv, wrap);
  // Sembunyikan tombol kirim & nonaktifkan card
  if (wrap) wrap.style.display = 'none';
  document.querySelectorAll('.pkg-upgrade-card:not(.current)').forEach(function(c) {
    c.style.opacity = '.45';
    c.style.pointerEvents = 'none';
  });
  _upgradePkgId = null; _upgradePkgName = null;
}

function selectUpgradePkg(pkgId, pkgName) {
  _upgradePkgId   = pkgId;
  _upgradePkgName = pkgName;
  // Highlight card yang dipilih
  document.querySelectorAll('.pkg-upgrade-card').forEach(function(c) {
    c.classList.remove('selected');
  });
  var card = document.getElementById('upg-card-' + pkgId);
  if (card) card.classList.add('selected');
  // Tampilkan tombol Kirim
  document.getElementById('upgradeBtnWrap').style.display = '';
}

function openUpgradeModal() {
  if (!_upgradePkgId) return;
  document.getElementById('upgradeModalPkgName').textContent = _upgradePkgName;
  openModal('modalUpgrade');
}

async function executeUpgrade() {
  if (!_upgradePkgId) return;
  var btn = document.getElementById('btnConfirmUpgrade');
  btn.disabled = true; btn.innerHTML = '<div class="spinner" style="width:16px;height:16px;border-color:rgba(255,255,255,.3);border-top-color:#fff"></div> Mengirim...';
  try {
    var r = await fetch('/portal/api/upgrade', {
      method: 'POST', headers: authH(),
      body: JSON.stringify({ package_id: _upgradePkgId, package_name: _upgradePkgName })
    });
    var j = await r.json();
    closeModal('modalUpgrade');
    if (j.success) {
      toast('Permintaan berhasil dikirim! Tim ISP akan menghubungi Anda segera.');
      if (j.wa_url) setTimeout(function(){ window.open(j.wa_url, '_blank'); }, 800);
      // Sembunyikan tombol kirim & reset pilihan
      document.getElementById('upgradeBtnWrap').style.display = 'none';
      document.querySelectorAll('.pkg-upgrade-card').forEach(function(c){ c.classList.remove('selected'); });
      _upgradePkgId = null; _upgradePkgName = null;
    } else if (j.blocked) {
      showUpgradeBlockedBanner(j.existing_ticket);
    } else {
      toast(j.message || 'Gagal mengirim permintaan', true);
    }
  } catch(e) {
    closeModal('modalUpgrade');
    toast('Gagal: ' + e.message, true);
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Kirim Permintaan';
  }
}

function loadAll() {
  billingLoaded = false; signalLoaded = false; wifiLoaded = false; ticketsLoaded = false;
  loadDashboard();
  loadAnnouncements();
}

// ══════════════════════════════════════════════════════════════
// ANNOUNCEMENTS — Gangguan massal, maintenance, info
// ══════════════════════════════════════════════════════════════
var _dismissedAnns = JSON.parse(localStorage.getItem('ann_dismissed') || '[]');

function dismissAnn(id) {
  _dismissedAnns.push(id);
  localStorage.setItem('ann_dismissed', JSON.stringify(_dismissedAnns.slice(-20)));
  var el = document.getElementById('ann-' + id);
  if (el) { el.style.opacity='0'; el.style.transition='opacity .2s'; setTimeout(function(){ el.remove(); checkAnnWrap(); }, 200); }
}

function checkAnnWrap() {
  var wrap = document.getElementById('annWrap');
  if (wrap && wrap.children.length === 0) wrap.style.display = 'none';
}

async function loadAnnouncements() {
  try {
    var r = await fetch('/portal/api/announcements', { headers: authH() });
    var j = await r.json();
    if (!j.success || !j.data || !j.data.length) return;

    var wrap = document.getElementById('annWrap');
    var icons = {
      gangguan:    '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
      maintenance: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>',
      info:        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
      promo:       '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>'
    };
    var typeLabel = { gangguan:'⚠ Gangguan Jaringan', maintenance:'🔧 Maintenance', info:'ℹ Informasi', promo:'🎁 Promo' };

    var hasNew = false;
    j.data.forEach(function(ann) {
      if (_dismissedAnns.indexOf(ann.id) !== -1) return; // sudah dismiss
      hasNew = true;
      var until = ann.show_until ? ' · Sampai ' + new Date(ann.show_until).toLocaleDateString('id-ID',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}) : '';
      var html = '<div class="ann-item ' + (ann.type||'info') + '" id="ann-' + ann.id + '">' +
        '<button class="ann-dismiss" onclick="dismissAnn(' + ann.id + ')" title="Tutup">✕</button>' +
        '<div class="ann-row">' +
          '<div class="ann-icon">' + (icons[ann.type] || icons.info) + '</div>' +
          '<div class="ann-body">' +
            '<div class="ann-type">' + (typeLabel[ann.type] || ann.type) + '</div>' +
            '<div class="ann-title">' + escHtml(ann.title) + '</div>' +
            (ann.content ? '<div class="ann-content">' + escHtml(ann.content) + '</div>' : '') +
            (until ? '<div class="ann-until">🕐' + until + '</div>' : '') +
          '</div>' +
        '</div>' +
      '</div>';
      wrap.insertAdjacentHTML('beforeend', html);
    });

    if (hasNew) wrap.style.display = '';
  } catch(e) { /* silent fail */ }
}
// ══════════════════════════════════════════════════════════════
var ticketsLoaded = false;

function escapeHtml(s) {
  return String(s == null ? '' : s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function tkStatusLabel(s) {
  return ({ open:'Terbuka', in_progress:'Diproses', resolved:'Selesai', closed:'Ditutup', pending:'Menunggu' })[s] || s;
}

function tkTypeLabel(t) {
  return ({ gangguan:'Gangguan', request:'Permintaan', maintenance:'Maintenance' })[t] || t;
}

function tkIconSvg(type) {
  // Icon per tipe tiket
  if (type === 'request') {
    return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
  }
  if (type === 'maintenance') {
    return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>';
  }
  // default: gangguan
  return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
}

async function loadTickets() {
  if (ticketsLoaded) return;
  ticketsLoaded = true;
  try {
    var r = await fetch('/portal/api/tickets', { headers: authH() });
    var j = await r.json();
    var list = document.getElementById('ticketList');
    if (!j.success || !j.data || !j.data.length) {
      list.innerHTML = '<div class="empty-state">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:36px;height:36px;margin-bottom:8px;opacity:.4"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>' +
        '<div>Belum ada laporan.<br>Buat laporan pertama Anda di atas.</div>' +
        '</div>';
      return;
    }
    var html = '';
    j.data.forEach(function(t) {
      var statusKey = t.status || 'open';
      var badgeLbl  = tkStatusLabel(statusKey);
      var typeLbl   = tkTypeLabel(t.type);
      var descHtml  = t.description ? '<div style="font-size:11px;color:var(--muted);margin-top:4px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">' + escapeHtml(t.description) + '</div>' : '';
      html += '<div class="ticket-item">' +
        '<div class="tk-row">' +
          '<div class="tk-icon ' + statusKey + '">' + tkIconSvg(t.type) + '</div>' +
          '<div class="tk-info">' +
            '<div class="tk-title">' + escapeHtml(t.title) + '</div>' +
            '<div class="tk-meta">' + (t.ticket_number ? '#' + escapeHtml(t.ticket_number) + ' · ' : '') + typeLbl + ' · ' + fmtDate(t.created_at) + '</div>' +
            '<span class="tk-badge tk-' + statusKey + '">' + badgeLbl + '</span>' +
            descHtml +
          '</div>' +
        '</div>' +
      '</div>';
    });
    list.innerHTML = html;
  } catch(e) {
    console.error('loadTickets:', e);
    document.getElementById('ticketList').innerHTML = '<div class="empty-state">Gagal memuat riwayat. Coba lagi nanti.</div>';
  }
}

async function submitTicket() {
  var title = document.getElementById('tkTitle').value.trim();
  var desc  = document.getElementById('tkDesc').value.trim();
  var type  = document.getElementById('tkType').value;

  if (!title) { toast('Judul laporan wajib diisi', true); return; }
  if (title.length < 5) { toast('Judul terlalu pendek (min. 5 karakter)', true); return; }

  var btn = document.getElementById('btnSubmitTicket');
  btn.disabled = true; btn.textContent = 'Mengirim...';
  try {
    var r = await fetch('/portal/api/tickets', {
      method: 'POST', headers: authH(),
      body: JSON.stringify({ title: title, description: desc, type: type })
    });
    var j = await r.json();
    toast(j.message || (j.success ? 'Laporan berhasil dikirim' : 'Gagal kirim'), !j.success);
    if (j.success) {
      document.getElementById('tkTitle').value = '';
      document.getElementById('tkDesc').value = '';
      document.getElementById('tkType').value = 'gangguan';
      ticketsLoaded = false;
      loadTickets();
    }
  } catch(e) { toast('Error: ' + e.message, true); }
  finally { btn.disabled = false; btn.textContent = 'Kirim Laporan'; }
}

