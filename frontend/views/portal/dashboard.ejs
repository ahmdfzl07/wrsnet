var signalLoaded = false;
async function loadSignal() {
  if (signalLoaded) return;
  signalLoaded = true;
  try {
    var r = await fetch('/portal/api/signal', { headers: authH() });
    var j = await r.json();
    if (!j.success || !j.data) {
      document.getElementById('ontInfo').innerHTML = '<div class="empty-state" style="grid-column:1/-1">Data ONT tidak tersedia</div>';
      document.getElementById('signalRow').innerHTML = '';
      document.getElementById('btnReboot').style.display = 'none';
      return;
    }
    var d = j.data;
    document.getElementById('ontInfo').innerHTML =
      '<div class="info-item"><div class="ii-label">Serial</div><div class="ii-value">' + (d.serial||'—') + '</div></div>' +
      '<div class="info-item"><div class="ii-label">Status</div><div class="ii-value" style="color:' + (d.online?'var(--green)':'var(--red)') + '"><span class="status-dot ' + (d.online?'dot-green':'dot-red') + '"></span>' + (d.online?'Online':'Offline') + '</div></div>' +
      '<div class="info-item"><div class="ii-label">Model</div><div class="ii-value">' + (d.model||'—') + '</div></div>' +
      '<div class="info-item"><div class="ii-label">WAN IP</div><div class="ii-value">' + (d.wan_ip||'—') + '</div></div>' +
      '<div class="info-item full"><div class="ii-label">Uptime</div><div class="ii-value">' + (d.uptime||'—') + '</div></div>';
    var rx = parseFloat(d.rx_power), rxC = isNaN(rx)?'':rx>-25?'sig-good':rx>-28?'sig-warn':'sig-bad';
    var temp = d.temperature?parseFloat(d.temperature):null, tC = temp===null?'':temp<50?'sig-good':temp<60?'sig-warn':'sig-bad';
    document.getElementById('signalRow').innerHTML =
      '<div class="sig-card"><div class="sig-val ' + rxC + '">' + (isNaN(rx)?'—':rx.toFixed(1)) + ' <small style="font-size:12px;font-weight:600">dBm</small></div><div class="sig-lbl">RX Power</div></div>' +
      '<div class="sig-card"><div class="sig-val ' + tC + '">' + (temp!==null?temp.toFixed(0):'—') + ' <small style="font-size:12px;font-weight:600">°C</small></div><div class="sig-lbl">Suhu ONT</div></div>';
    document.getElementById('btnReboot').style.display = '';
  } catch(e) { console.error('Signal:', e); }
}

