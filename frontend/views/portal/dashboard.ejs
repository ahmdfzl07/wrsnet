          '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:var(--muted)">ONT SN di data pelanggan:</span><b>' + escHtml(dbg.ont_sn) + '</b></div>' +
          '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:var(--muted)">GenieACS:</span><b style="color:' + statusColor + '">' + statusText + '</b></div>' +
          (dbg.genieacs_error ? '<div style="color:var(--red);margin-bottom:4px">Error: ' + escHtml(dbg.genieacs_error) + '</div>' : '') +
          '<div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="color:var(--muted)">Total device di GenieACS:</span><b>' + (dbg.total_in_genieacs || 0) + '</b></div>' +
          (dbg.sample_serials && dbg.sample_serials.length
            ? '<div style="margin-top:6px;color:var(--muted)">SN tersedia di GenieACS:</div>' +
              dbg.sample_serials.map(function(s){ return '<div style="font-family:monospace;font-size:10px;margin-top:2px;color:var(--text)">• ' + escHtml(s.sn || s.id) + '</div>'; }).join('')
            : '') +
        '</div>';
      }

      var hint = '';
      if (!dbg.genieacs_reachable) {
        hint = 'GenieACS server tidak bisa diakses. Cek konfigurasi di Settings → GenieACS.';
      } else if (dbg.total_in_genieacs === 0) {
        hint = 'GenieACS aktif tapi belum ada device. Pastikan ONT sudah terhubung ke ACS server.';
      } else if (dbg.ont_sn) {
        hint = 'ONT SN "' + dbg.ont_sn + '" tidak cocok dengan device di GenieACS. Samakan SN di data pelanggan dengan yang ada di atas.';
      } else if (/tidak terdaftar/i.test(msg)) {
        hint = 'ONT belum terdaftar di akun pelanggan. Hubungi ISP.';
      } else {
        hint = 'Pastikan ONT menyala & terhubung, atau hubungi ISP.';
      }

      document.getElementById('wifiOntInfo').innerHTML =
        '<div style="padding:4px">' +
          '<div style="font-weight:700;color:var(--text);margin-bottom:4px">ONT tidak ditemukan</div>' +
          '<div style="font-size:11px;color:var(--muted);line-height:1.5">' + hint + '</div>' +
          debugHtml +
        '</div>';
      document.getElementById('wifiNoOnt').style.display = 'none';
      document.getElementById('wifiFormCard').style.display = 'none';
      return;
    }

    var d = j.data;
    _wifiDeviceId = d.device_id;

    // Helper: kelas warna untuk RX Power
    var rxClass = '';
    if (d.rx_power !== null && d.rx_power !== undefined) {
      var rxNum = parseFloat(d.rx_power);
      rxClass = rxNum > -25 ? 'sig-good' : (rxNum > -28 ? 'sig-warn' : 'sig-bad');
    }

    // Status ONT card
    var html = '<div class="info-grid">';
    html += '<div class="info-item"><div class="ii-label">Status</div><div class="ii-value" style="color:' + (d.online ? 'var(--green)' : 'var(--red)') + '"><span class="status-dot ' + (d.online ? 'dot-green' : 'dot-red') + '"></span>' + (d.online ? 'Online' : 'Offline') + '</div></div>';
    html += '<div class="info-item"><div class="ii-label">Uptime</div><div class="ii-value">' + (d.uptime || '—') + '</div></div>';
    if (d.rx_power !== null && d.rx_power !== undefined) {
      html += '<div class="info-item"><div class="ii-label">RX Power</div><div class="ii-value ' + rxClass + '">' + parseFloat(d.rx_power).toFixed(1) + ' dBm</div></div>';
    }
    if (d.temperature !== null && d.temperature !== undefined) {
      html += '<div class="info-item"><div class="ii-label">Suhu ONT</div><div class="ii-value">' + parseFloat(d.temperature).toFixed(0) + ' °C</div></div>';
    }
    html += '</div>';
    document.getElementById('wifiOntInfo').innerHTML = html;

    // Tombol reboot: hanya tampil kalau ONT online
    var btnReboot = document.getElementById('btnWifiReboot');
    if (btnReboot) btnReboot.style.display = d.online ? '' : 'none';

    // Isi form WiFi
    var wifi = d.wifi || {};
    if (wifi.ssid_2g) document.getElementById('wSsid2g').value = wifi.ssid_2g;
    if (wifi.password_2g) document.getElementById('wPass2g').value = wifi.password_2g;

    if (wifi.ssid_5g || wifi.password_5g) {
      document.getElementById('wifi5gSection').style.display = '';
      if (wifi.ssid_5g) document.getElementById('wSsid5g').value = wifi.ssid_5g;
      if (wifi.password_5g) document.getElementById('wPass5g').value = wifi.password_5g;
    }

    document.getElementById('wifiFormCard').style.display = '';
    document.getElementById('wifiNoOnt').style.display = 'none';
  } catch(e) {
    console.error('loadWifi:', e);
    document.getElementById('wifiOntInfo').innerHTML = '<div class="empty-state">Gagal memuat data. Cek koneksi Anda.</div>';
  }
}

async function saveWifi() {
  var ssid2g = document.getElementById('wSsid2g').value.trim();
  var pass2g = document.getElementById('wPass2g').value;
  var ssid5g = document.getElementById('wSsid5g') ? document.getElementById('wSsid5g').value.trim() : '';
  var pass5g = document.getElementById('wPass5g') ? document.getElementById('wPass5g').value : '';

  if (!ssid2g && !pass2g && !ssid5g && !pass5g) {
    toast('Tidak ada perubahan', true); return;
  }
  if (pass2g && pass2g.length < 8) { toast('Password WiFi minimal 8 karakter', true); return; }
  if (pass5g && pass5g.length < 8) { toast('Password WiFi 5GHz minimal 8 karakter', true); return; }

  var btn = document.getElementById('btnSaveWifi');
  btn.disabled = true; btn.textContent = 'Menyimpan...';

  try {
    var body = {};
    if (ssid2g) body.ssid_2g = ssid2g;
    if (pass2g) body.password_2g = pass2g;
    if (ssid5g) body.ssid_5g = ssid5g;
    if (pass5g) body.password_5g = pass5g;

    var r = await fetch('/portal/api/wifi', {
      method: 'POST', headers: authH(), body: JSON.stringify(body)
    });
    var j = await r.json();
    toast(j.message || (j.success ? 'Berhasil disimpan' : 'Gagal'), !j.success);
    if (j.success) { wifiLoaded = false; setTimeout(function(){ wifiLoaded=false; loadWifi(); }, 5000); }
  } catch(e) { toast('Error: ' + e.message, true); }
  finally { btn.disabled = false; btn.textContent = 'Simpan Pengaturan WiFi'; }
}

