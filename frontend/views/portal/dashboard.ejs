    .pm-heading{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin:6px 0 10px;}
    .pm-group{border:1px solid var(--border);border-radius:14px;margin-bottom:10px;overflow:hidden;background:#fff;}
    .pm-group-head{display:flex;align-items:center;gap:12px;padding:14px 16px;cursor:pointer;user-select:none;transition:background .15s;}
    .pm-group-head:hover{background:#f8fafc;}
    .pm-group-head.open{background:#eff6ff;}
    .pm-group-ico{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--blue),var(--blue2));display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;}
    .pm-group-ico.is-ewallet{background:linear-gradient(135deg,#8b5cf6,#6d28d9);}
    .pm-group-ico.is-qris{background:linear-gradient(135deg,#f59e0b,#d97706);}
    .pm-group-ico.is-gateway{background:linear-gradient(135deg,#64748b,#475569);}
    .pm-group-ico.is-gw-active{background:linear-gradient(135deg,#06b6d4,#0891b2);box-shadow:0 4px 12px rgba(6,182,212,.35);}
    .pm-gw-card{margin-bottom:14px;border:2px solid #06b6d4!important;background:linear-gradient(135deg,#ecfeff,#cffafe)!important;position:relative;overflow:hidden;}
    .pm-gw-card::before{content:'';position:absolute;top:-50%;right:-30%;width:200px;height:200px;background:radial-gradient(circle,rgba(6,182,212,.2),transparent 70%);pointer-events:none;}
    .pm-gw-head{padding:14px 14px;background:transparent!important;}
    .pm-gw-head:hover{background:rgba(6,182,212,.06)!important;}
    .pm-gw-card:hover{transform:translateY(-1px);box-shadow:0 8px 22px rgba(6,182,212,.22);transition:all .2s;}
    .pm-gw-badge{display:inline-block;background:#06b6d4;color:#fff;font-size:9px;font-weight:800;padding:1px 7px;border-radius:8px;margin-left:5px;letter-spacing:.4px;vertical-align:1px;}
    .pm-gw-arrow{color:#0891b2;flex-shrink:0;}
    .pm-divider{display:flex;align-items:center;gap:10px;margin:14px 2px 10px;color:var(--muted);font-size:11px;font-weight:600;}
    .pm-divider::before,.pm-divider::after{content:'';flex:1;height:1px;background:var(--border);}
    .pm-divider span{padding:0 4px;text-transform:uppercase;letter-spacing:.6px;}
    .pm-group-text{flex:1;min-width:0;}
    .pm-group-title{font-size:13px;font-weight:700;color:var(--text);}
    .pm-group-sub{font-size:11px;color:var(--muted);margin-top:2px;}
    .pm-group-count{padding:2px 8px;border-radius:20px;background:#e2e8f0;color:var(--muted);font-size:10px;font-weight:700;}
    .pm-group-chev{color:var(--muted);transition:transform .25s;flex-shrink:0;}
    .pm-group-head.open .pm-group-chev{transform:rotate(180deg);}
    .pm-group-body{max-height:0;overflow:hidden;transition:max-height .3s ease;}
    .pm-group-head.open + .pm-group-body{max-height:2000px;}
    .pm-group-inner{padding:4px 10px 10px;}
    .pm-group-head.disabled{cursor:default;opacity:.65;}
    .pm-group-head.disabled:hover{background:#fff;}
    .pm-badge-soon{background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;}
    .pm-item{padding:12px;border-radius:11px;margin-bottom:8px;background:#f8fafc;border:1.5px solid transparent;transition:all .15s;}
    .pm-item:last-child{margin-bottom:0;}
    .pm-item-row{display:flex;align-items:center;gap:11px;}
    .pm-logo{width:40px;height:40px;border-radius:8px;background:#fff;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:800;font-size:10px;color:var(--text);letter-spacing:.3px;text-align:center;line-height:1;padding:0 2px;overflow:hidden;}
