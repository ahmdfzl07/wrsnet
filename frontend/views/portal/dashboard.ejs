    .pm-qris-box{background:#fff;border-radius:12px;padding:16px;text-align:center;}
    .pm-qris-box img{max-width:220px;width:100%;height:auto;border-radius:8px;}
    .pm-qris-hint{font-size:11px;color:var(--muted);margin-top:10px;line-height:1.5;}
    .pm-warn{background:#fffbeb;border:1px solid #fde68a;border-radius:12px;padding:11px 14px;margin-top:10px;margin-bottom:14px;display:flex;gap:10px;align-items:flex-start;}
    .pm-warn svg{width:16px;height:16px;color:#d97706;flex-shrink:0;margin-top:1px;}
    .pm-warn-text{font-size:11.5px;color:#78350f;line-height:1.55;}
