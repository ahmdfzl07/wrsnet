// ══════════════════════════════════════════════════════════════
// WEB PUSH — Service Worker + VAPID Subscribe
// ══════════════════════════════════════════════════════════════
var _swReg       = null;  // ServiceWorkerRegistration
var _vapidKey    = null;  // VAPID public key dari server
var _pushInited  = false;

// Konversi base64url → Uint8Array (untuk VAPID applicationServerKey)
function urlBase64ToUint8Array(base64String) {
  var padding = '='.repeat((4 - base64String.length % 4) % 4);
  var base64  = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  var raw     = window.atob(base64);
  var output  = new Uint8Array(raw.length);
  for (var i = 0; i < raw.length; i++) output[i] = raw.charCodeAt(i);
  return output;
}

// Deteksi nama device dari user-agent
function getDeviceName() {
  var ua = navigator.userAgent || '';
  if (/android/i.test(ua)) {
    var m = ua.match(/;\s*([^;)]+)\s*Build/);
    return m ? m[1].trim() : 'Android Device';
  }
  if (/iphone/i.test(ua)) return 'iPhone';
  if (/ipad/i.test(ua))   return 'iPad';
  return 'Desktop Browser';
}

// ── Init: register SW + cek status ───────────────────────────
// ── Environment detection ──────────────────────────────────────
// When running inside the Capacitor Android APK, window.Capacitor is defined
// by the native bridge. We also check for isNativePlatform() to be safe in
// hybrid scenarios (e.g. Capacitor running in browser for dev).
function _isCapacitorNative() {
  try {
    return !!(window.Capacitor && typeof window.Capacitor.isNativePlatform === 'function'
                               && window.Capacitor.isNativePlatform());
  } catch (_) { return false; }
}

async function initPush() {
  if (_pushInited) return;
  _pushInited = true;

  var card = document.getElementById('pushCard');
  if (!card) return;

  // Branch: Capacitor APK vs browser. In the APK the Web Push stack is not
  // available — we use the Capacitor PushNotifications plugin which talks to
  // FCM directly through the native layer.
  if (_isCapacitorNative()) {
    return _initCapacitorPush();
  }
  return _initWebPush();
}

// ── Web Push init (browser) ───────────────────────────────────
async function _initWebPush() {
  var card = document.getElementById('pushCard');

  // Cek support
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    showPushState('unsupported'); return;
  }

  try {
    // 1. Ambil VAPID key dari server
    var r = await fetch('/portal/api/push/vapid-key', { headers: authH() });
    var j = await r.json();
    if (!j.success || !j.vapid_public_key) {
      // Server push tidak aktif — sembunyikan card
      card.style.display = 'none'; return;
    }
    _vapidKey = j.vapid_public_key;

    // 2. Register Service Worker
    _swReg = await navigator.serviceWorker.register('/sw.js', { scope: '/' });
    await navigator.serviceWorker.ready;

    // 3. Cek permission
    var perm = Notification.permission;
    if (perm === 'denied') { showPushState('blocked'); return; }

    // 4. Cek apakah sudah subscribe di browser
    var existingSub = await _swReg.pushManager.getSubscription();

    if (existingSub) {
      // Sudah subscribe — cek di server juga
      var sr = await fetch('/portal/api/push/status', { headers: authH() });
      var sj = await sr.json();
      showPushState('on', sj.device_count || 1);
    } else {
      showPushState('off');
    }
  } catch (e) {
    console.error('[Push] initWebPush error:', e);
    card.style.display = 'none';
  }
}

// ── Capacitor (APK) Push init ─────────────────────────────────
// Uses @capacitor/push-notifications. The plugin must be installed and
// configured in the Android project — see docs/capacitor-push-setup.md.
var _capListenersBound = false;

async function _initCapacitorPush() {
  var card = document.getElementById('pushCard');

  try {
    var PushNotifications = window.Capacitor?.Plugins?.PushNotifications;
    if (!PushNotifications) {
      // Plugin belum di-install di APK build — sembunyikan card daripada
      // tampil "unsupported" yang misleading.
      console.warn('[Push] Capacitor PushNotifications plugin not available');
      card.style.display = 'none';
      return;
    }

    // Check current server-side status (is there already an FCM token for this customer?)
    var sr = await fetch('/portal/api/push/status', { headers: authH() });
    var sj = await sr.json();

    if (!sj.push_enabled) {
      // Server-side FCM credential tidak ter-setup — nothing we can do.
      card.style.display = 'none';
      return;
    }

    // Bind listeners once per session
    if (!_capListenersBound) {
      _capListenersBound = true;

      PushNotifications.addListener('registration', async function(token) {
        // token.value is the FCM registration token
        try {
          var r = await fetch('/portal/api/push/register-fcm', {
            method:  'POST',
            headers: authH(),
            body:    JSON.stringify({
              fcm_token:   token.value,
              device_name: getDeviceName() + ' (App)'
            })
          });
          var j = await r.json();
          if (j.success) {
            showPushState('on', (sj.fcm_count || 0) + 1);
          } else {
            showPushState('off');
            toast(j.message || 'Gagal daftar notifikasi', true);
          }
        } catch (e) {
          console.error('[Push] register-fcm error:', e);
          showPushState('off');
        }
      });

      PushNotifications.addListener('registrationError', function(err) {
        console.error('[Push] Capacitor registration error:', err);
        showPushState('off');
        toast('Gagal registrasi notifikasi', true);
      });

      // When a notification arrives while the app is in foreground, surface
      // it in-app (the native layer also fires a local notification). When
      // user taps a notification, navigate to the url embedded in data.
      PushNotifications.addListener('pushNotificationReceived', function(notif) {
        // optional: show in-app toast / badge update here
        console.log('[Push] Received:', notif);
      });
      PushNotifications.addListener('pushNotificationActionPerformed', function(action) {
        var url = action?.notification?.data?.url;
        if (url && typeof url === 'string' && url.startsWith('/portal')) {
          // SPA navigate — dashboard is single-page, so update hash or reload
          try { window.location.assign(url); } catch(_) {}
        }
      });
    }

    // Reflect current state in UI
    if (sj.fcm_count > 0) {
      showPushState('on', sj.fcm_count);
    } else {
      showPushState('off');
    }
  } catch (e) {
    console.error('[Push] initCapacitorPush error:', e);
    card.style.display = 'none';
  }
}

function showPushState(state, deviceCount) {
  var states = { loading:'pushLoading', unsupported:'pushNotSupported', blocked:'pushBlocked', off:'pushOff', on:'pushOn' };
  Object.values(states).forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });
  var active = states[state];
  if (active) {
    var el = document.getElementById(active);
    if (el) el.style.display = '';
  }
  if (state === 'on' && deviceCount) {
    var dc = document.getElementById('pushDeviceCount');
    if (dc) dc.textContent = deviceCount + ' perangkat terdaftar';
  }
}

// ── Enable Push ───────────────────────────────────────────────
async function enablePush() {
  // Branch to Capacitor plugin in the APK — the Web Push stack can't run there.
  if (_isCapacitorNative()) {
    return _enableCapacitorPush();
  }

  if (!_swReg || !_vapidKey) { toast('Push tidak tersedia', true); return; }

  var btn = document.getElementById('btnEnablePush');
  btn.disabled = true; btn.textContent = 'Meminta izin...';

  try {
    // 1. Minta permission
    var perm = await Notification.requestPermission();
    if (perm !== 'granted') {
      showPushState('blocked');
      btn.disabled = false; btn.textContent = 'Aktifkan Notifikasi';
      return;
    }

    btn.textContent = 'Mendaftarkan...';

    // 2. Subscribe ke push service
    var sub = await _swReg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(_vapidKey)
    });

    // 3. Kirim subscription ke server
    var r = await fetch('/portal/api/push/subscribe-auth', {
      method:  'POST',
      headers: authH(),
      body:    JSON.stringify({
        subscription: sub.toJSON(),
        device_name:  getDeviceName()
      })
    });
    var j = await r.json();

    if (j.success) {
      showPushState('on', 1);
      toast('Notifikasi push aktif! ✓');
    } else {
      toast(j.message || 'Gagal mendaftar', true);
      showPushState('off');
    }
  } catch (e) {
    console.error('[Push] enablePush error:', e);
    toast('Gagal: ' + e.message, true);
    showPushState('off');
  } finally {
    btn.disabled = false; btn.textContent = 'Aktifkan Notifikasi';
  }
}

// ── Enable Push on Capacitor (APK) ────────────────────────────
async function _enableCapacitorPush() {
  var PushNotifications = window.Capacitor?.Plugins?.PushNotifications;
  if (!PushNotifications) { toast('Plugin belum tersedia', true); return; }

  var btn = document.getElementById('btnEnablePush');
  if (btn) { btn.disabled = true; btn.textContent = 'Meminta izin...'; }

  try {
    // 1. Check/request permission. Plugin returns {receive: 'granted' | 'denied' | 'prompt'}.
    var perm = await PushNotifications.checkPermissions();
    if (perm.receive !== 'granted') {
      perm = await PushNotifications.requestPermissions();
    }
    if (perm.receive !== 'granted') {
      showPushState('blocked');
      return;
    }

    if (btn) btn.textContent = 'Mendaftarkan...';

    // 2. register() triggers the 'registration' listener we wired up in
    //    _initCapacitorPush(), which sends the FCM token to the server.
    //    No promise return here — we rely on the listener for the result.
    await PushNotifications.register();

    // Listener will update the UI when the token lands. Set a fallback in
    // case registration never fires (device offline, Play Services missing).
    setTimeout(function() {
      var onEl = document.getElementById('pushOn');
      if (onEl && onEl.style.display === 'none') {
        // Still not 'on' after 10s — something is wrong but don't confuse user
        console.warn('[Push] Registration did not complete within 10s');
      }
    }, 10000);
  } catch (e) {
    console.error('[Push] _enableCapacitorPush error:', e);
    toast('Gagal: ' + (e.message || 'unknown'), true);
    showPushState('off');
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = 'Aktifkan Notifikasi'; }
  }
}

// ── Disable Push ──────────────────────────────────────────────
async function disablePush() {
  if (!confirm('Nonaktifkan notifikasi push?\nAnda tidak akan mendapat reminder tagihan.')) return;

  // Branch to Capacitor flow in the APK
  if (_isCapacitorNative()) {
    return _disableCapacitorPush();
  }

  var btn = document.getElementById('btnDisablePush');
  btn.disabled = true; btn.textContent = 'Menonaktifkan...';

  try {
    // 1. Unsubscribe di browser
    var existingSub = _swReg && await _swReg.pushManager.getSubscription();
    var endpoint = null;
    if (existingSub) {
      endpoint = existingSub.endpoint;
      await existingSub.unsubscribe();
    }

    // 2. Hapus di server
    await fetch('/portal/api/push/unsubscribe', {
      method:  'POST',
      headers: authH(),
      body:    JSON.stringify({ endpoint })
    });

    showPushState('off');
    toast('Notifikasi push dinonaktifkan');
  } catch (e) {
    toast('Gagal: ' + e.message, true);
  } finally {
    btn.disabled = false; btn.textContent = 'Nonaktifkan Notifikasi';
  }
}

// ── Disable Push on Capacitor (APK) ───────────────────────────
// Note: Capacitor PushNotifications plugin does NOT expose getToken() on all
// platforms, so we ask the server to drop *all* FCM subs for this customer.
// This matches the UX (a single "Nonaktifkan" button) and avoids touching
// tokens belonging to other installs on other devices — each device's token
// is distinct, so this only removes the current one on re-register.
async function _disableCapacitorPush() {
  var btn = document.getElementById('btnDisablePush');
  if (btn) { btn.disabled = true; btn.textContent = 'Menonaktifkan...'; }

  try {
    // Server side: remove all subs for this customer (both platforms). This
    // is the same endpoint the web flow uses with no `endpoint` param.
    await fetch('/portal/api/push/unsubscribe', {
      method:  'POST',
      headers: authH(),
      body:    JSON.stringify({})
    });

    // Native side: unregister to stop the OS from delivering further pushes.
    // (Method name differs by plugin version — try removeAllListeners as
    // cleanup; actual FCM unregister happens via account token invalidation
    // on next app uninstall.)
    try {
      var PushNotifications = window.Capacitor?.Plugins?.PushNotifications;
      if (PushNotifications && typeof PushNotifications.removeAllDeliveredNotifications === 'function') {
        await PushNotifications.removeAllDeliveredNotifications();
      }
    } catch(_) { /* non-fatal */ }

    showPushState('off');
    toast('Notifikasi push dinonaktifkan');
  } catch (e) {
    toast('Gagal: ' + (e.message || 'unknown'), true);
  } finally {
    if (btn) { btn.disabled = false; btn.textContent = 'Nonaktifkan Notifikasi'; }
  }
}

// Inisialisasi push saat panel profil dibuka
var _origFillProfil = typeof fillProfil === 'function' ? fillProfil : function(){};
fillProfil = function() {
  _origFillProfil();
  initPush();
};

document.addEventListener('DOMContentLoaded', loadAll);
</script>
