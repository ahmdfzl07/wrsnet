async function payOnline(provider, method, fee = 0) {
  try {

    const response = await fetch("/api/payment/create", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        provider: provider,
        invoice_id: PAY_CONTEXT.invoice_id,
        method: method,
        admin_fee: fee
      }),
    });

    const res = await response.json();

    if (!res.success) {
      alert(res.message || "Gagal");
      return;
    }

    if (res.payment_url) {
      window.location.href = res.payment_url;
    }

  } catch (err) {
    console.error(err);
    alert("Error pembayaran");
  }
}

