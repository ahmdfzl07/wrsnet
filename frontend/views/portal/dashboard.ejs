    .pm-owner{font-size:11px;color:var(--muted);margin-top:2px;}
    .pm-copy-btn{padding:8px 12px;border-radius:9px;background:var(--blue);color:#fff;border:none;font-size:11px;font-weight:700;font-family:inherit;cursor:pointer;display:flex;align-items:center;gap:5px;flex-shrink:0;transition:all .15s;}
    .pm-copy-btn:hover{background:var(--blue2);}
    .pm-copy-btn.copied{background:var(--green);}
