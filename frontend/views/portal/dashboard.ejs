var ticketsLoaded = false;

function escapeHtml(s) {
  return String(s == null ? '' : s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function tkStatusLabel(s) {
  return ({ open:'Terbuka', in_progress:'Diproses', resolved:'Selesai', closed:'Ditutup', pending:'Menunggu' })[s] || s;
}

function tkTypeLabel(t) {
  return ({ gangguan:'Gangguan', request:'Permintaan', maintenance:'Maintenance' })[t] || t;
}

function tkIconSvg(type) {
  // Icon per tipe tiket
  if (type === 'request') {
    return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
  }
  if (type === 'maintenance') {
    return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>';
  }
  // default: gangguan
  return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
}

async function loadTickets() {
  if (ticketsLoaded) return;
  ticketsLoaded = true;
  try {
    var r = await fetch('/portal/api/tickets', { headers: authH() });
    var j = await r.json();
    var list = document.getElementById('ticketList');
    if (!j.success || !j.data || !j.data.length) {
      list.innerHTML = '<div class="empty-state">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:36px;height:36px;margin-bottom:8px;opacity:.4"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>' +
        '<div>Belum ada laporan.<br>Buat laporan pertama Anda di atas.</div>' +
        '</div>';
      return;
    }
    var html = '';
    j.data.forEach(function(t) {
      var statusKey = t.status || 'open';
      var badgeLbl  = tkStatusLabel(statusKey);
      var typeLbl   = tkTypeLabel(t.type);
      var descHtml  = t.description ? '<div style="font-size:11px;color:var(--muted);margin-top:4px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">' + escapeHtml(t.description) + '</div>' : '';
      html += '<div class="ticket-item">' +
        '<div class="tk-row">' +
          '<div class="tk-icon ' + statusKey + '">' + tkIconSvg(t.type) + '</div>' +
          '<div class="tk-info">' +
            '<div class="tk-title">' + escapeHtml(t.title) + '</div>' +
            '<div class="tk-meta">' + (t.ticket_number ? '#' + escapeHtml(t.ticket_number) + ' · ' : '') + typeLbl + ' · ' + fmtDate(t.created_at) + '</div>' +
            '<span class="tk-badge tk-' + statusKey + '">' + badgeLbl + '</span>' +
            descHtml +
          '</div>' +
        '</div>' +
      '</div>';
    });
    list.innerHTML = html;
  } catch(e) {
    console.error('loadTickets:', e);
    document.getElementById('ticketList').innerHTML = '<div class="empty-state">Gagal memuat riwayat. Coba lagi nanti.</div>';
  }
}

async function submitTicket() {
  var title = document.getElementById('tkTitle').value.trim();
  var desc  = document.getElementById('tkDesc').value.trim();
  var type  = document.getElementById('tkType').value;

  if (!title) { toast('Judul laporan wajib diisi', true); return; }
  if (title.length < 5) { toast('Judul terlalu pendek (min. 5 karakter)', true); return; }

  var btn = document.getElementById('btnSubmitTicket');
  btn.disabled = true; btn.textContent = 'Mengirim...';
  try {
    var r = await fetch('/portal/api/tickets', {
      method: 'POST', headers: authH(),
      body: JSON.stringify({ title: title, description: desc, type: type })
    });
    var j = await r.json();
    toast(j.message || (j.success ? 'Laporan berhasil dikirim' : 'Gagal kirim'), !j.success);
    if (j.success) {
      document.getElementById('tkTitle').value = '';
      document.getElementById('tkDesc').value = '';
      document.getElementById('tkType').value = 'gangguan';
      ticketsLoaded = false;
      loadTickets();
    }
  } catch(e) { toast('Error: ' + e.message, true); }
  finally { btn.disabled = false; btn.textContent = 'Kirim Laporan'; }
}

// ══════════════════════════════════════════════════════════════
// HUBUNGI CS (Contact Modal)
// ══════════════════════════════════════════════════════════════
function normalizeWa(num) {
  // Bersihkan nomor WA: hapus non-digit, normalize 08xx → 628xx
  if (!num) return '';
  var n = String(num).replace(/[^0-9]/g, '');
  if (n.startsWith('0'))    n = '62' + n.substring(1);
  else if (n.startsWith('8')) n = '62' + n;
  return n;
}

function openContactModal() {
  // Priority: settings dari DB → fallback hardcoded
  var rawWa    = (META && META.company_wa)    || DEFAULT_CS_WA;
  var rawPhone = (META && META.company_phone) || DEFAULT_CS_PHONE;
  var rawEmail = (META && META.company_email) || DEFAULT_CS_EMAIL;

  var wa    = rawWa ? normalizeWa(rawWa) : '';
  var phone = rawPhone ? String(rawPhone).trim() : '';
  var email = rawEmail ? String(rawEmail).trim() : '';
  var company = (META && META.company_name) || 'ISP';

  // Greeting untuk WA — sertakan ID pelanggan untuk memudahkan CS
  var custId   = CUST_DATA && CUST_DATA.customer ? CUST_DATA.customer.customer_id : '';
  var custName = CUST_DATA && CUST_DATA.customer ? CUST_DATA.customer.name : '';
  var waMsg    = 'Halo ' + company + ', saya ' + custName + ' (ID: ' + custId + '). Mohon bantuannya.';
  var waUrl    = wa ? 'https://wa.me/' + wa + '?text=' + encodeURIComponent(waMsg) : '';

  var emailSubject = 'Bantuan Pelanggan — ' + custId;
  var emailBody    = 'Halo ' + company + ',\n\nSaya ' + custName + ' (ID Pelanggan: ' + custId + ').\n\n[Tulis pertanyaan/keluhan Anda di sini]\n\nTerima kasih.';
  var emailUrl = email ? 'mailto:' + email + '?subject=' + encodeURIComponent(emailSubject) + '&body=' + encodeURIComponent(emailBody) : '';

  var telUrl = phone ? 'tel:' + phone.replace(/[^0-9+]/g, '') : '';

