.profile-avatar-wrap::after{content:'';position:absolute;bottom:1px;right:1px;width:9px;height:9px;border-radius:50%;background:#22c55e;border:2px solid #fff;}
.profile-info{flex:1;min-width:0;}
.profile-name{font-size:12.5px;font-weight:700;color:#0d1b3e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.3;}
.profile-role{font-size:10.5px;color:#94a3b8;text-transform:capitalize;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.profile-logout-btn{margin-left:auto;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:8px;color:#94a3b8;transition:all .15s;flex-shrink:0;text-decoration:none;}
.profile-logout-btn:hover{background:rgba(245,54,92,.12);color:#f5365c;}

/* ── Nav dropdown group ── */
.nav-group{margin:0;}
