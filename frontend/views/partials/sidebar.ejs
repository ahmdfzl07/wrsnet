<!-- Sidebar -->
<aside id="sidebar" class="sidebar">
<% const isDemoUser    = user && user.role && (user.role.name === 'demo'); %>
<% const isFinanceUser = user && user.role && (user.role.name === 'finance'); %>
<% const isNocUser     = user && user.role && (user.role.name === 'noc'); %>
<% function demoHide(flag) { return flag ? 'style="display:none;"' : ''; } %>
<% function financeHide(flag) { return flag ? 'style="display:none;"' : ''; } %>
  <div class="sidebar-header">
    <div class="sidebar-logo" id="sidebarBrand">
      <%
        // Ambil brand settings dari app (fallback ke default)
        const brandMode   = locals.brandMode   || locals.appSettings?.brand_mode   || 'name_tagline';
        const appName     = locals.appName     || locals.appSettings?.app_name     || 'DIGSnet';
        const appTagline  = locals.appTagline  || locals.appSettings?.app_tagline  || ' Management';
        const logoUrl     = locals.logoUrl     || locals.appSettings?.logo_url     || '';
      %>
      <% if (brandMode === 'logo_only' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="<%= appName %>" style="height:36px;object-fit:contain;">
      <% } else if (brandMode === 'name_logo' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="logo" style="height:32px;object-fit:contain;flex-shrink:0;">
        <span class="logo-text"><%= appName %></span>
      <% } else { %>
        <div class="logo-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
          </svg>
        </div>
        <div style="display:flex;flex-direction:column;line-height:1.2;">
          <span class="logo-text" style="font-size:15px;font-weight:800;"><%= appName %></span>
          <% if (brandMode === 'name_tagline' && appTagline) { %>
          <span style="font-size:9.5px;color:#94a3b8;font-weight:500;letter-spacing:.03em;"><%= appTagline %></span>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <nav class="sidebar-nav">

