<script>
(function(){
  const nameEl = document.getElementById('sidebarName');
  const av = document.getElementById('sidebarAvatar');
  if(nameEl && av){
    const name = nameEl.textContent.trim();
    const initials = name.split(/\s+/).filter(Boolean).map(w=>w[0]).slice(0,2).join('').toUpperCase() || 'A';
    av.textContent = initials;
  }
  // GenieACS online badge
  (async () => {
    try {
      const r = await fetch('/api/genieacs/stats');
      const j = await r.json();
      if (j.success && j.data?.online > 0) {
        const badge = document.getElementById('genieacs-online-badge');
        if (badge) { badge.textContent = j.data.online; badge.style.display = 'inline-flex'; }
      }
    } catch(e) {}
  })();

  const logoutBtn = document.getElementById('logoutBtnProfile') || document.getElementById('logoutBtn');
  if(logoutBtn){
    logoutBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      try { await fetch('/api/auth/logout',{method:'POST'}); } catch(err){}
      window.location.href='/login';
    });
  }
})();

// Nav dropdown group toggle (Billing & Invoice, etc.)
function toggleNavGroup(btn){
  const group = btn.closest('.nav-group');
  if (group) group.classList.toggle('open');
}
</script>
