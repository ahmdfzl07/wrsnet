}
.nav-group-toggle .nav-chev{
  width:14px;height:14px;margin-left:auto;flex-shrink:0;
  transition:transform .2s ease;color:currentColor;opacity:.55;
}
.nav-group.open .nav-group-toggle .nav-chev{transform:rotate(180deg);opacity:.85;}
.nav-group-children{
  max-height:0;overflow:hidden;
  transition:max-height .25s ease;
}
.nav-group.open .nav-group-children{max-height:240px;}
.nav-sub{
  display:flex;align-items:center;gap:10px;
  padding:8px 18px 8px 44px;
  font-size:12.5px;font-weight:500;color:#64748b;
  text-decoration:none;border-radius:0;
  position:relative;transition:background .15s,color .15s;
}
.nav-sub:hover{color:#1a6ef5;background:rgba(26,110,245,.05);}
.nav-sub.active{color:#1a6ef5;font-weight:700;background:rgba(26,110,245,.08);}
.nav-sub.active .nav-sub-dot{background:#1a6ef5;transform:scale(1.4);}
