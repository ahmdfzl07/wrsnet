<script>
  function toggleNavGroup(button) {
        // Mencari container group dari tombol yang diklik
        const group = button.closest('.nav-group');
        if (group) {
            // Toggle class 'open' untuk menampilkan/menyembunyikan anak menu
            group.classList.toggle('open');
            
            // Opsional: Jika ingin menutup group lain saat satu group dibuka (accordion style)
            // document.querySelectorAll('.nav-group').forEach(el => {
            //     if (el !== group) el.classList.remove('open');
            // });
        }
    }
</script>
