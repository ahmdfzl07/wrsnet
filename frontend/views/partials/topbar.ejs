  <%- include('./demo-banner') %>
<% } %>
<% const isFinanceUser = (typeof user !== 'undefined') && user && user.role && user.role.name === 'finance'; %>
<!-- Top Navigation Bar -->
<header class="topbar">
  <div class="topbar-left">
    <button class="sidebar-toggle" id="sidebarToggle">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="topbar-right">
    <div class="search-box" id="globalSearchWrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input type="text" placeholder="Cari perangkat, user..." id="globalSearch" autocomplete="off">
      <div class="global-search-dropdown" id="globalSearchDropdown"></div>
    </div>
    <div class="topbar-actions">

      <!-- CHAT PANEL -->
      <div class="chat-wrap">

        <button class="chat-float-btn" onclick="toggleChatPanel()">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21 15a4 4 0 0 1-4 4H8l-5 4V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/>
          </svg>
          <span id="chatBadge" class="chat-badge">0</span>
        </button>

        <div id="chatPanel" style="display:none;">

          <div class="chat-header">Live Chat</div>

          <div id="chatRoomList">
            <div class="empty">
              Tidak ada chat
            </div>
          </div>

        </div>

      </div>

      <!-- CHAT AREA -->
      <div id="chatContainer" style="display:none;">

        <div class="chat-header">
          <div class="chat-title">

            <div class="chat-avatar">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                viewBox="0 0 24 24" fill="currentColor">
                <path d="M21 15a4 4 0 0 1-4 4H8l-5 4V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/>
              </svg>
            </div>

            <div class="chat-meta">
              <div id="chatTitleText" class="chat-name">Chat</div>
              <div class="chat-status">Online Support</div>
            </div>

          </div>

          <button onclick="closeChat()" class="chat-close">
            ✕
          </button>
        </div>

        <div id="chatBox"></div>

        <div class="chat-input-area">
          <input id="chatInput" class="chat-input" placeholder="Tulis pesan..." />
          <button onclick="sendChat()" class="chat-send-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
              fill="currentColor">
              <path d="M2 21l21-9L2 3v7l15 2-15 2v7z"/>
            </svg>
          </button>
        </div>

      </div>

      <!-- Notification Bell -->
      <div class="notif-wrap" id="notifWrap">
        <button class="topbar-btn notif-bell-btn" id="notificationBtn" onclick="toggleNotifPanel()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 01-3.46 0"/>
          </svg>
          <span class="notif-count-badge" id="notifCountBadge" style="display:none;">0</span>
        </button>

        <!-- Notification Panel -->
        <div class="notif-panel" id="notifPanel" style="display:none;">
          <div class="notif-panel-hdr">
            <div>
              <div style="font-size:14px;font-weight:700;color:#0d1b3e;">Notifikasi</div>
              <div style="font-size:11px;color:#94a3b8;" id="notifSubtitle">–</div>
            </div>
            <button onclick="markAllNotifRead()" style="font-size:11.5px;color:#1a6ef5;background:none;border:none;cursor:pointer;font-weight:600;padding:0;">Tandai semua</button>
          </div>
          <div class="notif-panel-tabs">
            <button class="notif-tab active" onclick="switchNotifTab('all',this)">Semua</button>
            <button class="notif-tab" onclick="switchNotifTab('unread',this)">Belum dibaca</button>
          </div>
          <div class="notif-panel-list" id="notifPanelList">
            <div class="notif-empty-state">
              <svg width="32" height="32" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
              <p>Tidak ada notifikasi</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</header>

<style>
@media(min-width:769px){ .sidebar-toggle { display:none !important; } }

/* Notification */
.notif-wrap { position:relative; }
.notif-bell-btn {
  position:relative; width:36px; height:36px; border-radius:10px;
  display:flex; align-items:center; justify-content:center;
  background:none; border:none; cursor:pointer; color:#64748b;
  transition:all .15s;
}
.notif-bell-btn:hover { background:#f4f8ff; color:#1a6ef5; }
.notif-count-badge {
  position:absolute; top:-2px; right:-2px;
  min-width:16px; height:16px; border-radius:99px;
  background:#ef4444; color:#fff; font-size:9.5px; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  padding:0 4px; border:2px solid #fff; line-height:1;
}
.notif-panel {
  position:absolute; right:-8px; top:calc(100% + 10px);
  width:360px; background:#fff; border-radius:16px;
  box-shadow:0 8px 40px rgba(0,0,0,.14), 0 0 0 1px rgba(0,0,0,.06);
  z-index:9999; overflow:hidden;
  animation:notifSlide .2s ease;
}
@keyframes notifSlide{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.notif-panel-hdr {
  padding:14px 16px 10px; display:flex; align-items:flex-start;
  justify-content:space-between; border-bottom:1px solid #f1f5f9;
}
.notif-panel-tabs { display:flex; padding:0 16px; border-bottom:1px solid #f1f5f9; }
.notif-tab {
  padding:8px 12px; font-size:12px; font-weight:600; cursor:pointer;
  border:none; background:none; color:#94a3b8; border-bottom:2px solid transparent;
  transition:all .15s; margin-bottom:-1px;
}
.notif-tab.active { color:#1a6ef5; border-bottom-color:#1a6ef5; }
.notif-panel-list { max-height:380px; overflow-y:auto; }

/* ── Modern notification item ─────────────────────────────── */
.notif-item {
  display:flex; gap:11px; padding:12px 16px;
  border-bottom:1px solid #f1f5f9; cursor:pointer;
  transition:background .15s; position:relative;
}
.notif-item:last-child { border-bottom:none; }
.notif-item:hover { background:#f8faff; }
.notif-item.unread { background:#f8fbff; }

/* Icon container: rounded square dengan subtle background + outline icon */
.notif-icon {
  width:34px; height:34px; border-radius:10px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  font-size:0; /* hide any text fallback */
  position:relative;
}
.notif-icon svg {
  width:16px; height:16px;
  stroke-width:2;
  fill:none;
  stroke-linecap:round;
  stroke-linejoin:round;
}
/* Color variants — soft pastel bg + saturated stroke */
.notif-icon.overdue  { background:#fef2f2; }
.notif-icon.overdue  svg { stroke:#dc2626; }
.notif-icon.warning  { background:#fffbeb; }
.notif-icon.warning  svg { stroke:#d97706; }
.notif-icon.due      { background:#fef9c3; }
.notif-icon.due      svg { stroke:#a16207; }
.notif-icon.critical { background:#fef2f2; }
.notif-icon.critical svg { stroke:#b91c1c; }
.notif-icon.wa       { background:#f0fdf4; }
.notif-icon.wa       svg { stroke:#16a34a; }
.notif-icon.payment  { background:#f0fdf4; }
.notif-icon.payment  svg { stroke:#16a34a; }
.notif-icon.info     { background:#eff6ff; }
