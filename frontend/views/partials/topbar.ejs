<script src="/socket.io/socket.io.js"></script>
<script>
// const socket = io("https://admin.wrsnet.id/", {
//   auth: { token: localStorage.getItem("token") }
// });

const isLocal =
  window.location.hostname === "localhost" ||
  window.location.hostname === "127.0.0.1";

const socket = io(
  isLocal
    ? "http://localhost:3001"
    : "https://admin.wrsnet.id",
  {
    auth: {
      token: localStorage.getItem("token"),
    },
  }
);

const user = JSON.parse(localStorage.getItem("user") || "{}");
const customer = JSON.parse(localStorage.getItem("portal_customer") || "{}");

const USER_ID = user?.id ?? null;
const USER_NAME = user?.name ?? null;
const CUSTOMER_ID = customer?.id ?? null;

const TYPE = "admin";
const MY_ID = CUSTOMER_ID ?? USER_ID;

let CURRENT_ROOM = null;
let LAST_DATE = null;

function toggleChatPanel() {
  const panel = document.getElementById("chatPanel");
  if (panel.classList.contains("show")) {
    panel.classList.remove("show");
    setTimeout(() => panel.style.display = "none", 200);
  } else {
    panel.style.display = "block";
    setTimeout(() => panel.classList.add("show"), 10);
    loadChatRooms();
  }
  if (panel.style.display === "block") loadChatRooms();
}

function loadChatRooms() {
  fetch("/portal/api/chat-rooms")
    .then(res => res.json())
    .then(data => {
      const list = document.getElementById("chatRoomList");
      list.innerHTML = "";

      if (!data.length) {
        list.innerHTML = "<p style='padding:10px;'>Tidak ada chat</p>";
        return;
      }

      data.forEach(room => {
        const unread = parseInt(room.unread) || 0;

        const div = document.createElement("div");
        div.classList.add("chat-room");

        div.innerHTML = `
          <div><b>${room.name}</b></div>
          ${unread > 0 ? `<span class="chat-badge">${unread}</span>` : ""}
        `;

        div.onclick = () => openChatRoom(room.room, room.name);
        list.appendChild(div);
      });

      updateChatBadge(data);
    });
}

function openChatRoom(room, name) {
  if (CURRENT_ROOM) socket.emit("chat:leave", CURRENT_ROOM);

  CURRENT_ROOM = room;
  socket.emit("chat:join", CURRENT_ROOM);

  document.getElementById("chatPanel").style.display = "none";
  document.getElementById("chatContainer").style.display = "flex";

  document.getElementById("chatTitleText").innerText = name;

  document.getElementById("chatBadge").style.display = "none";

  fetch("/portal/api/chat/read", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({ room })
  });

  loadChatRoom(room);
}

function loadChatRoom(room) {
  const box = document.getElementById("chatBox");

  fetch(`/portal/api/chat/${room}`)
    .then(res => res.json())
    .then(data => {
      box.innerHTML = "";
      LAST_DATE = null;

      data.forEach(renderMessage);

      setTimeout(() => scrollBottom(), 100);
    });
}

socket.on("chat:receive", (data) => {

  const isMe =
    String(data.user_id) === String(MY_ID) &&
    data.type === TYPE;

  const isSameRoom = data.room === CURRENT_ROOM;

  const isCustomer = data.type === "customer";

  if (isSameRoom) {
    renderMessage(data);
    scrollBottom();
  }

  if (!isMe && isCustomer && !isSameRoom) {
    loadUnreadBadge();
  }
});

function formatDateLabel(dateStr) {
  const date = new Date(dateStr);
  const now = new Date();

  if (date.toDateString() === now.toDateString()) return "Hari ini";

  const yesterday = new Date();
  yesterday.setDate(now.getDate() - 1);

  if (date.toDateString() === yesterday.toDateString()) return "Kemarin";

  return date.toLocaleDateString("id-ID");
}

function renderMessage(data) {
  const box = document.getElementById("chatBox");

  const msgDate = new Date(data.created_at);
  const currentDate = msgDate.toDateString();

  if (LAST_DATE !== currentDate) {
    LAST_DATE = currentDate;

    const divider = document.createElement("div");
    divider.style.textAlign = "center";
    divider.style.margin = "10px 0";
    divider.style.fontSize = "11px";
    divider.style.color = "#666";
    divider.innerText = formatDateLabel(data.created_at);

    box.appendChild(divider);
  }

  const isMe = String(data.user_id) === String(MY_ID) && data.type === "admin";

  const wrap = document.createElement("div");
  wrap.style.display = "flex";
  wrap.style.flexDirection = "column";
  wrap.style.alignItems = isMe ? "flex-end" : "flex-start";
  wrap.style.margin = "8px 0";

  const bubble = document.createElement("div");
  bubble.classList.add("chat-bubble");
  bubble.classList.add(isMe ? "me" : "other");
  bubble.innerText = data.message;

  const meta = document.createElement("small");
  meta.style.fontSize = "11px";
  meta.style.opacity = "0.6";

  const time = msgDate.toLocaleTimeString("id-ID", {
    hour: "2-digit",
    minute: "2-digit"
  });

  meta.innerText = isMe ? `You • ${time}` : `${data.name} • ${time}`;

  wrap.appendChild(bubble);
  wrap.appendChild(meta);

  box.appendChild(wrap);
}

function sendChat() {
  const input = document.getElementById("chatInput");
  const message = input.value.trim();

  if (!message || !CURRENT_ROOM) return;

  socket.emit("chat:send", {
    room: CURRENT_ROOM,
    name: USER_NAME,
    user_id: MY_ID,
    type: TYPE,
    message
  });

  input.value = "";
}

function scrollBottom() {
  const box = document.getElementById("chatBox");
  box.scrollTo({
    top: box.scrollHeight,
    behavior: "smooth"
  });
}

// function updateChatBadge(dataRooms) {
//   const badge = document.getElementById("chatBadge");

//   let total = 0;
//   dataRooms.forEach(r => total += parseInt(r.unread || 0));

//   if (total > 0) {
//     badge.style.display = "inline-block";
//     badge.innerText = total;
//   } else {
//     badge.style.display = "none";
//   }
// }

function updateChatBadge(dataRooms) {
  const badge = document.getElementById("chatBadge");

  if (!Array.isArray(dataRooms) || dataRooms.length === 0) {
    badge.style.display = "none";
    return;
  }

  const total = dataRooms.reduce((sum, r) => {
    return sum + parseInt(r.unread || 0);
  }, 0);

  badge.style.display = total > 0 ? "inline-block" : "none";
  badge.innerText = total;
}

function loadUnreadBadge() {
  fetch("/portal/api/chat-rooms")
    .then(res => res.json())
    .then(data => {
      updateChatBadge(data);
    })
    .catch(err => console.error(err));
}

function closeChat() {
  document.getElementById("chatContainer").style.display = "none";
  if (CURRENT_ROOM) {
    socket.emit("chat:leave", CURRENT_ROOM);
    CURRENT_ROOM = null;
  }
}

document.getElementById("chatInput").addEventListener("keypress", function(e) {
  if (e.key === "Enter") {
    e.preventDefault();
    sendChat();
  }
});

document.addEventListener("DOMContentLoaded", () => {
  loadUnreadBadge();
});
</script>

<script>
// ── Notification Panel ─────────────────────────────────────────
let _notifOpen   = false;
let _notifTab    = 'all';
let _notifItems  = [];

function toggleNotifPanel() {
  _notifOpen = !_notifOpen;
  const panel = document.getElementById('notifPanel');
  if (panel) panel.style.display = _notifOpen ? 'block' : 'none';
  if (_notifOpen) loadNotifPanel();
}

// Close on outside click
document.addEventListener('click', function(e) {
  const wrap = document.getElementById('notifWrap');
  if (wrap && !wrap.contains(e.target)) {
    _notifOpen = false;
    const p = document.getElementById('notifPanel');
    if (p) p.style.display = 'none';
  }
});

async function loadNotifPanel() {
  const list = document.getElementById('notifPanelList');
  if (!list) return;
  list.innerHTML = '<div style="padding:20px;text-align:center;color:#94a3b8;font-size:12px;">Memuat...</div>';

  const url = _notifTab === 'unread' ? '/notifications?unread=true&limit=30' : '/notifications?limit=30';
  const d = await App.api(url);
  _notifItems = d?.data || [];

  updateNotifSubtitle();

  if (!_notifItems.length) {
    list.innerHTML = '<div class="notif-empty-state"><svg width="32" height="32" fill="none" stroke="#d1d5db" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg><p>Tidak ada notifikasi</p></div>';
    return;
  }

  list.innerHTML = _notifItems.map(n => {
    const icon = getNotifIcon(n.type, n.severity);
    const iconClass = getNotifIconClass(n.type, n.severity);
    const time = formatNotifTime(n.created_at);
    return `<div class="notif-item ${n.is_read ? '' : 'unread'}" onclick="readNotif(${n.id}, this)">
      <div class="notif-icon ${iconClass}">${icon}</div>
      <div class="notif-body">
        <div class="notif-title-row">
          <div class="notif-title">${escHtml(n.title)}</div>
          ${n.is_read ? '' : '<span class="notif-unread-dot" title="Belum dibaca"></span>'}
        </div>
        <div class="notif-msg">${escHtml(n.message)}</div>
        <div class="notif-time">${time}</div>
      </div>
    </div>`;
  }).join('');
}

function updateNotifSubtitle() {
  const unreadCount = _notifItems.filter(n => !n.is_read).length;
  const el = document.getElementById('notifSubtitle');
  if (el) el.textContent = unreadCount > 0 ? unreadCount + ' belum dibaca' : 'Semua sudah dibaca';
}

function getNotifIcon(type, severity) {
  // SVG inline icons — konsisten cross-browser, stroke-based, modern outline style
  const ICONS = {
    // Invoice & billing
    overdue:    '<svg viewBox="0 0 24 24"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>',
    due_today:  '<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/><circle cx="12" cy="15" r="1.5" fill="currentColor"/></svg>',
    due_soon:   '<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>',
    payment:    '<svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>',
    // Operations
    isolir:     '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M4.93 4.93l14.14 14.14"/></svg>',
    restore:    '<svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 4v5h5"/></svg>',
    // WhatsApp / messaging
    wa_incoming:    '<svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>',
    wa_disconnected:'<svg viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg>',
    // System
    critical:   '<svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    warning:    '<svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
    info:       '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  };

  // Map type ke icon — prioritas: type spesifik > severity > default
  if (type === 'overdue')         return ICONS.overdue;
  if (type === 'due_today')       return ICONS.due_today;
  if (type === 'due_soon')        return ICONS.due_soon;
  if (type === 'payment')         return ICONS.payment;
  if (type === 'isolir')          return ICONS.isolir;
  if (type === 'restore')         return ICONS.restore;
  if (type === 'wa_incoming')     return ICONS.wa_incoming;
  if (type === 'wa_disconnected') return ICONS.wa_disconnected;
  if (severity === 'critical')    return ICONS.critical;
  if (severity === 'warning')     return ICONS.warning;
  return ICONS.info;
}

function getNotifIconClass(type, severity) {
  // CSS class untuk background color icon container
  if (type === 'overdue')         return 'overdue';
  if (type === 'due_today')       return 'warning';
  if (type === 'due_soon')        return 'due';
  if (type === 'payment')         return 'payment';
  if (type === 'restore')         return 'payment';
  if (type === 'isolir')          return 'overdue';
  if (type === 'wa_incoming')     return 'wa';
  if (type === 'wa_disconnected') return 'warning';
  if (severity === 'critical')    return 'critical';
  if (severity === 'warning')     return 'warning';
  return 'info';
}

function formatNotifTime(dt) {
  if (!dt) return '';
  const now  = new Date();
  const d    = new Date(dt);
  const diff = Math.floor((now - d) / 1000);
  if (diff < 60)   return 'Baru saja';
  if (diff < 3600) return Math.floor(diff/60) + ' menit lalu';
  if (diff < 86400)return Math.floor(diff/3600) + ' jam lalu';
  return d.toLocaleDateString('id-ID', { day:'2-digit', month:'short' });
}

function escHtml(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

async function readNotif(id, el) {
  if (el && el.classList.contains('unread')) {
    el.classList.remove('unread');
    // Hapus unread dot dengan animasi fade-out
    const dot = el.querySelector('.notif-unread-dot');
    if (dot) {
      dot.style.transition = 'opacity .2s';
      dot.style.opacity = '0';
      setTimeout(() => dot.remove(), 200);
    }
    await App.api('/notifications/' + id + '/read', { method:'PUT' });
    updateNotifCount();
  }
}

async function markAllNotifRead() {
  await App.api('/notifications/read-all', { method:'PUT' });
  document.querySelectorAll('.notif-item.unread').forEach(el => {
    el.classList.remove('unread');
    const dot = el.querySelector('.notif-unread-dot');
    if (dot) dot.remove();
  });
  document.getElementById('notifCountBadge').style.display = 'none';
  const sub = document.getElementById('notifSubtitle');
  if (sub) sub.textContent = 'Semua sudah dibaca';
}

function switchNotifTab(tab, btn) {
  _notifTab = tab;
  document.querySelectorAll('.notif-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  loadNotifPanel();
}

async function updateNotifCount() {
  const d = await App.api('/notifications/unread-count');
  const count = d?.data?.count || 0;
  const badge = document.getElementById('notifCountBadge');
  if (badge) {
    badge.textContent = count > 99 ? '99+' : count;
    badge.style.display = count > 0 ? 'flex' : 'none';
  }
}

// Init + socket listener
document.addEventListener('DOMContentLoaded', () => {
  updateNotifCount();
  setInterval(updateNotifCount, 30000); // refresh tiap 30 detik

  // Socket real-time
  if (typeof io !== 'undefined') {
    const token = localStorage.getItem('token');
    const sock  = io({ auth: { token } });
    sock.on('notification:new', (data) => {
      updateNotifCount();
      // Show toast jika panel tertutup
      if (!_notifOpen && typeof App !== 'undefined') {
        const icons = { wa_incoming:'', overdue:'', due_today:'', payment:'' };
        App.showToast((icons[data.type]||'🔔') + ' ' + (data.title || 'Notifikasi baru'), 'info');
      }
      if (_notifOpen) loadNotifPanel();
    });
  }
});

// ── Global Search (Topbar) ──────────────────────────────────
//
// Search dengan debounce 250ms. Query paralel ke /customers, /devices,
// dan /infrastructure (kalau filter "all"). Hasil di-merge & ditampilkan
// di dropdown dengan kategori. Keyboard nav: arrow keys + Enter. 
(function() {
  const inputEl    = document.getElementById('globalSearch');
  const dropdownEl = document.getElementById('globalSearchDropdown');
  const wrapEl     = document.getElementById('globalSearchWrap');
  if (!inputEl || !dropdownEl) return;

  let debounceTimer = null;
  let lastQuery     = '';
  let resultItems   = []; // flat list untuk keyboard nav
  let activeIdx     = -1;
  let abortCtrl     = null;

  const ICONS = {
    cust:  '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
    dev:   '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
    infra: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polygon points="1,6 1,22 8,18 16,22 23,18 23,2 16,6 8,2 1,6"/></svg>'
  };

  function escHtmlLocal(s) {
    return String(s == null ? '' : s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  function openDropdown()  { dropdownEl.classList.add('open'); }
  function closeDropdown() { dropdownEl.classList.remove('open'); activeIdx = -1; }

  // Cari pelanggan + device + infrastructure paralel
  async function performSearch(q) {
    if (abortCtrl) abortCtrl.abort();
    abortCtrl = new AbortController();
    const signal = abortCtrl.signal;

    const tok = localStorage.getItem('token');
    const hdr = { 'X-Requested-With':'XMLHttpRequest' };
    if (tok && tok !== 'null') hdr['Authorization'] = 'Bearer ' + tok;
    const opts = { headers: hdr, credentials: 'include', signal };

    const enc = encodeURIComponent(q);

    // Ketiga endpoint sudah dijaga authentication — fail silently kalau forbidden
    const [custRes, devRes, infraRes] = await Promise.all([
      fetch('/api/customers?search=' + enc + '&limit=5', opts).then(r=>r.json()).catch(()=>null),
      fetch('/api/devices?search='   + enc + '&limit=5', opts).then(r=>r.json()).catch(()=>null),
      fetch('/api/infrastructure?search=' + enc + '&limit=5', opts).then(r=>r.json()).catch(()=>null)
    ]);

    if (signal.aborted) return; // result obsolete

    const customers = (custRes?.data || custRes?.customers || []).slice(0, 5);
    const devices   = (devRes?.data   || []).slice(0, 5);
    // Infra: filter agar hanya match nama (search endpoint mungkin tidak filter)
    const infras    = (infraRes?.data || []).filter(i =>
      (i.name||'').toLowerCase().includes(q.toLowerCase()) ||
      (i.address||'').toLowerCase().includes(q.toLowerCase())
    ).slice(0, 5);

    renderResults(customers, devices, infras, q);
  }

  function renderResults(customers, devices, infras, q) {
    resultItems = [];
    let html = '';

    if (customers.length) {
      html += '<div class="gsd-section">Pelanggan</div>';
      customers.forEach(c => {
        const idx = resultItems.length;
        resultItems.push({ url: '/customers/profile/' + c.id });
        const stat = c.status === 'active' ? 'active' : c.status === 'isolated' ? 'isolated' : 'inactive';
        const sub = [c.customer_id, c.phone, c.package?.name].filter(Boolean).join(' · ');
        html += `<a class="gsd-item" data-idx="${idx}" href="/customers/profile/${c.id}">
          <div class="gsd-icon cust">${ICONS.cust}</div>
          <div class="gsd-body">
            <div class="gsd-title">${escHtmlLocal(c.name)}</div>
            <div class="gsd-sub">${escHtmlLocal(sub)}</div>
          </div>
          <span class="gsd-status ${stat}">${escHtmlLocal(c.status||'')}</span>
        </a>`;
      });
    }

    if (devices.length) {
      html += '<div class="gsd-section">Perangkat</div>';
      devices.forEach(d => {
        const idx = resultItems.length;
        resultItems.push({ url: '/devices' });  // halaman list device — anchor by ID
        const stat = d.status === 'online' ? 'online' : 'offline';
        const sub = [d.ip_address, d.type, d.brand].filter(Boolean).join(' · ');
        html += `<a class="gsd-item" data-idx="${idx}" href="/devices?focus=${d.id}">
          <div class="gsd-icon dev">${ICONS.dev}</div>
          <div class="gsd-body">
            <div class="gsd-title">${escHtmlLocal(d.name)}</div>
            <div class="gsd-sub">${escHtmlLocal(sub)}</div>
          </div>
          <span class="gsd-status ${stat}">${escHtmlLocal(d.status||'')}</span>
        </a>`;
      });
    }

    if (infras.length) {
      html += '<div class="gsd-section">Infrastruktur</div>';
      infras.forEach(i => {
        const idx = resultItems.length;
        resultItems.push({ url: '/infrastructure' });
        const sub = [i.type?.toUpperCase(), i.address, i.status].filter(Boolean).join(' · ');
        html += `<a class="gsd-item" data-idx="${idx}" href="/infrastructure?focus=${i.id}">
          <div class="gsd-icon infra">${ICONS.infra}</div>
          <div class="gsd-body">
            <div class="gsd-title">${escHtmlLocal(i.name)}</div>
            <div class="gsd-sub">${escHtmlLocal(sub)}</div>
          </div>
        </a>`;
      });
    }

    if (!html) {
      html = `<div class="gsd-empty">Tidak ada hasil untuk "${escHtmlLocal(q)}"</div>`;
    }

    dropdownEl.innerHTML = html;
    openDropdown();
  }

  function setActive(idx) {
    const items = dropdownEl.querySelectorAll('.gsd-item');
    if (!items.length) return;
    activeIdx = ((idx % items.length) + items.length) % items.length;
    items.forEach((el, i) => el.classList.toggle('active', i === activeIdx));
    items[activeIdx].scrollIntoView({ block: 'nearest' });
  }

  inputEl.addEventListener('input', () => {
    const q = inputEl.value.trim();
    clearTimeout(debounceTimer);
    if (!q) { closeDropdown(); lastQuery=''; return; }
    if (q === lastQuery) return;
    lastQuery = q;
    // Show loading state
    dropdownEl.innerHTML = '<div class="gsd-loading">Mencari...</div>';
    openDropdown();
    debounceTimer = setTimeout(() => performSearch(q), 250);
  });

  inputEl.addEventListener('focus', () => {
    if (inputEl.value.trim() && resultItems.length) openDropdown();
  });

  inputEl.addEventListener('keydown', (e) => {
    const items = dropdownEl.querySelectorAll('.gsd-item');
    if (!items.length) return;
    if (e.key === 'ArrowDown') { e.preventDefault(); setActive(activeIdx + 1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(activeIdx - 1); }
    else if (e.key === 'Enter') {
      e.preventDefault();
      const target = activeIdx >= 0 ? items[activeIdx] : items[0];
      if (target) window.location.href = target.getAttribute('href');
    } else if (e.key === 'Escape') {
      closeDropdown();
      inputEl.blur();
    }
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!wrapEl.contains(e.target)) closeDropdown();
  });
})();
</script>

