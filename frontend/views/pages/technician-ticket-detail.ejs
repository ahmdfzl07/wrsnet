<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
  <meta name="theme-color" content="#1e40af">
  <title><%= typeof title !== 'undefined' ? title : 'Detail Ticket' %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.45.2/dist/apexcharts.min.js"></script>
  <style>
    :root{
      --font:'Plus Jakarta Sans',sans-serif;
      --nv:#2563eb;--nv2:#1d4ed8;--nv3:#1e40af;
      --teal:#06b6d4;--green:#10b981;--amber:#f59e0b;--red:#ef4444;
      --bg:#f1f5f9;--card:#fff;--border:#e2e8f0;
      --text:#0f172a;--muted:#64748b;--muted2:#94a3b8;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{height:100%;}
    body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:14px;-webkit-tap-highlight-color:transparent;}
    button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
    a{color:inherit;text-decoration:none;}
    ::-webkit-scrollbar{width:6px;height:6px;}
    ::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px;}

    /* ═══ LAYOUT ═══ */
    .page{max-width:1200px;margin:0 auto;padding:20px 24px 100px;}
    @media(max-width:640px){.page{padding:0 0 100px;}}

    /* ═══ MOBILE HEADER ═══ */
    .m-header{
      background:#020e2e;
      padding:14px 18px;color:#fff;position:relative;
      display:none;
    }
    .m-hdr-row{display:flex;align-items:center;gap:12px;position:relative;z-index:1;}
    .m-hdr-left{display:flex;align-items:center;gap:12px;}
    .m-back{width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;color:#fff;flex-shrink:0;}
    .m-back svg{width:16px;height:16px;}
    .m-hdr-title{font-size:15px;font-weight:700;}
    .m-hdr-sub{font-size:10.5px;color:rgba(255,255,255,.6);margin-top:1px;font-family:ui-monospace,monospace;letter-spacing:.3px;}
    @media(max-width:640px){.m-header{display:block;}}

    /* ═══ BACK BUTTON (desktop) ═══ */
    .back-row{display:flex;align-items:center;gap:12px;margin-bottom:16px;}
    .back-btn{
      display:inline-flex;align-items:center;gap:7px;padding:9px 16px;
      border-radius:10px;background:#fff;border:1px solid var(--border);
      font-size:13px;font-weight:700;color:var(--muted);transition:all .18s;
    }
    .back-btn:hover{background:var(--border);color:var(--text);}
    .back-btn svg{width:15px;height:15px;}
    @media(max-width:640px){.back-row{display:none;}}

    /* ═══ HEADER CARD ═══ */
    .ticket-header-card{
      background:linear-gradient(135deg,var(--nv3) 0%,var(--nv) 55%,#0284c7 100%);
      color:#fff;padding:26px 30px;border-radius:16px;margin-bottom:18px;
      box-shadow:0 10px 36px rgba(37,99,235,.3);position:relative;overflow:hidden;
    }
    .ticket-number{font-size:11px;opacity:.8;font-weight:700;margin-bottom:5px;letter-spacing:.08em;text-transform:uppercase;}
    .ticket-title{font-size:22px;font-weight:800;margin-bottom:14px;line-height:1.3;letter-spacing:-.3px;}
    .ticket-meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
    .meta-item{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:600;padding:5px 12px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:20px;color:#fff;}
    @media(max-width:640px){
      .ticket-header-card{padding:20px 18px;border-radius:14px;margin:14px 14px 14px;}
      .ticket-title{font-size:17px;margin-bottom:10px;}
    }

    /* ═══ DETAIL GRID ═══ */
    .detail-grid{display:grid;grid-template-columns:1fr 360px;gap:18px;}
    @media(max-width:1000px){.detail-grid{grid-template-columns:1fr;}}
    @media(max-width:640px){.detail-grid{padding:14px;gap:14px;}}

    /* ═══ CARDS ═══ */
    .card-modern{background:#fff;border-radius:14px;box-shadow:0 4px 16px rgba(0,0,0,.06);border:1px solid #f0f0f0;margin-bottom:16px;overflow:hidden;}
    .info-section{padding:22px 26px;border-bottom:1px solid #f0f0f0;}
    .info-section:last-child{border-bottom:none;}
    .section-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:9px;}
    .section-title svg{color:var(--nv);flex-shrink:0;width:16px;height:16px;}
    .info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:10px;}
    .info-item{padding:13px;background:var(--bg);border-radius:10px;border:1px solid var(--border);}
    .info-label{font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px;}
    .info-value{font-size:13.5px;font-weight:600;color:var(--text);word-break:break-word;}
    .info-value a{color:var(--nv);text-decoration:none;}
    .desc-box{padding:16px;background:var(--bg);border-radius:10px;line-height:1.7;color:#475569;font-size:13.5px;border:1px solid var(--border);}
    @media(max-width:640px){
      .info-section{padding:16px 18px;}
      .info-grid{grid-template-columns:1fr 1fr;}
    }

    /* ═══ MAP ═══ */
    #map{height:350px;border-radius:10px;overflow:hidden;margin-top:12px;box-shadow:0 4px 14px rgba(0,0,0,.08);border:2px solid var(--border);}
    .map-buttons{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;}
    .map-layer-control{position:absolute;top:10px;right:10px;z-index:1000;background:white;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.2);overflow:hidden;display:flex;}
    .map-layer-btn{padding:6px 12px;border:none;background:white;cursor:pointer;font-size:11px;font-weight:600;color:#4a5568;display:flex;align-items:center;gap:4px;transition:all .2s;border-right:1px solid var(--border);}
    .map-layer-btn:last-child{border-right:none;}
    .map-layer-btn:hover{background:var(--bg);}
    .map-layer-btn.active{background:var(--nv);color:white;}
    .map-layer-btn svg{width:14px;height:14px;flex-shrink:0;}
    /* Pulse markers */
    @keyframes pr{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.7);}50%{box-shadow:0 0 0 15px rgba(239,68,68,0);}}
    @keyframes pb{0%,100%{box-shadow:0 0 0 0 rgba(37,99,235,.7);}50%{box-shadow:0 0 0 15px rgba(37,99,235,0);}}
    @keyframes po{0%,100%{box-shadow:0 0 0 0 rgba(245,158,11,.7);}50%{box-shadow:0 0 0 15px rgba(245,158,11,0);}}
    @keyframes pg2{0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,.7);}50%{box-shadow:0 0 0 15px rgba(16,185,129,0);}}
    .pulse-red{animation:pr 2s infinite;} .pulse-blue{animation:pb 2s infinite;}
    .pulse-orange{animation:po 2s infinite;} .pulse-green{animation:pg2 2s infinite;}
    .custom-marker{position:relative;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:3px solid #fff;transition:transform .3s;}
    .custom-marker svg{width:18px;height:18px;color:#fff;z-index:2;}
    .custom-marker:hover{transform:scale(1.1);}
    .leaflet-popup-content-wrapper{border-radius:12px;padding:0;overflow:hidden;box-shadow:0 8px 25px rgba(0,0,0,.15);border:none;}
    .leaflet-popup-content{margin:0;width:240px!important;font-family:var(--font);}
    .popup-header{background:linear-gradient(135deg,var(--nv3),var(--nv));color:#fff;padding:12px 15px;text-align:center;}
    .popup-header h3{margin:0;font-size:14px;font-weight:700;}
    .popup-body{padding:12px 15px;background:#fff;}
    .popup-info-item{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f0f0f0;gap:8px;}
    .popup-info-item:last-child{border-bottom:none;}
    .popup-label{font-size:11px;color:var(--muted);font-weight:500;flex-shrink:0;}
    .popup-value{font-size:11px;color:var(--text);font-weight:600;text-align:right;word-break:break-word;}
    .popup-value a{color:var(--nv);text-decoration:none;}
    .popup-footer{padding:8px 12px;background:var(--bg);border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:6px;}
    .popup-footer a{display:flex;align-items:center;justify-content:center;gap:4px;padding:7px;color:#fff;text-decoration:none;border-radius:8px;font-size:11px;font-weight:700;transition:all .2s;}

    /* ═══ TIMELINE ═══ */
    .timeline-container{max-height:500px;overflow-y:auto;padding:12px;background:var(--bg);border-radius:12px;border:1px solid var(--border);}
    .timeline-item{
      padding:14px 16px;margin-bottom:10px;background:#fff;
      border-radius:10px;border:1px solid var(--border);
      box-shadow:0 1px 4px rgba(0,0,0,.03);transition:all .2s;
    }
    .timeline-item:hover{box-shadow:0 3px 10px rgba(0,0,0,.07);}
    .timeline-item:last-child{margin-bottom:0;}
    .timeline-foto{max-width:180px;max-height:120px;border-radius:8px;margin-top:8px;cursor:pointer;border:1px solid var(--border);transition:all .2s;object-fit:cover;}
    .timeline-foto:hover{transform:scale(1.03);box-shadow:0 4px 12px rgba(0,0,0,.12);}
    .tl-avatar{width:30px;height:30px;border-radius:50%;background:var(--nv);color:#fff;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;}

    /* ═══ ADD COMMENT ═══ */
    .comment-box{padding:18px 22px;background:var(--bg);border-radius:12px;border:1px solid var(--border);}
    .comment-box textarea{
      width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:10px;
      font-size:13.5px;font-family:inherit;resize:vertical;transition:all .2s;background:#fff;box-sizing:border-box;min-height:90px;
    }
    .comment-box textarea:focus{outline:none;border-color:var(--nv);box-shadow:0 0 0 3px rgba(37,99,235,.08);}
    .comment-box label{display:flex;align-items:center;gap:6px;margin-bottom:6px;font-weight:700;color:#475569;font-size:13px;}
    .comment-box label svg{color:var(--nv);}
    .comment-upload-row{display:flex;align-items:center;gap:12px;margin-top:10px;flex-wrap:wrap;}
    .comment-upload-row small{color:var(--muted);font-size:11px;}
    .file-preview{display:flex;gap:6px;flex-wrap:wrap;margin-top:8px;}
    .file-tag{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:20px;font-size:11px;font-weight:700;color:var(--nv);}
    .file-tag button{background:none;border:none;cursor:pointer;color:var(--nv);font-size:12px;line-height:1;padding:0 2px;}

    /* ═══ SIDEBAR ═══ */
    .sidebar-card{background:#fff;border-radius:14px;box-shadow:0 4px 16px rgba(0,0,0,.06);padding:22px;margin-bottom:16px;border:1px solid #f0f0f0;}
    .sidebar-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:9px;}
    .sidebar-title svg{color:var(--nv);flex-shrink:0;width:16px;height:16px;}

    /* SLA Gauge */
    .sla-gauge-wrap{display:flex;align-items:center;gap:14px;padding:4px 0;}
    #slaGaugeChart{flex-shrink:0;}
    .sla-stats{flex:1;display:flex;flex-direction:column;gap:8px;}
    .sla-stat-row{display:flex;justify-content:space-between;align-items:center;padding:7px 10px;background:var(--bg);border:1px solid var(--border);border-radius:8px;}
    .sla-stat-lbl{font-size:11px;font-weight:600;color:var(--muted);}
    .sla-stat-val{font-size:13px;font-weight:800;color:var(--text);}
    .sla-due-row{font-size:10px;color:var(--muted2);text-align:center;margin-top:4px;}

    /* Resolution time banner — muncul saat tiket resolved/closed */
    .resolution-time{
      display:none;
      margin-top:12px;
      padding:12px 14px;
      border-radius:12px;
      background:linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%);
      border:1px solid #a7f3d0;
      position:relative;
      overflow:hidden;
    }
    .resolution-time.show{display:block;animation:resIn .35s cubic-bezier(.4,0,.2,1);}
    @keyframes resIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
    .resolution-time::before{
      content:'';
      position:absolute;top:-20px;right:-20px;
      width:80px;height:80px;border-radius:50%;
      background:radial-gradient(circle,rgba(16,185,129,.12),transparent 70%);
      pointer-events:none;
    }
    .rt-head{
      display:flex;align-items:center;gap:8px;
      font-size:10.5px;font-weight:700;color:#047857;
      text-transform:uppercase;letter-spacing:.4px;
      margin-bottom:6px;position:relative;
    }
    .rt-head svg{width:13px;height:13px;flex-shrink:0;}
    .rt-duration{
      font-size:16px;font-weight:800;color:#065f46;
      letter-spacing:-.3px;line-height:1.25;
      position:relative;
    }
    .rt-sub{
      font-size:10.5px;color:#059669;
      margin-top:4px;font-weight:500;
      position:relative;
    }
    .rt-badge{
      display:inline-flex;align-items:center;gap:3px;
      margin-left:6px;padding:1px 7px;border-radius:20px;
      font-size:9.5px;font-weight:800;text-transform:uppercase;letter-spacing:.3px;
      vertical-align:middle;
    }
    .rt-badge.ontime{background:#10b981;color:#fff;}
    .rt-badge.late{background:#ef4444;color:#fff;}

    /* Status Progress */
    .sflow{display:flex;flex-direction:column;gap:6px;}
    .sfi{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:9px;border:1.5px solid var(--border);background:var(--bg);transition:.2s;}
    .sfi.done{border-color:#bbf7d0;background:#f0fdf4;}
    .sfi.active{border-color:var(--nv);background:#dbeafe;box-shadow:0 0 0 3px rgba(37,99,235,.08);}
    .sfi-dot{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:var(--border);color:var(--muted);padding:5px;}
    .sfi-dot svg{width:100%;height:100%;display:block;}
    .sfi.done .sfi-dot{background:linear-gradient(135deg,#15803d,#22c55e);color:#fff;}
    .sfi.active .sfi-dot{background:linear-gradient(135deg,var(--nv3),var(--nv));color:#fff;}
    .sfi-lbl{flex:1;font-size:12px;font-weight:700;color:#4b5563;}
    .sfi-sub{font-size:10px;font-weight:500;color:var(--muted2);}
    .sfi.done .sfi-lbl{color:#15803d;}
    .sfi.active .sfi-lbl{color:var(--nv);}
    .sfi-chip{font-size:9px;font-weight:800;padding:2px 7px;border-radius:5px;background:var(--nv);color:#fff;letter-spacing:.03em;}

    /* Quick Action Buttons */
    .qa-list{display:flex;flex-direction:column;gap:8px;}
    .qab{display:flex;align-items:center;gap:10px;padding:11px 16px;border-radius:10px;border:none;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;transition:.2s;text-decoration:none;box-shadow:0 2px 8px rgba(0,0,0,.07);width:100%;}
    .qab:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(0,0,0,.12);}
    .qab svg{flex-shrink:0;width:14px;height:14px;}
    .qab-status{background:linear-gradient(135deg,var(--nv3),var(--nv));color:#fff;}
    .qab-success{background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;}
    .qab-warning{background:linear-gradient(135deg,#92400e,#d97706);color:#fff;}
    .qab-gray{background:#f3f4f6;color:#374151;border:1.5px solid var(--border);box-shadow:none;}

    /* Buttons */
    .btn{padding:10px 18px;border-radius:10px;border:none;cursor:pointer;font-weight:700;font-size:13px;transition:all .2s;display:inline-flex;align-items:center;gap:7px;box-shadow:0 4px 12px rgba(0,0,0,.1);font-family:inherit;text-decoration:none;justify-content:center;width:100%;margin-bottom:8px;}
    .btn svg{flex-shrink:0;width:14px;height:14px;}
    .btn:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(0,0,0,.15);}
    .btn-primary{background:linear-gradient(135deg,var(--nv3),var(--nv));color:#fff;}
    .btn-success{background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;}

    /* Status modal */
    .mover{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;}
    .mover.show{display:flex;}
    .mbox{background:#fff;border-radius:16px;width:90%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:mIn .25s ease-out;max-height:90vh;overflow-y:auto;}
    @keyframes mIn{from{transform:translateY(40px);opacity:0}to{transform:none;opacity:1}}
    .mhd{background:linear-gradient(135deg,var(--nv3),var(--nv));color:#fff;padding:18px 22px;border-radius:16px 16px 0 0;display:flex;justify-content:space-between;align-items:center;}
    .mhd h3{margin:0;font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px;}
    .mcls{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.2);border:none;color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;line-height:1;}
    .mcls:hover{background:rgba(255,255,255,.35);transform:rotate(90deg);}
    .mbdy{padding:20px 22px;}
    .fg{margin-bottom:14px;}
    .fl{display:block;margin-bottom:6px;font-size:11px;font-weight:700;color:#4b5563;text-transform:uppercase;letter-spacing:.4px;}
    .fc{width:100%;padding:9px 12px;border:1.5px solid var(--border);border-radius:9px;font-size:13px;font-family:inherit;background:var(--bg);color:var(--text);transition:.2s;}
    .fc:focus{outline:none;border-color:var(--nv);box-shadow:0 0 0 3px rgba(37,99,235,.1);background:#fff;}
    .stgrid{display:flex;flex-direction:column;gap:6px;}
    .stop{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:9px;border:2px solid var(--border);cursor:pointer;transition:.2s;background:var(--bg);text-align:left;width:100%;}
    .stop:hover{border-color:var(--nv);background:#dbeafe;}
    .stop.sel{border-color:var(--nv);background:#dbeafe;}
    .stop-ico{width:32px;height:32px;flex-shrink:0;display:flex;align-items:center;justify-content:center;border-radius:8px;background:var(--border);padding:6px;color:var(--muted);transition:.2s;}
    .stop-ico svg{width:100%;height:100%;display:block;}
    .stop.sel .stop-ico,.stop:hover .stop-ico{background:#bfdbfe;color:var(--nv);}
    .stop-txt{flex:1;}
    .stop-lbl{font-size:13px;font-weight:700;color:var(--text);}
    .stop-desc{font-size:11px;color:var(--muted);margin-top:1px;}

    /* Badges */
    .sbadge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:7px;font-size:11px;font-weight:700;}
    .s-open{background:#fef3c7;color:#92400e;} .s-prog{background:#dbeafe;color:var(--nv3);}
    .s-pend{background:#ede9fe;color:#4c1d95;} .s-res{background:#dcfce7;color:#14532d;}
    .s-cls{background:#f3f4f6;color:#374151;}

    /* Lightbox */
    .lb{display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.95);align-items:center;justify-content:center;}
    .lb.show{display:flex;}
    .lb img{max-width:90%;max-height:90%;border-radius:12px;}
    .lbx{position:absolute;top:18px;right:28px;width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,.15);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;transition:all .2s;}
    .lbx:hover{background:rgba(255,255,255,.3);transform:rotate(90deg);}

    /* Loading */
    .loading-wrap{display:flex;align-items:center;justify-content:center;min-height:60vh;}
    .loading-inner{text-align:center;color:var(--muted);}
    .spinner-svg{width:40px;height:40px;color:var(--nv);margin-bottom:12px;animation:spin .8s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg)}}
    @media(max-width:768px){.ticket-title{font-size:17px;}}

    /* Bottom nav (mobile) */
    .btm-nav{
      display:none;position:fixed;bottom:0;left:0;right:0;
      background:#fff;border-top:1px solid var(--border);
      padding:8px 12px 14px;z-index:50;box-shadow:0 -4px 20px rgba(0,0,0,.05);
    }
    .btm-nav-inner{display:flex;justify-content:space-around;max-width:480px;margin:0 auto;}
    .bn{display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 10px;border-radius:10px;color:var(--muted2);font-size:10.5px;font-weight:700;transition:all .18s;flex:1;}
    .bn svg{width:20px;height:20px;}
    .bn.active{color:var(--nv);}
    .bn-fab{
      position:absolute;top:-24px;left:50%;transform:translateX(-50%);
      width:54px;height:54px;border-radius:50%;
      background:linear-gradient(135deg,var(--nv),var(--nv2));
      color:#fff;display:flex;align-items:center;justify-content:center;
      box-shadow:0 10px 24px rgba(37,99,235,.45);border:4px solid #fff;
    }
    .bn-fab svg{width:22px;height:22px;}
    @media(max-width:640px){.btm-nav{display:block;}}
  </style>
</head>
<body>

<!-- Mobile header -->
<div class="m-header">
  <div class="m-hdr-row">
    <div class="m-hdr-left">
      <a class="m-back" href="/technician?tab=tickets">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
      <div>
        <div class="m-hdr-title">Detail Tiket</div>
        <div class="m-hdr-sub" id="mhNum">—</div>
      </div>
    </div>
  </div>
</div>

<div class="page">
  <!-- Desktop back -->
  <div class="back-row">
    <a href="/technician?tab=tickets" class="back-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Kembali ke Daftar Tiket
    </a>
  </div>

  <!-- Loading -->
  <div id="loadingDiv" class="loading-wrap">
    <div class="loading-inner">
      <svg class="spinner-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      <div style="font-weight:600;">Memuat detail ticket...</div>
    </div>
  </div>

  <!-- Main content (hidden until loaded) -->
  <main id="mainContent" style="display:none;">

    <!-- Ticket Header -->
    <div class="ticket-header-card">
      <div class="ticket-number" id="hNum">—</div>
      <div class="ticket-title" id="hTitle">—</div>
      <div class="ticket-meta" id="hMeta"></div>
    </div>

    <div class="detail-grid">
      <!-- LEFT -->
      <div>
        <!-- Customer -->
        <div class="card-modern" id="custCard" style="display:none;">
          <div class="info-section">
            <h4 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> Informasi Pelanggan</h4>
            <div class="info-grid" id="custGrid"></div>
          </div>
        </div>

        <!-- Ticket detail -->
        <div class="card-modern">
          <div class="info-section">
            <h4 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg> Detail Ticket</h4>
            <div class="info-grid" id="detailGrid"></div>
          </div>
          <div class="info-section" id="descSection" style="display:none;">
            <h4 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="13" y1="18" x2="3" y2="18"/></svg> Keterangan</h4>
            <div class="desc-box" id="descBox"></div>
          </div>
        </div>

        <!-- Map -->
        <div class="card-modern" id="mapCard" style="display:none;">
          <div class="info-section">
            <h4 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Lokasi</h4>
            <div id="map"></div>
            <div class="map-buttons" id="mapBtns"></div>
          </div>
        </div>

        <!-- Timeline -->
        <div class="card-modern">
          <div class="info-section">
            <h4 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Timeline &amp; Update</h4>
            <div class="timeline-container" id="tlContainer">
              <p style="text-align:center;color:var(--muted);padding:20px;">Memuat timeline...</p>
            </div>
          </div>
          <!-- Add comment -->
          <div class="info-section">
            <h4 class="section-title" style="margin-bottom:14px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg> Tambah Update</h4>
            <div class="comment-box">
              <textarea id="commentText" rows="3" placeholder="Tulis komentar atau update progress..."></textarea>
              <div class="file-preview" id="filePreview"></div>
              <div class="comment-upload-row">
                <label style="cursor:pointer;display:inline-flex;align-items:center;gap:5px;padding:7px 14px;background:#fff;border:1.5px solid var(--border);border-radius:9px;font-size:12px;font-weight:700;color:var(--muted);transition:all .18s;margin:0;" onmouseover="this.style.borderColor='var(--nv)';this.style.color='var(--nv)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  Upload Foto
                  <input type="file" id="commentFile" accept="image/*,.pdf" multiple style="display:none;">
                </label>
                <small>Max 5MB · JPG, PNG, GIF · Ctrl+Enter kirim</small>
                <button class="btn btn-primary" style="margin-left:auto;width:auto;margin-bottom:0;padding:9px 18px;" id="sendBtn" onclick="sendComment()">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Kirim
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Sidebar -->
      <div>
        <!-- SLA Gauge -->
        <div class="sidebar-card">
          <h4 class="sidebar-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            SLA Tracker
            <span id="slaBadge" class="sbadge s-prog" style="font-size:10px;margin-left:auto;"></span>
          </h4>
          <div class="sla-gauge-wrap">
            <div id="slaGaugeChart"></div>
            <div class="sla-stats">
              <div class="sla-stat-row"><span class="sla-stat-lbl">Target</span><span class="sla-stat-val" id="slaTgt">—</span></div>
              <div class="sla-stat-row"><span class="sla-stat-lbl">Tersisa</span><span class="sla-stat-val" id="slaRem">—</span></div>
            </div>
          </div>
          <div class="sla-due-row" id="slaDue"></div>
          <!-- Resolution time banner (muncul saat tiket selesai) -->
          <div class="resolution-time" id="resolutionTime">
            <div class="rt-head">
              Completion Duration
              <span class="rt-badge" id="rtBadge">On-Time</span>
            </div>
            <div class="rt-duration" id="rtDuration">—</div>
            <div class="rt-sub" id="rtSub">—</div>
          </div>
        </div>

        <!-- Quick Actions (teknisi version) -->
        <div class="sidebar-card">
          <h4 class="sidebar-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Quick Actions
          </h4>
          <div class="qa-list" id="qaList"></div>
        </div>

        <!-- Status Progress -->
        <div class="sidebar-card">
          <h4 class="sidebar-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Status Progress
          </h4>
          <div class="sflow" id="sflow"></div>
        </div>
      </div>
    </div>
  </main>
</div>

<!-- Lightbox -->
<div class="lb" id="lb" onclick="this.classList.remove('show')">
  <button class="lbx" onclick="event.stopPropagation();$('lb').classList.remove('show')">
