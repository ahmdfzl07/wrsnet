const DONE_ICO=`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
function renderStatusFlow(cur){
  const ci=SSTEPS.findIndex(s=>s.key===cur);
  $('sflow').innerHTML=SSTEPS.map((s,i)=>`<div class="sfi ${i<ci?'done':''} ${i===ci?'active':''}">
