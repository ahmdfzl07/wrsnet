  const mkI=L.divIcon({html:`<div class="custom-marker ${pulse}" style="background:${tc};"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">${ico}</svg></div>`,className:'',iconSize:[40,40],iconAnchor:[20,20]});
  const c=t.customer;
