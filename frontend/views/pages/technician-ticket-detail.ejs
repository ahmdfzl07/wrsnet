async function sendComment(){
  const txt=$('commentText').value.trim();
  if(!txt&&selFiles.length===0){$('commentText').focus();return;}
  const btn=$('sendBtn');btn.disabled=true;btn.innerHTML='<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg> Mengirim...';
  try{
    const fdata=new FormData();
    fdata.append('content',txt);fdata.append('type',selFiles.length>0&&!txt?'photo':'comment');
    selFiles.forEach(f=>fdata.append('attachments',f));
    const token=getToken();
    const j=await fetch('/api/tickets/'+TID+'/timeline',{
      method:'POST',
      headers:token?{'Authorization':'Bearer '+token}:{},
      credentials:'include',
      body:fdata
    }).then(r=>r.json());
    if(j.success){$('commentText').value='';selFiles=[];$('filePreview').innerHTML='';$('commentFile').value='';showToast('Update berhasil dikirim','success');await loadTicket();}
