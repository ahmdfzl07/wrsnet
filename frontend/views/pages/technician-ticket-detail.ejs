    <div class="sfi-lbl">${s.lbl}<br><span class="sfi-sub">${s.desc}</span></div>
    ${i===ci?'<span class="sfi-chip">Aktif</span>':''}
  </div>`).join('');
}

/* ═══ TIMELINE ═══ */
function renderTimeline(items){
  const c=$('tlContainer');
  if(!items.length){c.innerHTML='<p style="text-align:center;color:var(--muted);padding:20px;">Belum ada aktivitas</p>';return;}
  const ICON={
    created:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>',
    assigned:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>',
    assignment:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>',
    status_change:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>',
    status_changed:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/></svg>',
    comment:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>',
    photo:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
    resolution:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>',
    system:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33"/></svg>',
  };
  c.innerHTML=[...items].reverse().map(tl=>{
    const un=tl.user?.name||'Sistem',ui=un.charAt(0).toUpperCase();
    const tlDate=tl.created_at||tl.createdAt;
    const dt=tlDate?new Date(tlDate).toLocaleString('id-ID',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
    const icon=ICON[tl.type]||ICON.comment;
    let body=tl.content?`<p style="margin:6px 0 0;color:#475569;line-height:1.6;font-size:13.5px;">${esc(tl.content)}</p>`:'';
    if(tl.attachments?.length){
      const imgs=tl.attachments.filter(a=>/\.(jpg|jpeg|png|gif|webp)$/i.test(a.url));
      const files=tl.attachments.filter(a=>!/\.(jpg|jpeg|png|gif|webp)$/i.test(a.url));
      if(imgs.length)body+=`<div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">${imgs.map(a=>`<img src="${a.url}" class="timeline-foto" onclick="openLb('${a.url}')" alt="">`).join('')}</div>`;
      if(files.length)body+=`<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">${files.map(a=>`<a href="${a.url}" target="_blank" class="file-tag">📄 ${esc(a.filename||'File')}</a>`).join('')}</div>`;
    }
    return`<div class="timeline-item ${tl.type}"><div style="display:flex;justify-content:space-between;align-items:flex-start;gap:12px;"><div style="flex:1;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
        <span class="tl-avatar">${ui}</span>
        <div><strong style="color:var(--text);font-size:13.5px;display:flex;align-items:center;gap:5px;">${icon} ${esc(un)}</strong>${tl.user?.role?`<small style="color:var(--muted);font-size:10.5px;display:block;text-transform:uppercase;letter-spacing:.5px;">${esc(typeof tl.user.role==='object'?tl.user.role.display_name||tl.user.role.name:tl.user.role)}</small>`:''}</div>
      </div>${body}</div>
      <small style="color:var(--muted2);white-space:nowrap;font-size:10.5px;">${dt}</small>
    </div></div>`;
  }).join('');
}

/* ═══ SEND COMMENT ═══ */
async function sendComment(){
  const txt=$('commentText').value.trim();
  if(!txt&&selFiles.length===0){$('commentText').focus();return;}
  const btn=$('sendBtn');btn.disabled=true;btn.innerHTML='<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg> Mengirim...';
  try{
    const fdata=new FormData();
    fdata.append('content',txt);fdata.append('type',selFiles.length>0&&!txt?'photo':'comment');
    selFiles.forEach(f=>fdata.append('attachments',f));
    const token=getToken();
    const j=await fetch('/api/tickets/'+TID+'/timeline',{
      method:'POST',
      headers:token?{'Authorization':'Bearer '+token}:{},
      credentials:'include',
      body:fdata
    }).then(r=>r.json());
    if(j.success){$('commentText').value='';selFiles=[];$('filePreview').innerHTML='';$('commentFile').value='';showToast('Update berhasil dikirim','success');await loadTicket();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
  btn.disabled=false;btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Kirim Update';
}
$('commentFile')?.addEventListener('change',function(){
  selFiles=[...selFiles,...Array.from(this.files)];
  $('filePreview').innerHTML=selFiles.map((f,i)=>`<span class="file-tag">${f.type.startsWith('image/')?'🖼':'📄'} ${f.name.substring(0,20)}<button onclick="selFiles.splice(${i},1);this.parentNode.remove()">×</button></span>`).join('');
});

/* ═══ MAP ═══ */
function initMap(lat,lng,t){
  if(leafMap){leafMap.remove();leafMap=null;}
  leafMap=L.map('map').setView([lat,lng],15);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap'}).addTo(leafMap);
  const tc=TC[t.type]||'#ef4444';
  const pulse={gangguan:'pulse-red',request:'pulse-blue',installation:'pulse-green',maintenance:'pulse-orange'}[t.type]||'pulse-blue';
  const ico={gangguan:'<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>',request:'<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07"/>',installation:'<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>',maintenance:'<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>'}[t.type]||'<circle cx="12" cy="10" r="3"/>';
  const mkI=L.divIcon({html:`<div class="custom-marker ${pulse}" style="background:${tc};"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">${ico}</svg></div>`,className:'',iconSize:[40,40],iconAnchor:[20,20]});
  const c=t.customer;
  const ph=c?`<div class="leaflet-popup-content"><div class="popup-header"><h3>${esc(c.name)}</h3></div><div class="popup-body"><div class="popup-info-item"><span class="popup-label">Kategori</span><span class="popup-value" style="color:${tc};">${TL[t.type]||t.type}</span></div><div class="popup-info-item"><span class="popup-label">WhatsApp</span><span class="popup-value"><a href="https://wa.me/62${(c.phone||'').replace(/^0/,'')}">${esc(c.phone||'—')}</a></span></div><div class="popup-info-item"><span class="popup-label">Alamat</span><span class="popup-value">${esc(c.address||'—')}</span></div></div><div class="popup-footer"><a href="https://www.google.com/maps?q=${lat},${lng}" target="_blank" style="background:linear-gradient(135deg,var(--nv3),var(--nv));">Maps</a><a href="https://wa.me/62${(c.phone||'').replace(/^0/,'')}" target="_blank" style="background:linear-gradient(135deg,#25d366,#128c7e);">Hubungi</a></div></div>`:'<div style="padding:12px;font-size:13px;">Lokasi Ticket</div>';
  L.marker([lat,lng],{icon:mkI}).addTo(leafMap).bindPopup(ph,{maxWidth:260}).openPopup();
}

/* ═══ STATUS MODAL ═══ */
function openStatusModal(){
  if(!tkData)return;selStatus=tkData.status;$('statusNote').value='';
  $('statusGrid').innerHTML=SSTEPS.map(s=>`<button class="stop ${s.key===tkData.status?'sel':''}" onclick="pickStatus('${s.key}',this)"><div class="stop-ico">${s.ico}</div><div class="stop-txt"><div class="stop-lbl">${s.lbl}</div><div class="stop-desc">${SD[s.key]||''}</div></div></button>`).join('');
  openM('mStatus');
}
function pickStatus(key,el){selStatus=key;document.querySelectorAll('.stop').forEach(e=>e.classList.remove('sel'));el.classList.add('sel');}
async function submitStatus(){
  if(!selStatus||selStatus===tkData.status){showToast('Pilih status yang berbeda','warn');return;}
  try{
    const note=$('statusNote').value.trim();
    const j=await authFetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:selStatus})}).then(r=>r.json());
    if(j.success){
      if(note)await authFetch('/api/tickets/'+TID+'/timeline',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({content:note,type:'comment'})});
      closeM('mStatus');showToast('Status berhasil diupdate!','success');await loadTicket();
    }else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}

/* ═══ QUICK ACTIONS ═══ */
async function quickResolve(){
  if(!confirm('Tandai tiket ini selesai?'))return;
  try{
    const j=await authFetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'resolved',resolved_at:new Date().toISOString()})}).then(r=>r.json());
    if(j.success){showToast('Tiket ditandai selesai!','success');await loadTicket();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}
async function claimTicket(){
  if(!confirm('Ambil tiket ini dan tugaskan ke Anda?'))return;
  try{
    // Get current user id
    const me=await authFetch('/api/auth/profile').then(r=>r.json());
    const uid=me?.data?.id;
    if(!uid){showToast('Tidak dapat mengidentifikasi user','error');return;}
    const j=await authFetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({assigned_to:uid,status:'in_progress'})}).then(r=>r.json());
    if(j.success){showToast('Tiket berhasil diambil!','success');await loadTicket();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}
function startGps(){
  sessionStorage.setItem('tracking_ticket_id',TID);
  location.href='/technician-tracking?ticket='+TID;
}

/* ═══ UTIL ═══ */
function showToast(msg,type='info'){
  const COL={success:'#15803d',error:'#dc2626',warn:'#d97706',info:'#2563eb'};
  const t=document.createElement('div');
  t.style.cssText=`position:fixed;bottom:90px;left:50%;transform:translateX(-50%);z-index:99999;padding:11px 18px;border-radius:10px;background:${COL[type]||'#2563eb'};color:#fff;font-size:13px;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,.25);animation:mIn .25s ease-out;max-width:300px;font-family:var(--font);`;
  t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),3000);
}
function openLb(src){$('lbi').src=src;$('lb').classList.add('show');}
function openM(id){$(id).classList.add('show');}
function closeM(id){$(id).classList.remove('show');}
document.querySelectorAll('.mover').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('show');}));
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){['mStatus'].forEach(closeM);$('lb').classList.remove('show');}
  if(e.ctrlKey&&e.key==='Enter')sendComment();
});
</script>
