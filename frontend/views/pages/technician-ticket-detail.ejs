    status_changed:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/></svg>',
    comment:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>',
    photo:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
    resolution:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>',
    system:'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33"/></svg>',
  };
  c.innerHTML=[...items].reverse().map(tl=>{
    const un=tl.user?.name||'Sistem',ui=un.charAt(0).toUpperCase();
    const tlDate=tl.created_at||tl.createdAt;
    const dt=tlDate?new Date(tlDate).toLocaleString('id-ID',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
    const icon=ICON[tl.type]||ICON.comment;
    let body=tl.content?`<p style="margin:6px 0 0;color:#475569;line-height:1.6;font-size:13.5px;">${esc(tl.content)}</p>`:'';
    if(tl.attachments?.length){
      const imgs=tl.attachments.filter(a=>/\.(jpg|jpeg|png|gif|webp)$/i.test(a.url));
      const files=tl.attachments.filter(a=>!/\.(jpg|jpeg|png|gif|webp)$/i.test(a.url));
      if(imgs.length)body+=`<div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">${imgs.map(a=>`<img src="${a.url}" class="timeline-foto" onclick="openLb('${a.url}')" alt="">`).join('')}</div>`;
