var pendingLat = null;
var pendingLng = null;
var map = null;
var odpEventBound = false;
var allCustomers = [], selectedCustomerId = null;
let trafficData = {};
let allInfraPoints = {};
let openPopupCustId = null;
const custChartRange = {};
const trafficHistory = {};

function getTicketIdFromUrl() {
  const path = window.location.pathname;
  const parts = path.split("/").filter(Boolean);
  return parts[parts.length - 1];
}

document.addEventListener("DOMContentLoaded", async function () {
  updateCoordPreview(null, null);

  const ticketId = window.location.pathname.split("/").pop();

  try {
    const response = await fetch(`/api/tickets/${ticketId}`);
    const res = await response.json();

    // window.lockCustomerId = res.data.customerRegistration?.customer_id || null;
    window.lockCustomerId = res.customer?.customer_id || null;
    window.currentCustomer = res.customer || null;
    window.currentCustomerOdp = res || null;

    const btnAssignOdp = document.getElementById("btnAssignOdp");
    const btnCekOdp = document.getElementById("btnCekOdp");

    const role = window.currentUser?.role;

    if (res.odp && res.odp.id) {
      btnAssignOdp.style.display = "none";
      btnCekOdp.style.display = "inline-flex";
      window.currentOdp = res.odp;
    } else {
      btnCekOdp.style.display = "none";
      btnAssignOdp.style.display = "inline-flex";
    }

    await loadAllCustomers();

    if (window.lockCustomerId) {
      searchCustomer('');
    }

  } catch (err) {
    console.error("Gagal memuat data ticket:", err);
  }

  document.addEventListener("input", function (e) {
    if (e.target.id === "manualLat" || e.target.id === "manualLng") {
      applyManualCoord();
    }
  });

  const latInput = document.getElementById("manualLat");
  const lngInput = document.getElementById("manualLng");

  if (latInput) latInput.setAttribute("readonly", true);
  if (lngInput) lngInput.setAttribute("readonly", true);
});

function initMapOdp() {
  if (typeof L === "undefined") return;

  map = L.map("map").setView([-6.2, 106.8], 13);

  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

  map.on("click", function (e) {
    const lat = e.latlng.lat;
    const lng = e.latlng.lng;

    pendingLat = lat;
    pendingLng = lng;

    document.getElementById("manualLat").value = lat.toFixed(6);
    document.getElementById("manualLng").value = lng.toFixed(6);

    updateCoordPreview(lat, lng);
  });
}

async function openAssignOdpModal() {
  const ticketId = getTicketIdFromUrl();

  if (!ticketId) {
    alert("ID ticket tidak ditemukan");
    return;
  }

  try {
    const res = await fetch(`/api/tickets/${ticketId}`);
    if (!res.ok) return;

    const result = await res.json();
    const ticket = result.data;

    if (!ticket) return;

    const lat =
      ticket.customerRegistration?.latitude ??
      ticket.customer?.latitude ??
      ticket.latitude ??
      null;

    const lng =
      ticket.customerRegistration?.longitude ??
      ticket.customer?.longitude ??
      ticket.longitude ??
      null;

    pendingLat = lat;
    pendingLng = lng;

    document.getElementById("manualLat").value = lat ?? "";
    document.getElementById("manualLng").value = lng ?? "";

    updateCoordPreview(lat, lng);

    if (lat && lng && map && typeof map.setView === "function") {
      map.setView([lat, lng], 15);
    }

    await loadParentSelects(ticket);
    updateOdpButton(ticket);

    document.getElementById("infraModal").style.display = "flex";

    if (!odpEventBound) {
      odpEventBound = true;

      document.addEventListener("click", function (e) {
        const btn = e.target.closest("#odp-upload-btn");

        if (btn) {
          const input = document.getElementById("odp-photo-input");
          if (input) {
            input.value = "";
            input.click();
          }
        }

        const removeBtn = e.target.closest("#odp-photo-remove");
        if (removeBtn) {
          removeOdpPhoto();
        }

        if (e.target.id === "odp-photo-preview" && e.target.src) {
          window.open(e.target.src, "_blank");
        }
      });

      document.addEventListener("change", function (e) {
        if (e.target.id !== "odp-photo-input") return;

        const file = e.target.files && e.target.files[0];
        if (!file) return;

        const prev = document.getElementById("odp-photo-preview");
        const remBtn = document.getElementById("odp-photo-remove");
        const btn = document.getElementById("odp-upload-btn");

        const reader = new FileReader();

        reader.onload = (ev) => {
          if (prev) {
            prev.src = ev.target.result;
            prev.style.display = "block";
          }

          if (remBtn) remBtn.style.display = "inline-block";

          if (btn) {
            btn.innerHTML =
              '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> ' +
              (file.name.length > 20
                ? file.name.slice(0, 18) + "…"
                : file.name);
          }
        };

        reader.readAsDataURL(file);
      });
    }
  } catch (err) {
    console.error(err);
  }
}

