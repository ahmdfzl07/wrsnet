<script>const TID='<%= ticketId %>';</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
'use strict';
let tkData=null,leafMap=null,selFiles=[],selStatus=null;
const $=id=>document.getElementById(id);
const esc=s=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const fd=d=>d?new Date(d).toLocaleString('id-ID',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
const fd2=d=>d?new Date(d).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}):'—';

function getToken(){const ls=localStorage.getItem('token');if(ls)return ls;const m=document.cookie.match(/(?:^|;\s*)token=([^;]+)/);return m?decodeURIComponent(m[1]):null;}
function authFetch(url,opts={}){
  const t=getToken();
  const h=opts.headers||{};
  if(t)h['Authorization']='Bearer '+t;
  return fetch(url,{...opts,headers:h,credentials:'include'});
}

const TC={gangguan:'#dc2626',request:'#2563eb',installation:'#16a34a',maintenance:'#d97706'};
const TL={gangguan:'Gangguan',request:'Request',installation:'Instalasi',maintenance:'Maintenance'};
const PL={critical:'Critical',high:'Tinggi',medium:'Sedang',low:'Rendah'};
const SL={open:'Open',in_progress:'In Progress',pending:'Pending',resolved:'Resolved',closed:'Closed'};
const SC={open:'s-open',in_progress:'s-prog',pending:'s-pend',resolved:'s-res',closed:'s-cls'};
const SI={open:'',in_progress:'',pending:'',resolved:'',closed:''};
const SD={open:'Menunggu penanganan',in_progress:'Sedang ditangani',pending:'Menunggu / on hold',resolved:'Masalah diselesaikan',closed:'Ticket ditutup'};

document.addEventListener('DOMContentLoaded',()=>{loadTicket();});

async function loadTicket(){
  try{
    const j=await authFetch('/api/tickets/'+TID).then(r=>r.json());
    if(!j.success){$('loadingDiv').innerHTML=`<div class="loading-inner"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--red)" stroke-width="2" style="margin-bottom:12px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><div style="font-weight:700;color:var(--red);">Ticket tidak ditemukan</div><a href="/technician?tab=tickets" style="color:var(--nv);font-weight:700;margin-top:8px;display:inline-block;">← Kembali</a></div>`;return;}
    tkData=j.data;renderTicket(tkData);
    $('loadingDiv').style.display='none';$('mainContent').style.display='block';
  }catch(e){$('loadingDiv').innerHTML=`<div class="loading-inner" style="color:var(--red);">Error: ${e.message}</div>`;}
}

function renderTicket(t){
  $('hNum').textContent=t.ticket_number||'Ticket #'+String(t.id).padStart(4,'0');
  $('hTitle').textContent=t.title;
  const mhN=$('mhNum'); if(mhN) mhN.textContent=t.ticket_number||'#'+t.id;
  const tc=TC[t.type]||'#666';
  const PC2={'critical':'#ef4444','high':'#f97316','medium':'#eab308','low':'#22c55e'};
  const SC2={'open':'#f59e0b','in_progress':'#3b82f6','pending':'#8b5cf6','resolved':'#22c55e','closed':'#9ca3af'};
  const pc=PC2[t.priority]||'rgba(255,255,255,.3)',sc=SC2[t.status]||'rgba(255,255,255,.3)';
  const dateStr=fd2(t.created_at);
  $('hMeta').innerHTML=`
    ${dateStr&&dateStr!=='—'?`<span class="meta-item">${dateStr}</span>`:''}
    <span class="meta-item" style="background:${tc}28;border-color:${tc}50;">${TL[t.type]||t.type}</span>
    <span class="meta-item" style="background:${pc}28;border-color:${pc}55;">${PL[t.priority]||t.priority}</span>
    <span class="meta-item" style="background:${sc}28;border-color:${sc}55;">${SI[t.status]||''} ${SL[t.status]||t.status}</span>`;

  // Customer
  if(t.customer){
    const c=t.customer;$('custCard').style.display='block';
    $('custGrid').innerHTML=`
      <div class="info-item"><div class="info-label">NAMA</div><div class="info-value">${esc(c.name)}</div></div>
      <div class="info-item"><div class="info-label">WHATSAPP</div><div class="info-value"><a href="https://wa.me/62${(c.phone||'').replace(/^0/,'')}" target="_blank">📱 ${esc(c.phone||'—')}</a></div></div>
      <div class="info-item"><div class="info-label">EMAIL</div><div class="info-value">${esc(c.email||'—')}</div></div>
      <div class="info-item" style="grid-column:1/-1;"><div class="info-label">ALAMAT</div><div class="info-value">${esc(c.address||'—')}</div></div>`;
  }

  // Detail grid
  $('detailGrid').innerHTML=`
    <div class="info-item"><div class="info-label">KATEGORI</div><div class="info-value">${TL[t.type]||t.type}</div></div>
    <div class="info-item"><div class="info-label">PRIORITAS</div><div class="info-value">${PL[t.priority]||t.priority}</div></div>
    <div class="info-item"><div class="info-label">STATUS</div><div class="info-value">${SI[t.status]||''} ${SL[t.status]||t.status}</div></div>
    <div class="info-item"><div class="info-label">TEKNISI</div><div class="info-value">${t.assignee?esc(t.assignee.name):'<span style="color:#ea580c;">Belum ditugaskan</span>'}</div></div>
    <div class="info-item"><div class="info-label">DIBUAT</div><div class="info-value">${fd(getCreatedAt(t))}</div></div>
    <div class="info-item"><div class="info-label">DEADLINE</div><div class="info-value">${t.due_at?fd(t.due_at):'—'}</div></div>
    ${t.resolved_at?`<div class="info-item"><div class="info-label">DISELESAIKAN</div><div class="info-value">${fd(t.resolved_at)}</div></div>`:''}
    ${t.closed_at?`<div class="info-item"><div class="info-label">DITUTUP</div><div class="info-value">${fd(t.closed_at)}</div></div>`:''}
    ${t.location_note?`<div class="info-item" style="grid-column:1/-1;"><div class="info-label">LOKASI</div><div class="info-value">${esc(t.location_note)}</div></div>`:''}`;
  if(t.description){$('descSection').style.display='block';$('descBox').textContent=t.description;}

  // Quick actions (teknisi)
  let qa='';
  if(!['resolved','closed'].includes(t.status)){
    qa+=`<button class="qab qab-status" onclick="openStatusModal()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>Update Status</button>`;
    qa+=`<button class="qab qab-success" onclick="quickResolve()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Tandai Selesai</button>`;
  }
  if(!t.assigned_to){
    qa+=`<button class="qab qab-warning" onclick="claimTicket()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 7"/></svg>Ambil Tiket Ini</button>`;
  }
  qa+=`<button class="qab qab-status" onclick="startGps()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>Mulai GPS Tracking</button>`;
  qa+=`<hr style="border:none;border-top:1px solid #f0f0f0;margin:2px 0;">`;
  qa+=`<a href="/technician?tab=tickets" class="qab qab-gray"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>Kembali</a>`;
  $('qaList').innerHTML=qa;

  renderSLA(t);
  renderStatusFlow(t.status);

  // Map
  const lat=parseFloat(t.latitude||t.customer?.latitude);
  const lng=parseFloat(t.longitude||t.customer?.longitude);
  if(!isNaN(lat)&&!isNaN(lng)){
    $('mapCard').style.display='block';
    setTimeout(()=>initMap(lat,lng,t),300);
    const c=t.customer;
    if(c){
      $('mapBtns').innerHTML=`<a href="https://www.google.com/maps?q=${lat},${lng}" target="_blank" class="btn btn-primary" style="width:auto;margin-bottom:0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> Maps</a>${c.phone?`<a href="https://wa.me/62${(c.phone).replace(/^0/,'')}" target="_blank" class="btn btn-success" style="width:auto;margin-bottom:0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg> Hubungi</a>`:''}`;
    }
  }

  renderTimeline(t.timelines||[]);
}

/* ═══ SLA ═══ */
let slaChart=null;

/* Ambil created_at dengan fallback lengkap
   — field camelCase / snake_case / timestamp pertama dari timeline */
function getCreatedAt(t){
  if(!t) return null;
  return t.created_at
      || t.createdAt
      || t.created
      || (Array.isArray(t.timelines) && t.timelines.length
            ? (t.timelines[0].created_at || t.timelines[0].createdAt)
            : null);
}

/* Format durasi ms → teks Indonesia yang natural
   Contoh: "1 jam 30 menit", "2 hari 3 jam", "45 menit", "30 detik" */
function fmtResolutionTime(ms){
  if(ms < 0) ms = 0;
  const s = Math.floor(ms / 1000);
  if(s < 60) return s + ' detik';

  const m = Math.floor(s / 60);
  if(m < 60){
    return m + ' menit';
  }

  const h = Math.floor(m / 60);
  const rm = m % 60;
  if(h < 24){
    return rm > 0 ? h + ' jam ' + rm + ' menit' : h + ' jam';
  }

  const d = Math.floor(h / 24);
  const rh = h % 24;
  if(d < 7){
    return rh > 0 ? d + ' hari ' + rh + ' jam' : d + ' hari';
  }

  // ≥ 7 hari, tampilkan minggu + hari
  const w = Math.floor(d / 7);
  const rd = d % 7;
  return rd > 0 ? w + ' minggu ' + rd + ' hari' : w + ' minggu';
}

/* Build text "Dibuat Xxx → Selesai Yyy" untuk sub-label */
function buildResolutionSub(t, endAt){
  const createdRaw = getCreatedAt(t);
  const created = new Date(createdRaw);
  const ended = new Date(endAt);
  const fmtShort = (d) => {
    const sameDay = created.toDateString() === ended.toDateString();
    if(sameDay){
      return d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    }
    return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short' }) + ' ' +
           d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
  };
  return fmtShort(created) + ' → ' + fmtShort(ended);
}

function renderSLA(t){
  const done=['resolved','closed'].includes(t.status);
  $('slaBadge').textContent=done?(t.status==='closed'?'Ditutup':'Selesai'):'Aktif';
  $('slaBadge').className='sbadge '+(done?'s-res':'s-prog');
  let pct=0,color='#16a34a',remText='—',tgtText=(t.sla_hours||24)+'h',dueText='';
  if(done){pct=100;remText=t.status==='closed'?'Ditutup':'Selesai';}
  else if(t.due_at){
    const cr=new Date(t.created_at).getTime(),due=new Date(t.due_at).getTime(),now=Date.now();
    const total=due-cr;pct=total>0?Math.min(100,Math.max(0,(now-cr)/total*100)):0;
    if(isNaN(pct))pct=0;
    const rem=due-now,over=rem<0;
    const h=Math.floor(Math.abs(rem)/3600000),m=Math.floor((Math.abs(rem)%3600000)/60000);
    const rs=h>24?`${Math.floor(h/24)}h ${h%24}j`:h>0?`${h}j ${m}m`:`${m} menit`;
    color=over?'#dc2626':pct>80?'#ea580c':pct>60?'#d97706':'#16a34a';
    remText=over?`${rs}`:rs;dueText='Due: '+fd(t.due_at);
  }
  $('slaTgt').textContent=tgtText;$('slaRem').textContent=remText;$('slaRem').style.color=color;$('slaDue').textContent=dueText;

  // ── Resolution-time panel (hanya tampil kalau tiket sudah selesai) ──
  const rtPanel = document.getElementById('resolutionTime');
  if(rtPanel){
    const endAt = t.resolved_at || t.closed_at;
    const createdAt = getCreatedAt(t);
    if(done && createdAt && endAt){
      const ms = new Date(endAt) - new Date(createdAt);
      if(ms >= 0){
        const duration = fmtResolutionTime(ms);
        const onTime = t.due_at ? (new Date(endAt) <= new Date(t.due_at)) : null;

        document.getElementById('rtDuration').textContent = 'Terselesaikan dalam ' + duration;
        document.getElementById('rtSub').textContent = buildResolutionSub(t, endAt);

        const badge = document.getElementById('rtBadge');
        if(onTime === true){
          badge.className = 'rt-badge ontime';
          badge.textContent = 'On-Time';
          badge.style.display = '';
          rtPanel.style.background = 'linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%)';
          rtPanel.style.borderColor = '#a7f3d0';
          document.querySelector('#resolutionTime .rt-head').style.color = '#047857';
          document.getElementById('rtDuration').style.color = '#065f46';
          document.getElementById('rtSub').style.color = '#059669';
        } else if(onTime === false){
          badge.className = 'rt-badge late';
          badge.textContent = 'Over SLA';
          badge.style.display = '';
          rtPanel.style.background = 'linear-gradient(135deg,#fef2f2 0%,#fee2e2 100%)';
          rtPanel.style.borderColor = '#fecaca';
          document.querySelector('#resolutionTime .rt-head').style.color = '#b91c1c';
          document.getElementById('rtDuration').style.color = '#7f1d1d';
          document.getElementById('rtSub').style.color = '#dc2626';
        } else {
          badge.style.display = 'none';
          rtPanel.style.background = 'linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%)';
          rtPanel.style.borderColor = '#a7f3d0';
        }
        rtPanel.classList.add('show');
      } else {
        rtPanel.classList.remove('show');
      }
    } else if(done && endAt){
      // Fallback: created_at tidak tersedia sama sekali — tetap tampilkan info minimal
      document.getElementById('rtDuration').textContent = 'Diselesaikan ' + new Date(endAt).toLocaleString('id-ID', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
      document.getElementById('rtSub').textContent = 'Durasi tidak tersedia (data pembuatan tiket hilang)';
      const badge = document.getElementById('rtBadge');
      if(badge) badge.style.display = 'none';
      rtPanel.style.background = '#f8fafc';
      rtPanel.style.borderColor = '#e2e8f0';
      document.querySelector('#resolutionTime .rt-head').style.color = '#64748b';
      document.getElementById('rtDuration').style.color = '#334155';
      document.getElementById('rtSub').style.color = '#94a3b8';
      rtPanel.classList.add('show');
    } else {
      rtPanel.classList.remove('show');
    }
  }

  const safePct=isNaN(pct)?0:Math.round(pct);
  const gaugeOpts={series:[safePct],chart:{type:'radialBar',height:130,width:120,sparkline:{enabled:true}},plotOptions:{radialBar:{startAngle:-135,endAngle:135,hollow:{size:'55%'},track:{background:'#f0f0f0',strokeWidth:'97%',margin:4},dataLabels:{name:{show:true,offsetY:16,color:'#9ca3af',fontSize:'9px',fontWeight:700,fontFamily:'Plus Jakarta Sans',formatter:()=>'SLA'},value:{offsetY:-10,color:color,fontSize:'18px',fontWeight:800,fontFamily:'Plus Jakarta Sans',formatter:v=>v+'%'}}}},fill:{type:'gradient',gradient:{shade:'dark',type:'horizontal',gradientToColors:[color],stops:[0,100],colorStops:[{offset:0,color:done?'#22c55e':pct>80?'#f97316':pct>60?'#facc15':'#4ade80',opacity:1},{offset:100,color:color,opacity:1}]}},stroke:{lineCap:'round'},labels:['SLA']};
  if(slaChart){slaChart.updateOptions(gaugeOpts,true,true);}
  else{const el=$('slaGaugeChart');if(el&&window.ApexCharts){slaChart=new ApexCharts(el,gaugeOpts);slaChart.render();}}
}

