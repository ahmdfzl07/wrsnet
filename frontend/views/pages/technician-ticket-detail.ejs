/* ═══ QUICK ACTIONS ═══ */
async function quickResolve(){
  if(!confirm('Tandai tiket ini selesai?'))return;
  try{
    const j=await authFetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'resolved',resolved_at:new Date().toISOString()})}).then(r=>r.json());
    if(j.success){showToast('Tiket ditandai selesai!','success');await loadTicket();location.reload();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}
async function claimTicket(){
  if(!confirm('Ambil tiket ini dan tugaskan ke Anda?'))return;
  try{
    // Get current user id
    const me=await authFetch('/api/auth/profile').then(r=>r.json());
    const uid=me?.data?.id;
    if(!uid){showToast('Tidak dapat mengidentifikasi user','error');return;}
    const j=await authFetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({assigned_to:uid,status:'in_progress'})}).then(r=>r.json());
    if(j.success){showToast('Tiket berhasil diambil!','success');await loadTicket();location.reload();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}
