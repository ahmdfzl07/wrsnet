<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Registrasi Customer</title>

<link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

<style>
  body {
    margin: 0;
    background: url('https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=1974') no-repeat center center fixed;
    background-size: cover;
    position: relative;
    font-family: sans-serif;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: linear-gradient(
      to bottom right,
      rgba(15,23,42,0.85),
      rgba(30,41,59,0.9)
    );
    backdrop-filter: blur(6px);
    z-index: -1;
  }

  .bg-ambient {
    position: fixed;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
  }

  .blob {
    position: absolute;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(59,130,246,0.4), transparent 70%);
    filter: blur(80px);
    animation: floatBlob 20s infinite alternate ease-in-out;
  }

  .blob:nth-child(2) {
    background: radial-gradient(circle, rgba(14,165,233,0.4), transparent 70%);
    left: 60%;
    top: 40%;
    animation-delay: 5s;
  }

  .blob:nth-child(3) {
    background: radial-gradient(circle, rgba(168,85,247,0.4), transparent 70%);
    left: 20%;
    top: 60%;
    animation-delay: 10s;
  }

  @keyframes floatBlob {
    0% { transform: translate(0,0) scale(1); }
    100% { transform: translate(100px, -80px) scale(1.2); }
  }
  .glass {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255,255,255,0.15);
    box-shadow:
      0 20px 60px rgba(0,0,0,0.6),
      inset 0 0 30px rgba(255,255,255,0.05);
    color: white;
  }
  .glow {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(59,130,246,0.4), transparent);
    filter: blur(100px);
    z-index: -1;
  }
  label {
    color: rgba(255,255,255,0.7);
  }

  input, textarea, select {
    background: rgba(255,255,255,0.05);
    color: white;
    border: 1px solid rgba(255,255,255,0.1);
  }

  input::placeholder {
    color: rgba(255,255,255,0.3);
  }
  .ts-dropdown {
    background: rgba(30, 41, 59, 0.95) !important;
    color: white !important;
    border-radius: 12px;
    backdrop-filter: blur(10px);
  }

  .ts-dropdown .option {
    color: white !important;
    padding: 10px;
  }

  .ts-dropdown .option:hover {
    background: rgba(59,130,246,0.6) !important;
    color: white !important;
  }

  .ts-dropdown .active {
    background: #2563eb !important;
    color: white !important;
  }

  .ts-control {
    background: rgba(255,255,255,0.05) !important;
    color: white !important;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .ts-control input {
    color: white !important;
  }
  .ts-dropdown {
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    animation: fadeDropdown 0.2s ease;
  }
  .ts-dropdown,
  .ts-dropdown-content {
    background-color: #1e293b !important;
    color: #fff !important;
  }

  .ts-dropdown .option {
    color: #fff !important;
    background: transparent !important;
  }

  .ts-dropdown .option:hover {
    background: #2563eb !important;
    color: #fff !important;
  }

  .ts-dropdown .active {
    background: #1d4ed8 !important;
    color: #fff !important;
  }

  .ts-control {
    background-color: rgba(255,255,255,0.05) !important;
    color: white !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
  }

  .ts-control input {
    color: white !important;
  }

  .ts-control input::placeholder {
    color: rgba(255,255,255,0.4) !important;
  }
  .ts-dropdown .option {
    color: #ffffff !important;
  }

  .ts-dropdown [data-selectable] {
    color: #ffffff !important;
  }
  .ts-dropdown * {
    color: #ffffff !important;
  }
  @keyframes fadeDropdown {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  select {
    color: white;
    background: rgba(255,255,255,0.05);
  }
  .input-modern:focus {
    box-shadow:
      0 0 0 2px #3b82f6,
      0 0 20px rgba(59,130,246,0.5);
    transform: translateY(-2px) scale(1.01);
  }
  .glass:hover {
    transform: translateY(-5px) scale(1.005);
    transition: all 0.4s ease;
  }
</style>
</head>

<body class="bg-gradient-to-br from-blue-50 to-slate-100 min-h-screen">
<div class="bg-ambient">
  <div class="blob top-0 left-0"></div>
  <div class="blob"></div>
  <div class="blob"></div>
</div>
<div class="flex justify-center items-center gap-6 pt-8">
  <img src="https://e.ebilling.id:2096/img/logo/3275WRSNET%201%20(REMOVE%20BACKGROUND).png" class="h-10">
  <div class="w-[2px] h-8 bg-slate-300"></div>
  <img src="https://gmdp.net.id/build/assets/gmdp%20logo-Cm7eDGKF.webp" class="h-10">
</div>

<div class="max-w-5xl mx-auto mt-6 mb-10 glass rounded-3xl shadow-2xl p-10 transition hover:shadow-[0_20px_60px_rgba(0,0,0,0.15)]">

  <h2 class="text-xl font-bold text-center mb-6">Registrasi Customer</h2>

  <div class="relative">
    <div class="glow top-0 left-0"></div>
    <div class="glow bottom-0 right-0"></div>
    <form id="formRegister" class="grid grid-cols-12 gap-4">

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">NIK (16 digit)</label>
        <input id="nik" maxlength="16"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Nama Lengkap</label>
        <input id="custName"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">No HP</label>
        <input id="custPhone"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Email</label>
        <input id="custEmail"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Paket</label>
        <select id="custPackage"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
        </select>
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Tanggal Instalasi</label>
        <input type="date" id="custInstallDate"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Referral</label>
        <input id="custReferral"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-12 flex items-center gap-3 mt-6">
        <div class="h-px flex-1 bg-slate-200"></div>
          <span class="text-xs text-slate-400 font-semibold tracking-wider">WILAYAH & LOKASI</span>
        <div class="h-px flex-1 bg-slate-200"></div>
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Provinsi</label>
        <select id="custProvinsi"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition"></select>
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Kabupaten</label>
        <select id="custKabupaten"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition"></select>
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Kecamatan</label>
        <select id="custKecamatan"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition"></select>
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Kelurahan</label>
        <select id="custKelurahan"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition"></select>
      </div>

      <div class="col-span-3">
        <label class="text-xs font-semibold text-slate-500">RT</label>
        <input id="custRt"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-3">
        <label class="text-xs font-semibold text-slate-500">RW</label>
        <input id="custRw"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition">
      </div>

      <div class="col-span-12">
        <label class="text-xs font-semibold text-slate-500">Alamat</label>
        <textarea id="custAddress"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition"></textarea>
      </div>

      <div class="col-span-6">
        <label class="text-xs font-semibold text-slate-500">Koordinat</label>
        <input id="custCoordinates" placeholder="-6.2,106.8"
          class="mt-1 w-full px-3 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-blue-500 transition" readonly>
      </div>

      <div class="col-span-12">
        <div id="map" class="h-[350px] rounded-xl shadow-inner border"></div>
      </div>

      <div class="col-span-12 flex gap-3 mt-6">
        <button type="submit"
          class="flex-1 btn-primary bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 text-white py-3 rounded-xl font-semibold transition transform hover:scale-[1.03] active:scale-[0.98] shadow-lg">
          Daftar
        </button>

        <a href="/portal/login"
          class="flex-1 text-center bg-slate-200 hover:bg-slate-300 py-3 rounded-xl font-semibold transition">
          Batal
        </a>
      </div>

    </form>
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  const API = window.location.origin + "/api/wilayah";
  let provinsiSelect, kabupatenSelect, kecamatanSelect, kelurahanSelect;

  let packageSelect;
  async function loadPackages() {
    const res = await fetch("/api/packages");
    const json = await res.json();

    if (!json?.success) return;

    const data = json.data
      .filter(p => p.is_active == 1)
      .map(p => ({
        value: p.id,
        text: `${p.name} — Rp ${Number(p.price).toLocaleString("id-ID")}/bln`,
        price: p.price
      }));

    if (packageSelect) {
      packageSelect.destroy();
    }

    packageSelect = new TomSelect("#custPackage", {
      options: data,
      valueField: "value",
      labelField: "text",
      searchField: ["text"],

      placeholder: "Pilih paket...",

      render: {
        option: function(data, escape) {
          return `
            <div class="flex justify-between items-center px-2 py-2">
              <span>${escape(data.text)}</span>
            </div>
          `;
        },
        item: function(data, escape) {
          return `<div>${escape(data.text)}</div>`;
        }
      }
    });
  }

  function resetWilayah(level){
    if(level === "provinsi"){
      if(kabupatenSelect){kabupatenSelect.destroy(); kabupatenSelect=null;}
      if(kecamatanSelect){kecamatanSelect.destroy(); kecamatanSelect=null;}
      if(kelurahanSelect){kelurahanSelect.destroy(); kelurahanSelect=null;}

      custKabupaten.innerHTML = '<option value="">Pilih Kabupaten</option>';
      custKecamatan.innerHTML = '<option value="">Pilih Kecamatan</option>';
      custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    }

    if(level === "kabupaten"){
      if(kecamatanSelect){kecamatanSelect.destroy(); kecamatanSelect=null;}
      if(kelurahanSelect){kelurahanSelect.destroy(); kelurahanSelect=null;}

      custKecamatan.innerHTML = '<option value="">Pilih Kecamatan</option>';
      custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    }

    if(level === "kecamatan"){
      if(kelurahanSelect){kelurahanSelect.destroy(); kelurahanSelect=null;}
      custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    }
  }

  async function loadProvinsi(){
    const res = await fetch("/api/wilayah/provinsi");
    const data = await res.json();

    custProvinsi.innerHTML = '<option value="">Pilih Provinsi</option>';
    data.forEach(i=>{
      custProvinsi.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    provinsiSelect = new TomSelect("#custProvinsi",{
      onChange(val){
        resetWilayah("provinsi");
        if(val) loadKabupaten(val);
      }
    });
  }

  async function loadKabupaten(id){
    const res = await fetch(`${API}/kabupaten/${id}`);
    const data = await res.json();

    custKabupaten.innerHTML = '<option value="">Pilih Kabupaten</option>';
    data.forEach(i=>{
      custKabupaten.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    kabupatenSelect = new TomSelect("#custKabupaten",{
      onChange(val){
        resetWilayah("kabupaten");
        if(val) loadKecamatan(val);
      }
    });
  }

  async function loadKecamatan(id){
    const res = await fetch(`${API}/kecamatan/${id}`);
    const data = await res.json();

    custKecamatan.innerHTML = '<option value="">Pilih Kecamatan</option>';
    data.forEach(i=>{
      custKecamatan.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    kecamatanSelect = new TomSelect("#custKecamatan",{
      onChange(val){
        resetWilayah("kecamatan");
        if(val) loadKelurahan(val);
      }
    });
  }

  async function loadKelurahan(id){
    const res = await fetch(`${API}/kelurahan/${id}`);
    const data = await res.json();

    custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    data.forEach(i=>{
      custKelurahan.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    kelurahanSelect = new TomSelect("#custKelurahan");
  }

  loadProvinsi();
  loadPackages();

  nik.addEventListener("input", function(){
    this.value = this.value.replace(/\D/g,'');
    if(this.value.length > 16){
      this.value = this.value.slice(0,16);
    }
  });

  formRegister.addEventListener("submit", async function(e){
    e.preventDefault();

    const btn = document.querySelector(".btn-primary");
    const original = btn.innerHTML;

    btn.innerHTML = "Memproses...";
    btn.disabled = true;

    try {

      if(nik.value.length !== 16){
        alert("NIK harus 16 digit!");
        return;
      }

      const [lat, lng] = custCoordinates.value.split(',');

      const data = {
        nik: nik.value,
        name: custName.value,
        phone: custPhone.value,
        email: custEmail.value,
        address: custAddress.value,
        province_id: custProvinsi.value,
        kabupaten: custKabupaten.value,
        kecamatan: custKecamatan.value,
        kelurahan: custKelurahan.value,
        rt: custRt.value,
        rw: custRw.value,
        package_id: custPackage.value,
        installation_date: custInstallDate.value,
        latitude: lat,
        longitude: lng,
        referral: custReferral.value,
      };

      const res = await fetch("/api/register/customer", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (!res.ok || !result.success) {
        alert(result.message || "Gagal registrasi");
        return;
      }

      btn.innerHTML = "Berhasil ✓";

      setTimeout(()=>{
        location.reload();
      },1200);

    } finally {
      setTimeout(()=>{
        btn.disabled = false;
        btn.innerHTML = original;
      },1200);
    }
  });

  let map, marker;

  const defaultLat = -6.200000;
  const defaultLng = 106.816666;

  function initMap(lat = defaultLat, lng = defaultLng) {

    map = L.map('map').setView([lat, lng], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap'
    }).addTo(map);

    marker = L.marker([lat, lng], { draggable: true }).addTo(map);

    setCoordinates(lat, lng);

    marker.on('dragend', function (e) {
      const { lat, lng } = e.target.getLatLng();
      setCoordinates(lat, lng);
    });

    map.on('click', function (e) {
      const { lat, lng } = e.latlng;

      marker.setLatLng([lat, lng]);
      setCoordinates(lat, lng);
    });
  }

  function setCoordinates(lat, lng){
    const val = lat.toFixed(6) + ',' + lng.toFixed(6);
    custCoordinates.value = val;
  }

  function detectLocation(){
    if(navigator.geolocation){
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        map.setView([lat, lng], 15);
        marker.setLatLng([lat, lng]);
        setCoordinates(lat, lng);
      });
    }
  }

  initMap();

  detectLocation();
</script>

</body>
</html>