<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Registrasi Customer</title>

<link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>
  body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background: radial-gradient(circle at 10% 10%, #1e40af, #020617 70%);
    color: white;
    overflow-x: hidden;
  }

  body::before,
  body::after {
    content: "";
    position: fixed;
    width: 500px;
    height: 500px;
    filter: blur(120px);
    z-index: -1;
  }

  body::before {
    background: radial-gradient(circle, rgba(59,130,246,0.35), transparent);
    top: -100px;
    left: -100px;
  }

  body::after {
    background: radial-gradient(circle, rgba(168,85,247,0.35), transparent);
    bottom: -120px;
    right: -120px;
  }

  .glass {
    background: linear-gradient(
      145deg,
      rgba(255,255,255,0.08),
      rgba(255,255,255,0.02)
    );
    backdrop-filter: blur(30px);
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow:
      0 20px 60px rgba(0,0,0,0.6),
      inset 0 0 30px rgba(255,255,255,0.05);
    transition: all .3s ease;
  }

  .glass:hover {
    transform: translateY(-4px) scale(1.01);
  }

  .input {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    color: white;
    padding: 12px 14px;
    border-radius: 14px;
    transition: all 0.25s ease;
  }

  .input::placeholder {
    color: rgba(255,255,255,0.4);
  }

  .input:focus {
    outline: none;
    border-color: #60a5fa;
    box-shadow:
      0 0 0 2px rgba(59,130,246,0.4),
      0 10px 25px rgba(59,130,246,0.2);
    transform: translateY(-1px);
  }

  .btn {
    padding: 12px;
    border-radius: 14px;
    font-weight: 600;
    transition: all 0.25s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg,#3b82f6,#6366f1);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(99,102,241,0.4);
  }

  .btn-gray {
    background: rgba(255,255,255,0.08);
  }

  .step {
    display: none;
    animation: fade .4s ease;
  }
  .step.active { display:block; }

  @keyframes fade {
    from {opacity:0; transform:translateY(15px);}
    to {opacity:1;}
  }

  .progress-bar {
    height: 6px;
    background: rgba(255,255,255,0.1);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg,#3b82f6,#a855f7,#22c55e);
    transition: width .4s ease;
  }

  .review-card {
    background: rgba(255,255,255,0.05);
    border-radius: 16px;
    padding: 14px;
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .review-label {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
  }

  .review-value {
    font-weight: 600;
  }

  .ts-control {
    background: rgba(255,255,255,0.04) !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    border-radius: 14px !important;
    padding: 8px 10px !important;
    color: white !important;
    min-height: 48px;
    display: flex;
    align-items: center;
  }

  .ts-control input {
    color: white !important;
  }

  .ts-control input::placeholder {
    color: rgba(255,255,255,0.4) !important;
  }

  .ts-control.focus {
    border-color: #60a5fa !important;
    box-shadow:
      0 0 0 2px rgba(59,130,246,0.4),
      0 10px 25px rgba(59,130,246,0.2);
  }

  .ts-dropdown {
    background: rgba(15,23,42,0.95) !important;
    border-radius: 14px !important;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(20px);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.6);
  }

  .ts-dropdown .option {
    padding: 10px 14px;
    color: white !important;
    transition: 0.2s;
  }

  .ts-dropdown .option:hover {
    background: rgba(59,130,246,0.5) !important;
  }

  .ts-dropdown .active {
    background: linear-gradient(135deg,#3b82f6,#6366f1) !important;
  }

  .ts-dropdown {
    z-index: 999999 !important;
    position: absolute !important;
  }

  .glass {
    overflow: visible !important;
  }

  .ts-control {
    cursor: pointer;
    pointer-events: auto !important;
  }

  .ts-wrapper {
    position: relative;
    z-index: 9999;
  }

  .input,
  .ts-control {
    height: 48px;
    font-size: 14px;
  }

  textarea.input {
    height: auto;
    min-height: 80px;
  }

  #map {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .header-hero {
    position: relative;
    padding-top: 40px;
    padding-bottom: 10px;
    display: flex;
    justify-content: center;
  }

  .header-hero::before {
    content: "";
    position: absolute;
    width: 400px;
    height: 200px;
    background: radial-gradient(circle, rgba(59,130,246,0.25), transparent);
    filter: blur(80px);
    top: 0;
    z-index: -1;
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 20px;
    background: rgba(255,255,255,0.05);
    padding: 10px 20px;
    border-radius: 20px;
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .logo-wrap img {
    height: 40px;
    object-fit: contain;
    transition: 0.3s;
  }

  .logo-wrap img:hover {
    transform: scale(1.05);
  }

  .logo-wrap .divider {
    width: 2px;
    height: 30px;
    background: rgba(255,255,255,0.2);
  }

  @media (max-width: 768px){

    .glass:hover {
      transform: none !important;
    }

    .glass {
      transform: none !important;
      padding: 18px !important;
      margin: 10px !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }

    h2 {
      font-size: 18px;
    }

    .grid {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }

    .btn {
      font-size: 14px;
      padding: 10px;
    }

    .review-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 6px;
    }

    .review-value {
      font-size: 14px;
      word-break: break-word;
    }

    .progress-bar {
      height: 5px;
    }

    #map {
      height: 200px !important;
    }

    .logo-wrap {
      gap: 12px;
      padding: 8px 14px;
    }

    .logo-wrap img {
      height: 28px;
    }

    .logo-wrap .divider {
      height: 20px;
    }

  }

  /* @media (max-width: 400px){
    body {
      font-size: 13px;
    }

    .input,
    .ts-control {
      height: 44px;
    }
  } */
</style>
</head>

<body>

<div class="header-hero">
  <div class="logo-wrap">
    <img src="https://e.ebilling.id:2096/img/logo/3275WRSNET%201%20(REMOVE%20BACKGROUND).png">
    <div class="divider"></div>
    <img src="https://gmdp.net.id/build/assets/gmdp%20logo-Cm7eDGKF.webp">
  </div>
</div>
<div class="max-w-4xl mx-auto mt-6 p-6 glass rounded-2xl">
  <h2 class="text-center text-xl font-bold mb-6">Registrasi Customer</h2>
  <form id="formRegister">
    <!-- PROGRESS -->
    <div class="progress-bar mb-6">
      <div id="progressFill" class="progress-fill"></div>
    </div>
    <!-- STEP 1 DATA -->
    <div class="step active">
      <div class="grid grid-cols-2 gap-4">
        <input id="nik" placeholder="NIK" class="input">
        <input id="custName" placeholder="Nama" class="input">
        <input id="custPhone" placeholder="HP" class="input">
        <input id="custEmail" placeholder="Email" class="input">
        <input id="custReferral" placeholder="Referral" class="input">
      </div>

      <button type="button" onclick="nextStep()" class="btn btn-primary w-full mt-4">Lanjut</button>
    </div>

    <!-- STEP 2 LAYANAN -->
    <div class="step">
      <div class="grid md:grid-cols-2 gap-4">
        <select id="custPackage"></select>
        <input type="date" id="custInstallDate" class="input w-full" placeholder="Tanggal Instalasi">
      </div>

      <div class="flex gap-2 mt-4">
        <button onclick="prevStep()" type="button" class="btn btn-gray flex-1">Kembali</button>
        <button onclick="nextStep()" type="button" class="btn btn-primary flex-1">Lanjut</button>
      </div>
    </div>

    <!-- STEP 3 ALAMAT -->
    <div class="step">
      <div class="grid md:grid-cols-2 gap-4">

        <select id="custProvinsi"></select>
        <select id="custKabupaten"></select>

        <select id="custKecamatan"></select>
        <select id="custKelurahan"></select>

        <input id="custRt" placeholder="RT" class="input">
        <input id="custRw" placeholder="RW" class="input">

        <textarea id="custAddress" class="input md:col-span-2" placeholder="Alamat"></textarea>

        <input id="custCoordinates" class="input md:col-span-2" readonly>

        <div id="map" class="md:col-span-2"></div>

      </div>

      <div class="flex gap-2 mt-4">
        <button onclick="prevStep()" type="button" class="btn btn-gray flex-1">Kembali</button>
        <button onclick="nextStep()" type="button" class="btn btn-primary flex-1">Lanjut</button>
      </div>
    </div>

    <!-- STEP 4 REVIEW -->
    <div class="step">
      <div id="reviewBox" class="space-y-2 text-sm"></div>

      <div class="flex gap-2 mt-4">
        <button onclick="prevStep()" type="button" class="btn btn-gray flex-1">Kembali</button>
        <button type="submit" class="btn btn-primary flex-1">Submit</button>
      </div>
    </div>
  </form>
</div>


<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  const API = window.location.origin + "/api/wilayah";
  let provinsiSelect, kabupatenSelect, kecamatanSelect, kelurahanSelect;

  let packageSelect;
  async function loadPackages() {
    const res = await fetch("/api/packages/public");
    const json = await res.json();

    if (!json?.success) return;

    const data = json.data
      .filter(p => p.is_active == 1)
      .map(p => ({
        value: p.id,
        text: `${p.name} — Rp ${Number(p.price).toLocaleString("id-ID")}/bln`,
        price: p.price
      }));

    if (packageSelect) {
      packageSelect.destroy();
    }

    packageSelect = new TomSelect("#custPackage", {
      options: data,
      valueField: "value",
      labelField: "text",
      searchField: ["text"],

      placeholder: "Pilih paket...",

      dropdownParent: "body",

      render: {
        option: function(data, escape) {
          return `
            <div class="flex justify-between items-center px-2 py-2">
              <span>${escape(data.text)}</span>
            </div>
          `;
        },
        item: function(data, escape) {
          return `<div>${escape(data.text)}</div>`;
        }
      }
    });
  }

  function resetWilayah(level){
    if(level === "provinsi"){
      if(kabupatenSelect){kabupatenSelect.destroy(); kabupatenSelect=null;}
      if(kecamatanSelect){kecamatanSelect.destroy(); kecamatanSelect=null;}
      if(kelurahanSelect){kelurahanSelect.destroy(); kelurahanSelect=null;}

      custKabupaten.innerHTML = '<option value="">Pilih Kabupaten</option>';
      custKecamatan.innerHTML = '<option value="">Pilih Kecamatan</option>';
      custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    }

    if(level === "kabupaten"){
      if(kecamatanSelect){kecamatanSelect.destroy(); kecamatanSelect=null;}
      if(kelurahanSelect){kelurahanSelect.destroy(); kelurahanSelect=null;}

      custKecamatan.innerHTML = '<option value="">Pilih Kecamatan</option>';
      custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    }

    if(level === "kecamatan"){
      if(kelurahanSelect){kelurahanSelect.destroy(); kelurahanSelect=null;}
      custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    }
  }

  async function loadProvinsi(){
    const res = await fetch("/api/wilayah/provinsi");
    const data = await res.json();

    custProvinsi.innerHTML = '<option value="">Pilih Provinsi</option>';
    data.forEach(i=>{
      custProvinsi.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    provinsiSelect = new TomSelect("#custProvinsi",{
      onChange(val){
        resetWilayah("provinsi");
        if(val) loadKabupaten(val);
      }
    });
  }

  async function loadKabupaten(id){
    const res = await fetch(`${API}/kabupaten/${id}`);
    const data = await res.json();

    custKabupaten.innerHTML = '<option value="">Pilih Kabupaten</option>';
    data.forEach(i=>{
      custKabupaten.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    kabupatenSelect = new TomSelect("#custKabupaten",{
      onChange(val){
        resetWilayah("kabupaten");
        if(val) loadKecamatan(val);
      }
    });
  }

  async function loadKecamatan(id){
    const res = await fetch(`${API}/kecamatan/${id}`);
    const data = await res.json();

    custKecamatan.innerHTML = '<option value="">Pilih Kecamatan</option>';
    data.forEach(i=>{
      custKecamatan.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    kecamatanSelect = new TomSelect("#custKecamatan",{
      onChange(val){
        resetWilayah("kecamatan");
        if(val) loadKelurahan(val);
      }
    });
  }

  async function loadKelurahan(id){
    const res = await fetch(`${API}/kelurahan/${id}`);
    const data = await res.json();

    custKelurahan.innerHTML = '<option value="">Pilih Kelurahan</option>';
    data.forEach(i=>{
      custKelurahan.innerHTML += `<option value="${i.id}">${i.name}</option>`;
    });

    kelurahanSelect = new TomSelect("#custKelurahan");
  }

  nik.addEventListener("input", function(){
    this.value = this.value.replace(/\D/g,'');
    if(this.value.length > 16){
      this.value = this.value.slice(0,16);
    }
  });

  formRegister.addEventListener("submit", async function(e){
    e.preventDefault();

    const btn = document.querySelector(".btn-primary");
    const original = btn.innerHTML;

    btn.innerHTML = "Memproses...";
    btn.disabled = true;

    try {

      if(nik.value.length !== 16){
        alert("NIK harus 16 digit!");
        return;
      }

      const [lat, lng] = custCoordinates.value.split(',');

      const data = {
        nik: nik.value,
        name: custName.value,
        phone: custPhone.value,
        email: custEmail.value,
        address: custAddress.value,
        province_id: custProvinsi.value,
        kabupaten: custKabupaten.value,
        kecamatan: custKecamatan.value,
        kelurahan: custKelurahan.value,
        rt: custRt.value,
        rw: custRw.value,
        package_id: custPackage.value,
        installation_date: custInstallDate.value,
        latitude: lat,
        longitude: lng,
        referral: custReferral.value,
      };

      const res = await fetch("/api/register/customer", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (!res.ok || !result.success) {
        alert(result.message || "Gagal registrasi");
        return;
      }

      btn.innerHTML = "Berhasil ✓";

      setTimeout(()=>{
        location.reload();
      },1200);

    } finally {
      setTimeout(()=>{
        btn.disabled = false;
        btn.innerHTML = original;
      },1200);
    }
  });

  let map, marker;

  const defaultLat = -6.200000;
  const defaultLng = 106.816666;

  function initMap(lat = defaultLat, lng = defaultLng) {

    map = L.map('map').setView([lat, lng], 13);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap'
    }).addTo(map);

    marker = L.marker([lat, lng], { draggable: true }).addTo(map);

    setCoordinates(lat, lng);

    marker.on('dragend', function (e) {
      const { lat, lng } = e.target.getLatLng();
      setCoordinates(lat, lng);
    });

    map.on('click', function (e) {
      const { lat, lng } = e.latlng;

      marker.setLatLng([lat, lng]);
      setCoordinates(lat, lng);
    });
  }

  function setCoordinates(lat, lng){
    const val = lat.toFixed(6) + ',' + lng.toFixed(6);
    custCoordinates.value = val;
  }

  function detectLocation(){
    if(navigator.geolocation){
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        map.setView([lat, lng], 15);
        marker.setLatLng([lat, lng]);
        setCoordinates(lat, lng);
      });
    }
  }

  let step = 0;
  const steps = document.querySelectorAll(".step");
  const progressFill = document.getElementById("progressFill");

  function updateProgress(){
    const percent = ((step+1)/4)*100;
    progressFill.style.width = percent + "%";
  }

  function showStep(i){
    steps.forEach((s,idx)=>s.classList.toggle("active",idx===i));
    updateProgress();

    setTimeout(() => {
      if(map){
        map.invalidateSize();
      }
    }, 200);
  }

  function nextStep(){
    if(step===2) generateReview();
    if(step<3){ step++; showStep(step); }
  }

  function prevStep(){
    if(step>0){ step--; showStep(step); }
  }

  function generateReview(){
    const data = [
      ["Nama", custName.value],
      ["NIK", nik.value],
      ["HP", custPhone.value],
      ["Email", custEmail.value],
      ["Paket", custPackage.options[custPackage.selectedIndex]?.text],
      ["Tgl Instalasi", custInstallDate.value],
      ["Alamat", custAddress.value],
      ["Koordinat", custCoordinates.value]
    ];

    reviewBox.innerHTML = data.map(item => `
      <div class="review-card">
        <div>
          <div class="review-label">${item[0]}</div>
          <div class="review-value">${item[1] || '-'}</div>
        </div>
      </div>
    `).join('');
  }

  document.addEventListener("DOMContentLoaded", function () {
    loadProvinsi();
    loadPackages();

    initMap();
    detectLocation();
    updateProgress();
  });
</script>

</body>
</html>