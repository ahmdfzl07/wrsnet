<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>403 — Akses Ditolak</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{
      font-family:'DM Sans',system-ui,sans-serif;
      min-height:100vh;
      display:flex;align-items:center;justify-content:center;
      background:linear-gradient(135deg,#0b1e4e 0%,#1a3a8c 50%,#1a6ef5 100%);
      color:#fff;padding:20px;
    }
    .card{
      background:rgba(255,255,255,.08);
      backdrop-filter:blur(20px);
      -webkit-backdrop-filter:blur(20px);
      border:1px solid rgba(255,255,255,.15);
      border-radius:24px;
      padding:48px 40px;
      max-width:460px;width:100%;
      text-align:center;
      box-shadow:0 20px 60px rgba(0,0,0,.3);
    }
    .icon-wrap{
      width:96px;height:96px;border-radius:50%;
      background:rgba(245,54,92,.15);border:2px solid rgba(245,54,92,.4);
      display:flex;align-items:center;justify-content:center;
      margin:0 auto 24px;
    }
    .icon-wrap svg{width:48px;height:48px;color:#ff6b8a;}
    h1{font-size:28px;font-weight:800;margin-bottom:12px;letter-spacing:-.5px;}
    .code{
      display:inline-block;font-size:11px;font-weight:700;
      letter-spacing:.1em;text-transform:uppercase;
      background:rgba(255,107,138,.15);color:#ff8fa3;
      padding:4px 10px;border-radius:6px;margin-bottom:18px;
    }
    p{font-size:14.5px;color:rgba(255,255,255,.75);line-height:1.6;margin-bottom:28px;}
    .actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
    .btn{
      padding:11px 22px;border-radius:10px;font-weight:600;font-size:13.5px;
      text-decoration:none;transition:all .15s;display:inline-flex;align-items:center;gap:6px;
      border:none;cursor:pointer;font-family:inherit;
    }
    .btn-primary{background:#fff;color:#1a3a8c;}
    .btn-primary:hover{transform:translateY(-1px);box-shadow:0 8px 20px rgba(0,0,0,.2);}
    .btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2);}
    .btn-ghost:hover{background:rgba(255,255,255,.18);}
  </style>
</head>
<body>
  <div class="card">
    <div class="icon-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>
    <div class="code">403 Forbidden</div>
    <h1>Akses Ditolak</h1>
    <p><%= typeof message !== 'undefined' && message ? message : 'Anda tidak memiliki izin untuk mengakses halaman ini. Hubungi administrator bila Anda merasa ini adalah kesalahan.' %></p>
    <div class="actions">
      <a href="javascript:history.back()" class="btn btn-ghost">← Kembali</a>
      <a href="/" class="btn btn-primary">Ke Beranda</a>
    </div>
  </div>
</body>
</html>
