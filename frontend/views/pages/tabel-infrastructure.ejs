<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
let allData = [];
let filteredData = [];
let currentPage = 1;
let trafficData = {};
let allInfraPoints = {};
let openPopupCustId = null;
const custChartRange = {};
const trafficHistory = {};
const perPage = 10;

function showToast(msg,type='info'){
  const COL={success:'#15803d',error:'#dc2626',warn:'#d97706',info:'#1d4ed8'};
  const t=document.createElement('div');
  t.style.cssText=`position:fixed;bottom:20px;right:20px;z-index:99999;padding:11px 18px;border-radius:9px;background:${COL[type]||'#1d4ed8'};color:#fff;font-size:13px;font-weight:700;box-shadow:0 4px 20px rgba(0,0,0,.2);animation:mIn .25s ease-out;max-width:300px;`;
  t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),3000);
}

async function loadInfrastructure() {
  const res = await fetch('/api/tabel-infrastructure');
  const json = await res.json();

  if (!json.success) return;

  allData = json.data;
  filteredData = [...allData];

  updateStats(allData);

  renderPage(1);
}

function updateStats(data) {
  const count = (type) => data.filter(x => x.type === type).length;

  document.getElementById('scTotal').innerText = data.length || 0;
  document.getElementById('scODP').innerText = count('odp') || 0;
  document.getElementById('scODC').innerText = count('odc') || 0;
  document.getElementById('scONT').innerText = count('tower') || 0;
  document.getElementById('scPOP').innerText = count('pop') || 0;
  document.getElementById('scCustomer').innerText = count('customer') || 0;
}

function renderPage(page) {
  currentPage = page;

  const start = (page - 1) * perPage;
  const end = start + perPage;

  const pageData = filteredData.slice(start, end);

  renderCards(pageData);
  renderPagination();
}

const getIcon = (type) => {
  if (type === 'odp') return '📡';
  if (type === 'pop') return '📦';
  if (type === 'odc') return '🗄️';
  if (type === 'tower') return '📶';
  if (type === 'customer') return '👤';
  return '📦';
};

function getPopTypeLabel(type) {
  const map = {
    olt: 'OLT (Optical Line Terminal)',
    mdf: 'MDF (Main Distribution Frame)',
    datacenter: 'Datacenter',
    other: 'Lainnya'
  };

  return map[type] || type || '-';
}

function renderCards(data) {
  const grid = document.getElementById('pkgGrid');
  grid.innerHTML = '';

  data.forEach(pt => {

    const parentName =
      pt.parent && (pt.parent.type === 'odp' || pt.parent.type === 'odc')
        ? pt.parent.name
        : '-';

    let customerName = '-';
    if (pt.type === 'customer' && pt.customer) {
      customerName = pt.customer.name;
    }

    const card = `
    <div class="pkg-card new">

      <div class="pkg-card-header ${pt.type}">

        <div class="hdr-overlay"></div>

        <div class="hdr-content">

          <div class="hdr-left">
            <div class="icon-box">
              ${getIcon(pt.type)}
            </div>

            <div>
              <div class="pkg-name">${pt.name}</div>
              <div class="pkg-sub">
                ${pt.type.toUpperCase()}
              </div>
            </div>
          </div>

          <div class="status-badge ${pt.status}">
            ${pt.status}
          </div>

        </div>

      </div>

      <div class="pkg-card-body">

        <div class="info-block coord-row">
          <div class="coord-info">
            <span>📍</span>
            <span>${pt.latitude}, ${pt.longitude}</span>
          </div>

          <a
            href="https://www.google.com/maps/dir/?api=1&destination=${pt.latitude},${pt.longitude}"
            target="_blank"
            class="nav-btn"
          >
            🧭 Navigasi
          </a>
        </div>

        ${pt.address ? `
          <div class="info-block address-block">
            <span>🏠</span>
            <span>${pt.address}</span>
          </div>
          ` : ''}

        <div class="info-block">
          <span>🔗</span>
          <span>${parentName}</span>
        </div>

        ${pt.type === 'customer' ? `
        <div class="info-block">
          <span>👤</span>
          <span>${customerName}</span>
        </div>
        ` : ''}

        ${pt.type === "pop" || pt.notes ? `
          <div class="detail-box">

            ${pt.type === "pop" ? `
              <div class="detail-row">
                <span class="detail-label">⚡ Tipe POP</span>
                <span class="detail-value">
                  ${getPopTypeLabel(pt.metadata?.pop_type)}
                </span>
              </div>
            ` : ''}

            ${pt.notes ? `
              <div class="detail-row">
                <span class="detail-label">📝 Catatan</span>
                <span class="detail-value">
                  ${pt.notes}
                </span>
              </div>
            ` : ''}

          </div>
        ` : ''}

        <div class="divider"></div>

        <div class="bottom-stats">
          <div>
            <div class="stat-label">Capacity</div>
            <div class="stat-val">${pt.capacity ?? '-'}</div>
          </div>
          <div>
            <div class="stat-label">Used</div>
            <div class="stat-val">${pt.used_ports ?? 0}</div>
          </div>
        </div>

      </div>

    </div>
    `;

    grid.innerHTML += card;
  });
}
