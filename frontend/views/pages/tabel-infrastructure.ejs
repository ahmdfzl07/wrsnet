function renderPagination() {
  const totalPage = Math.ceil(filteredData.length / perPage);
  const container = document.getElementById('pagination');

  if (!container) return;

  container.innerHTML = '';

  let pages = [];

  pages.push(1);

  for (let i = currentPage - 1; i <= currentPage + 1; i++) {
    if (i > 1 && i < totalPage) {
      pages.push(i);
    }
  }

  if (totalPage > 1) pages.push(totalPage);

  pages = [...new Set(pages)].sort((a, b) => a - b);

  let lastPage = 0;

  pages.forEach(p => {

    if (p - lastPage > 1) {
      container.innerHTML += `<span style="padding:6px 10px;color:#999">...</span>`;
    }

    container.innerHTML += `
      <button onclick="renderPage(${p})"
        style="
          margin:0 3px;
          padding:6px 10px;
          border-radius:8px;
          border:1px solid ${p === currentPage ? '#1a6ef5' : '#ddd'};
          background:${p === currentPage ? '#1a6ef5' : '#fff'};
          color:${p === currentPage ? '#fff' : '#333'};
          cursor:pointer;
          font-weight:600;
        ">
        ${p}
      </button>
    `;

    lastPage = p;
  });
}

document.getElementById('pkgSearch').addEventListener('input', e => {
  const val = e.target.value.toLowerCase();

  filteredData = allData.filter(x =>
    x.name.toLowerCase().includes(val)
  );

  updateStats(allData);
  renderPage(1);
});

function filterType(type, e) {
  if (type === 'all') {
    filteredData = [...allData]; 
  } else {
    filteredData = allData.filter(x => x.type === type);
  }

  updateStats(allData);
  renderPage(1);

  document.querySelectorAll('.fin-card').forEach(c => c.classList.remove('fc-active'));

  e.currentTarget.classList.add('fc-active');
}

function handleDetail(type, id) {
  const data = allData.find(x => x.id == id);

  if (!data) return;

  if (type === 'odp') {
    window.currentCustomer = data;
    window.currentCustomerOdp = data;
    openCekOdp();
  } 
  else if (type === 'odc') {
    openCekOdc(data);
  } 
  else if (type === 'tower') {
    openCekOnt(data);
  } 
  else if (type === 'customer') {
    window.currentCustomer = data;
    window.currentCustomerOdp = data;
    openCustomer();
  }
}

