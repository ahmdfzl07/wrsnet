<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    :root {
      --d-bg:#eef2f9; --d-card:#fff; --d-border:#e0e7f3;
      --d-text:#0d1b3e; --d-muted:#6b7fa8;
      --d-blue1:#1a6ef5; --d-blue2:#0047cc;
      --d-green:#00c896; --d-red:#f5365c; --d-orange:#fb8c00;
    }
    .pkg-page { font-family:'DM Sans',sans-serif; background:var(--d-bg) !important; }
    .btn-outline { background:#fff; border:1.5px solid var(--d-border); color:#374151; padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; font-family:inherit; transition:all .15s; }
    .btn-outline:hover { background:#f8fafc; border-color:#cbd5e1; }
    .btn-blue { background:linear-gradient(135deg,#1a6ef5,#0047cc); border:none; color:#fff; padding:8px 16px; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:6px; font-family:inherit; transition:all .15s; }
    .btn-blue:hover { opacity:.9; }
    /* ── STAT CARDS — single strip ── */
    .fin-grid, .fin-grid-4 {
      display: grid; grid-template-columns: repeat(6, 1fr);
      background: #fff; border-radius: 16px;
      border: 1px solid #e8eaed; overflow: hidden; margin-bottom: 20px;
    }
    .fin-card {
      padding: 20px 22px 18px; border-right: 1px solid #e8eaed;
      cursor: pointer; display: flex; flex-direction: column; gap: 0;
      position: relative; overflow: hidden; transition: background .15s;
    }
    .fin-card::before, .fin-card::after { display:none !important; content:none !important; }
    .fin-card .b1,.fin-card .b2,.fin-card .b3,
    .fin-card .orb,.fin-card .orb1,.fin-card .orb2 { display:none !important; }
    .fin-card:last-child { border-right: none; }
    .fin-card:hover { background: #fafbff; }
    .fin-card.fc-active { background: #2563eb; border-color: #2563eb; }
    .fin-card.fc-active:hover { background: #1d4ed8; }
    .fin-card.fc-active .xc-lbl  { color: rgba(255,255,255,.70); }
    .fin-card.fc-active .xc-val  { color: #fff; }
    .fin-card.fc-active .xc-sub  { color: rgba(255,255,255,.60); }
    .fin-card.fc-active .xc-pill { background: rgba(255,255,255,.20) !important; color: rgba(255,255,255,.90) !important; }
    .fin-card.fc-active .sp-line { stroke: rgba(255,255,255,.70) !important; }
    .fin-card.fc-active .sp-fill { fill: rgba(255,255,255,.12) !important; }
    .fin-card.fc-active .sp-dot  { fill: #fff !important; }
    .xc-lbl  { font-size:12px; font-weight:500; color:#64748b; margin-bottom:10px; transition:color .15s; }
    .xc-body { display:flex; align-items:flex-end; justify-content:space-between; gap:8px; }
    .xc-left { display:flex; flex-direction:column; min-width:0; }
    .xc-val  { font-size:30px; font-weight:800; color:#0f172a; letter-spacing:-1.2px; line-height:1; transition:color .15s; }
    @media(max-width:1400px){ .xc-val { font-size:26px; } }
    .xc-meta { display:flex; align-items:center; gap:5px; margin-top:6px; flex-wrap:wrap; }
    .xc-pill { display:inline-flex; align-items:center; padding:1px 6px; border-radius:100px; font-size:10.5px; font-weight:700; white-space:nowrap; flex-shrink:0; transition:all .15s; }
    .xc-blue   { background:#dbeafe; color:#1d4ed8; }
    .xc-green  { background:#dcfce7; color:#16a34a; }
    .xc-red    { background:#fee2e2; color:#dc2626; }
    .xc-amber  { background:#fef3c7; color:#b45309; }
    .xc-teal   { background:#cffafe; color:#0e7490; }
    .xc-orange { background:#ffedd5; color:#c2410c; }
    .xc-purple { background:#ede9fe; color:#7c3aed; }
    .xc-sub  { font-size:11px; color:#94a3b8; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; transition:color .15s; }
    .xc-spark { flex-shrink:0; width:72px; height:36px; }
    .xc-spark svg { width:72px; height:36px; }
    .sp-fill { transition:fill .3s; }
    .sp-line { stroke-width:1.8; fill:none; stroke-linecap:round; stroke-linejoin:round; }
    @media(max-width:700px) {
      .fin-grid, .fin-grid-4 { grid-template-columns:repeat(2,1fr); }
      .fin-card { border-right:none; border-bottom:1px solid #e8eaed; }
      .fin-card:nth-child(odd)  { border-right:1px solid #e8eaed; }
      .fin-card:nth-child(even) { border-right:none; }
      .fin-card:nth-last-child(-n+2) { border-bottom:none; }
    }
    @media(max-width:400px) {
      .fin-grid, .fin-grid-4 { grid-template-columns:1fr; }
      .fin-card { border-right:none !important; border-bottom:1px solid #e8eaed; }
      .fin-card:last-child { border-bottom:none; }
    }
    .search-wrap { position:relative; }
    .search-wrap input { width:100%;padding:10px 14px 10px 40px;box-sizing:border-box;border:1.5px solid var(--d-border);border-radius:12px;font-family:'DM Sans',sans-serif;font-size:13.5px;color:var(--d-text);background:#fff;transition:border-color .15s,box-shadow .15s;outline:none; }
    .search-wrap input:focus { border-color:var(--d-blue1);box-shadow:0 0 0 3px rgba(26,110,245,.1); }
    .search-wrap .si { position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--d-muted);pointer-events:none; }
    .filter-select { padding:10px 14px;border:1.5px solid var(--d-border);border-radius:12px;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--d-text);background:#fff;cursor:pointer;outline:none;transition:border-color .15s; }
    .filter-select:focus { border-color:var(--d-blue1); }
    .pkg-card-header.odp {
      background: linear-gradient(135deg, #2563eb, #1e3a8a); /* blue */
    }

    .pkg-card-header.odc {
      background: linear-gradient(135deg, #16a34a, #065f46); /* green */
    }

    .pkg-card-header.tower {
      background: linear-gradient(135deg, #f97316, #9a3412); /* orange */
    }

    .pkg-card-header.pop {
      background: linear-gradient(135deg, #756e95, #7c3aed); /* purple */
    }

    .pkg-card-header.customer {
      background: linear-gradient(135deg, #0ea5e9, #155e75); /* teal */
    }
    .pkg-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
    }

    @media (max-width: 900px) {
      .pkg-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 1024px) {
      .pkg-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .pkg-grid {
        grid-template-columns: 1fr;
      }
    }
    .pkg-card {
      min-height: 220px;
      display: flex;
      flex-direction: column;
    }

    .pkg-card-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    
    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
    .a1{animation:fadeUp .45s ease both} .a2{animation:fadeUp .45s .07s ease both}
    .a3{animation:fadeUp .45s .14s ease both} .a4{animation:fadeUp .45s .21s ease both}
    .a5{animation:fadeUp .45s .28s ease both}
    @media(max-width:1100px) { .fin-grid-4 { grid-template-columns:repeat(2,1fr) !important; } }
    @media(max-width:640px) {
      .fin-grid-4 { grid-template-columns:1fr 1fr !important;gap:10px !important; }
      .fin-card { padding:16px !important; } .fin-card .fc-val { font-size:26px !important; }
      .fin-card .fc-bar-bg { display:none; }
      .pkg-grid { grid-template-columns:1fr; }
    }
  
    /* ── Standardize card height (match queue.ejs) ── */
    .fin-card { min-height: 108px; }
    .xc-val   { font-size: 30px; font-weight: 800; color: #0f172a; letter-spacing: -1.2px; line-height: 1; transition: color .15s; }
    .xc-lbl   { font-size: 12px; font-weight: 500; color: #64748b; margin-bottom: 10px; letter-spacing: .1px; transition: color .15s; }
    .xc-sub   { font-size: 11px; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 140px; transition: color .15s; }
    .xc-meta  { display: flex; align-items: center; gap: 5px; margin-top: 6px; flex-wrap: nowrap; overflow: hidden; }
    .xc-spark { flex-shrink: 0; width: 72px; height: 36px; }
    .xc-spark svg { width: 72px; height: 36px; }
    @media(max-width:1400px){ .xc-val { font-size: 26px; } }
    /* CLEAN META STYLE */
  .pkg-meta.clean {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 12px;
    }

    .meta-item {
      font-size: 12.5px;
      color: #334155;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .meta-item.status {
      font-weight: 600;
    }

    .meta-item.status.active {
      color: #16a34a;
    }

    .meta-item.status.inactive {
      color: #dc2626;
    }

    .meta-row {
      font-size: 12px;
      color: #64748b;
      margin-bottom: 6px;
    }

    .meta-bottom {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: #0f172a;
      font-weight: 600;
      margin-top: 10px;
    }
    .btn-detail {
      background: #2563eb;
      color: #fff;
      border: none;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 11.5px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
    }

    .btn-detail:hover {
      background: #1d4ed8;
    }
    .mover{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;}
    .mover.show{display:flex;}
    .mbox{background:#fff;border-radius:16px;width:90%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:mIn .25s ease-out;max-height:90vh;overflow-y:auto;}
    .mhd{background:linear-gradient(135deg,var(--nv3),var(--nv));color:#fff;padding:18px 22px;border-radius:16px 16px 0 0;display:flex;justify-content:space-between;align-items:center;}
    .mhd h3{margin:0;font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px;}
    .mbdy{padding:20px 22px;}
    .cp-popup-wrap .leaflet-popup-content-wrapper {
      padding: 0 !important;
      border-radius: 14px !important;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.22) !important;
      border: none !important;
      min-width: 260px;
    }
    .cp-popup-wrap .leaflet-popup-content { margin: 0 !important; width: auto !important; }
    .cp-popup-wrap .leaflet-popup-tip-container { display: none; }
    .cp-popup-wrap .leaflet-popup-close-button {
      color: rgba(255,255,255,0.7) !important;
      font-size: 18px !important;
      top: 10px !important;
      right: 12px !important;
      z-index: 10;
    }
    .cp-popup-wrap .leaflet-popup-close-button:hover { color: #fff !important; }

    .cp-popup { font-family: 'DM Sans', sans-serif; width: 260px; }
    .cp-header {
      background: #1e3a8a;
      color: #fff;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 15px;
      font-weight: 700;
    }
    .cp-body { background: #fff; padding: 4px 0 8px; }
    .cp-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 7px 16px;
      border-bottom: 1px solid #f1f5f9;
      font-size: 13px;
    }
    .cp-row:last-child { border-bottom: none; }
    .cp-lbl { color: #94a3b8; font-weight: 500; }
    .cp-val { color: #1e293b; font-weight: 600; text-align: right; max-width: 155px; }
    .cp-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-top: 1px solid #f1f5f9;
    }
    .cp-btn {
      padding: 11px 0;
      border: none;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      transition: opacity .15s;
      font-family: 'DM Sans', sans-serif;
    }
    .cp-btn:hover { opacity: 0.85; }
    .cp-nav {
      background: #1e3a8a;
      color: #fff;
      border-radius: 0 0 0 14px;
    }
    .cp-edit {
      background: #f1f5f9;
      color: #334155;
      border-radius: 0 0 14px 0;
      border-left: 1px solid #e2e8f0;
    }

    .mover{
        position:fixed;
        inset:0;
        background:rgba(0,0,0,.55);
        display:none;
        justify-content:center;
        align-items:center;
        z-index:99999;
        padding:20px;
    }

    .mbox{
        background:#fff;
        width:100%;
        max-width:900px;
        border-radius:16px;
        overflow:hidden;
        box-shadow:0 20px 60px rgba(0,0,0,.2);
        max-height:90vh;
        display:flex;
        flex-direction:column;
    }

    .mhdInf{
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:18px 24px;
        border-bottom:1px solid #e5e7eb;
    }

    .mhdInf h3{
        margin:0;
        font-size:20px;
        font-weight:700;
    }

    .mcls{
        border:none;
        background:none;
        font-size:28px;
        cursor:pointer;
        color:#666;
    }

    .mcls:hover{
        color:#ef4444;
    }

    .mbdy{
        overflow-y:auto;
        padding:20px;
    }

    .mft{
        border-top:1px solid #e5e7eb;
        padding:16px 20px;
        display:flex;
        justify-content:flex-end;
        gap:10px;
    }

    .modal-tabs{
        display:flex;
        gap:10px;
        flex-wrap:wrap;
        margin-bottom:20px;
    }

    .modal-tab{
        border:none;
        background:#f1f5f9;
        padding:10px 18px;
        border-radius:10px;
        cursor:pointer;
        font-weight:600;
        transition:.2s;
    }

    .modal-tab:hover{
        background:#dbeafe;
    }

    .modal-tab.active{
        background:#2563eb;
        color:white;
    }

    .tab-panel{
        display:none;
    }

    .tab-panel.active{
        display:block;
    }

    .finput{
        width:100%;
        padding:12px 14px;
        border:1px solid #d1d5db;
        border-radius:10px;
        font-size:14px;
        margin-bottom:12px;
        box-sizing:border-box;
    }

    .finput:focus{
        outline:none;
        border-color:#2563eb;
        box-shadow:0 0 0 3px rgba(37,99,235,.15);
    }

    textarea.finput{
        resize:vertical;
        min-height:90px;
    }

    .grid2{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:12px;
    }

    .w-card{
        background:#f8fafc;
        border:1px solid #e2e8f0;
        border-radius:12px;
    }

    .btn-blue{
        background:#2563eb;
        color:white;
        border:none;
        padding:12px 18px;
        border-radius:10px;
        cursor:pointer;
        font-weight:600;
    }

    .btn-blue:hover{
        background:#1d4ed8;
    }

    .btn-outline{
        background:white;
        color:#374151;
        border:1px solid #d1d5db;
        padding:12px 18px;
        border-radius:10px;
        cursor:pointer;
        font-weight:600;
    }

    .btn-outline:hover{
        background:#f3f4f6;
    }

    input[type=file]{
        width:100%;
        padding:10px;
        border:1px dashed #cbd5e1;
        border-radius:10px;
        margin-bottom:12px;
    }

    #odc-photo-preview,
    #odp-photo-preview,
    #pop-photo-preview{
        width:100%;
        max-height:220px;
        object-fit:cover;
        border-radius:12px;
        border:1px solid #e5e7eb;
        margin-top:10px;
    }

    .customer-search-wrap{
        position:relative;
    }

    #custDropdown{
        position:absolute;
        left:0;
        right:0;
        top:100%;
        background:white;
        border:1px solid #d1d5db;
        border-radius:10px;
        box-shadow:0 8px 20px rgba(0,0,0,.08);
        max-height:250px;
        overflow-y:auto;
        z-index:999;
    }

    .customer-item{
        padding:12px 14px;
        cursor:pointer;
        border-bottom:1px solid #f1f5f9;
    }

    .customer-item:hover{
        background:#eff6ff;
    }

    #custSelected{
        padding:15px;
        background:#eff6ff;
        border:1px solid #bfdbfe;
        border-radius:12px;
        margin-bottom:15px;
    }
    .coord-box {
      background: #f8fafc;
      border-radius: 12px;
      padding: 12px 14px;
      border: 1px solid #e2e8f0;
    }

    .coord-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-weight: 600;
    }

    .coord-value {
      margin-top: 6px;
      font-size: 13px;
      color: #334155;
      font-family: monospace;
    }

    .badge {
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 999px;
      font-weight: 600;
    }

    .badge.empty {
      background: #f1f5f9;
      color: #64748b;
    }

    .badge.filled {
      background: #dcfce7;
      color: #16a34a;
    }
    .coord-value {
      cursor: pointer;
      transition: 0.2s;
    }

    .coord-value:hover {
      color: #2563eb;
    }

    @media(max-width:768px){

        .mover{
            padding:10px;
        }

        .mbox{
            max-height:95vh;
            border-radius:14px;
        }

        .grid2{
            grid-template-columns:1fr;
        }

        .modal-tabs{
            display:grid;
            grid-template-columns:1fr 1fr;
        }

        .modal-tab{
            width:100%;
        }

        .mhdInf h3{
            font-size:17px;
        }
    }
    .form-section{
      margin-bottom:18px;
      padding:14px;
      border:1px solid #e5e7eb;
      border-radius:12px;
      background:#fafafa;
    }

    .form-section h4{
      margin:0 0 10px;
      font-size:13px;
      font-weight:700;
      color:#334155;
    }
    .tab-panel {
      opacity: 0;
      transform: translateY(15px);
      transition: all .3s ease;
      position: absolute;
      width: 100%;
      pointer-events: none;
    }

    .tab-panel.active {
      opacity: 1;
      transform: translateY(0);
      position: relative;
      pointer-events: auto;
    }
    .flbl {
      display:block;
      font-size:11.5px;
      font-weight:700;
      color:#64748b;
      margin-bottom:6px;
      margin-top:10px;
      letter-spacing:.04em;
      text-transform:uppercase;
    }

    .flbl .req {
      color:#ef4444;
    }
    .pkg-card {
      border-radius: 16px;
      border: 1px solid #e2e8f0;
      overflow: hidden;
      transition: all .25s ease;
    }

    .pkg-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 30px rgba(0,0,0,.08);
    }

    .status-badge {
      font-size: 10px;
      padding: 3px 8px;
      border-radius: 999px;
    }

    .status-badge.active {
      background: #dcfce7;
      color: #16a34a;
    }

    .status-badge.inactive {
      background: #fee2e2;
      color: #dc2626;
    }
    .status-badge.maintenance {
      background: #fef9c3;
      color: #ca8a04;
    }
    .pkg-card.new {
      border-radius: 18px;
      overflow: hidden;
      background: #fff;
      border: 1px solid #e2e8f0;
      transition: all .3s ease;
      position: relative;
    }

    .pkg-card.new:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(0,0,0,.12);
    }

    .pkg-card-header {
      position: relative;
      padding: 16px;
      color: white;
    }

    .hdr-overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top right, rgba(255,255,255,.25), transparent);
      pointer-events: none;
    }

    .hdr-content {
      position: relative;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .hdr-left {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .icon-box {
      background: rgba(255,255,255,.2);
      padding: 8px;
      border-radius: 10px;
      font-size: 16px;
      backdrop-filter: blur(6px);
    }

    .pkg-sub {
      font-size: 11px;
      opacity: .8;
    }

    .pkg-card-body {
      padding: 16px;
    }

    .info-block {
      display: flex;
      gap: 8px;
      font-size: 13px;
      color: #334155;
      margin-bottom: 6px;
    }

    .divider {
      height: 1px;
      background: #e2e8f0;
      margin: 12px 0;
    }

    .bottom-stats {
      display: flex;
      justify-content: space-between;
    }

    .stat-label {
