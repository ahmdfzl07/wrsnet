});

async function loadAllCustomers() {
  try {
    const res = await fetch('/api/customers?limit=500');

    const json = await res.json();

    if (json?.success) {
      allCustomers = Array.isArray(json.data)
        ? json.data
        : (json.data?.rows || []);
    } else {
      allCustomers = [];
    }

  } catch (err) {
    console.error('Gagal load customer:', err);
    allCustomers = [];
  }
}

document.addEventListener('input', async (e) => {
  if (e.target.id !== 'addressSearch') return;

  clearTimeout(searchTimeout);

  searchTimeout = setTimeout(() => {
    searchAddress(e.target.value);
  }, 500);
});

async function searchAddress(keyword) {
  if (!keyword || keyword.length < 3) {
    document.getElementById('searchResults').innerHTML = '';
    return;
  }

  try {

    const res = await fetch(
      `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(keyword)}&limit=5`
    );

    const data = await res.json();

    const results = document.getElementById('searchResults');

    results.innerHTML = data.map(item => `
      <div class="search-item"
           onclick="selectSearchLocation(
             ${item.lat},
             ${item.lon},
             '${item.display_name.replace(/'/g,"\\'")}'
           )">
        ${item.display_name}
      </div>
    `).join('');

  } catch(err) {
    console.error(err);
  }

}

function setLocation(lat, lng, address = '') {

  selectedLat = parseFloat(lat);
  selectedLng = parseFloat(lng);

  document.getElementById("coordPreview").innerHTML =
    `${selectedLat.toFixed(6)}, ${selectedLng.toFixed(6)}`;

  const status = document.getElementById("coordStatus");

  status.textContent = "Lokasi dipilih";
  status.classList.remove("empty");
  status.classList.add("filled");

  document.getElementById("rePickBtn").style.display = "inline-flex";

  if (marker) {
    marker.setLatLng([selectedLat, selectedLng]);
  } else {
    marker = L.marker([selectedLat, selectedLng]).addTo(map);
  }

  const activeTab =
    document.querySelector('#modalTabs .modal-tab.active').dataset.tab;

  const fieldMap = {
    odc: 'odc-address',
    odp: 'odp-address',
    tower: 'tower-address',
    pop: 'pop-address',
    customer: 'cust-address'
  };

  const addressField =
    document.getElementById(fieldMap[activeTab]);

  if (addressField && address) {
    addressField.value = address;
  }
}

async function selectSearchLocation(lat, lng, address) {
  setLocation(lat, lng, address);
  map.setView([lat, lng], 18);
  document.getElementById('searchResults').innerHTML = '';
}

function initMapPicker() {
  if (map) return;

  map = L.map('mapPick').setView([-6.2, 106.8], 10);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  map.on('click', async function(e) {

    const { lat, lng } = e.latlng;

    try {

      const res = await fetch(
        `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`
      );

      const data = await res.json();

      setLocation(
        lat,
        lng,
        data.display_name || ''
      );

    } catch(err) {

      console.error(err);

      setLocation(lat, lng);

    }
  });
}

function openModal() {
  document.getElementById("infraModal").style.display = "flex";

  setTimeout(() => {
    initMapPicker();
    map.invalidateSize(); 
  }, 200);
}

function closeModal() {
    document.getElementById('infraModal').style.display = 'none';
}

function switchTab(type, btn) {

    currentType = type;

    document
        .querySelectorAll('.modal-tab')
        .forEach(el => el.classList.remove('active'));

    btn.classList.add('active');

    document
        .querySelectorAll('.tab-panel')
        .forEach(el => el.classList.remove('active'));

    const target = document.getElementById(`tab-${type}`);
    target.classList.add('active');

    const title = document.getElementById('modalTitle');

    title.style.opacity = 0;

    setTimeout(() => {
        title.innerText = editId
            ? `Edit ${type.toUpperCase()}`
            : `Tambah ${type.toUpperCase()}`;

        title.style.opacity = 1;
    }, 150);
}

function resetForm() {
    editId = null;
    document
        .querySelectorAll('#infraModal input')
        .forEach(el => {

            if (
                el.type !== 'hidden' &&
                el.type !== 'file'
            ) {
                el.value = '';
            }

        });

    document
        .querySelectorAll('#infraModal textarea')
        .forEach(el => el.value = '');

    document
        .querySelectorAll('#infraModal select')
        .forEach(el => {
            if(el.options.length)
                el.selectedIndex = 0;
        });

    selectedCustomer = null;
    updateCoordinatePreview();
}

function setCoordinate(lat, lng) {

    selectedLat = lat;
    selectedLng = lng;

    updateCoordinatePreview();
}

function updateCoordinatePreview() {

  const status = document.getElementById('coordStatus');
  const el = document.getElementById('coordPreview');

  if (selectedLat !== null && selectedLng !== null) {

    el.innerHTML = `${selectedLat.toFixed(6)}, ${selectedLng.toFixed(6)}`;

    status.textContent = "Lokasi dipilih";
    status.classList.remove("empty");
    status.classList.add("filled");

  } else {

    el.innerHTML = '-';

    status.textContent = "Belum dipilih";
    status.classList.remove("filled");
    status.classList.add("empty");

  }
}

function copyCoord() {
  if (selectedLat === null || selectedLng === null) return;

  const text = `${selectedLat.toFixed(6)}, ${selectedLng.toFixed(6)}`;
  navigator.clipboard.writeText(text);

  showToast('Koordinat disalin', 'success');
}

function setupImagePreview(
    inputId,
    previewId,
    hiddenId
) {

    const input = document.getElementById(inputId);

    if(!input) return;

    input.addEventListener('change', e => {

        const file = e.target.files[0];

        if(!file) return;

        const reader = new FileReader();

        reader.onload = function(ev){

            const img =
                document.getElementById(previewId);

            img.src = ev.target.result;
            img.style.display = 'block';

            document
                .getElementById(hiddenId)
                .value = ev.target.result;

        };

        reader.readAsDataURL(file);

    });

}

