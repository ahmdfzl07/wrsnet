}

function validateRequired(fields) {
  for (let f of fields) {
    const el = document.getElementById(f.id);

    if (!el || !el.value || el.value.trim() === '') {
      showToast(f.label + ' wajib diisi', 'warning');
      el?.focus();
      return false;
    }
  }
  return true;
}

async function savePoint() {

  if (selectedLat === null || selectedLng === null) {
    showToast('Klik peta untuk memilih koordinat lokasi', 'warning');
    enterPlaceMode(currentType);
    return;
  }

  let payload = {
    type: currentType,
    latitude: selectedLat,
    longitude: selectedLng
  };

  switch(currentType){

    case 'odc':

      if (!validateRequired([
        {id:'odc-name', label:'Nama ODC'},
        {id:'odc-capacity', label:'Capacity'},
        {id:'odc-used', label:'Used Port'},
        {id:'odc-address', label:'Alamat'}
      ])) return;

      payload = {
        ...payload,
        name: document.getElementById('odc-name').value,
        capacity: parseInt(document.getElementById('odc-capacity').value),
        used_ports: parseInt(document.getElementById('odc-used').value),
        address: document.getElementById('odc-address').value,
        status: document.getElementById('odc-status').value,
        notes: document.getElementById('odc-notes').value,
        metadata: {
          photo_url: document.getElementById('odc-photo-url').value
        }
      };
    break;

    case 'odp':

      if (!validateRequired([
        {id:'odp-name', label:'Nama ODP'},
        {id:'odp-capacity', label:'Capacity'},
        {id:'odp-used', label:'Used Port'},
        {id:'odp-parent', label:'Parent ODC'},
        {id:'odp-address', label:'Alamat'}
      ])) return;

      payload = {
        ...payload,
        name: document.getElementById('odp-name').value,
        capacity: parseInt(document.getElementById('odp-capacity').value),
        used_ports: parseInt(document.getElementById('odp-used').value),
        parent_id: document.getElementById('odp-parent').value,
        address: document.getElementById('odp-address').value,
        status: document.getElementById('odp-status').value,
        notes: document.getElementById('odp-notes').value,
        metadata: {
          photo_url: document.getElementById('odp-photo-url').value
        }
      };
    break;

    case 'tower':

      if (!validateRequired([
        {id:'tower-name', label:'Nama Tiang'},
        {id:'tower-address', label:'Alamat'}
      ])) return;

      payload = {
        ...payload,
        name: document.getElementById('tower-name').value,
        address: document.getElementById('tower-address').value,
        status: document.getElementById('tower-status').value,
        notes: document.getElementById('tower-notes').value
      };
    break;

    case 'pop':

      if (!validateRequired([
        {id:'pop-name', label:'Nama POP'},
        {id:'pop-capacity', label:'Capacity'},
        {id:'pop-used', label:'Used Port'},
        {id:'pop-address', label:'Alamat'}
      ])) return;

      payload = {
        ...payload,
        name: document.getElementById('pop-name').value,
        capacity: parseInt(document.getElementById('pop-capacity').value),
        used_ports: parseInt(document.getElementById('pop-used').value),
        address: document.getElementById('pop-address').value,
        status: document.getElementById('pop-status').value,
        notes: document.getElementById('pop-notes').value,
        metadata: {
          pop_type: document.getElementById('pop-pop-type').value,
          photo_url: document.getElementById('pop-photo-url').value
        }
      };
    break;

    case 'customer':

      if (!selectedCustomer) {
        showToast('Pilih customer dulu', 'warning');
        return;
      }

      if (!validateRequired([
        {id:'cust-parent', label:'Parent ODP'},
        {id:'cust-address', label:'Alamat'}
      ])) return;

      const cust = allCustomers.find(c => c.id === selectedCustomer);

      payload = {
        ...payload,
        name: cust ? cust.name : 'Customer',
        parent_id: document.getElementById('cust-parent').value,
        address: document.getElementById('cust-address').value,
        notes: document.getElementById('cust-notes').value,
        metadata: {
          customer_id: selectedCustomer
        }
      };
    break;
  }

  try {

    const url = editId
      ? `/api/infrastructure/${editId}`
      : '/api/infrastructure';

    const method = editId ? 'PUT' : 'POST';

    const res = await fetch(url,{
      method,
      headers:{
        'Content-Type':'application/json'
      },
      body: JSON.stringify(payload)
    });

    const result = await res.json();

    if (!result.success) {
      showToast(result.message || 'Gagal simpan', 'error');
      return;
    }

    showToast('Berhasil simpan!', 'success');

    closeModal();

    setTimeout(() => {
      window.location.reload();
    }, 800);

  } catch(err){
    console.error(err);
    showToast('Gagal menyimpan data', 'error');
  }
}

