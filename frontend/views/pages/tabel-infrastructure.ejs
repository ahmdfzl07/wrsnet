async function loadParentSelects() {
  try {
    const [odcRes, odpRes] = await Promise.all([
      fetch('/api/infrastructure?type=odc'),
      fetch('/api/infrastructure?type=odp')
    ]);

    const odcJson = await odcRes.json();
    const odpJson = await odpRes.json();

    const odcList = odcJson?.success ? odcJson.data : [];
    const odpList = odpJson?.success ? odpJson.data : [];

    const odpParent = document.getElementById('odp-parent');
    const custParent = document.getElementById('cust-parent');

    if (odpParent) {
      odpParent.innerHTML = '<option value="">-- Pilih ODC --</option>';
      odcList.forEach(o => {
        odpParent.innerHTML += `<option value="${o.id}">${o.name}</option>`;
      });
    }

    if (custParent) {
      custParent.innerHTML = '<option value="">-- Pilih ODP --</option>';
      odpList.forEach(o => {
        custParent.innerHTML += `<option value="${o.id}">${o.name}</option>`;
      });
    }

  } catch (err) {
    console.error('Gagal load parent:', err);
  }
}

function searchCustomer(query) {
  const dd = document.getElementById('custDropdown');

  if (!query || query.length < 2) {
    dd.classList.remove('open');
    dd.innerHTML = '';
    return;
  }

  const q = query.toLowerCase();

  const filtered = allCustomers
    .filter(c =>
      (c.name || '').toLowerCase().includes(q) ||
      (c.customer_id || '').toLowerCase().includes(q)
    )
    .slice(0, 10);

  if (filtered.length === 0) {
    dd.innerHTML = `<div class="customer-item" style="color:#94a3b8">Tidak ditemukan</div>`;
  } else {
    dd.innerHTML = filtered.map(c => `
      <div class="customer-item"
        onclick="selectCustomer(
          ${c.id},
          '${(c.name || '').replace(/'/g, "\\'")}',
          '${(c.customer_id || '').replace(/'/g, "\\'")}',
          '${(c.address || '').replace(/'/g, "\\'")}',
          '${(c.package?.name || '-').replace(/'/g, "\\'")}'
        )">
        <strong>${c.name}</strong><br>
        <small style="color:#64748b">
          ${c.customer_id} · ${c.package?.name || '-'}
        </small>
      </div>
    `).join('');
  }

  dd.classList.add('open');
}

