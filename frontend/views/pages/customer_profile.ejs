/* ── Traffic History Chart ──────────────────────────────── */
var _trafRange    = 'rt';
var _trafHistory  = [];  // ring buffer live [{rx,tx}]
var _trafTimer    = null;
var _trafCanvas   = null;
var _trafCtx      = null;

function initTrafficChart() {
  _trafCanvas = document.getElementById('trafficChart');
  if (!_trafCanvas) return;
  _trafCtx = _trafCanvas.getContext('2d');
  _trafRange = 'rt';
  _trafHistory = [];
  if (_trafTimer) clearInterval(_trafTimer);
  // Set correct pixel dimensions
  syncCanvasSize();
  drawEmptyTraf('Memulai polling…');
  // Start live polling
  startTrafPolling();
  // ResizeObserver untuk responsive
  if (window.ResizeObserver) {
    var ro = new ResizeObserver(function() {
      syncCanvasSize();
      if (_trafHistory.length > 0) {
        drawTrafChart(_trafHistory.map(function(h){ return {rx_mbps:h.rx, tx_mbps:h.tx}; }));
      }
    });
    var wrap = document.getElementById('trafWrap');
    if (wrap) ro.observe(wrap);
  }
}

function syncCanvasSize() {
  if (!_trafCanvas) return;
  var wrap = document.getElementById('trafWrap') || _trafCanvas.parentElement;
  var cssW = wrap ? wrap.clientWidth  : (_trafCanvas.offsetWidth  || 900);
  var cssH = 180;  // CSS height tetap 180px
  // Set display size via CSS
  _trafCanvas.style.width  = '100%';
  _trafCanvas.style.height = cssH + 'px';
  // Set actual pixel buffer = CSS size (1:1, tidak perlu DPR scaling di sini
  // karena font kita sudah proporsional)
  if (_trafCanvas.width !== cssW || _trafCanvas.height !== cssH) {
    _trafCanvas.width  = cssW;
    _trafCanvas.height = cssH;
  }
}

function startTrafPolling() {
  if (_trafTimer) clearInterval(_trafTimer);
  fetchTrafLive();
  _trafTimer = setInterval(function(){
    if (_trafRange === 'rt') fetchTrafLive();
  }, 2000);
}

async function fetchTrafLive() {
  try {
    var data = await App.api('/mikrotik/customer-traffic');
    if (!data || !data.success) return;
    var custId = parseInt(CUST_ID);
    var d = data.data.find(function(x){ return x.id === custId; });
    if (!d) return;
    _trafHistory.push({ rx: (d.rateDown||0)/1e6, tx: (d.rateUp||0)/1e6 });
    if (_trafHistory.length > 60) _trafHistory.shift();
    if (_trafRange === 'rt') {
      drawTrafChart(_trafHistory.map(function(h){ return {rx_mbps:h.rx, tx_mbps:h.tx}; }));
      var note = document.getElementById('trafNote');
      if (note) {
        var fR = function(v){ return v>=1 ? v.toFixed(1)+' Mbps' : (v*1000).toFixed(0)+' Kbps'; };
        note.textContent = 'Live · ↓'+fR((d.rateDown||0)/1e6)+' ↑'+fR((d.rateUp||0)/1e6);
      }
    }
  } catch(e) { /* silent */ }
}

function setTrafRange(range, btnEl) {
  _trafRange = range;
  // Update button styles
  var tabs = document.getElementById('trafTabs');
  if (tabs) tabs.querySelectorAll('.traf-tab').forEach(function(b){
    b.classList.remove('active');
  });
  if (btnEl) btnEl.classList.add('active');

  if (range === 'rt') {
    if (_trafHistory.length > 0) {
      drawTrafChart(_trafHistory.map(function(h){ return {rx_mbps:h.rx, tx_mbps:h.tx}; }));
    } else {
      drawEmptyTraf('Menunggu data live…');
    }
  } else {
    fetchTrafHistory(range);
  }
}

async function fetchTrafHistory(range) {
  var queueName = window._profileQueueName;
  var pppoeUser = window._profilePPPoEUser;
  if (!queueName && !pppoeUser) {
    drawEmptyTraf('Tidak ada queue / PPPoE username — aktifkan Simple Queue atau isi field PPPoE');
    var note = document.getElementById('trafNote');
    if (note) note.textContent = 'Tidak ada queue';
    return;
  }
  var note = document.getElementById('trafNote');
  if (note) note.textContent = 'Memuat…';
  drawEmptyTraf('Memuat data…');
  try {
    var tok = localStorage.getItem('token');
    var hdr = {'X-Requested-With':'XMLHttpRequest'};
    if (tok && tok !== 'null') hdr['Authorization'] = 'Bearer '+tok;
    // Prefer queueName (exact match); fallback ke pppoeUser (LIKE match dynamic queue)
    var qs = queueName
      ? 'queueName='+encodeURIComponent(queueName)
      : 'pppoeUser='+encodeURIComponent(pppoeUser);
    var url = '/api/mikrotik/customer-history?'+qs+'&range='+range;
    var res  = await fetch(url, {headers:hdr, credentials:'include'});
    var data = await res.json();
    if (_trafRange !== range) return; // user changed tab
    if (!data.success || !data.data || data.data.length === 0) {
      drawEmptyTraf('Belum ada data history untuk '+range);
      if (note) note.textContent = 'Tidak ada data · '+range;
      return;
    }
    drawTrafChart(data.data);
    var maxDl = Math.max.apply(null, data.data.map(function(d){ return d.rx_mbps; }));
    var maxUl = Math.max.apply(null, data.data.map(function(d){ return d.tx_mbps; }));
    var fmtM  = function(v){ return v>=1 ? v.toFixed(1)+' Mbps' : (v*1000).toFixed(0)+' Kbps'; };
    if (note) note.textContent = range+' · ↓'+fmtM(maxDl)+' ↑'+fmtM(maxUl)+' peak · '+data.data.length+' titik';
  } catch(e) {
    drawEmptyTraf('Gagal: '+esc(e.message));
    var note2 = document.getElementById('trafNote');
    if (note2) note2.textContent = 'Error';
  }
}

function drawTrafChart(data) {
  if (!_trafCanvas) return;
  syncCanvasSize();
  var cv  = _trafCanvas;
  var ctx = cv.getContext('2d');
  var dpr = window.devicePixelRatio || 1;
  var W   = cv.width, H = cv.height;

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);

  if (!data || data.length < 2) { drawEmptyTraf('Tidak ada data'); return; }

  var pad  = { t: 14, b: 8, l: 38, r: 12 };
  var cW   = W - pad.l - pad.r;
  var cH   = H - pad.t - pad.b;
  var n    = data.length;
  var step = cW / Math.max(n - 1, 1);

  var maxVal = 0;
  data.forEach(function(d){ maxVal = Math.max(maxVal, d.rx_mbps||0, d.tx_mbps||0); });
  if (maxVal < 0.001) maxVal = 0.01;
  var mag = Math.pow(10, Math.floor(Math.log10(maxVal)));
  maxVal  = Math.ceil(maxVal / mag) * mag;

  var fmtY = function(v) {
    if (v === 0) return '0';
    return v >= 1 ? v.toFixed(v < 10 ? 1 : 0)+'M' : (v*1000).toFixed(0)+'K';
  };

  // Font size proporsional terhadap canvas — TIDAK pakai px absolut
  var fs   = Math.max(9, Math.round(Math.min(W, H) * 0.055));
  var font = fs + 'px sans-serif';

  // Horizontal grid lines (4 lines)
  var gridCount = 4;
  ctx.strokeStyle  = '#e8eef6';
  ctx.lineWidth    = 1;
  ctx.fillStyle    = '#94a3b8';
  ctx.font         = font;
  ctx.textAlign    = 'right';
  ctx.textBaseline = 'middle';
  for (var i = 0; i <= gridCount; i++) {
    var gy = pad.t + (cH / gridCount) * i;
    var gv = maxVal * (1 - i / gridCount);
    ctx.beginPath();
    ctx.moveTo(pad.l, gy);
    ctx.lineTo(pad.l + cW, gy);
    ctx.stroke();
    ctx.fillText(fmtY(gv), pad.l - 4, gy);
  }

  // Left axis border
  ctx.strokeStyle = '#d1d9e6';
  ctx.lineWidth   = 1;
  ctx.beginPath();
  ctx.moveTo(pad.l, pad.t);
  ctx.lineTo(pad.l, pad.t + cH);
  ctx.stroke();

  // Draw helper
  var drawSeries = function(key, lineClr, fillClr) {
    if (n < 2) return;
    var pts = data.map(function(d, i) {
      var v = Math.max(0, d[key] || 0);
      return {
        x: pad.l + i * step,
        y: pad.t + cH - (v / maxVal) * cH
      };
    });

    // Area fill
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pad.t + cH);
    pts.forEach(function(p) { ctx.lineTo(p.x, p.y); });
    ctx.lineTo(pts[pts.length-1].x, pad.t + cH);
    ctx.closePath();
    ctx.fillStyle = fillClr;
    ctx.fill();

    // Smooth line
    ctx.beginPath();
    ctx.moveTo(pts[0].x, pts[0].y);
    for (var j = 1; j < pts.length; j++) {
      var cpx = (pts[j-1].x + pts[j].x) / 2;
      ctx.bezierCurveTo(cpx, pts[j-1].y, cpx, pts[j].y, pts[j].x, pts[j].y);
    }
    ctx.strokeStyle  = lineClr;
    ctx.lineWidth    = 2;
    ctx.lineJoin     = 'round';
    ctx.lineCap      = 'round';
    ctx.stroke();
  };

  // Upload first (behind), then download
  drawSeries('tx_mbps', '#f97316', 'rgba(249,115,22,0.13)');
  drawSeries('rx_mbps', '#2563eb', 'rgba(37,99,235,0.18)');

  // Peak label top-right corner
  var peakDl = Math.max.apply(null, data.map(function(d){ return d.rx_mbps||0; }));
  ctx.fillStyle    = '#64748b';
  ctx.font         = 'bold ' + font;
  ctx.textAlign    = 'right';
  ctx.textBaseline = 'top';
  ctx.fillText('↓' + fmtY(peakDl), W - pad.r, pad.t);
}

function drawEmptyTraf(msg) {
  if (!_trafCanvas) return;
  syncCanvasSize();
  var cv  = _trafCanvas;
  var ctx = cv.getContext('2d');
  var W   = cv.width, H = cv.height;
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f8fafc';
  ctx.fillRect(0, 0, W, H);
  ctx.fillStyle    = '#94a3b8';
  ctx.font         = '12px sans-serif';
  ctx.textAlign    = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(msg || 'Tidak ada data', W / 2, H / 2);
}

