/* ── Timeline builder ───────────────────────────────────── */
function buildTimeline(items) {
  var groups={};
  items.forEach(function(item){
    var rawDate = item.date||'';
    var dk = rawDate ? new Date(rawDate) : null;
    dk = (dk && !isNaN(dk.getTime())) ? rawDate.substring(0,10) : 'unknown';
    if(!groups[dk]) groups[dk]=[];
    groups[dk].push(item);
  });
  var todayStr=new Date().toISOString().substring(0,10);
  var yestStr=new Date(Date.now()-86400000).toISOString().substring(0,10);
  var html='';
  Object.keys(groups).forEach(function(dk){
    var dlbl=dk===todayStr?'Hari Ini':dk===yestStr?'Kemarin':fmtD(dk);
    var itemsHtml='';
    groups[dk].forEach(function(item){
      var t=item.type, d=item.data;
      var ts=item.date?new Date(item.date).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}):'';
      var bg='#f1f5f9',ic='#64748b',lbl=t,cls='';
      if(t==='invoice'){bg='#fffbeb';ic='#b45309';lbl='Invoice Dibuat';cls='bub-inv';}
      else if(t==='payment'||t==='payment_tx'){bg='#f0fdf4';ic='#16a34a';lbl='Pembayaran';cls='bub-pay';}
      var icon='';
      if(t==='invoice') icon='<svg width="15" height="15" fill="none" stroke="'+ic+'" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>';
      else icon='<svg width="15" height="15" fill="none" stroke="'+ic+'" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
      var content='';
      if(t==='invoice') content='<div class="tl-txt" style="font-weight:700">'+esc(d.invoice_no||String(d.id||''))+' — '+fmtRp(d.amount)+'</div><div class="tl-sub">Jatuh tempo: '+fmtD(d.due_date)+'</div>';
      else content='<div class="tl-txt" style="font-weight:700">'+fmtRp(d.amount)+' — Lunas</div>'+(d.invoice_no?'<div class="tl-sub">Invoice '+esc(d.invoice_no)+'</div>':'')+(d.payment_method?'<div class="tl-sub"><span class="badge bb">'+esc(d.payment_method)+'</span></div>':'');
      itemsHtml+='<div class="tl-item"><div class="tl-dot" style="background:'+bg+'">'+icon+'</div><div style="flex:1;min-width:0"><div class="tl-bub '+cls+'"><div class="tl-bt"><span class="tl-typ" style="color:'+ic+'">'+lbl+'</span><span class="tl-tm">'+ts+'</span></div>'+content+'</div></div></div>';
    });
    html+='<div class="tl-day"><div class="tl-dh"><span class="tl-dl">'+dlbl+'</span><div class="tl-ln"></div></div>'+itemsHtml+'</div>';
  });
  return html;
}

/* ── Tab switching ──────────────────────────────────────── */
function switchTab(name, btn) {
  document.querySelectorAll('.cp-tab').forEach(function(b){ b.classList.remove('active'); });
  document.querySelectorAll('.cp-panel > div').forEach(function(p){ p.style.display='none'; });
  btn.classList.add('active');
  var panel = document.getElementById('tab-'+name);
  if (panel) panel.style.display='block';
}

