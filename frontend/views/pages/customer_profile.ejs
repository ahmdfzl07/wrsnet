/* ── ONT Info (ODP, RX, Status) ─────────────────────────── */
async function fetchOntInfo(custId, ontSn) {
  // Fetch RX Power + Status dari GenieACS
  try {
    var rRes = await App.api('/infrastructure/customer/'+custId+'/rx-power');

    var valRx     = document.getElementById('val-rx');
    var valStatus = document.getElementById('val-ont-status');

    if (rRes && rRes.success && rRes.data) {
      var d   = rRes.data;
      var rx  = parseFloat(d.rx_power);
      var online = d.online;

      // Signal color
      var clr = '#16a34a', qty = 'Bagus';
      if (rx < -27)       { clr = '#dc2626'; qty = 'Kritis'; }
      else if (rx < -25)  { clr = '#d97706'; qty = 'Lemah'; }

      // 5-bar indicator
      var barsHtml = [1,2,3,4,5].map(function(i){
        var active = rx >= -27 + (i*1.5);
        return '<span class="sig-bar" style="height:'+(4+i*3)+'px;background:'+(active?clr:'#e2e8f0')+'"></span>';
      }).join('');

      // Temp badge
      var tmpBadge = d.temperature
        ? '<span style="font-size:10px;color:#64748b;background:#f1f5f9;padding:1px 5px;border-radius:4px;margin-left:4px">'+d.temperature+'°C</span>'
        : '';

      if (valRx) valRx.innerHTML = '<div style="display:flex;align-items:center;gap:6px">'
        +'<div class="sig-bars">'+barsHtml+'</div>'
        +'<span style="font-family:monospace;font-weight:700;color:'+clr+';font-size:12px">'+rx.toFixed(2)+' dBm</span>'
        +'<span class="ont-badge '+(clr==='#16a34a'?'ont-online':clr==='#d97706'?'ont-warn':'ont-warn')+'">'+qty+'</span>'
        +tmpBadge
        +'</div>';

      // Status online/offline
      if (valStatus) valStatus.innerHTML = online
        ? '<span class="ont-badge ont-online">● ONLINE</span>'
          +(d.last_inform ? '<span style="font-size:10px;color:#94a3b8;margin-left:5px">'+ago(d.last_inform)+'</span>' : '')
        : '<span class="ont-badge ont-offline">● OFFLINE</span>'
          +(d.last_inform ? '<span style="font-size:10px;color:#94a3b8;margin-left:5px">'+ago(d.last_inform)+'</span>' : '');

    } else {
      var errTxt = (rRes && rRes.error) ? esc(rRes.error) : 'Tidak tersedia';
      if (valRx)     valRx.innerHTML     = '<span style="font-size:11px;color:#94a3b8">'+errTxt+'</span>';
      if (valStatus) valStatus.innerHTML = '<span style="font-size:11px;color:#94a3b8">–</span>';
    }
  } catch(e) {
    var vr = document.getElementById('val-rx');
    var vs = document.getElementById('val-ont-status');
    if (vr) vr.innerHTML = '<span style="font-size:11px;color:#94a3b8">Error</span>';
    if (vs) vs.innerHTML = '<span style="font-size:11px;color:#94a3b8">–</span>';
  }

  // Fetch ODP info dari infrastructure map
  try {
    var mapRes = await App.api('/infrastructure/map');
    var valOdp = document.getElementById('val-odp');
    if (!valOdp) return;

    if (mapRes && mapRes.success && mapRes.data) {
      var pts = mapRes.data;
      var odpName = null, odpStatus = null;

      // Cari customer point yang memiliki parent ODP
      pts.forEach(function(pt){
        if (pt.type === 'customer' && pt.parent_id && pt.metadata) {
          try {
            var meta = typeof pt.metadata === 'string' ? JSON.parse(pt.metadata) : pt.metadata;
            if (meta.customer_id === parseInt(custId)) {
              var parent = pts.find(function(p){ return p.id === pt.parent_id; });
              if (parent && parent.type === 'odp') {
                odpName   = parent.name;
                odpStatus = parent.status;
              }
            }
          } catch(err) {}
        }
      });

      if (odpName) {
        var odpClr = odpStatus === 'active' ? '#16a34a' : '#d97706';
        valOdp.innerHTML = '<span style="font-weight:700;color:'+odpClr+'">'+esc(odpName)+'</span>';
      } else {
        valOdp.innerHTML = '<span style="font-size:11px;color:#94a3b8">Belum terhubung ke ODP</span>';
      }
    } else {
      var vo = document.getElementById('val-odp');
      if (vo) vo.innerHTML = '<span style="font-size:11px;color:#94a3b8">–</span>';
    }
  } catch(e) {
    var vo2 = document.getElementById('val-odp');
    if (vo2) vo2.innerHTML = '<span style="font-size:11px;color:#94a3b8">Error</span>';
  }
}

// ago() helper untuk last_inform
function ago(d) {
  if (!d) return '';
  var diff = Math.floor((Date.now() - new Date(d).getTime()) / 1000);
  if (diff < 60)    return diff+'d lalu';
  if (diff < 3600)  return Math.floor(diff/60)+'m lalu';
  if (diff < 86400) return Math.floor(diff/3600)+'j lalu';
  return Math.floor(diff/86400)+'h lalu';
}

