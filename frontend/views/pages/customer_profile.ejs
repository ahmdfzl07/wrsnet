function setMapLayer(type) {
  if (!_leafletMap || !_layerStreet || !_layerSat) return;
  var btnStreet = document.getElementById('mapBtnStreet');
  var btnSat    = document.getElementById('mapBtnSat');

  if (type === 'satellite') {
    _leafletMap.removeLayer(_layerStreet);
    _layerSat.addTo(_leafletMap);
    if (btnStreet) btnStreet.classList.remove('active');
    if (btnSat)    btnSat.classList.add('active');
  } else {
    _leafletMap.removeLayer(_layerSat);
    _layerStreet.addTo(_leafletMap);
    if (btnSat)    btnSat.classList.remove('active');
    if (btnStreet) btnStreet.classList.add('active');
  }
}

/* ── Usage (Simple Queue) ───────────────────────────────── */
async function loadUsage() {
  var el = document.getElementById('usageContent');
  if (!el) return;
  el.innerHTML = '<div class="u-load"><div class="u-spin"></div><span>Memuat data dari MikroTik…</span></div>';
  try {
    var data = await App.api('/mikrotik/customer-traffic');
    if (!data || !data.success || !Array.isArray(data.data)) {
      el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted);font-size:12px">Tidak dapat terhubung ke MikroTik</div>';
      return;
    }
    var cu = data.data.find(function(x){ return x.id===parseInt(CUST_ID); });
    if (!cu) {
      el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted);font-size:12px">Data usage tidak ditemukan.<br><span style="font-size:11px">Pastikan Simple Queue / PPPoE sudah dikonfigurasi.</span></div>';
      return;
    }
    renderUsage(cu);
  } catch(e) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--red);font-size:12px">Error: '+esc(e.message||'Koneksi gagal')+'</div>';
  }
}

function renderUsage(d) {
  var el = document.getElementById('usageContent');
  if (!el) return;
  var online  = d.online;
  var dlUtil  = d.utilDown||0;
  var ulUtil  = d.utilUp||0;
  var dlB = fmtBytes(d.bytesDown).split(' '), ulB = fmtBytes(d.bytesUp).split(' ');

  var html = '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:12px">'
    +'<span class="uso '+(online?'uso-on':'uso-off')+'"><span class="uso-dot"></span>'+(online?'Online':'Offline')+'</span>'
    +(d.queueName?'<span style="font-size:11px;color:var(--muted)">Queue: <strong style="color:var(--text);font-family:monospace">'+esc(d.queueName)+'</strong></span>':'')
    +(d.uptime?'<span style="font-size:11px;color:var(--muted)">Uptime: <strong style="color:var(--text)">'+esc(d.uptime)+'</strong></span>':'')
    +(d.onlineSource?'<span style="font-size:10px;background:var(--pg);color:var(--muted);padding:2px 7px;border-radius:8px;border:1px solid var(--border)">'+d.onlineSource.toUpperCase()+'</span>':'')
    +'</div>'
    +'<div class="usage-grid">'
      +'<div class="uc dl"><div class="uc-orb"></div>'
        +'<div class="uc-lbl"><svg width="11" height="11" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>Total Download</div>'
        +'<div class="uc-val">'+dlB[0]+'<span class="uc-unit">'+(dlB[1]||'')+'</span></div>'
        +'<div class="uc-rate">↓ '+fmtRate(d.rateDown)+' real-time</div>'
      +'</div>'
      +'<div class="uc ul"><div class="uc-orb"></div>'
        +'<div class="uc-lbl"><svg width="11" height="11" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>Total Upload</div>'
        +'<div class="uc-val">'+ulB[0]+'<span class="uc-unit">'+(ulB[1]||'')+'</span></div>'
        +'<div class="uc-rate">↑ '+fmtRate(d.rateUp)+' real-time</div>'
      +'</div>'
    +'</div>';

  if (d.maxDown>0||d.maxUp>0) {
    html += '<div class="usage-ratio">'
      +'<div style="font-size:10.5px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em">Rasio Download vs Upload</div>'
      +'<div class="ubar-row">'
        +'<span style="font-size:10px;color:#1a6ef5;font-weight:700;white-space:nowrap">↓ '+dlUtil+'%</span>'
        +'<div class="ubar-bg"><div class="ubar-dl" style="width:'+dlUtil+'%"></div></div>'
        +'<div class="ubar-bg"><div class="ubar-ul" style="width:'+ulUtil+'%"></div></div>'
        +'<span style="font-size:10px;color:#00a07a;font-weight:700;white-space:nowrap">↑ '+ulUtil+'%</span>'
      +'</div>'
      +'<div style="display:flex;justify-content:space-between;margin-top:6px;font-size:11px;color:var(--muted)">'
        +'<span>Max DL: '+fmtRate(d.maxDown)+'</span><span>Max UL: '+fmtRate(d.maxUp)+'</span>'
      +'</div>'
    +'</div>';
  }
  if (d.ip) html += '<div style="font-size:11px;color:var(--muted);font-family:monospace;margin-top:6px">IP: <strong style="color:var(--text)">'+esc(d.ip)+'</strong></div>';
  el.innerHTML = html;

  // Store queue info for chart
  window._profileQueueName = d.queueName || null;
  // Untuk pelanggan PPPoE yang sedang offline, dynamic queue tidak ada di MikroTik
  // sehingga d.queueName = null. Pakai pppoe username sebagai fallback agar history
  // chart bisa load via /api/mikrotik/customer-history?pppoeUser=...
  window._profilePPPoEUser = d.pppoe || null;
  window._profileCustId    = parseInt(CUST_ID);
}

/* ── Quick actions ──────────────────────────────────────── */
function openWA(phone) {
  if (!phone) return;
  var n = phone.replace(/[^0-9]/g,'');
  if (n.startsWith('0')) n = '62'+n.slice(1);
  window.open('https://wa.me/'+n,'_blank');
}

/* ── Edit Customer Modal ──────────────────────────────────── */
var _editCustId = null;

function openEditModal(cust) {
  _editCustId = cust.id;
  var modal = document.getElementById('editProfileModal');
  if (!modal) return;

  // Fill fields
  var set = function(id, val) { var el=document.getElementById(id); if(el) el.value=val||''; };
  set('ep-name',         cust.name);
  set('ep-phone',        cust.phone);
  set('ep-email',        cust.email);
  set('ep-address',      cust.address);
  set('ep-billing-date', cust.billing_date||1);
  set('ep-install-date', (cust.installation_date||'').substring(0,10));
  set('ep-status',       cust.status||'active');
  set('ep-pppoe',        cust.pppoe_username);
  set('ep-ont-sn',       cust.ont_sn);
  set('ep-static-ip',    cust.static_ip);
  document.getElementById('ep-msg').textContent = '';

  // Load packages
  App.api('/packages').then(function(r){
    var sel = document.getElementById('ep-package');
    if (!sel) return;
    sel.innerHTML = '<option value="">— Pilih Paket —</option>';
    if (r && r.data) {
      (Array.isArray(r.data)?r.data:(r.data.rows||[])).forEach(function(p){
        var opt = document.createElement('option');
        opt.value = p.id; opt.textContent = p.name + ' ('+fmtRp(p.price)+')';
        sel.appendChild(opt);
      });
    }
    sel.value = cust.package_id || '';
  }).catch(function(){});

  // Load mikrotik devices — endpoint: /isolir/devices (sama dengan customers.js)
  App.api('/isolir/devices').then(function(r){
    var sel = document.getElementById('ep-mikrotik');
    if (!sel) return;
    sel.innerHTML = '<option value="">— Pilih Router —</option>';
    if (r && r.data && Array.isArray(r.data)) {
      r.data.forEach(function(m){
        var opt = document.createElement('option');
        opt.value = m.id;
        opt.textContent = (m.name||'Router') + (m.host ? ' ('+m.host+')' : '');
        sel.appendChild(opt);
      });
    }
    sel.value = cust.mikrotik_id || '';
  }).catch(function(){
    var sel = document.getElementById('ep-mikrotik');
    if (sel) sel.innerHTML = '<option value="">— Tidak ada router —</option>';
  });

  // Load portal credentials (customer_id login + status password + last login)
  loadPortalCredentials(cust.id);

  modal.classList.add('open');
}

// ── Portal Credentials (admin-side) ──────────────────────────────────
function loadPortalCredentials(custId) {
  // Default state: locked, empty pw field
  var cidInput = document.getElementById('ep-cid');
  var cidBtn   = document.getElementById('ep-cid-toggle');
  var pwInput  = document.getElementById('ep-pw');
  var hint     = document.getElementById('ep-pw-hint');
  var last     = document.getElementById('ep-portal-last');
  var enabled  = document.getElementById('ep-portal-enabled');
  var cidWarn  = document.getElementById('ep-cid-warn');

  if (cidInput) { cidInput.value=''; cidInput.readOnly = true; cidInput.style.background='#eef2f7'; cidInput.style.cursor='not-allowed'; }
  if (cidBtn)   { cidBtn.textContent = 'Ubah'; }
  if (cidWarn)  { cidWarn.style.display = 'none'; }
  if (pwInput)  { pwInput.value=''; pwInput.type='password'; }
  if (hint)     { hint.textContent='Memuat…'; hint.style.color='#94a3b8'; }
  if (last)     { last.textContent=''; }
  if (enabled)  { enabled.checked = true; }

  App.api('/customers/'+custId+'/portal-credentials').then(function(r){
    if (!r || !r.success || !r.data) {
      if (hint) { hint.textContent = 'Tidak dapat memuat data kredensial portal'; hint.style.color='#dc2626'; }
      return;
    }
    var d = r.data;
    if (cidInput) cidInput.value = d.customer_id || '';
    if (enabled)  enabled.checked = !!d.portal_enabled;
    if (hint) {
      if (d.has_custom_password) {
        hint.innerHTML = '✓ Password sudah diset. Kosongkan untuk tidak mengubah.';
        hint.style.color = '#16a34a';
      } else if (d.fallback_login_hint) {
        hint.innerHTML = 'Belum ada password custom — pelanggan login pakai nomor HP: <span style="font-family:DM Mono,monospace;color:#0d1b3e;font-weight:600;">'+d.fallback_login_hint+'</span>';
        hint.style.color = '#b45309';
      } else {
        hint.innerHTML = '⚠ Belum ada password & belum ada nomor HP — pelanggan tidak bisa login.';
        hint.style.color = '#dc2626';
      }
    }
    if (last) {
      if (d.last_portal_login) {
        var dt = new Date(d.last_portal_login);
        last.textContent = 'Login terakhir: ' + dt.toLocaleString('id-ID', { dateStyle:'medium', timeStyle:'short' });
      } else {
        last.textContent = 'Pelanggan belum pernah login ke portal.';
      }
    }
  }).catch(function(e){
    if (hint) { hint.textContent = 'Gagal memuat: ' + (e.message||'error'); hint.style.color='#dc2626'; }
  });
}

function togglePortalCidEdit() {
  var cidInput = document.getElementById('ep-cid');
  var btn      = document.getElementById('ep-cid-toggle');
  var warn     = document.getElementById('ep-cid-warn');
  if (!cidInput || !btn) return;
  var nowLocked = cidInput.readOnly;
  if (nowLocked) {
    // Unlock
    cidInput.readOnly = false;
    cidInput.style.background = '#fff';
    cidInput.style.cursor = 'text';
    cidInput.focus();
    cidInput.select();
    btn.textContent = 'Batal';
    btn.style.color = '#dc2626';
    btn.style.borderColor = '#fecaca';
    if (warn) warn.style.display = 'block';
  } else {
    // Lock (cancel edit) — reload original value
    var custId = _editCustId;
    if (custId) loadPortalCredentials(custId);
    btn.style.color = '#1a6ef5';
    btn.style.borderColor = '#e4ecf7';
  }
}

function togglePortalPwVisibility() {
  var pw = document.getElementById('ep-pw');
  if (!pw) return;
  pw.type = (pw.type === 'password') ? 'text' : 'password';
}

function generatePortalPassword() {
  // 8 karakter mudah dibaca — tanpa O/0/I/l yang ambigu
  var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789abcdefghjkmnpqrstuvwxyz';
  var out = '';
  var arr = new Uint32Array(8);
  if (window.crypto && window.crypto.getRandomValues) {
    window.crypto.getRandomValues(arr);
    for (var i=0;i<8;i++) out += chars[arr[i] % chars.length];
  } else {
    for (var j=0;j<8;j++) out += chars[Math.floor(Math.random()*chars.length)];
  }
  var pw = document.getElementById('ep-pw');
  if (pw) { pw.value = out; pw.type = 'text'; }
}

async function resetPortalPasswordToPhone() {
  if (!_editCustId) return;
  if (!confirm('Reset password pelanggan? Setelah reset, pelanggan akan login menggunakan nomor HP-nya sendiri.')) return;
  try {
    var r = await App.api('/customers/'+_editCustId+'/portal-credentials/reset', { method: 'POST' });
    if (r && r.success) {
      App.showToast(r.message || 'Password direset', 'success');
      loadPortalCredentials(_editCustId);
      var pw = document.getElementById('ep-pw');
      if (pw) pw.value = '';
    } else {
      App.showToast(r && r.message ? r.message : 'Gagal reset password', 'error');
    }
  } catch(err) {
    App.showToast('Error: ' + (err.message||err), 'error');
  }
}

async function savePortalCredentials() {
  // Dipanggil dari saveEditProfile() sesudah profil tersimpan.
  // Hanya kirim field yang benar-benar diubah supaya tidak overwrite data lain.
  if (!_editCustId) return { ok:true };

  var cidInput = document.getElementById('ep-cid');
  var pwInput  = document.getElementById('ep-pw');
  var enabled  = document.getElementById('ep-portal-enabled');
  var payload  = {};

  // Customer ID — hanya kirim kalau input ter-unlock (user benar-benar mengubahnya)
  if (cidInput && !cidInput.readOnly) {
    var cid = (cidInput.value||'').trim();
    if (cid) payload.customer_id = cid;
  }
  // Password — kirim kalau ada isi
  if (pwInput && pwInput.value) {
    if (pwInput.value.length < 6) {
      return { ok:false, message:'Password portal minimal 6 karakter' };
    }
    payload.new_password = pwInput.value;
  }
  // portal_enabled — selalu sync (cheap; satu boolean)
  if (enabled) payload.portal_enabled = !!enabled.checked;

  // Kalau tidak ada perubahan kredensial yang signifikan (cuma toggle yang sama),
  // skip — backend akan return 400 "Tidak ada perubahan".
  // Kita tetap kirim kalau ada toggle/cid/pw, biar simpel.
  if (!('customer_id' in payload) && !('new_password' in payload)) {
    // Kalau cuma toggle enabled, tetap kirim — backend akan handle.
    // Kecuali kalau enabled = state sebelumnya, tapi kita tidak track itu — biarkan saja.
  }

  try {
    var r = await App.api('/customers/'+_editCustId+'/portal-credentials', {
      method: 'POST',
      body: JSON.stringify(payload)
    });
    if (r && r.success) {
      // Kalau password baru di-generate / di-set, tampilkan ke admin sekali.
      if (r.data && r.data.new_password) {
        showPortalPasswordResult(r.data.customer_id || (cidInput && cidInput.value), r.data.new_password);
      }
      return { ok:true };
    } else {
      return { ok:false, message: (r && r.message) ? r.message : 'Gagal update kredensial portal' };
    }
  } catch(err) {
    return { ok:false, message: err.message || String(err) };
  }
}

