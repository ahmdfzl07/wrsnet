<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Profil Pelanggan' %> - <%= appName %></title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    :root{
      --pg:#f0f4fb;--white:#fff;--border:#e4ecf7;
      --text:#0d1b3e;--text2:#4a5a7a;--muted:#8898b8;
      --blue:#1a6ef5;--blue2:#0047cc;--green:#00c896;--red:#f5365c;
      --orange:#fb8c00;--cyan:#0891b2;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{background:var(--pg)!important;font-family:'DM Sans',sans-serif;}
    .main-content{background:var(--pg)!important;padding:0!important;}
    .cp-page{padding:0;}

    /* Page header — mengikuti style customers.ejs */
    .cp-ph{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:20px;}
    .cp-ph-left{}
    .cp-ph-bc{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);margin-bottom:6px;}
    .cp-ph-bc a{color:var(--blue);text-decoration:none;font-weight:600;}
    .cp-ph-bc a:hover{opacity:.75;}
    .cp-ph-bc svg{flex-shrink:0;}
    .cp-ph-left h1{font-size:22px;font-weight:800;color:#0f172a;margin:0 0 3px;letter-spacing:-.3px;font-family:'Plus Jakarta Sans','DM Sans',sans-serif;}
    .cp-ph-left .cp-ph-sub{font-size:13px;color:#64748b;margin:0;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
    .cp-ph-right{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
    .btn-ph{display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;border:1.5px solid;transition:all .15s;white-space:nowrap;text-decoration:none;font-family:'DM Sans',sans-serif;}
    .btn-ph-outline{background:#fff;border-color:#e2e8f0;color:#374151;}
    .btn-ph-outline:hover{background:#f8fafc;border-color:#cbd5e1;}
    .btn-ph-primary{background:#2563eb;border-color:#2563eb;color:#fff;}
    .btn-ph-primary:hover{background:#1d4ed8;border-color:#1d4ed8;}
    .btn-ph-green{background:#16a34a;border-color:#16a34a;color:#fff;}
    .btn-ph-green:hover{background:#15803d;}
    /* Banner action buttons — responsive */
    .cp-banner-btns{position:absolute;bottom:12px;right:16px;display:flex;gap:7px;z-index:10;}
    .cp-banner-btns .btn-ph{padding:7px 14px;font-size:12.5px;border-radius:9px;}
    @media(max-width:640px){
      .cp-banner-btns{bottom:8px;right:10px;gap:5px;}
      .cp-banner-btns .btn-ph{padding:6px 10px;font-size:11px;border-radius:8px;gap:4px;}
      .cp-banner-btns .btn-ph svg{width:12px;height:12px;}
      .cp-banner-btns .btn-ph span{display:none;}
    }
    /* Breadcrumb lama disembunyikan */
    .cp-bc{display:none;}

    /* Hero */
    .cp-hero{border-radius:20px;overflow:hidden;margin-bottom:16px;background:var(--white);border:1px solid var(--border);box-shadow:0 2px 16px rgba(13,27,62,.07);}
    .cp-banner{height:110px;position:relative;overflow:hidden;}
    .cp-banner::before{content:'';position:absolute;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.1);right:-40px;top:-80px;}
    .cp-banner::after{content:'';position:absolute;width:110px;height:110px;border-radius:50%;background:rgba(255,255,255,.07);left:60px;bottom:-55px;}
    .cp-body{padding:0 24px 20px;}
    /* Banner action bar — posisi absolute di atas banner kanan */
    .cp-banner-actions{position:absolute;bottom:10px;right:16px;display:flex;gap:6px;z-index:10;}
    /* Top row: hanya avatar, margin negatif untuk overlap banner */
    .cp-top{margin-top:-36px;margin-bottom:10px;}
    .cp-av{width:72px;height:72px;border-radius:50%;border:4px solid #fff;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:#fff;box-shadow:0 4px 18px rgba(0,0,0,.18);flex-shrink:0;position:relative;z-index:5;}
    .cp-actions{display:flex;gap:7px;flex-wrap:wrap;align-items:center;margin-top:12px;}
    .cp-name{font-size:18px;font-weight:800;color:var(--text);letter-spacing:-.3px;}
    .cp-sub{font-size:12px;color:var(--muted);margin-top:2px;}
    .cp-infogrid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid var(--border);margin-top:14px;padding-top:16px;}
    .cp-fi{padding:0 20px 14px 0;}
    .cp-fl{font-size:10.5px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:4px;}
    .cp-fv{font-size:13.5px;font-weight:600;color:var(--text);}
    .cp-fv.mono{font-family:'DM Mono',monospace;font-size:13px;}

    /* Badges */
    .badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;gap:4px;}
    .bg{background:#e6fff7;color:#007a5e;} .br{background:#fff0f2;color:var(--red);}
    .by{background:#fffbeb;color:#b45309;} .bb{background:#eef3ff;color:var(--blue);}
    .bgy{background:#f1f5f9;color:#64748b;}

    /* Buttons */
    .btn{display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:11px;font-size:13px;font-weight:700;text-decoration:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;white-space:nowrap;}
    .btn-pri{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;box-shadow:0 3px 10px rgba(26,110,245,.3);}
    .btn-pri:hover{transform:translateY(-1px);}
    .btn-ghost{background:var(--white);color:var(--text2);border:1.5px solid var(--border);}
    .btn-ghost:hover{border-color:var(--blue);color:var(--blue);background:#f0f5ff;}
    .btn-wa{background:#e6fff7;color:#00875a;border:1.5px solid #a7f3d0;}
    .btn-sm{padding:6px 12px;font-size:12px;border-radius:9px;}

    /* Map below hero */
    .cp-maphero{border-radius:16px;overflow:hidden;border:1px solid var(--border);background:var(--white);margin-bottom:16px;box-shadow:0 2px 12px rgba(13,27,62,.05);}
    .cp-maphd{display:flex;align-items:center;justify-content:space-between;padding:11px 16px;background:var(--white);border-bottom:1px solid var(--border);}
    .cp-maphd-l{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:700;color:var(--text);}
    .cp-mapbody{height:340px;position:relative;}
    .cp-mapbody .leaflet-container{height:100%;width:100%;}
    .cp-nocoord{display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:8px;color:var(--muted);font-size:12px;}
    /* Map layer toggle */
    .map-layer-toggle{position:absolute;top:10px;right:10px;z-index:1000;display:flex;gap:4px;}
    .mlt-btn{padding:4px 9px;font-size:10px;font-weight:700;border-radius:6px;cursor:pointer;border:none;font-family:sans-serif;transition:all .12s;box-shadow:0 1px 4px rgba(0,0,0,.2);}
    .mlt-btn.active{background:#1d4ed8;color:#fff;}
    .mlt-btn:not(.active){background:rgba(255,255,255,.9);color:#374151;}
    /* Anti-grid tile fix — eliminasi border/gap antar tile */
    .leaflet-tile{
      border:0!important;outline:0!important;margin:0!important;padding:0!important;
      box-shadow:none!important;border-radius:0!important;
      image-rendering:auto;
    }
    .leaflet-tile-container img{display:block;border:0!important;outline:0!important;}
    .leaflet-tile-pane{opacity:1!important;}
    .leaflet-zoom-animated .leaflet-tile-container{will-change:transform;}
    .leaflet-container .leaflet-tile-pane .leaflet-layer{opacity:1!important;}
    /* Customer map popup */
    .cmp-wrap .leaflet-popup-content-wrapper{padding:0;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(13,27,62,.18);border:none;min-width:220px;}
    .cmp-wrap .leaflet-popup-content{margin:0;width:auto!important;}
    .cmp-wrap .leaflet-popup-tip-container{display:none;}
    .cmp-wrap .leaflet-popup-close-button{right:10px;top:10px;color:#fff;font-size:16px;font-weight:700;z-index:10;opacity:.8;}
    .cmp-wrap .leaflet-popup-close-button:hover{opacity:1;}
    .cmp-hd{background:linear-gradient(135deg,#1a6ef5,#0047cc);padding:14px 16px 12px;color:#fff;position:relative;}
    .cmp-hd-av{width:36px;height:36px;border-radius:50%;border:2.5px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;background:rgba(255,255,255,.18);flex-shrink:0;}
    .cmp-hd-row{display:flex;align-items:center;gap:10px;}
    .cmp-hd-name{font-size:14px;font-weight:800;letter-spacing:-.2px;line-height:1.2;}
    .cmp-hd-cid{font-size:11px;opacity:.75;margin-top:1px;}
    .cmp-hd-orb{position:absolute;width:70px;height:70px;border-radius:50%;background:rgba(255,255,255,.07);right:-15px;top:-20px;}
    .cmp-body{padding:12px 14px;background:#fff;}
    .cmp-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid #f1f5f9;gap:8px;}
    .cmp-row:last-child{border-bottom:none;padding-bottom:0;}
    .cmp-lbl{font-size:11px;color:#94a3b8;font-weight:500;}
    .cmp-val{font-size:12px;color:#0d1b3e;font-weight:600;text-align:right;}
    .cmp-foot{display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid #f1f5f9;}
    .cmp-btn{padding:10px 8px;font-size:12px;font-weight:700;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;font-family:'DM Sans',sans-serif;transition:opacity .15s;text-decoration:none;color:#fff!important;}
    .cmp-btn:hover{opacity:.85;}
    .cmp-btn-nav{background:#1a6ef5;color:#fff!important;border-radius:0 0 0 16px;}
    .cmp-btn-wa{background:#16a34a;color:#fff!important;border-radius:0 0 16px 0;}

    /* Usage */
    .cp-card{background:var(--white);border-radius:16px;border:1px solid var(--border);padding:16px;box-shadow:0 2px 12px rgba(13,27,62,.05);}
    .cp-card-title{font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:6px;}
    .usage-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
    .uc{border-radius:14px;padding:15px 16px;position:relative;overflow:hidden;color:#fff;min-height:85px;}
    .uc.dl{background:linear-gradient(135deg,#1a6ef5,#0047cc);}
    .uc.ul{background:linear-gradient(135deg,#00c896,#00a07a);}
    .uc-orb{position:absolute;width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,.08);right:-16px;top:-16px;pointer-events:none;}
    .uc-lbl{font-size:9px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;opacity:.8;margin-bottom:5px;display:flex;align-items:center;gap:4px;}
    .uc-val{font-size:24px;font-weight:800;font-family:'DM Mono',monospace;line-height:1;}
    .uc-unit{font-size:12px;font-weight:600;opacity:.8;margin-left:2px;}
    .uc-rate{font-size:11px;opacity:.7;margin-top:3px;}
    .usage-ratio{background:var(--pg);border-radius:10px;padding:11px 13px;margin-bottom:10px;}
    .ubar-row{display:flex;align-items:center;gap:8px;margin-top:7px;}
    .ubar-bg{flex:1;height:7px;background:#dce7f5;border-radius:99px;overflow:hidden;}
    .ubar-dl{height:100%;background:linear-gradient(90deg,#1a6ef5,#0047cc);border-radius:99px;transition:width .8s;}
    .ubar-ul{height:100%;background:linear-gradient(90deg,#00c896,#00a07a);border-radius:99px;transition:width .8s;}
    .uso{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
    .uso-on{background:#f0fdf4;color:#16a34a;} .uso-off{background:#f1f5f9;color:#64748b;}
    .uso-dot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0;}
    .u-load{display:flex;align-items:center;justify-content:center;gap:10px;padding:24px;color:var(--muted);font-size:12px;}
    .u-spin{width:20px;height:20px;border:2.5px solid rgba(26,110,245,.15);border-top-color:#1a6ef5;border-radius:50%;animation:spin .7s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* Grid */
    .cp-grid{display:grid;grid-template-columns:300px 1fr;gap:16px;align-items:start;}
    .cp-sidebar{display:flex;flex-direction:column;gap:14px;}
    .stat-mg{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
    .stat-m{background:var(--pg);border-radius:12px;padding:12px;text-align:center;border:1px solid var(--border);}
    .stat-mn{font-size:24px;font-weight:800;font-family:'DM Mono',monospace;line-height:1.1;}
    .stat-ml{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-top:2px;}
    .info-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid #f4f7fd;gap:12px;}
    .info-row:last-child{border-bottom:none;padding-bottom:0;}
    .ilbl{font-size:12px;color:var(--muted);font-weight:500;}
    .ival{font-size:12.5px;font-weight:700;color:var(--text);text-align:right;}

    /* Tabs */
    .cp-tabs{display:flex;gap:2px;background:var(--white);border-radius:16px 16px 0 0;border:1px solid var(--border);border-bottom:none;padding:10px 12px 0;overflow-x:auto;scrollbar-width:none;}
    .cp-tabs::-webkit-scrollbar{display:none;}
    .cp-tab{padding:8px 14px;border-radius:10px 10px 0 0;font-size:12.5px;font-weight:700;cursor:pointer;border:none;background:none;color:var(--muted);transition:all .15s;display:flex;align-items:center;gap:6px;font-family:'DM Sans',sans-serif;white-space:nowrap;position:relative;}
    .cp-tab::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;border-radius:2px 2px 0 0;background:transparent;transition:background .15s;}
    .cp-tab.active{color:var(--blue);}
    .cp-tab.active::after{background:var(--blue);}
    .cp-tab:hover:not(.active){color:var(--text2);background:var(--pg);}
    .tab-badge{background:var(--blue);color:#fff;font-size:9.5px;font-weight:800;padding:1px 6px;border-radius:10px;line-height:1.6;}
    .cp-tab:not(.active) .tab-badge{background:#d4dce8;color:var(--text2);}
    .cp-panel{background:var(--white);border:1px solid var(--border);border-top:none;border-radius:0 0 16px 16px;}
    .pscroll{overflow-y:auto;max-height:calc(100vh - 300px);scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
    .pscroll::-webkit-scrollbar{width:4px;}
    .pscroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

    /* Timeline */
    .tl-list{padding:18px 20px;}
    .tl-day{margin-bottom:20px;}
    .tl-dh{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
    .tl-dl{font-size:10.5px;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;white-space:nowrap;}
    .tl-ln{flex:1;height:1px;background:var(--border);}
    .tl-item{display:flex;gap:11px;margin-bottom:10px;}
    .tl-dot{width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
    .tl-bub{border-radius:12px;padding:10px 13px;border:1.5px solid;flex:1;min-width:0;}
    .bub-inv{background:#fffbeb;border-color:#fde68a;}
    .bub-pay{background:#f0fdf4;border-color:#86efac;}
    .tl-bt{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:4px;}
    .tl-typ{font-size:9.5px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;}
    .tl-tm{font-size:10.5px;color:var(--muted);font-family:'DM Mono',monospace;white-space:nowrap;}
    .tl-txt{font-size:13px;color:var(--text);line-height:1.5;}
    .tl-sub{font-size:11px;color:var(--muted);margin-top:4px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}

    /* Table */
    .dtbl{width:100%;border-collapse:collapse;}
    .dtbl th{font-size:10.5px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;padding:10px 16px;border-bottom:2px solid var(--border);text-align:left;background:#fafcff;white-space:nowrap;}
    .dtbl td{font-size:12.5px;color:var(--text);padding:10px 16px;border-bottom:1px solid #f4f7fd;vertical-align:middle;}
    .dtbl tr:last-child td{border-bottom:none;}
    .dtbl tr:hover td{background:#fafcff;}

    /* Empty */
    .empty-st{padding:52px 24px;text-align:center;color:var(--muted);}
    .empty-st .ei{font-size:36px;margin-bottom:10px;opacity:.6;}
    .empty-st p{font-size:13px;}

    /* Quick reply */
    .qr-bar{padding:12px 18px;border-top:1px solid var(--border);background:#fff;position:sticky;bottom:0;border-radius:0 0 16px 16px;}
    .qr-row{display:flex;gap:8px;align-items:center;}
    .qr-ta{flex:1;border:1.5px solid var(--border);border-radius:999px;padding:9px 16px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;resize:none;line-height:1.4;transition:all .15s;background:#f8fafd;color:var(--text);}
    .qr-ta:focus{border-color:var(--blue);background:#fff;}
    .qr-ta::placeholder{color:var(--muted);}
    .qr-send{width:38px;height:38px;border-radius:12px;background:linear-gradient(135deg,var(--blue),var(--blue2));border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .14s;}
    .qr-send:hover{transform:scale(1.07);}
    .qr-status{font-size:11.5px;margin-top:6px;padding:4px 10px;border-radius:8px;display:none;}
    .qr-ok{background:#e6fff7;color:#007a5e;} .qr-err{background:#fff0f2;color:var(--red);}

    /* Loading */
    .cp-load{display:flex;align-items:center;justify-content:center;padding:60px;color:var(--muted);}
    .cp-spin{width:36px;height:36px;border:3px solid rgba(26,110,245,.15);border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite;margin-right:12px;}

    /* Responsive */
    @media(max-width:960px){.cp-grid{grid-template-columns:1fr;}.cp-sidebar{display:grid;grid-template-columns:1fr 1fr;gap:14px;}.stat-mg{grid-template-columns:repeat(4,1fr);}}
    @media(max-width:640px){.cp-page{padding:0 10px 20px;}.cp-hero{border-radius:14px;}.cp-banner{height:88px;}.cp-av{width:56px;height:56px;font-size:20px;}.cp-top{margin-top:-28px;}.cp-name{font-size:16px;}.cp-banner-actions{bottom:8px;right:12px;gap:5px;}.cp-banner-actions .btn-sm{padding:5px 10px;font-size:11px;}.cp-infogrid{grid-template-columns:repeat(2,1fr);}.cp-sidebar{grid-template-columns:1fr;}.stat-mg{grid-template-columns:repeat(4,1fr);gap:5px;}.cp-tab{padding:7px 9px;font-size:11px;}.cp-tab svg{display:none;}.usage-grid{grid-template-columns:1fr;}}
    @media(max-width:380px){.stat-mg{grid-template-columns:repeat(2,1fr);}}
    /* ONT signal bars */
    .sig-bars{display:flex;align-items:flex-end;gap:2px;}
    .sig-bar{width:3px;border-radius:1px;background:#e2e8f0;}
    .ont-badge{font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;}
    .ont-online{background:#e6fff7;color:#16a34a;}
    .ont-offline{background:#fff0f2;color:#dc2626;}
    .ont-warn{background:#fffbeb;color:#d97706;}

    /* Traffic History */
    .traf-card{background:var(--white);border-radius:16px;border:1px solid var(--border);padding:16px;box-shadow:0 2px 12px rgba(13,27,62,.05);margin-bottom:16px;}
    .traf-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;}
    .traf-hd-l{display:flex;align-items:center;gap:7px;font-size:12px;font-weight:700;color:var(--text);}
    .traf-tabs{display:flex;gap:4px;}
    .traf-tab{padding:3px 9px;font-size:10px;font-weight:700;border-radius:5px;cursor:pointer;border:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-family:'DM Sans',sans-serif;transition:all .12s;}
    .traf-tab.active{background:#1d4ed8;color:#fff;border-color:#1d4ed8;}
    .traf-canvas-wrap{position:relative;border-radius:10px;overflow:hidden;background:#f8fafc;border:1px solid #e2e8f0;}
    #trafficChart{display:block;width:100%;height:180px;}
    .traf-note{display:flex;align-items:center;justify-content:space-between;margin-top:6px;flex-wrap:wrap;gap:4px;}
    .traf-note-txt{font-size:10.5px;color:var(--muted);}
    .traf-legend{display:flex;gap:10px;}
    .traf-leg{display:flex;align-items:center;gap:4px;font-size:10px;font-weight:600;}
    .traf-leg-dl{width:10px;height:3px;background:#2563eb;border-radius:2px;}
    .traf-leg-ul{width:10px;height:3px;background:#f97316;border-radius:2px;}
  </style>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <main class="page-content">
      <div class="cp-page" id="cpPage">
        <div class="cp-load" id="cpLoading">
          <div class="cp-spin"></div>
          <span>Memuat profil pelanggan…</span>
        </div>
        <div id="cpContent" style="display:none"></div>
      </div>
    </main>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/app.js"></script>
<script>
const CUST_ID = '<%= typeof custId !== "undefined" ? custId : "" %>';

/* ── Helpers ─────────────────────────────────────────────── */
const MN = ['','Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agt','Sep','Okt','Nov','Des'];
function fmtD(d) {
  if (!d) return '—';
  var dt = new Date(d);
  if (isNaN(dt.getTime())) return '—';
  return dt.getDate()+' '+MN[dt.getMonth()+1]+' '+dt.getFullYear();
}
function fmtRp(v) { return 'Rp '+Number(v||0).toLocaleString('id-ID'); }
function esc(s)   { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function fmtBytes(b){ b=parseInt(b)||0; if(b>=1073741824) return (b/1073741824).toFixed(2)+' GB'; if(b>=1048576) return (b/1048576).toFixed(1)+' MB'; if(b>=1024) return Math.round(b/1024)+' KB'; return b+' B'; }
function fmtRate(r) { r=parseInt(r)||0; if(r>=1000000) return (r/1000000).toFixed(1)+' Mbps'; if(r>=1000) return Math.round(r/1000)+' Kbps'; return r+' bps'; }

const GRAD=[['#1a6ef5','#0047cc'],['#f5365c','#c0183a'],['#00c896','#00a07a'],['#fb8c00','#e65100'],
            ['#0ea5e9','#0284c7'],['#06b6d4','#0891b2'],['#f59e0b','#d97706'],['#10b981','#059669']];
function getGrad(s){ var h=0; for(var i=0;i<s.length;i++) h=((h<<5)-h)+s.charCodeAt(i); return GRAD[Math.abs(h)%GRAD.length]; }
function getInit(s){ return (String(s||'?').trim()[0]||'?').toUpperCase(); }

/* ── Build HTML helpers (no template literals) ───────────── */
function mkEl(tag, attrs, inner) {
  var a=''; for(var k in attrs) a+=' '+k+'="'+attrs[k]+'"';
  return '<'+tag+a+'>'+inner+'</'+tag+'>';
}
function mkDiv(cls, inner) { return '<div class="'+cls+'">'+inner+'</div>'; }
function mkSpan(cls, inner){ return '<span class="'+cls+'">'+inner+'</span>'; }

/* ── Load Profile ────────────────────────────────────────── */
async function loadProfile() {
  if (!CUST_ID) {
    document.getElementById('cpLoading').innerHTML = '<p style="color:var(--red)">Customer ID tidak valid.</p>';
    return;
  }
  try {
    var r = await Promise.all([
      App.api('/customers/'+CUST_ID),
      App.api('/billing/invoices?customer_id='+CUST_ID+'&limit=50')
    ]);
    var custR=r[0], invR=r[1];
    if (!custR || !custR.success) {
      document.getElementById('cpLoading').innerHTML = '<p style="color:var(--red)">Customer tidak ditemukan. <a href="/customers" style="color:var(--blue)">← Kembali</a></p>';
      return;
    }

    var c        = custR.data;
    // Ambil invoices dari billing endpoint, fallback ke c.invoices dari CustomerController
    var invoices = (invR && invR.data && Array.isArray(invR.data)) ? invR.data
                 : (invR && invR.data && invR.data.rows && Array.isArray(invR.data.rows)) ? invR.data.rows
                 : (Array.isArray(c.invoices) ? c.invoices : []);

    // Derive payments dari invoices yang sudah paid (tidak perlu endpoint terpisah)
    // Setiap invoice paid = 1 transaksi pembayaran
    var payments = invoices
      .filter(function(inv){ return inv.status === 'paid' && inv.paid_date; })
      .map(function(inv){
        return {
          id:             inv.id,
          payment_date:   inv.paid_date,
          amount:         inv.amount || inv.total,
          invoice_no:     inv.invoice_no || inv.invoice_number,
          payment_method: inv.payment_method || null,
          validated_by:   inv.validated_by || null,
          created_by:     inv.validated_by || null
        };
      });
    var gc       = getGrad(c.phone||c.customer_id||String(c.id));
    var c1=gc[0], c2=gc[1];
    var init     = getInit(c.name);
    var grad     = 'linear-gradient(135deg,'+c1+','+c2+')';

    var totalPaid   = payments.reduce(function(s,p){ return s+Number(p.amount||0); },0);
    var unpaidInv   = invoices.filter(function(i){ return ['unpaid','overdue'].indexOf(i.status)>=0; });
    var totalUnpaid = unpaidInv.reduce(function(s,i){ return s+Number(i.amount||0); },0);

    // Timeline
    var timeline=[];
    // Hanya push invoice events — payments sudah include di payments array (tidak double)
    invoices.forEach(function(inv){
      timeline.push({type:'invoice', date:inv.created_at, data:inv});
    });
    payments.forEach(function(p){
      timeline.push({type:'payment_tx', date:p.payment_date, data:p});
    });
    timeline.sort(function(a,b){ return new Date(b.date)-new Date(a.date); });

    // Status badge
    var stMap={active:['bg','Aktif'],inactive:['bgy','Nonaktif'],suspended:['br','Suspended'],isolated:['br','Isolir']};
    var stArr=stMap[c.status||'inactive']||['bgy','Unknown'];
    var sbc=stArr[0], sbl=stArr[1];

    // Due date
    // ── Kalkulasi Jatuh Tempo ─────────────────────────────────
    // Logic: jika invoice aktif sudah lunas, tampilkan due date BULAN DEPAN
    // Jika belum bayar / overdue, tampilkan due date invoice tersebut

    var dueD = null, duePaid = false, dueHtml = '—';

    // Cari invoice unpaid/overdue terbaru dulu
    var unpaidInvDue = invoices.find(function(i){ return ['unpaid','overdue'].indexOf(i.status)>=0; });

    if (unpaidInvDue && unpaidInvDue.due_date) {
      // Ada tagihan belum lunas — tampilkan due date invoice tsb
      dueD    = unpaidInvDue.due_date;
      duePaid = false;

    } else if (invoices.length > 0 && invoices[0].status === 'paid') {
      // Invoice terbaru sudah lunas — hitung due date bulan depan
      duePaid = true;
      var lastDue = invoices[0].due_date;
      if (lastDue) {
        var lastDt   = new Date(lastDue + 'T00:00:00');
        // Due date berikutnya = bulan depan, tanggal billing_date
        var bilDay   = c.billing_date ? Math.min(parseInt(c.billing_date)||lastDt.getDate(), 28) : lastDt.getDate();
        var nextDue  = new Date(lastDt.getFullYear(), lastDt.getMonth()+1, bilDay);
        dueD = nextDue.getFullYear()+'-'+('0'+(nextDue.getMonth()+1)).slice(-2)+'-'+('0'+bilDay).slice(-2);
      }

    } else if (c.latest_due_date || c.due_date) {
      dueD = c.latest_due_date || c.due_date;

    } else if (c.billing_date) {
      // Fallback: kalkulasi dari billing_date + installation_date
      var bd   = Math.min(parseInt(c.billing_date)||1, 28);
      var ref  = c.installation_date ? new Date(c.installation_date) : new Date();
      var cand = new Date(ref.getFullYear(), ref.getMonth(), bd);
      if (cand <= ref) cand = new Date(ref.getFullYear(), ref.getMonth()+1, bd);
      dueD = cand.getFullYear()+'-'+('0'+(cand.getMonth()+1)).slice(-2)+'-'+('0'+cand.getDate()).slice(-2);
    }

    if (dueD) {
      var due = new Date(dueD+'T00:00:00');
      var tn  = new Date(); tn.setHours(0,0,0,0);
      var dff = Math.round((due - tn) / 86400000);
      var dfs = due.toLocaleDateString('id-ID', {day:'2-digit', month:'2-digit', year:'numeric'});

      if (duePaid) {
        // Sudah bayar periode ini — tampilkan due date berikutnya dengan badge hijau
        if (dff <= 0) {
          dueHtml = dfs + '<br><span class="badge bg" style="font-size:10px;margin-top:3px">✓ Lunas · Jatuh tempo hari ini</span>';
        } else if (dff <= 7) {
          dueHtml = dfs + '<br><span class="badge bg" style="font-size:10px;margin-top:3px">✓ Lunas · '+dff+' hari lagi</span>';
        } else {
          dueHtml = dfs + '<br><span class="badge bg" style="font-size:10px;margin-top:3px">✓ Lunas periode ini</span>';
        }
      } else {
        // Belum bayar — tampilkan status merah/orange
        if (dff < 0) {
          dueHtml = '<span style="color:var(--red);font-weight:700">'+dfs+'</span><br><small style="color:var(--red)">'+Math.abs(dff)+' hari lalu</small>';
        } else if (dff === 0) {
          dueHtml = '<span style="color:var(--orange);font-weight:700">'+dfs+'</span><br><small style="color:var(--orange)">Hari ini!</small>';
        } else if (dff <= 7) {
          dueHtml = '<span style="color:var(--orange);font-weight:700">'+dfs+'</span><br><small style="color:var(--orange)">'+dff+' hari lagi</small>';
        } else {
          dueHtml = dfs;
        }
      }
    }
    // Package badge
    var pkgBadge='';
    if (c.package&&c.package.name) pkgBadge='<span class="badge bb">'+esc(c.package.name)+'</span>';
    else if (c.package_name) pkgBadge='<span class="badge bb">'+esc(c.package_name)+'</span>';

    // Price
    var priceStr = (c.package&&c.package.price) ? fmtRp(c.package.price) : (c.monthly_fee ? fmtRp(c.monthly_fee) : '—');

    // Coord
    var hasCoord = !!(c.latitude && c.longitude);
    var coordTxt = hasCoord
      ? '<span style="font-size:11px;color:var(--muted);font-family:monospace">'+Number(c.latitude).toFixed(5)+', '+Number(c.longitude).toFixed(5)+'</span>'
      : '<a href="/customers?edit='+c.id+'" style="font-size:11px;color:var(--blue);font-weight:600;text-decoration:none">+ Tambah Koordinat</a>';
    var mapBody = hasCoord
      ? '<div id="custMap" style="height:100%;width:100%"></div>'
        +'<div class="map-layer-toggle">'
          +'<button class="mlt-btn active" id="mapBtnStreet">Peta</button>'
          +'<button class="mlt-btn" id="mapBtnSat">Satelit</button>'
        +'</div>'
      : '<div class="cp-nocoord"><svg width="34" height="34" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="opacity:.3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg><span>Koordinat belum diatur</span></div>';

    // Tagihan card
    var tagihanHtml='';
    if (totalUnpaid>0||totalPaid>0) {
      tagihanHtml = '<div class="cp-card">'
        +'<div class="cp-card-title"><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>Tagihan</div>'
        +(totalUnpaid>0 ? '<div class="info-row"><span class="ilbl">Belum Lunas</span><span class="ival" style="color:var(--red)">'+fmtRp(totalUnpaid)+'</span></div>' : '')
        +(totalPaid>0   ? '<div class="info-row"><span class="ilbl">Total Lunas</span><span class="ival" style="color:var(--green)">'+fmtRp(totalPaid)+'</span></div>' : '')
        +(c.created_at  ? '<div class="info-row"><span class="ilbl">Pelanggan Sejak</span><span class="ival">'+fmtD(c.created_at)+'</span></div>' : '')
        +'</div>';
    }

    // Teknis card — always shown jika ada data teknis atau ont_sn
    var hasTeknis = !!(c.pppoe_username||c.ont_sn||c.static_ip);
    var teknisHtml = '<div class="cp-card" id="teknisCrd">'
      +'<div class="cp-card-title"><svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>Teknis</div>'
      +(c.pppoe_username ? '<div class="info-row"><span class="ilbl">PPPoE</span><span class="ival" style="font-family:monospace;font-size:12px">'+esc(c.pppoe_username)+'</span></div>' : '')
      +(c.static_ip      ? '<div class="info-row"><span class="ilbl">Static IP</span><span class="ival" style="font-family:monospace;font-size:12px">'+esc(c.static_ip)+'</span></div>' : '')
      +(c.ont_sn         ? '<div class="info-row"><span class="ilbl">ONT SN</span><span class="ival" style="font-family:monospace;font-size:12px">'+esc(c.ont_sn)+'</span></div>' : '')
      // ODP row — diisi async
      +'<div class="info-row" id="row-odp"><span class="ilbl">ODP</span><span class="ival" id="val-odp" style="font-size:12px;color:#94a3b8">Memuat…</span></div>'
      // RX row
      +'<div class="info-row" id="row-rx"><span class="ilbl">RX Signal</span><span class="ival" id="val-rx">Memuat…</span></div>'
      // Status ONT row
      +'<div class="info-row" id="row-ont-status"><span class="ilbl">Status ONT</span><span class="ival" id="val-ont-status"><span style="font-size:11px;color:#94a3b8">Memuat…</span></span></div>'
      +'</div>';

    // Invoice table
    var invHtml = invoices.length===0
      ? '<div class="empty-st"><div class="ei">🧾</div><p>Belum ada invoice.</p></div>'
      : (function(){
          var rows=invoices.map(function(inv){
            var sc={paid:'bg',unpaid:'by',overdue:'br',cancelled:'bgy'}[inv.status]||'bgy';
            return '<tr>'
              +'<td data-label="Invoice" style="font-family:monospace;font-size:12px">'+esc(inv.invoice_no||String(inv.id||''))+'</td>'
              +'<td data-label="Periode" style="color:var(--muted)">'+(inv.period_month||'—')+'/'+(inv.period_year||'—')+'</td>'
              +'<td data-label="Nominal" style="font-weight:700">'+fmtRp(inv.amount)+'</td>'
              +'<td data-label="Jatuh Tempo"><div style="font-size:12px">'+fmtD(inv.due_date)+'</div>'+(inv.paid_date?'<div style="font-size:11px;color:var(--green);margin-top:1px">Lunas '+fmtD(inv.paid_date)+'</div>':'')+'</td>'
              +'<td data-label="Status"><span class="badge '+sc+'">'+esc(inv.status||'')+'</span></td>'
              +'</tr>';
          }).join('');
          return '<table class="dtbl"><thead><tr><th>No. Invoice</th><th>Periode</th><th>Nominal</th><th>Jatuh Tempo</th><th>Status</th></tr></thead><tbody>'+rows+'</tbody></table>';
        })();

    // Payment table
    var payHtml = payments.length===0
      ? '<div class="empty-st"><div class="ei">💳</div><p>Belum ada pembayaran.</p></div>'
      : (function(){
          var rows=payments.map(function(p){
            return '<tr>'
              +'<td data-label="Tanggal" style="font-family:monospace;font-size:11.5px;color:var(--muted)">'+fmtD(p.payment_date)+'</td>'
              +'<td data-label="Jumlah" style="font-weight:700;color:var(--blue)">'+fmtRp(p.amount)+'</td>'
              +'<td data-label="Metode"><span class="badge bb">'+esc(p.payment_method||p.method||'—')+'</span></td>'
              +'<td data-label="Invoice" style="font-family:monospace;font-size:11.5px">'+esc(p.invoice_no||'—')+'</td>'
              +'<td data-label="Oleh" style="font-size:12px;color:var(--muted)">'+esc(p.validated_by||p.created_by||'—')+'</td>'
              +'</tr>';
          }).join('');
          return '<table class="dtbl"><thead><tr><th>Tanggal</th><th>Jumlah</th><th>Metode</th><th>Invoice</th><th>Dicatat Oleh</th></tr></thead><tbody>'+rows+'</tbody></table>';
        })();

    // Timeline HTML
    var tlHtml = timeline.length===0
      ? '<div class="empty-st"><div class="ei">📭</div><p>Belum ada aktivitas.</p></div>'
      : buildTimeline(timeline);

    // Assembe full HTML — Page header
    var stBadgeClr = {active:'#16a34a',isolated:'#dc2626',suspended:'#d97706',inactive:'#64748b'}[c.status]||'#64748b';
    var stBadgeBg  = {active:'#f0fdf4',isolated:'#fff0f2',suspended:'#fffbeb',inactive:'#f1f5f9'}[c.status]||'#f1f5f9';
    var pkgSub = (c.package&&c.package.name) ? c.package.name : (c.package_name||'');

    var html = ''
    // Page header — judul "Customer Detail" + breadcrumb + tombol aksi
    +'<div class="cp-ph">'
      +'<div class="cp-ph-left">'
        +'<h1>Customer Detail</h1>'
        +'<p class="cp-ph-sub">'
          +'<a href="/customers" style="color:var(--blue);text-decoration:none;font-weight:600">Data Pelanggan</a>'
          +'<svg width="12" height="12" fill="none" stroke="#94a3b8" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>'
          +'<span style="color:#374151;font-weight:600">'+esc(c.name)+'</span>'
        +'</p>'
      +'</div>'
      +'<div class="cp-ph-right"></div>'
    +'</div>'

    // Hero
    +'<div class="cp-hero">'
      +'<div class="cp-banner" style="background:'+grad+'">'
        +'<div class="cp-banner-btns">'
          +'<a href="tel:'+esc(c.phone||'')+'" class="btn-ph btn-ph-outline" style="background:rgba(255,255,255,.92);border-color:rgba(255,255,255,.5);color:#0d1b3e;">'
            +'<svg width="13" height="13" fill="none" stroke="#0d1b3e" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>'
            +'<span>Hubungi</span>'
          +'</a>'
          +'<button class="btn-ph btn-ph-outline" id="btnEditProfile" style="background:rgba(255,255,255,.92);border-color:rgba(255,255,255,.5);color:#0d1b3e;">'
            +'<svg width="13" height="13" fill="none" stroke="#0d1b3e" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>'
            +'<span>Edit</span>'
          +'</button>'
          +'<button class="btn-ph btn-ph-green" id="btnSendWA">'
            +'<svg width="13" height="13" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>'
            +'<span>Kirim WA</span>'
          +'</button>'
        +'</div>'
      +'</div>'
      +'<div class="cp-body">'
        +'<div class="cp-top">'
          +'<div class="cp-av" style="background:'+grad+'">'+init+'</div>'
        +'</div>'
        +'<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:4px">'
          +'<div class="cp-name">'+esc(c.name)+'</div>'
          +'<span class="badge '+sbc+'">'+sbl+'</span>'+pkgBadge
        +'</div>'
        +'<div class="cp-sub">'+esc(c.email||'')+'</div>'
        +'<div class="cp-infogrid">'
          +'<div class="cp-fi"><div class="cp-fl">No. HP / WA</div><div class="cp-fv mono">'+esc(c.phone||'—')+'</div></div>'
          +'<div class="cp-fi"><div class="cp-fl">CID</div><div class="cp-fv mono">'+esc(c.customer_id||'—')+'</div></div>'
          +'<div class="cp-fi"><div class="cp-fl">Harga Paket</div><div class="cp-fv" style="color:var(--blue)">'+priceStr+'</div></div>'
          +'<div class="cp-fi"><div class="cp-fl">Aktivasi</div><div class="cp-fv">'+fmtD(c.installation_date||c.activation_date)+'</div></div>'
          +'<div class="cp-fi"><div class="cp-fl">Jatuh Tempo</div><div class="cp-fv">'+dueHtml+'</div></div>'
          +(c.address ? '<div class="cp-fi"><div class="cp-fl">Alamat</div><div class="cp-fv" style="font-size:13px;font-weight:500;color:var(--text2)">'+esc(c.address.substring(0,50))+'</div></div>' : '')
        +'</div>'
      +'</div>'
    +'</div>'

    // MAP
    +'<div class="cp-maphero">'
