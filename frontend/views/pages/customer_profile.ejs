async function saveEditProfile() {
  var btn = document.getElementById('ep-save-btn');
  var msg = document.getElementById('ep-msg');
  if (!_editCustId) return;

  var val = function(id){ var el=document.getElementById(id); return el?el.value.trim():''; };
  var name = val('ep-name');
  if (!name) { msg.innerHTML='<span style="color:#dc2626">Nama tidak boleh kosong</span>'; return; }

  if (btn) { btn.textContent='Menyimpan…'; btn.disabled=true; }
  if (msg) msg.textContent = '';

  try {
    var payload = {
      name:              name,
      phone:             val('ep-phone'),
      email:             val('ep-email'),
      address:           val('ep-address'),
      package_id:        val('ep-package') || null,
      billing_date:      parseInt(val('ep-billing-date'))||1,
      installation_date: val('ep-install-date') || null,
      status:            val('ep-status') || 'active',
      pppoe_username:    val('ep-pppoe'),
      ont_sn:            val('ep-ont-sn'),
      static_ip:         val('ep-static-ip') || null,
      mikrotik_id:       val('ep-mikrotik') || null
    };

    var res = await App.api('/customers/'+_editCustId, {
      method: 'PUT',
      body: JSON.stringify(payload)
    });

    if (res && res.success) {
      // Profil berhasil disimpan. Sekarang sync portal credentials.
      // savePortalCredentials() hanya mengirim field yang berubah; backend
      // akan return 400 "Tidak ada perubahan" kalau kosong — itu OK (kita skip).
      var pcRes = await savePortalCredentials();
      if (!pcRes.ok && pcRes.message && pcRes.message !== 'Tidak ada perubahan') {
        // Profil sudah ke-save tapi portal credentials gagal — tampilkan warning,
        // jangan tutup modal supaya admin bisa retry.
        if (msg) msg.innerHTML = '<span style="color:#dc2626">Profil tersimpan, tapi kredensial portal gagal: '+esc(pcRes.message)+'</span>';
        if (btn) { btn.textContent='Simpan'; btn.disabled=false; }
        return;
      }
      if (msg) msg.innerHTML = '<span style="color:#16a34a">✓ Berhasil disimpan</span>';
      // Kalau ada new_password yang ditampilkan via modal kredensial,
      // jangan langsung tutup modal edit — biarkan admin baca dulu.
      var pwModalShown = !!document.getElementById('portalPwResultModal');
      setTimeout(function(){
        closeEditModal();
        loadProfile();
      }, pwModalShown ? 200 : 800);
    } else {
      if (msg) msg.innerHTML = '<span style="color:#dc2626">'+(res&&res.message?esc(res.message):'Gagal menyimpan')+'</span>';
    }
  } catch(e) {
    if (msg) msg.innerHTML = '<span style="color:#dc2626">Error: '+esc(e.message)+'</span>';
  } finally {
    if (btn) { btn.textContent='Simpan'; btn.disabled=false; }
  }
}
