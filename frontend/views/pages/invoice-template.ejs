<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= title %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    :root{
      --d-bg:#eef2f9;--d-card:#fff;--d-border:#e0e7f3;
      --d-text:#0d1b3e;--d-muted:#6b7fa8;--d-blue1:#1a6ef5;
    }
    body{background:var(--d-bg);font-family:'DM Sans',sans-serif;}

    /* ── Page layout ─────────────────────────────────────── */
    .it-page{padding:0;max-width:none;margin:0;}
    .it-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;flex-wrap:wrap;gap:12px;}
    .it-title{font-size:22px;font-weight:800;color:var(--d-text);letter-spacing:-.01em;}
    .it-sub{font-size:13px;color:var(--d-muted);margin-top:3px;}
    .it-actions{display:flex;gap:10px;}
    .it-btn{padding:9px 16px;border-radius:10px;font-size:13px;font-weight:700;border:none;cursor:pointer;
      display:inline-flex;align-items:center;gap:7px;font-family:inherit;transition:all .15s;}
    .it-btn-primary{background:linear-gradient(135deg,#1a6ef5,#0047cc);color:#fff;box-shadow:0 4px 10px -2px rgba(26,110,245,.4);}
    .it-btn-primary:hover{transform:translateY(-1px);box-shadow:0 6px 14px -2px rgba(26,110,245,.5);}
    .it-btn-ghost{background:#fff;color:var(--d-text);border:1.5px solid var(--d-border);}
    .it-btn-ghost:hover{border-color:var(--d-blue1);color:var(--d-blue1);}
    .it-btn-danger{background:#fff;color:#dc2626;border:1.5px solid #fecaca;}
    .it-btn-danger:hover{background:#fef2f2;border-color:#dc2626;}

    /* ── Split layout ────────────────────────────────────── */
    .it-split{display:grid;grid-template-columns:380px 1fr;gap:20px;align-items:start;}
    @media (max-width:1100px){.it-split{grid-template-columns:1fr;}}

    /* ── Mobile tab switcher (hanya muncul di mobile) ── */
    .it-mobile-tabs{display:none;}

    /* ── MOBILE STYLES (< 768px) ───────────────────── */
    @media (max-width:767px){
      .it-page{padding:12px 12px 100px;}
      .it-hdr{flex-direction:column;align-items:stretch;gap:10px;margin-bottom:14px;}
      .it-hdr > div:first-child{order:1;}
      .it-actions{order:2;display:grid;grid-template-columns:1fr 1fr;gap:8px;}
      .it-actions .it-btn{padding:10px 12px;font-size:12px;justify-content:center;}
      .it-title{font-size:18px;}
      .it-sub{font-size:11.5px;}

      /* Tab switcher Edit/Preview */
      .it-mobile-tabs{
        display:flex;background:#fff;border:1px solid var(--d-border);
        border-radius:10px;padding:4px;gap:4px;margin-bottom:14px;
      }
      .it-mobile-tab{
        flex:1;padding:9px 12px;border:none;background:transparent;
        border-radius:7px;font-size:12.5px;font-weight:700;color:var(--d-muted);
        cursor:pointer;font-family:inherit;display:inline-flex;
        align-items:center;justify-content:center;gap:6px;transition:all .15s;
      }
      .it-mobile-tab svg{width:14px;height:14px;}
      .it-mobile-tab.active{background:linear-gradient(135deg,#1a6ef5,#0047cc);color:#fff;}

      /* Tab-mode: hide form atau preview sesuai active */
      .it-split.tab-mode-form    .it-preview-wrap{display:none;}
      .it-split.tab-mode-preview .it-form{display:none;}

      /* Form: disable sticky di mobile, full height */
      .it-form{
        position:static !important;top:auto !important;
        max-height:none;border-radius:14px;
      }
      .it-sec-hdr{padding:13px 14px;}
      .it-sec-icon{width:28px;height:28px;}
      .it-sec-title{font-size:12.5px;}
      .it-sec-body{padding:12px 14px 16px;}

      .it-input,.it-select,.it-textarea{padding:10px 12px;font-size:14px;}
      .it-color-row input[type=color]{width:42px;height:42px;}

      .it-toggle-row{padding:11px 0;}
      .it-toggle-row .lbl{font-size:13px;}

      /* Preview: full width, smaller paper */
      .it-preview-wrap{position:static !important;height:auto;top:auto !important;}
      .it-preview-hdr{flex-wrap:wrap;gap:8px;}
      .it-preview-frame{
        padding:14px 8px;border-radius:12px;
        height:auto;min-height:60vh;max-height:80vh;
      }
      /* Preview paper auto-fit lebar layar */
      .pv-paper{
        width:100% !important;
        max-width:794px;
        min-height:auto !important;
      }
      /* Reset zoom paksa 1 di mobile, atur via auto-fit */
      .it-preview-zoom{display:none;} /* hide zoom buttons di mobile */
      .it-preview-hdr{display:none;}  /* sembunyikan strip kosong di mobile */

      .it-savebar{
        position:fixed;bottom:0;left:0;right:0;
        background:#fff;border-top:1px solid var(--d-border);
        padding:12px 14px;z-index:10;
        box-shadow:0 -4px 12px rgba(0,0,0,.08);
      }
    }
    /* TABLET (768-1100px) ─────────────────────────── */
    @media (min-width:768px) and (max-width:1100px){
      .it-page{padding:16px;}
      .it-form{position:static;max-height:none;}
      .it-preview-wrap{position:static;height:auto;}
      .it-preview-frame{padding:18px;height:auto;min-height:70vh;}
      .pv-paper{transform-origin:top center;}
      /* Sembunyikan strip zoom di tablet juga — auto-fit lebih masuk akal di layar kecil */
      .it-preview-hdr{display:none;}
    }

    /* ── Left form ───────────────────────────────────────── */
    .it-form{background:#fff;border:1px solid var(--d-border);border-radius:20px;overflow:hidden;
      max-height:calc(100vh - 130px);overflow-y:auto;position:sticky;top:78px;}
    .it-form::-webkit-scrollbar{width:8px;}
    .it-form::-webkit-scrollbar-track{background:#f8fafc;}
    .it-form::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:4px;}

    .it-section{border-bottom:1px solid var(--d-border);}
    .it-section:last-child{border-bottom:none;}
    .it-sec-hdr{padding:14px 18px;display:flex;align-items:center;gap:10px;cursor:pointer;
      user-select:none;background:linear-gradient(180deg,#f8faff,#fff);transition:background .15s;}
    .it-sec-hdr:hover{background:#eff6ff;}
    .it-sec-icon{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#1a6ef5,#0047cc);
      display:flex;align-items:center;justify-content:center;flex-shrink:0;}
    .it-sec-icon svg{width:14px;height:14px;stroke:#fff;}
    .it-sec-title{flex:1;font-size:13px;font-weight:700;color:var(--d-text);}
    .it-sec-chev{width:16px;height:16px;color:var(--d-muted);transition:transform .2s;}
    .it-section.open .it-sec-chev{transform:rotate(90deg);}
    .it-sec-body{display:none;padding:14px 18px 18px;}
    .it-section.open .it-sec-body{display:block;}

    /* form fields */
    .it-field{margin-bottom:12px;}
    .it-field:last-child{margin-bottom:0;}
    .it-label{display:block;font-size:10px;font-weight:700;letter-spacing:.06em;
      text-transform:uppercase;color:var(--d-muted);margin-bottom:5px;}
    .it-input,.it-select,.it-textarea{
      width:100%;padding:9px 11px;border-radius:8px;border:1.5px solid var(--d-border);
      font-size:13px;box-sizing:border-box;font-family:inherit;outline:none;
      background:#fff;color:var(--d-text);transition:border-color .15s;
    }
    .it-input:focus,.it-select:focus,.it-textarea:focus{border-color:var(--d-blue1);}
    .it-textarea{resize:vertical;min-height:60px;font-family:inherit;}
    .it-hint{font-size:10.5px;color:var(--d-muted);margin-top:4px;}

    /* Color picker row */
    .it-color-row{display:flex;align-items:center;gap:8px;}
    .it-color-row input[type=color]{
      width:38px;height:38px;border:1.5px solid var(--d-border);
      border-radius:8px;cursor:pointer;padding:2px;background:#fff;
    }
    .it-color-row .it-input{flex:1;font-family:'DM Mono',monospace;font-size:12px;}

    /* Toggle row */
    .it-toggle-row{display:flex;align-items:center;justify-content:space-between;
      padding:9px 0;gap:10px;}
    .it-toggle-row + .it-toggle-row{border-top:1px solid #f1f5f9;}
    .it-toggle-row .lbl{font-size:12.5px;color:var(--d-text);font-weight:600;flex:1;}
    .it-toggle-row .desc{display:block;font-size:10.5px;color:var(--d-muted);font-weight:400;margin-top:2px;}
    .it-switch{position:relative;width:38px;height:22px;cursor:pointer;flex-shrink:0;}
    .it-switch input{position:absolute;opacity:0;pointer-events:none;}
    .it-switch .knob{
      position:absolute;inset:0;border-radius:20px;background:#cbd5e1;
      transition:background .2s;
    }
    .it-switch .knob::after{
      content:'';position:absolute;top:2px;left:2px;
      width:18px;height:18px;border-radius:50%;background:#fff;
      box-shadow:0 1px 3px rgba(0,0,0,.15);transition:left .2s;
    }
    .it-switch input:checked + .knob{background:#1a6ef5;}
    .it-switch input:checked + .knob::after{left:18px;}

    /* Preset chips */
    .it-presets{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}
    .it-preset{padding:4px 10px;border-radius:6px;background:#f1f5f9;color:#475569;
      border:1px solid #e2e8f0;font-size:10.5px;font-weight:700;cursor:pointer;
      font-family:inherit;transition:all .12s;}
    .it-preset:hover{background:var(--d-blue1);color:#fff;border-color:var(--d-blue1);}
    .it-preset.active{background:var(--d-blue1);color:#fff;border-color:var(--d-blue1);}

    /* Right preview */
    .it-preview-wrap{position:sticky;top:78px;height:calc(100vh - 130px);}
    .it-preview-hdr{display:flex;justify-content:flex-end;align-items:center;
      margin-bottom:10px;padding:0 4px;}
    .it-preview-label{font-size:11px;font-weight:700;color:var(--d-muted);
      letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:center;gap:6px;}
    .it-preview-dot{width:6px;height:6px;border-radius:50%;background:#16a34a;
      box-shadow:0 0 0 0 #16a34a;animation:pulse 2s infinite;}
    @keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(22,163,74,.7);}50%{box-shadow:0 0 0 6px rgba(22,163,74,0);}}
    .it-preview-zoom{display:flex;gap:4px;}
    .it-zoom-btn{padding:4px 8px;border-radius:6px;background:#fff;border:1px solid var(--d-border);
      font-size:11px;font-weight:700;color:var(--d-muted);cursor:pointer;font-family:inherit;}
    .it-zoom-btn.active{background:var(--d-blue1);color:#fff;border-color:var(--d-blue1);}

    .it-preview-frame{
      width:100%;height:calc(100% - 32px);
      background:#fff;border:1px solid var(--d-border);border-radius:14px;
      overflow:auto;display:flex;justify-content:center;padding:20px 12px;
      box-shadow:inset 0 1px 4px rgba(0,0,0,.04);
    }
    .it-preview-frame::-webkit-scrollbar{width:10px;height:10px;}
    .it-preview-frame::-webkit-scrollbar-track{background:#f8fafc;}
    .it-preview-frame::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:5px;}

    /* ── Actual invoice mockup (preview) ─────────────────── */
    /* CSS variables di-set dinamis dari JS via inline style */
    .pv-paper{
      background:#fff;
      width:794px;       /* A4 portrait at 96dpi */
      min-height:1123px;
      padding:0;         /* padding ada di dalam .invoice-paper */
      box-shadow:0 8px 30px -8px rgba(0,0,0,.15);
      transform-origin:top center;
      transition:transform .2s;
      box-sizing:border-box;
      overflow:hidden;
      border-radius:0;
    }
    /* .invoice-paper dari renderer punya padding 50px 60px sendiri */
    .pv-paper, .pv-paper * { box-sizing:border-box; }
    .pv-row{display:flex;justify-content:space-between;align-items:flex-start;}
    .pv-logo{width:64px;height:64px;border-radius:14px;display:flex;align-items:center;
      justify-content:center;font-weight:800;font-size:30px;color:#fff;}
    .pv-logo img{width:100%;height:100%;object-fit:contain;border-radius:14px;}
    .pv-company-info{text-align:right;font-size:11px;line-height:1.7;color:#64748b;}
    .pv-company-info b{display:block;color:#0f172a;font-size:13px;margin-bottom:3px;}

    .pv-block-title{font-size:10.5px;font-weight:700;letter-spacing:.12em;
      text-transform:uppercase;color:#94a3b8;margin-bottom:8px;}
    .pv-recipient-name{font-size:18px;font-weight:700;color:#0f172a;margin-bottom:3px;}
    .pv-recipient-cid{display:inline-block;background:#dbeafe;color:#1d4ed8;
      padding:2px 8px;border-radius:4px;font-size:10.5px;font-weight:700;margin:4px 0;}
    .pv-recipient-line{font-size:11px;color:#64748b;margin-top:3px;line-height:1.6;}

    .pv-invoice-title{font-size:38px;font-weight:800;letter-spacing:-.02em;text-align:right;}
    .pv-invoice-meta{margin-top:10px;text-align:right;font-size:11px;color:#64748b;line-height:2;}
    .pv-invoice-meta dt{font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;font-weight:700;margin-top:8px;}
    .pv-invoice-meta dd{margin:0;font-weight:700;color:#0f172a;font-size:12px;}

    .pv-table{width:100%;border-collapse:collapse;margin-top:30px;font-size:12px;}
    .pv-table thead th{
      font-size:9.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;
      background:#f8fafc;padding:12px 14px;text-align:left;
    }
    .pv-table thead th:nth-child(3),.pv-table thead th:nth-child(4),.pv-table thead th:nth-child(5){text-align:right;}
    .pv-table thead th:nth-child(3){text-align:center;}
    .pv-table tbody td{padding:14px;border-bottom:1px solid #f1f5f9;font-size:12px;color:#0f172a;}
    .pv-item-name{font-weight:700;}
    .pv-item-desc{font-size:10.5px;color:#94a3b8;margin-top:2px;}

    .pv-totals{margin-top:18px;display:flex;justify-content:flex-end;}
    .pv-totals-box{min-width:280px;}
    .pv-totals-row{display:flex;justify-content:space-between;padding:8px 14px;font-size:12px;color:#475569;}
    .pv-totals-row.grand{
      margin-top:6px;border-radius:8px;padding:14px;font-size:14px;font-weight:800;
      color:#fff;
    }
    .pv-totals-row.grand .v{font-size:16px;}

    .pv-status-row{margin-top:30px;padding-top:18px;border-top:1px solid #f1f5f9;
      display:flex;gap:30px;font-size:11px;color:#64748b;}
    .pv-status-row .lbl{font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:#94a3b8;font-weight:700;display:block;margin-bottom:4px;}

    .pv-banner{margin-top:24px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;
      padding:14px 18px;display:flex;gap:12px;align-items:center;font-size:12px;color:#15803d;}
    .pv-banner b{color:#14532d;}

    .pv-bank-info{margin-top:24px;background:#f8fafc;border-radius:12px;padding:14px 18px;font-size:11px;color:#475569;}
    .pv-bank-info .pv-bank-row{display:flex;justify-content:space-between;padding:5px 0;}

    .pv-footer{margin-top:30px;padding-top:18px;border-top:1px solid #f1f5f9;
      display:flex;justify-content:space-between;align-items:flex-start;gap:30px;}
    .pv-footer-text{font-size:11px;color:#64748b;line-height:1.7;flex:1;}
    .pv-signature{width:140px;height:80px;border:1.5px dashed #cbd5e1;border-radius:8px;
      display:flex;align-items:center;justify-content:center;color:#cbd5e1;font-size:10px;
      font-weight:700;text-transform:uppercase;letter-spacing:.08em;}

    /* Reset btn / save sticky bar */
    .it-savebar{
      position:sticky;bottom:0;background:#fff;border-top:1px solid var(--d-border);
      padding:14px 18px;display:flex;gap:8px;justify-content:flex-end;
    }
  </style>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar', { active: active }) %>
  <div class="main-content">
    <%- include('../partials/topbar', { user: user }) %>
    <main class="page-content">
    <div class="it-page">
      <!-- Header -->
      <div class="it-hdr">
        <div>
          <div class="it-title">Template Invoice</div>
          <div class="it-sub">Atur tampilan invoice yang akan dilihat & dicetak pelanggan</div>
        </div>
        <div class="it-actions">
          <button class="it-btn it-btn-danger" onclick="resetTemplate()">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M5 19a9 9 0 0014.5-3.5M19 5A9 9 0 004.5 8.5"/></svg>
            Reset Default
          </button>
          <button class="it-btn it-btn-ghost" onclick="window.open('/invoice-template/preview-print','_blank')">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Preview Print
          </button>
        </div>
      </div>

      <!-- Mobile tab switcher (hanya tampil di < 768px) -->
      <div class="it-mobile-tabs">
        <button type="button" class="it-mobile-tab active" data-mtab="form" onclick="switchMobileTab('form')">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit
        </button>
        <button type="button" class="it-mobile-tab" data-mtab="preview" onclick="switchMobileTab('preview')">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Preview
        </button>
      </div>

      <div class="it-split tab-mode-form" id="itSplit">
        <!-- ── LEFT FORM ────────────────────────────────── -->
        <div class="it-form">

          <!-- Section: Warna -->
          <div class="it-section open">
            <div class="it-sec-hdr" onclick="toggleSection(this)">
              <div class="it-sec-icon"><svg fill="none" stroke-width="2" viewBox="0 0 24 24"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 22a9 9 0 0 1 0-18c5 0 9 4 9 8 0 3-2 4-3 4-2 0-2 2 0 3-1 1-3 3-6 3z"/></svg></div>
              <div class="it-sec-title">Warna & Brand</div>
              <svg class="it-sec-chev" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
            <div class="it-sec-body">
              <div class="it-field">
                <label class="it-label">Warna Primary (Header)</label>
                <div class="it-color-row">
                  <input type="color" id="primary_color" value="<%= tplSettings.invtpl_primary_color || '#1a6ef5' %>">
                  <input type="text" class="it-input" id="primary_color_hex" value="<%= tplSettings.invtpl_primary_color || '#1a6ef5' %>">
                </div>
                <div class="it-presets">
                  <button class="it-preset" onclick="setPrimaryColor('#1a6ef5')" style="background:#1a6ef5;color:#fff;border-color:#1a6ef5;">Biru</button>
                  <button class="it-preset" onclick="setPrimaryColor('#1e3a8a')" style="background:#1e3a8a;color:#fff;border-color:#1e3a8a;">Navy</button>
                  <button class="it-preset" onclick="setPrimaryColor('#0d9488')" style="background:#0d9488;color:#fff;border-color:#0d9488;">Teal</button>
                  <button class="it-preset" onclick="setPrimaryColor('#0f172a')" style="background:#0f172a;color:#fff;border-color:#0f172a;">Hitam</button>
                </div>
              </div>
              <div class="it-field">
                <label class="it-label">Warna Aksen (Subtotal Box, Highlight)</label>
                <div class="it-color-row">
                  <input type="color" id="accent_color" value="<%= tplSettings.invtpl_accent_color || '#1d4ed8' %>">
                  <input type="text" class="it-input" id="accent_color_hex" value="<%= tplSettings.invtpl_accent_color || '#1d4ed8' %>">
                </div>
              </div>
              <div class="it-field">
                <label class="it-label">Warna Teks Utama</label>
                <div class="it-color-row">
                  <input type="color" id="text_color" value="<%= tplSettings.invtpl_text_color || '#0f172a' %>">
                  <input type="text" class="it-input" id="text_color_hex" value="<%= tplSettings.invtpl_text_color || '#0f172a' %>">
                </div>
              </div>
            </div>
          </div>

          <!-- Section: Font & Layout -->
          <div class="it-section">
            <div class="it-sec-hdr" onclick="toggleSection(this)">
              <div class="it-sec-icon" style="background:linear-gradient(135deg,#7c3aed,#5b21b6);"><svg fill="none" stroke-width="2" viewBox="0 0 24 24"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg></div>
              <div class="it-sec-title">Font & Tipografi</div>
              <svg class="it-sec-chev" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
            <div class="it-sec-body">
              <div class="it-field">
                <label class="it-label">Jenis Font</label>
                <select class="it-select" id="font_family">
                  <option value="Inter"  <%= (tplSettings.invtpl_font_family || 'Inter') === 'Inter'  ? 'selected' : '' %>>Inter (modern, clean)</option>
                  <option value="Plus Jakarta Sans" <%= tplSettings.invtpl_font_family === 'Plus Jakarta Sans' ? 'selected' : '' %>>Plus Jakarta Sans (friendly)</option>
                  <option value="Poppins" <%= tplSettings.invtpl_font_family === 'Poppins' ? 'selected' : '' %>>Poppins (rounded)</option>
                  <option value="DM Sans" <%= tplSettings.invtpl_font_family === 'DM Sans' ? 'selected' : '' %>>DM Sans (default app)</option>
                  <option value="system-ui" <%= tplSettings.invtpl_font_family === 'system-ui' ? 'selected' : '' %>>System (cepat load)</option>
                </select>
              </div>
              <div class="it-field">
                <label class="it-label">Style Header</label>
                <select class="it-select" id="header_style">
                  <option value="banner"  <%= (tplSettings.invtpl_header_style || 'banner') === 'banner' ? 'selected' : '' %>>Banner Solid (warna penuh)</option>
                  <option value="minimal" <%= tplSettings.invtpl_header_style === 'minimal' ? 'selected' : '' %>>Minimal (logo + judul, tanpa banner)</option>
                  <option value="split"   <%= tplSettings.invtpl_header_style === 'split'   ? 'selected' : '' %>>Split (logo kiri, info kanan)</option>
                </select>
              </div>
              <div class="it-field">
                <label class="it-label">Ukuran Kertas</label>
                <select class="it-select" id="paper_size" disabled>
                  <option value="A4">A4 Portrait (210 × 297 mm)</option>
                </select>
                <div class="it-hint">Saat ini hanya support A4 portrait.</div>
              </div>
            </div>
          </div>

          <!-- Section: Logo & Company -->
          <div class="it-section">
            <div class="it-sec-hdr" onclick="toggleSection(this)">
              <div class="it-sec-icon" style="background:linear-gradient(135deg,#0d9488,#0f766e);"><svg fill="none" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
              <div class="it-sec-title">Logo & Identitas Perusahaan</div>
              <svg class="it-sec-chev" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
            <div class="it-sec-body">
              <div class="it-field">
                <div class="it-toggle-row">
                  <span class="lbl">Tampilkan Logo<span class="desc">Logo di pojok kiri atas invoice</span></span>
                  <label class="it-switch"><input type="checkbox" id="show_logo" <%= tplSettings.invtpl_show_logo !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
                </div>
              </div>
              <div class="it-field">
                <label class="it-label">URL Logo (override)</label>
                <input type="text" class="it-input" id="logo_url" value="<%= tplSettings.invtpl_logo_url || '' %>" placeholder="Kosongkan untuk pakai logo Brand global">
                <div class="it-hint">Default: <%= appSettings.logo_url || '(tidak ada)' %></div>
              </div>
              <script>window._DEFAULT_LOGO_URL = <%- JSON.stringify(appSettings.logo_url || '') %>;</script>
              <div class="it-field">
                <label class="it-label">Nama Perusahaan</label>
                <input type="text" class="it-input" id="company_name" value="<%= tplSettings.invtpl_company_name || appSettings.company_name || appSettings.app_name || 'ISP Provider' %>">
              </div>
              <div class="it-field">
                <label class="it-label">Tagline / Subtitle</label>
                <input type="text" class="it-input" id="company_tagline" value="<%= tplSettings.invtpl_company_tagline || 'Internet Service Provider' %>">
              </div>
              <div class="it-field">
                <label class="it-label">Alamat</label>
                <textarea class="it-textarea" id="company_address" rows="2"><%= tplSettings.invtpl_company_address || '' %></textarea>
              </div>
              <div class="it-field">
                <label class="it-label">Telepon</label>
                <input type="text" class="it-input" id="company_phone" value="<%= tplSettings.invtpl_company_phone || appSettings.company_whatsapp || '' %>">
              </div>
              <div class="it-field">
                <label class="it-label">Email</label>
                <input type="text" class="it-input" id="company_email" value="<%= tplSettings.invtpl_company_email || '' %>">
              </div>
            </div>
          </div>

          <!-- Section: Bagian Tampilan -->
          <div class="it-section">
            <div class="it-sec-hdr" onclick="toggleSection(this)">
              <div class="it-sec-icon" style="background:linear-gradient(135deg,#f59e0b,#b45309);"><svg fill="none" stroke-width="2" viewBox="0 0 24 24"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
              <div class="it-sec-title">Bagian yang Ditampilkan</div>
              <svg class="it-sec-chev" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
            <div class="it-sec-body">
              <div class="it-toggle-row">
                <span class="lbl">Subtotal<span class="desc">Tampilkan baris subtotal sebelum pajak</span></span>
                <label class="it-switch"><input type="checkbox" id="show_subtotal" <%= tplSettings.invtpl_show_subtotal !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
              <div class="it-toggle-row">
                <span class="lbl">PPN / Pajak<span class="desc">Baris pajak (auto-hide jika tidak ada PPN)</span></span>
                <label class="it-switch"><input type="checkbox" id="show_tax" <%= tplSettings.invtpl_show_tax !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
              <div class="it-toggle-row">
                <span class="lbl">Tanggal Jatuh Tempo<span class="desc">Tampilkan due date di header detail</span></span>
                <label class="it-switch"><input type="checkbox" id="show_due_date" <%= tplSettings.invtpl_show_due_date !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
              <div class="it-toggle-row">
                <span class="lbl">Metode Pembayaran<span class="desc">Section "Metode pembayaran" + status</span></span>
                <label class="it-switch"><input type="checkbox" id="show_payment_method" <%= tplSettings.invtpl_show_payment_method !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
              <div class="it-toggle-row">
                <span class="lbl">Banner Layanan Aktif<span class="desc">Reminder kapan layanan aktif sampai</span></span>
                <label class="it-switch"><input type="checkbox" id="show_active_until" <%= tplSettings.invtpl_show_active_until !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
              <div class="it-toggle-row">
                <span class="lbl">Info Bank Transfer<span class="desc">List rekening dari Settings Pembayaran</span></span>
                <label class="it-switch"><input type="checkbox" id="show_bank_info" <%= tplSettings.invtpl_show_bank_info === '1' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
              <div class="it-toggle-row">
                <span class="lbl">Kotak Stempel/TTD<span class="desc">Area kosong stempel di footer</span></span>
                <label class="it-switch"><input type="checkbox" id="show_signature" <%= tplSettings.invtpl_show_signature !== '0' ? 'checked' : '' %>><span class="knob"></span></label>
              </div>
            </div>
          </div>

          <!-- Section: Teks Custom -->
          <div class="it-section">
            <div class="it-sec-hdr" onclick="toggleSection(this)">
              <div class="it-sec-icon" style="background:linear-gradient(135deg,#dc2626,#991b1b);"><svg fill="none" stroke-width="2" viewBox="0 0 24 24"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></div>
              <div class="it-sec-title">Label & Teks Custom</div>
              <svg class="it-sec-chev" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </div>
            <div class="it-sec-body">
              <div class="it-field">
                <label class="it-label">Label "Invoice"</label>
                <input type="text" class="it-input" id="invoice_label" value="<%= tplSettings.invtpl_invoice_label || 'INVOICE' %>" maxlength="30">
              </div>
              <div class="it-field">
                <label class="it-label">Label "Tagihan Untuk"</label>
                <input type="text" class="it-input" id="section_recipient_label" value="<%= tplSettings.invtpl_section_recipient_label || 'TAGIHAN UNTUK' %>" maxlength="30">
              </div>
              <div class="it-field">
                <label class="it-label">Label "Detail Invoice"</label>
                <input type="text" class="it-input" id="section_detail_label" value="<%= tplSettings.invtpl_section_detail_label || 'DETAIL INVOICE' %>" maxlength="30">
              </div>
              <div class="it-field">
                <label class="it-label">Pesan Footer (Atas)</label>
                <textarea class="it-textarea" id="thank_you_text" rows="2" placeholder="Terima kasih telah menggunakan layanan kami."><%= tplSettings.invtpl_thank_you_text || 'Terima kasih telah menggunakan layanan kami.' %></textarea>
              </div>
              <div class="it-field">
                <label class="it-label">Footer Text (Bawah)</label>
                <textarea class="it-textarea" id="footer_text" rows="3" placeholder="Dokumen ini di-generate otomatis..."><%= tplSettings.invtpl_footer_text || 'Dokumen ini di-generate otomatis oleh sistem. Invoice ini sah tanpa tanda tangan basah.' %></textarea>
              </div>
            </div>
          </div>

          <!-- Save bar -->
          <div class="it-savebar">
            <button class="it-btn it-btn-ghost" onclick="location.href='/billing'">Batal</button>
            <button class="it-btn it-btn-primary" id="btnSave" onclick="saveTemplate()">
              <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Simpan Template
            </button>
          </div>
        </div>

        <!-- ── RIGHT PREVIEW ────────────────────────────── -->
        <div class="it-preview-wrap">
          <div class="it-preview-hdr">
            <!-- Label "Live Preview · Data Contoh" sengaja dihilangkan agar tampilan lebih clean,
                 terutama di mobile/tablet dimana strip ini tidak fit dengan baik. -->
            <div></div>
            <div class="it-preview-zoom">
              <button class="it-zoom-btn" onclick="setZoom(0.6)">60%</button>
              <button class="it-zoom-btn active" data-zoom="0.7" onclick="setZoom(0.7)">70%</button>
              <button class="it-zoom-btn" onclick="setZoom(0.85)">85%</button>
              <button class="it-zoom-btn" onclick="setZoom(1)">100%</button>
            </div>
          </div>
          <div class="it-preview-frame" id="previewFrame">
            <div class="pv-paper" id="pvPaper">
              <!-- Konten preview di-render oleh JS -->
            </div>
          </div>
        </div>
      </div>
    </div>
    </main>
    <%- include('../partials/footer') %>
  </div>
</div>

  <script src="/js/app.js"></script>
  <script src="/js/invoice-renderer.js"></script>
  <script>
    // ═══════════════════════════════════════════════════════════
    // Live preview engine — pakai shared InvoiceRenderer
    // ═══════════════════════════════════════════════════════════
    function $(id){ return document.getElementById(id); }

    function readForm() {
      return {
        primary_color: $('primary_color').value,
        accent_color:  $('accent_color').value,
        text_color:    $('text_color').value,
        font_family:   $('font_family').value,
        header_style:  $('header_style').value,
        paper_size:    'A4',
        show_logo:     $('show_logo').checked,
        logo_url:      $('logo_url').value.trim() || (window._DEFAULT_LOGO_URL || ''),
        company_name:  $('company_name').value || 'ISP Provider',
        company_tagline: $('company_tagline').value,
        company_address: $('company_address').value,
        company_phone:   $('company_phone').value,
        company_email:   $('company_email').value,
        show_subtotal:       $('show_subtotal').checked,
        show_tax:            $('show_tax').checked,
        show_due_date:       $('show_due_date').checked,
        show_payment_method: $('show_payment_method').checked,
        show_active_until:   $('show_active_until').checked,
        show_bank_info:      $('show_bank_info').checked,
        show_signature:      $('show_signature').checked,
        invoice_label:           $('invoice_label').value || 'INVOICE',
        section_recipient_label: $('section_recipient_label').value || 'TAGIHAN UNTUK',
        section_detail_label:    $('section_detail_label').value || 'DETAIL INVOICE',
        thank_you_text:          $('thank_you_text').value,
        footer_text:             $('footer_text').value,
      };
    }

    // Render preview pakai shared renderer (sumber kebenaran tunggal — invoice asli pakai ini juga)
    function renderPreview() {
      if (typeof InvoiceRenderer === 'undefined') {
        console.warn('InvoiceRenderer not loaded yet');
        return;
      }
      const cfg = readForm();
      const sample = InvoiceRenderer.sampleData();
      InvoiceRenderer.render('#pvPaper', sample, cfg);
    }

    function setPrimaryColor(hex){
      $('primary_color').value = hex;
      $('primary_color_hex').value = hex;
      // Sync presets active state
      document.querySelectorAll('.it-preset').forEach(b => b.classList.remove('active'));
      renderPreview();
    }

    // Section toggle
    function toggleSection(hdr){ hdr.parentElement.classList.toggle('open'); }

    // Color sync (color input ↔ hex text input)
    function bindColorSync(colorId, hexId){
      const c = $(colorId), h = $(hexId);
      c.addEventListener('input', () => { h.value = c.value; renderPreview(); });
      h.addEventListener('input', () => {
        if (/^#[0-9a-fA-F]{6}$/.test(h.value)) { c.value = h.value; renderPreview(); }
      });
    }

    // Zoom — di mobile/tablet (< 1100px) skip transform sama sekali, paper sudah responsive via CSS
    function setZoom(z){
      const paper = $('pvPaper');
      if (!paper) return;

      const isSmallViewport = window.matchMedia('(max-width:1100px)').matches;
      if (isSmallViewport) {
        // Reset semua inline transform — paper akan auto-fit ke container via CSS width:100%
        paper.style.transform = '';
        paper.style.transformOrigin = '';
        paper.style.marginBottom = '';
        return;
      }

      // Desktop: pakai transform scale sesuai parameter (atau auto-fit)
      if (z === 'auto' || !z) {
        const frame = document.querySelector('.it-preview-frame');
        if (frame) {
          const fw = frame.clientWidth - 32;
          const scale = Math.min(1, fw / 794);
          paper.style.transform = 'scale(' + scale + ')';
          paper.style.transformOrigin = 'top center';
          paper.style.marginBottom = scale < 1 ? -(1123 * (1-scale)) + 'px' : '0';
        }
        return;
      }
      paper.style.transform = 'scale(' + z + ')';
      paper.style.transformOrigin = 'top center';
      paper.style.marginBottom = (z < 1 ? -(1123 * (1-z)) : 0) + 'px';
      document.querySelectorAll('.it-zoom-btn').forEach(b => b.classList.remove('active'));
      const btn = [...document.querySelectorAll('.it-zoom-btn')].find(b => b.textContent.includes(Math.round(z*100)+'%'));
      if (btn) btn.classList.add('active');
    }

    // Mobile tab switcher (Edit / Preview)
    function switchMobileTab(tab) {
      const split = document.getElementById('itSplit');
      if (!split) return;
      split.classList.remove('tab-mode-form', 'tab-mode-preview');
      split.classList.add('tab-mode-' + tab);
      document.querySelectorAll('.it-mobile-tab').forEach(b => {
        b.classList.toggle('active', b.dataset.mtab === tab);
      });
      // Re-fit zoom kalau switch ke preview (frame size baru saja terbuka)
      if (tab === 'preview') {
        setTimeout(() => setZoom(0.7), 50);
      }
    }

    // Save
    async function saveTemplate(){
      const cfg = readForm();
      const payload = {
        invtpl_primary_color: cfg.primary_color,
        invtpl_accent_color:  cfg.accent_color,
        invtpl_text_color:    cfg.text_color,
        invtpl_font_family:   cfg.font_family,
        invtpl_paper_size:    cfg.paper_size,
        invtpl_header_style:  cfg.header_style,
        invtpl_show_logo:     cfg.show_logo ? '1' : '0',
        invtpl_logo_url:      cfg.logo_url,
        invtpl_company_name:  cfg.company_name,
        invtpl_company_tagline: cfg.company_tagline,
        invtpl_company_address: cfg.company_address,
        invtpl_company_phone:   cfg.company_phone,
        invtpl_company_email:   cfg.company_email,
        invtpl_show_subtotal:       cfg.show_subtotal ? '1' : '0',
        invtpl_show_tax:            cfg.show_tax ? '1' : '0',
        invtpl_show_due_date:       cfg.show_due_date ? '1' : '0',
        invtpl_show_payment_method: cfg.show_payment_method ? '1' : '0',
        invtpl_show_active_until:   cfg.show_active_until ? '1' : '0',
        invtpl_show_bank_info:      cfg.show_bank_info ? '1' : '0',
        invtpl_show_signature:      cfg.show_signature ? '1' : '0',
        invtpl_invoice_label:           cfg.invoice_label,
        invtpl_section_recipient_label: cfg.section_recipient_label,
        invtpl_section_detail_label:    cfg.section_detail_label,
        invtpl_thank_you_text:          cfg.thank_you_text,
        invtpl_footer_text:             cfg.footer_text,
      };
      const btn = $('btnSave');
      btn.disabled = true; const orig = btn.innerHTML; btn.innerHTML = 'Menyimpan...';
      try {
        const d = await App.api('/app-settings', { method: 'POST', body: JSON.stringify(payload) });
        if (d?.success) App.showToast('Template invoice tersimpan', 'success');
        else App.showToast(d?.message || 'Gagal menyimpan', 'error');
      } catch(e){ App.showToast(e.message || 'Error', 'error'); }
      finally { btn.disabled = false; btn.innerHTML = orig; }
    }

    function resetTemplate(){
      if (!confirm('Reset semua pengaturan template ke default?\n\nPerubahan akan langsung tersimpan.')) return;
      const defaults = {
        primary_color: '#1a6ef5', accent_color: '#1d4ed8', text_color: '#0f172a',
        font_family: 'Inter', header_style: 'banner',
        show_logo: true, logo_url: '',
        company_name: 'ISP Provider', company_tagline: 'Internet Service Provider',
        company_address: '', company_phone: '', company_email: '',
        show_subtotal: true, show_tax: true, show_due_date: true,
        show_payment_method: true, show_active_until: true, show_bank_info: false, show_signature: true,
        invoice_label: 'INVOICE', section_recipient_label: 'TAGIHAN UNTUK', section_detail_label: 'DETAIL INVOICE',
        thank_you_text: 'Terima kasih telah menggunakan layanan kami.',
        footer_text: 'Dokumen ini di-generate otomatis oleh sistem. Invoice ini sah tanpa tanda tangan basah.'
      };
      Object.entries(defaults).forEach(([k,v]) => {
        const el = $(k);
        if (!el) return;
        if (typeof v === 'boolean') el.checked = v;
        else el.value = v;
      });
      $('primary_color_hex').value = defaults.primary_color;
      $('accent_color_hex').value  = defaults.accent_color;
      $('text_color_hex').value    = defaults.text_color;
      renderPreview();
      saveTemplate();
    }

    // Init
    document.addEventListener('DOMContentLoaded', () => {
      bindColorSync('primary_color', 'primary_color_hex');
      bindColorSync('accent_color',  'accent_color_hex');
      bindColorSync('text_color',    'text_color_hex');

      // Live preview saat input apapun berubah
      document.querySelectorAll('.it-form input, .it-form select, .it-form textarea').forEach(el => {
        el.addEventListener('input',  renderPreview);
        el.addEventListener('change', renderPreview);
      });

      // Initial render + zoom
      renderPreview();
      setZoom(0.7);

      // Re-fit saat resize / rotate (debounced)
      let _resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(_resizeTimer);
        _resizeTimer = setTimeout(() => setZoom(0.7), 150);
      });
    });
  </script>
</body>
</html>
