<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'GPS Tracking' %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  
  <style>
    /* ═══════════════════════════════════════════════════════
       OVERRIDE main-content padding untuk full-screen layout
    ═══════════════════════════════════════════════════════ */
    body .main-content {
      padding: 0 !important;
      overflow: hidden;
    }

    /* ═══════════════════════════════════════════════════════
       THEME - Blue Gradient
    ═══════════════════════════════════════════════════════ */
    :root {
      --f-bg: #f4f6f9;
      --f-card: #ffffff;
      --f-primary: #2563eb;
      --f-primary-light: #dbeafe;
      --f-primary-dark: #1d4ed8;
      --f-primary-darker: #1e40af;
      --f-gradient: linear-gradient(135deg, #2563eb, #1d4ed8);
      --f-gradient-light: linear-gradient(135deg, #3b82f6, #2563eb);
      --f-accent: #f59e0b;
      --f-accent-light: #fef3c7;
      --f-danger: #ef4444;
      --f-danger-light: #fee2e2;
      --f-success: #10b981;
      --f-text: #1e293b;
      --f-text2: #64748b;
      --f-text3: #94a3b8;
      --f-border: #e2e8f0;
      --f-border2: #f1f5f9;
      --f-shadow: 0 1px 3px rgba(0,0,0,0.06);
      --f-shadow-lg: 0 8px 25px rgba(0,0,0,0.08);
      --f-radius: 12px;
    }

    /* ═══════════════════════════════════════════════════════
       LAYOUT - Fixed Height
    ═══════════════════════════════════════════════════════ */
    .fleet-page {
      background: var(--f-bg);
      display: grid;
      grid-template-columns: 1fr 380px;
      grid-template-rows: auto 1fr auto;
      overflow: hidden;
      /* Isi sisa tinggi di dalam main-content */
      height: calc(100vh - 60px); /* 60px = tinggi topbar global */
      max-height: calc(100vh - 60px);
    }

    /* ═══ TOPBAR ═══ */
    .fleet-topbar {
      grid-column: 1 / 2;
      grid-row: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 20px;
      background: var(--f-card);
      border-bottom: 1px solid var(--f-border);
      z-index: 2;
    }

    .ft-left { display: flex; align-items: center; gap: 12px; }

    .ft-title {
      font-size: 17px;
      font-weight: 700;
      color: var(--f-text);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .ft-title svg { color: var(--f-primary); }

    .ft-right { display: flex; align-items: center; gap: 8px; }

    .btn-f {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: 6px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
      border: 1px solid var(--f-border);
      background: var(--f-card);
      color: var(--f-text);
      font-family: inherit;
    }

    .btn-f:hover { background: #f8fafc; border-color: #cbd5e1; }

    .btn-f.primary {
      background: var(--f-gradient);
      color: white;
      border-color: transparent;
      box-shadow: 0 2px 8px rgba(37,99,235,0.3);
    }

    .btn-f.primary:hover { box-shadow: 0 4px 14px rgba(37,99,235,0.4); }

    .btn-f.active {
      background: var(--f-primary);
      color: white;
      border-color: var(--f-primary);
    }

    /* ═══ MAP ═══ */
    .fleet-map {
      grid-column: 1 / 2;
      grid-row: 2;
      position: relative;
      overflow: hidden;
      min-height: 0; /* penting untuk grid: izinkan flex/grid child menyusut */
    }

    #map { position: absolute; inset: 0; z-index: 1; }

    /* Map Search */
    .m-search {
      position: absolute;
      top: 14px;
      left: 14px;
      z-index: 1000;
    }

    .m-search input {
      width: 260px;
      padding: 9px 12px 9px 36px;
      border: 1px solid var(--f-border);
      border-radius: 8px;
      font-size: 13px;
      font-family: inherit;
      background: white;
      box-shadow: var(--f-shadow);
      transition: all 0.2s;
    }

    .m-search input:focus {
      outline: none;
      border-color: var(--f-primary);
      box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
    }

    .m-search svg {
      position: absolute;
      left: 11px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--f-text3);
    }

    /* Map Controls */
    .m-ctrl {
      position: absolute;
      top: 14px;
      right: 14px;
      z-index: 1000;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .m-ctrl-btn {
      width: 36px;
      height: 36px;
      background: white;
      border: 1px solid var(--f-border);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.15s;
      color: var(--f-text);
      box-shadow: var(--f-shadow);
    }

    .m-ctrl-btn:hover { background: #f8fafc; }

    .m-ctrl-btn.active {
      background: var(--f-primary);
      color: white;
      border-color: var(--f-primary);
    }

    /* Separator di antara grup tombol ctrl */
    .m-ctrl-sep {
      width: 28px;
      height: 1px;
      background: var(--f-border);
      margin: 2px auto;
    }

    /* Satellite button di m-ctrl - active state */
    .m-ctrl-sat.active {
      background: linear-gradient(135deg, #1e3a5f, #0f2744);
      color: #7dd3fc;
      border-color: #1e3a5f;
    }

    /* Di desktop: sembunyikan tombol sat di m-ctrl (sudah ada di topbar) */
    @media (min-width: 769px) {
      .m-ctrl-sep, .m-ctrl-sat { display: none; }
    }

    /* Stats Overlay on Map */
    .m-stats {
      position: absolute;
      bottom: 16px;
      left: 16px;
      z-index: 1000;
      background: white;
      border-radius: var(--f-radius);
      padding: 14px 18px;
      box-shadow: var(--f-shadow-lg);
      display: flex;
      align-items: center;
      gap: 20px;
      border: 1px solid var(--f-border2);
    }

    .ms-item { display: flex; align-items: center; gap: 8px; }

    .ms-num {
      font-size: 24px;
      font-weight: 800;
      color: var(--f-text);
      line-height: 1;
    }

    .ms-detail { display: flex; flex-direction: column; }

    .ms-label { font-size: 11.5px; font-weight: 600; color: var(--f-text); }

    .ms-sub {
      font-size: 11px;
      color: var(--f-primary);
      font-weight: 600;
      cursor: pointer;
    }

    .ms-sub:hover { text-decoration: underline; }

    .ms-div { width: 1px; height: 32px; background: var(--f-border); }

    .ms-bar {
      width: 4px;
      height: 24px;
      border-radius: 2px;
      flex-shrink: 0;
    }

    .ms-bar.idle { background: var(--f-accent); }
    .ms-bar.active { background: var(--f-primary); }

    /* ═══ BOTTOM PANELS ═══ */
    .fleet-bottom {
      grid-column: 1 / 2;
      grid-row: 3;
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-top: 1px solid var(--f-border);
      background: var(--f-card);
      max-height: 260px;
      overflow: hidden;
    }

    .bp { padding: 18px 22px; overflow-y: auto; }
    .bp + .bp { border-left: 1px solid var(--f-border); }

    .bp-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }

    .bp-title { font-size: 14px; font-weight: 700; color: var(--f-text); }

    .bp-action {
      font-size: 12px;
      font-weight: 600;
      color: var(--f-primary);
      cursor: pointer;
    }

    .bp-action:hover { text-decoration: underline; }

    /* Chart Bars */
    .chart-bars {
      display: flex;
      align-items: flex-end;
      gap: 5px;
      height: 120px;
      padding-top: 8px;
    }

    .cb-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
    }

    .cb-bar {
      width: 100%;
      max-width: 30px;
      border-radius: 3px 3px 0 0;
      min-height: 4px;
      transition: all 0.3s;
      position: relative;
      cursor: pointer;
    }

    .cb-bar.cur { background: var(--f-primary); }
    .cb-bar.past { background: var(--f-accent); }
    .cb-bar.future { background: var(--f-border); border: 1px dashed var(--f-text3); min-height: 8px; }

    .cb-bar:hover { opacity: 0.8; }

    .cb-lbl { font-size: 10px; color: var(--f-text3); font-weight: 600; }

    .cb-tip {
      position: absolute;
      top: -26px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--f-text);
      color: white;
      padding: 2px 7px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 600;
      white-space: nowrap;
      display: none;
      pointer-events: none;
    }

    .cb-bar:hover .cb-tip { display: block; }

    /* Alerts */
    .al-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px solid var(--f-border2);
    }

    .al-item:last-child { border-bottom: none; }

    .al-av {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      flex-shrink: 0;
      color: white;
    }

    .al-av.warn { background: var(--f-accent); }
    .al-av.danger { background: var(--f-danger); }
    .al-av.info { background: var(--f-primary); }

    .al-body { flex: 1; min-width: 0; }
    .al-name { font-size: 13px; font-weight: 700; color: var(--f-text); }
    .al-time { font-size: 11px; color: var(--f-text3); }
    .al-msg { font-size: 12px; color: var(--f-text2); margin-top: 2px; }

    .al-pin {
      width: 28px;
      height: 28px;
      border-radius: 50%;
      border: 1px solid var(--f-border);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
      align-self: center;
      color: var(--f-text3);
      transition: all 0.15s;
    }

    .al-pin:hover { background: var(--f-primary-light); color: var(--f-primary); }

    /* ═══ RIGHT SIDEBAR ═══ */
    .fleet-side {
      grid-row: 1 / 4;
      grid-column: 2;
      background: var(--f-card);
      border-left: 1px solid var(--f-border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .fs-head {
      padding: 16px 18px;
      border-bottom: 1px solid var(--f-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .fs-title { font-size: 15px; font-weight: 700; color: var(--f-text); }

    .fs-action {
      font-size: 12px;
      font-weight: 600;
      color: var(--f-primary);
      cursor: pointer;
    }

    .fs-action:hover { text-decoration: underline; }

    .fs-list { flex: 1; overflow-y: auto; }

    /* Trip Card */
    .tc {
      border-bottom: 1px solid var(--f-border2);
      padding: 14px 18px;
      cursor: pointer;
      transition: background 0.12s;
    }

    .tc:hover { background: #f8fafc; }

    .tc-head {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 10px;
    }

    .tc-av {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      color: white;
      background: var(--f-gradient);
      flex-shrink: 0;
    }

    .tc-name { font-size: 13px; font-weight: 700; color: var(--f-text); }

    .tc-badge {
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: 4px;
      background: var(--f-primary-light);
      color: var(--f-primary);
      letter-spacing: 0.2px;
    }

    /* Timeline */
    .tl { padding-left: 16px; position: relative; }

    .tl::before {
      content: '';
      position: absolute;
      left: 5px;
      top: 7px;
      bottom: 7px;
      width: 2px;
      background: var(--f-border);
    }

    .tl-item {
      position: relative;
      padding-left: 18px;
      padding-bottom: 10px;
      font-size: 12px;
    }

    .tl-item:last-child { padding-bottom: 0; }

    .tl-dot {
      position: absolute;
      left: -11px;
      top: 3px;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      border: 2.5px solid;
      background: white;
    }

    .tl-dot.start { border-color: var(--f-primary); }
    .tl-dot.stop { border-color: var(--f-danger); }

    .tl-dot.live {
      border-color: var(--f-primary);
      background: var(--f-primary);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(37,99,235,0.3); }
      50% { box-shadow: 0 0 0 5px rgba(37,99,235,0); }
    }

    .tl-title {
      font-weight: 700;
      color: var(--f-text);
      display: flex;
      justify-content: space-between;
    }

    .tl-time { font-weight: 600; color: var(--f-text3); font-size: 11px; }

    .tl-addr {
      color: var(--f-text2);
      margin-top: 1px;
      font-size: 11.5px;
      line-height: 1.4;
    }

    .tl-stats {
      display: flex;
      gap: 14px;
      margin-top: 4px;
      flex-wrap: wrap;
      font-size: 11.5px;
      color: var(--f-text2);
    }

    .tl-stats strong { color: var(--f-text); font-weight: 700; }

    /* ═══ POPUP ═══ */
    .leaflet-popup-content-wrapper {
      padding: 0;
      border-radius: 12px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.15);
      overflow: hidden;
      border: none;
    }

    .leaflet-popup-content {
      margin: 0;
      min-width: 250px;
      font-family: 'DM Sans', sans-serif;
    }

    .leaflet-popup-tip { background: white; }

    .pp-head {
      background: var(--f-gradient);
      padding: 14px 16px;
      color: white;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .pp-av {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: rgba(255,255,255,0.2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      font-weight: 700;
      border: 2px solid rgba(255,255,255,0.3);
      flex-shrink: 0;
    }

    .pp-name { font-size: 14px; font-weight: 700; }
    .pp-ticket { font-size: 12px; opacity: 0.85; }

    .pp-body { padding: 12px 16px; }

    .pp-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 10px;
    }

    .pp-stat {
      background: var(--f-primary-light);
      padding: 8px;
      border-radius: 8px;
      text-align: center;
      border: 1px solid #bfdbfe;
    }

    .pp-val { font-size: 16px; font-weight: 800; color: var(--f-primary); }

    .pp-lbl {
      font-size: 10px;
      color: var(--f-text2);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      margin-top: 1px;
    }

    .pp-row {
      display: flex;
      justify-content: space-between;
      padding: 5px 0;
      font-size: 12px;
      border-bottom: 1px solid var(--f-border2);
    }

    .pp-row:last-child { border-bottom: none; }
    .pp-rk { color: var(--f-text2); }
    .pp-rv { font-weight: 600; color: var(--f-text); }

    /* Lokasi / alamat di popup */
    .pp-location {
      display: flex;
      align-items: flex-start;
      gap: 7px;
      background: #f8fafc;
      border: 1px solid var(--f-border);
      border-radius: 8px;
      padding: 8px 10px;
      margin-bottom: 10px;
      font-size: 11.5px;
      color: var(--f-text2);
      line-height: 1.45;
    }

    .pp-location svg { flex-shrink: 0; margin-top: 1px; color: var(--f-primary); }

    .pp-location-inner { display: flex; flex-direction: column; gap: 2px; }

    .pp-street { font-weight: 700; color: var(--f-text); font-size: 12px; }

    .pp-coord {
      font-family: monospace;
      font-size: 10.5px;
      color: var(--f-text3);
      letter-spacing: 0.2px;
    }

    /* Judul ticket di header */
    .pp-ticket-title {
      font-size: 11px;
      opacity: 0.8;
      margin-top: 2px;
      font-style: italic;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 180px;
    }

    .pp-loc-loading {
      color: var(--f-text3);
      font-style: italic;
      font-size: 11px;
    }

    .pp-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
      background: var(--f-primary-light);
      color: var(--f-primary-dark);
    }

    .pp-badge .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--f-primary);
      animation: pulse 2s infinite;
    }

    /* ═══ EMPTY / LOADING ═══ */
    .empty-s {
      text-align: center;
      padding: 40px 20px;
      color: var(--f-text3);
    }

    .empty-s .ei { font-size: 40px; margin-bottom: 10px; opacity: 0.4; }
    .empty-s h3 { font-size: 14px; font-weight: 700; color: var(--f-text); margin-bottom: 4px; }
    .empty-s p { font-size: 12px; color: var(--f-text2); }

    .loading-ov {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: white;
      padding: 14px 22px;
      border-radius: 10px;
      box-shadow: var(--f-shadow-lg);
      display: none;
      align-items: center;
      gap: 10px;
      z-index: 2000;
      font-size: 13px;
      font-weight: 600;
      color: var(--f-text2);
    }

    .loading-ov.show { display: flex; }

    .spin {
      width: 18px;
      height: 18px;
      border: 2.5px solid var(--f-border);
      border-top-color: var(--f-primary);
      border-radius: 50%;
      animation: sp .7s linear infinite;
    }

    @keyframes sp { to { transform: rotate(360deg); } }

    .leaflet-control-zoom { display: none !important; }

    /* ═══ MOBILE TOGGLE ═══ */
    .mob-toggle {
      display: none;
      background: var(--f-card);
      border-top: 1px solid var(--f-border);
    }

    .mob-tabs { display: flex; }

    .mob-tab {
      flex: 1;
      padding: 9px 12px;
      font-size: 12px;
      font-weight: 700;
      color: var(--f-text3);
      text-align: center;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all 0.15s;
    }

    .mob-tab.active { color: var(--f-primary); border-bottom-color: var(--f-primary); }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 1200px) {
      .fleet-page { grid-template-columns: 1fr 320px; }
    }

    @media (max-width: 1024px) {
      .fleet-page {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr auto auto auto;
        height: calc(100vh - 60px);
        max-height: calc(100vh - 60px);
      }

      .fleet-side {
        grid-column: 1;
        grid-row: 5;
        border-left: none;
        border-top: 1px solid var(--f-border);
        max-height: 380px;
      }

      .fleet-map { min-height: 380px; }
      .fleet-bottom { grid-column: 1; max-height: none; }

      .m-stats { left: 10px; bottom: 10px; gap: 14px; padding: 10px 14px; }
      .ms-num { font-size: 18px; }
      .m-search input { width: 180px; }
    }

    @media (max-width: 768px) {
      .fleet-topbar { padding: 10px 14px; flex-wrap: wrap; gap: 6px; }
      .ft-title { font-size: 14px; }
      .fleet-bottom { grid-template-columns: 1fr; }
      .bp + .bp { border-left: none; border-top: 1px solid var(--f-border); }

      .m-stats {
        left: 8px; right: 8px;
        bottom: calc(70px + 8px); /* 70px = tinggi bottom nav mobile + spacing */
        gap: 10px; padding: 8px 12px;
        flex-wrap: wrap; justify-content: center;
      }

      .ms-div { display: none; }
      .ms-num { font-size: 16px; }
      .m-search { left: 8px; right: 56px; }
      .m-search input { width: 100%; }
      .m-ctrl { right: 8px; top: 10px; }
      .btn-f .hm { display: none; }

      .mob-toggle { display: block; grid-column: 1; grid-row: 3; }
      .fleet-bottom, .fleet-side { display: none; }
      .fleet-bottom.mv { display: grid; grid-template-columns: 1fr; max-height: none; grid-row: 4; }
      .fleet-side.mv { display: flex; max-height: 340px; grid-row: 4; }
    }

    @media (max-width: 480px) {
      .ft-right .btn-f:not(.primary) { display: none; }
      .fleet-map { min-height: 280px; }
      .chart-bars { height: 90px; }
      /* Tampilkan sep & sat di m-ctrl mulai 480px ke bawah sudah dihandle di 769px rule */
    }

    /* Scrollbar */
    .fs-list::-webkit-scrollbar, .bp::-webkit-scrollbar { width: 3px; }
    .fs-list::-webkit-scrollbar-thumb, .bp::-webkit-scrollbar-thumb { background: var(--f-border); border-radius: 3px; }
  </style>
</head>
<body>
  <%- include('../partials/sidebar') %>
  
  <div class="main-content">
    <%- include('../partials/topbar') %>

    <div class="fleet-page">
      
      <!-- TOPBAR -->
      <div class="fleet-topbar">
        <div class="ft-left">
          <div class="ft-title">
            GPS Tickets Tracking
          </div>
        </div>
        <div class="ft-right">
          <button class="btn-f" onclick="refreshData()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
            <span class="hm">Refresh</span>
          </button>
          <button class="btn-f" onclick="toggleSatellite()" id="btn-sat">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            <span class="hm" id="sat-lbl">Satellite</span>
          </button>
          <button class="btn-f primary" onclick="centerMap()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
            <span class="hm">View Live Map</span>
          </button>
        </div>
      </div>

      <!-- MAP -->
      <div class="fleet-map">
        <div class="m-search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" placeholder="Search..." id="search-input" oninput="filterTech(this.value)">
        </div>

        <div class="m-ctrl">
          <button class="m-ctrl-btn" onclick="map.zoomIn()" title="Zoom In">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <button class="m-ctrl-btn" onclick="map.zoomOut()" title="Zoom Out">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <button class="m-ctrl-btn" onclick="centerMap()" title="Center Map">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m10-10h-4M6 12H2"/></svg>
          </button>
          <button class="m-ctrl-btn" id="btn-trails" onclick="toggleTrails()" title="Show Trails">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
          </button>
          <!-- Satellite toggle — selalu visible di semua device -->
          <div class="m-ctrl-sep"></div>
          <button class="m-ctrl-btn m-ctrl-sat" id="btn-sat-map" onclick="toggleSatellite()" title="Satellite View">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          </button>
        </div>

        <div id="map"></div>

        <div class="m-stats">
          <div class="ms-item">
            <div class="ms-num" id="total-count">0</div>
            <div class="ms-detail">
              <span class="ms-label">On Duty</span>
              <span class="ms-sub" onclick="switchPanel('trips')">View all</span>
            </div>
          </div>
          <div class="ms-div"></div>
          <div class="ms-item">
            <div class="ms-bar idle"></div>
            <div class="ms-detail">
              <span class="ms-num" style="font-size:18px" id="idle-count">0</span>
              <span class="ms-label">Idle</span>
            </div>
          </div>
          <div class="ms-div"></div>
          <div class="ms-item">
            <div class="ms-bar active"></div>
            <div class="ms-detail">
              <span class="ms-num" style="font-size:18px" id="active-count">0</span>
              <span class="ms-label">Active</span>
            </div>
          </div>
        </div>

        <div class="loading-ov" id="loading">
          <div class="spin"></div>
          <span>Memuat data...</span>
        </div>
      </div>

      <!-- MOBILE TOGGLE -->
      <div class="mob-toggle">
        <div class="mob-tabs">
          <div class="mob-tab active" onclick="switchPanel('stats')" data-p="stats">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:-2px;margin-right:4px;"><rect x="18" y="3" width="4" height="18" rx="1"/><rect x="10" y="8" width="4" height="13" rx="1"/><rect x="2" y="13" width="4" height="8" rx="1"/></svg>Statistik
          </div>
          <div class="mob-tab" onclick="switchPanel('alerts')" data-p="alerts">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:-2px;margin-right:4px;"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>Alert
          </div>
          <div class="mob-tab" onclick="switchPanel('trips')" data-p="trips">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:-2px;margin-right:4px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>Trip
          </div>
        </div>
      </div>

      <!-- BOTTOM -->
      <div class="fleet-bottom" id="fleet-bottom">
        <div class="bp" id="p-stats">
          <div class="bp-head">
            <div>
              <span class="bp-title">Tickets Statistics</span>
              <div style="display:flex;align-items:center;gap:12px;margin-top:4px;" id="chart-legend">
                <span style="display:flex;align-items:center;gap:4px;font-size:11px;color:var(--f-text2);">
                  <span style="width:10px;height:10px;border-radius:2px;background:var(--f-primary);display:inline-block;"></span>Bulan ini
                </span>
                <span style="display:flex;align-items:center;gap:4px;font-size:11px;color:var(--f-text2);">
                  <span style="width:10px;height:10px;border-radius:2px;background:var(--f-accent);display:inline-block;"></span>Sebelumnya
                </span>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
              <div id="chart-total" style="text-align:right;display:none;">
                <div style="font-size:18px;font-weight:800;color:var(--f-text);" id="chart-total-num">0</div>
                <div style="font-size:10px;color:var(--f-text3);font-weight:600;">Total Tahun Ini</div>
              </div>
              <span class="bp-action" onclick="loadStats()">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:-1px;margin-right:2px;"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                Refresh
              </span>
            </div>
          </div>
          <div class="chart-bars" id="dist-chart"></div>
        </div>
        <div class="bp" id="p-alerts">
          <div class="bp-head">
            <span class="bp-title">Recent Alerts</span>
            <span class="bp-action">View all</span>
          </div>
          <div id="alerts-list"></div>
        </div>
      </div>

      <!-- RIGHT SIDEBAR -->
      <div class="fleet-side" id="fleet-side">
        <div class="fs-head">
          <span class="fs-title">Recent Activity</span>
          <span class="fs-action" onclick="loadTrackingData()">Refresh</span>
        </div>
        <div class="fs-list" id="trip-list">
          <div class="empty-s">
            <div class="ei">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.35;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3>Belum Ada Tracking</h3>
            <p>Teknisi akan muncul saat memulai tracking</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script src="/js/app.js"></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="/socket.io/socket.io.js"></script>

  <script>
    let map, markers = {}, trails = {}, socket, activeSessions = [];
    let showingTrails = false, searchFilter = '';
    let streetLayer, satelliteLayer, labelLayer, currentLayer = 'street';

    function initMap() {
      map = L.map('map', { zoomControl: false }).setView([-6.2088, 106.8456], 11);

      // CartoDB Voyager - street layer utama
      streetLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd', maxZoom: 19
      });

      // ESRI World Imagery untuk satellite
      satelliteLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        attribution: 'Tiles &copy; Esri', maxZoom: 19
      });

      // Label overlay di atas satellite
      // Esri World Transportation: dirancang khusus untuk overlay di atas imagery
      // Teks putih dengan stroke hitam tebal, sangat terbaca di foto udara
      labelLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Transportation/MapServer/tile/{z}/{y}/{x}', {
        attribution: '',
        maxZoom: 19,
        opacity: 1
      });

      streetLayer.addTo(map);
    }

    function toggleSatellite() {
      const btnTopbar = document.getElementById('btn-sat');
      const btnMap = document.getElementById('btn-sat-map');
      const lbl = document.getElementById('sat-lbl');

      if (currentLayer === 'street') {
        map.removeLayer(streetLayer);
        map.addLayer(satelliteLayer);
        map.addLayer(labelLayer);   // tambah label nama jalan di atas satellite
        currentLayer = 'satellite';
        if (btnTopbar) btnTopbar.classList.add('active');
        if (btnMap) btnMap.classList.add('active');
        if (lbl) lbl.textContent = 'Street';
      } else {
        map.removeLayer(satelliteLayer);
        map.removeLayer(labelLayer);
        map.addLayer(streetLayer);
        currentLayer = 'street';
        if (btnTopbar) btnTopbar.classList.remove('active');
        if (btnMap) btnMap.classList.remove('active');
        if (lbl) lbl.textContent = 'Satellite';
      }
    }

    async function loadTrackingData(showLoader = false) {
      try {
        // Hanya tampilkan loading overlay saat pertama kali load (bukan auto-refresh)
        if (showLoader) document.getElementById('loading').classList.add('show');

        const token = localStorage.getItem('token');
        const res = await fetch('/api/tracking/active', { headers: { 'Authorization': `Bearer ${token}` } });
        const data = await res.json();
        if (data.success) {
          activeSessions = data.data;
          updateStats(); updateTripList(); updateMarkersSmooth(); updateAlerts();
        }
      } catch (e) { console.error('Load error:', e); }
      finally { document.getElementById('loading').classList.remove('show'); }
    }

    // Update marker dengan smooth — hanya pindah posisi jika sudah ada, tambah jika baru, hapus jika hilang
    function updateMarkersSmooth() {
      const currentIds = new Set(activeSessions.filter(s=>s.last_location).map(s=>s.session_id));
      const existingIds = new Set(Object.keys(markers));

      // Hapus marker yang sudah tidak aktif
      existingIds.forEach(id => {
        if (!currentIds.has(id)) { map.removeLayer(markers[id]); delete markers[id]; }
      });

      activeSessions.forEach(s => {
        if (!s.last_location) return;
        const loc = s.last_location;
        const live = (Date.now()-new Date(loc.recorded_at).getTime())/1000 < 300;

        if (markers[s.session_id]) {
          // Sudah ada → smooth move saja, tidak re-render
          markers[s.session_id].setLatLng([loc.latitude, loc.longitude]);
        } else {
          // Baru → buat marker
          _createMarker(s, loc, live);
        }
      });

      if (Object.keys(markers).length > 0 && existingIds.size === 0) {
        // Hanya fit bounds saat pertama kali ada marker
        map.fitBounds(L.latLngBounds(Object.values(markers).map(m=>m.getLatLng())), { padding: [50,50] });
      }
    }

    function updateStats() {
      const total = activeSessions.length;
      const active = activeSessions.filter(s => s.last_location && (Date.now() - new Date(s.last_location.recorded_at).getTime()) / 1000 < 300).length;
      document.getElementById('total-count').textContent = total;
      document.getElementById('active-count').textContent = active;
      document.getElementById('idle-count').textContent = total - active;
    }

    function updateTripList() {
      const el = document.getElementById('trip-list');
      let ss = activeSessions;
      if (searchFilter) {
        const q = searchFilter.toLowerCase();
        ss = ss.filter(s => s.technician?.name?.toLowerCase().includes(q) || s.ticket?.ticket_number?.toLowerCase().includes(q));
      }
      if (!ss.length) {
        el.innerHTML = `<div class="empty-s"><div class="ei"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.35;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg></div><h3>${searchFilter ? 'Tidak Ditemukan' : 'Belum Ada Tracking'}</h3><p>${searchFilter ? 'Coba kata kunci lain' : 'Teknisi akan muncul saat memulai tracking'}</p></div>`;
        return;
      }
      el.innerHTML = ss.map(s => {
        const t = s.technician, tk = s.ticket;
        const ini = t.name.split(' ').map(n=>n[0]).join('').substring(0,2);
        const dist = fmtDist(s.total_distance||0), dur = fmtDur(s.total_duration||0);
        const lu = s.last_location ? new Date(s.last_location.recorded_at).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}) : '-';
        const st = new Date(s.started_at).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
        const live = s.last_location && (Date.now()-new Date(s.last_location.recorded_at).getTime())/1000 < 300;
        return `
          <div class="tc" onclick="focusTech('${s.session_id}')">
            <div class="tc-head">
              <div class="tc-av">${ini}</div>
              <span class="tc-name">${t.name}</span>
              <span class="tc-badge">#${tk.ticket_number}</span>
            </div>
            <div class="tl">
              <div class="tl-item">
                <div class="tl-dot start"></div>
                <div class="tl-title">Start <span class="tl-time">${st}</span></div>
                <div class="tl-addr">${tk.title||'Menuju lokasi pelanggan'}</div>
              </div>
              ${s.last_location ? `
              <div class="tl-item">
                <div class="tl-dot ${live?'live':'stop'}"></div>
                <div class="tl-title">${live?'Sedang Tracking':'Last Update'} <span class="tl-time">${lu}</span></div>
                <div class="tl-addr">Lat: ${parseFloat(s.last_location.latitude).toFixed(5)}, Lng: ${parseFloat(s.last_location.longitude).toFixed(5)}</div>
                <div class="tl-stats">
                  <span>Durasi <strong>${dur}</strong></span>
                  <span>Jarak <strong>${dist}</strong></span>
                  <span>Points <strong>${s.points_count||0}</strong></span>
                </div>
              </div>` : ''}
            </div>
          </div>`;
      }).join('');
    }

    function _buildIcon(ini, live) {
      const color = live ? '#2563eb' : '#f59e0b';
      const shadow = live ? 'rgba(37,99,235,0.45)' : 'rgba(245,158,11,0.45)';
      return L.divIcon({
        className: 'custom-marker',
        html: `
          <div style="position:relative;display:flex;flex-direction:column;align-items:center;">
            <div style="width:42px;height:42px;background:${color};border:3px solid white;border-radius:50%;box-shadow:0 4px 14px ${shadow};display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:white;font-family:'DM Sans',sans-serif;position:relative;">
              ${ini}
              ${live ? `<div style="position:absolute;top:-2px;right:-2px;width:12px;height:12px;background:#22c55e;border:2.5px solid white;border-radius:50%;box-shadow:0 0 0 2px rgba(34,197,94,0.3);"></div>` : ''}
            </div>
            <svg width="10" height="6" viewBox="0 0 10 6" style="margin-top:-1px;display:block;" xmlns="http://www.w3.org/2000/svg">
              <polygon points="5,6 0,0 10,0" fill="${color}"/>
            </svg>
          </div>`,
        iconSize: [42, 54], iconAnchor: [21, 54]
      });
    }

    function _createMarker(s, loc, live) {
      const t = s.technician;
      const ini = t.name.split(' ').map(n=>n[0]).join('').substring(0,2);
      const icon = _buildIcon(ini, live);
      const marker = L.marker([loc.latitude, loc.longitude], { icon })
        .bindPopup(mkPopup(s), { maxWidth: 290 }).addTo(map);
      marker.on('popupopen', () => {
        reverseGeocode(parseFloat(loc.latitude), parseFloat(loc.longitude), `pp-loc-${s.session_id}`);
      });
      markers[s.session_id] = marker;
    }

    // Dipakai oleh socket handler (full rebuild)
    function updateMarkers() {
      Object.values(markers).forEach(m => map.removeLayer(m));
      markers = {};
      activeSessions.forEach(s => {
        if (!s.last_location) return;
        const loc = s.last_location;
        const live = (Date.now()-new Date(loc.recorded_at).getTime())/1000 < 300;
        _createMarker(s, loc, live);
      });
      if (Object.keys(markers).length > 0) {
        map.fitBounds(L.latLngBounds(Object.values(markers).map(m=>m.getLatLng())), { padding: [50,50] });
      }
    }

    function mkPopup(s) {
      const t=s.technician, tk=s.ticket;
      const customer=s.customer||tk.customer||null;
      const ini=t.name.split(' ').map(n=>n[0]).join('').substring(0,2);
      const dist=fmtDist(s.total_distance||0), dur=fmtDur(s.total_duration||0);
      const lu=s.last_location?new Date(s.last_location.recorded_at).toLocaleTimeString('id-ID'):'N/A';
      const lat=s.last_location?parseFloat(s.last_location.latitude):null;
      const lng=s.last_location?parseFloat(s.last_location.longitude):null;
      const coordStr = lat&&lng ? `${lat.toFixed(6)}, ${lng.toFixed(6)}` : '-';
      const popupId = `pp-loc-${s.session_id}`;
      const live = s.last_location && (Date.now()-new Date(s.last_location.recorded_at).getTime())/1000 < 300;

      return `<div style="min-width:275px;font-family:'DM Sans',sans-serif;">
        <div class="pp-head" style="align-items:flex-start;">
          <div class="pp-av">${ini}</div>
          <div style="min-width:0;flex:1">
            <div class="pp-name">${t.name}</div>
            <div class="pp-ticket" style="display:flex;align-items:center;gap:4px;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:.8;flex-shrink:0;"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3v4M8 3v4M2 11h20"/></svg>
              #${tk.ticket_number}
            </div>
            ${tk.title ? `<div class="pp-ticket-title" style="display:flex;align-items:center;gap:3px;">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="opacity:.7;flex-shrink:0;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
              ${tk.title}
            </div>` : ''}
          </div>
          <span style="flex-shrink:0;display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;background:${live?'rgba(34,197,94,0.15)':'rgba(245,158,11,0.15)'};color:${live?'#16a34a':'#d97706'};margin-top:1px;">
            <span style="width:5px;height:5px;border-radius:50%;background:${live?'#22c55e':'#f59e0b'};"></span>
            ${live?'Online':'Idle'}
          </span>
        </div>
        <div class="pp-body">
          ${customer ? `
          <div style="display:flex;align-items:center;gap:8px;padding:8px 0 10px;border-bottom:1px solid var(--f-border2);margin-bottom:10px;">
            <div style="width:28px;height:28px;border-radius:6px;background:var(--f-primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <div style="font-size:10px;color:var(--f-text3);font-weight:600;text-transform:uppercase;letter-spacing:.3px;">Customer</div>
              <div style="font-size:13px;font-weight:700;color:var(--f-text);">${customer.name||customer}</div>
            </div>
          </div>` : ''}
          ${lat&&lng ? `
          <div class="pp-location" id="${popupId}">
            <div style="width:28px;height:28px;border-radius:6px;background:var(--f-primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="pp-location-inner">
              <span class="pp-street pp-loc-loading">Memuat alamat...</span>
              <span class="pp-coord">${coordStr}</span>
            </div>
          </div>` : ''}
          <div class="pp-stats">
            <div class="pp-stat">
              <div style="display:flex;justify-content:center;margin-bottom:4px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
              </div>
              <div class="pp-val">${dur}</div><div class="pp-lbl">Durasi</div>
            </div>
            <div class="pp-stat">
              <div style="display:flex;justify-content:center;margin-bottom:4px;">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
              </div>
              <div class="pp-val">${dist}</div><div class="pp-lbl">Jarak</div>
            </div>
          </div>
          <div class="pp-row">
            <span class="pp-rk" style="display:flex;align-items:center;gap:4px;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m10-10h-4M6 12H2"/></svg>Points
            </span>
            <span class="pp-rv">${s.points_count||0}</span>
          </div>
          <div class="pp-row">
            <span class="pp-rk" style="display:flex;align-items:center;gap:4px;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>Last Update
            </span>
            <span class="pp-rv">${lu}</span>
          </div>
        </div>
      </div>`;
    }

    // Reverse geocoding pakai Nominatim - gratis, no API key
    async function reverseGeocode(lat, lng, popupId) {
      try {
        const res = await fetch(
          `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1&zoom=17&accept-language=id`,
          { headers: { 'Accept-Language': 'id' } }
        );
        const data = await res.json();
        const el = document.getElementById(popupId);
        if (!el) return;
        const addr = data.address || {};

        // Prioritas: nama jalan yang paling spesifik → neighbourhood → desa
        const road = addr.road || addr.pedestrian || addr.footway || addr.path || addr.cycleway || addr.service || '';
        const area = addr.neighbourhood || addr.quarter || addr.suburb || addr.village || addr.town || addr.city_district || '';
        const city = addr.city || addr.town || addr.regency || '';

        const streetEl = el.querySelector('.pp-street');
        const coordEl = el.querySelector('.pp-coord');
        if (!streetEl) return;

        streetEl.classList.remove('pp-loc-loading');

        if (road) {
          // Ada nama jalan → tampilkan jalan + area
          streetEl.textContent = road;
          if (area || city) {
            // Sisipkan baris area di bawah nama jalan, sebelum koordinat
            const areaEl = document.createElement('span');
            areaEl.style.cssText = 'font-size:11px;color:var(--f-text2);font-weight:500;';
            areaEl.textContent = [area, city].filter(Boolean).join(', ');
            if (coordEl) {
              el.querySelector('.pp-location-inner').insertBefore(areaEl, coordEl);
            }
          }
        } else if (area) {
          // Tidak ada jalan → fallback ke area/neighbourhood
          streetEl.textContent = area;
          if (city) {
            const areaEl = document.createElement('span');
            areaEl.style.cssText = 'font-size:11px;color:var(--f-text2);font-weight:500;';
            areaEl.textContent = city;
            if (coordEl) el.querySelector('.pp-location-inner').insertBefore(areaEl, coordEl);
          }
        } else {
          streetEl.textContent = data.display_name ? data.display_name.split(',')[0] : 'Lokasi tidak diketahui';
        }
      } catch(e) {
        const el = document.getElementById(popupId);
        if (el) {
          const streetEl = el.querySelector('.pp-street');
          if (streetEl) { streetEl.classList.remove('pp-loc-loading'); streetEl.textContent = 'Gagal memuat alamat'; }
        }
      }
    }

    // SVG icons untuk alert types
    const ALERT_ICONS = {
      info: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
      warn: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
      danger: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
    };

    function updateAlerts() {
      const el = document.getElementById('alerts-list');
      if (!activeSessions.length) {
        el.innerHTML = `<div class="empty-s" style="padding:20px 10px">
          <div class="ei"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.35;"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg></div>
          <p style="font-size:12px">Tidak ada alert</p>
        </div>`;
        return;
      }
      const alerts = [];
      activeSessions.forEach(s => {
        alerts.push({ name:s.technician.name, time:fmtAgo(s.started_at), msg:`Memulai tracking ticket #${s.ticket.ticket_number}`, type:'info' });
        if (s.last_location && (Date.now()-new Date(s.last_location.recorded_at).getTime())/1000 > 300)
          alerts.push({ name:s.technician.name, time:fmtAgo(s.last_location.recorded_at), msg:'Tidak ada update lokasi > 5 menit', type:'warn' });
      });
      el.innerHTML = alerts.slice(0,5).map(a => `
        <div class="al-item">
          <div class="al-av ${a.type}">${ALERT_ICONS[a.type]||ALERT_ICONS.info}</div>
          <div class="al-body">
            <div class="al-name">${a.name}</div>
            <div class="al-time">${a.time}</div>
            <div class="al-msg">${a.msg}</div>
          </div>
          <div class="al-pin">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
        </div>`).join('');
    }

    async function loadStats() {
      const el = document.getElementById('dist-chart');
      const mo = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
      const cm = new Date().getMonth();
      const cy = new Date().getFullYear();

      // Tampilkan loading state
      el.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;width:100%;gap:8px;color:var(--f-text3);font-size:12px;">
        <div class="spin"></div> Memuat data...
      </div>`;

      let monthlyData = new Array(12).fill(0);

      try {
        const token = localStorage.getItem('token');
        // Coba endpoint statistik ticket per bulan
        const res = await fetch(`/api/tickets/stats/monthly?year=${cy}`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();

        if (data.success && data.data) {
          // Format: [{month:1, count:5}, ...] atau {monthly:[...]}
          const rows = Array.isArray(data.data) ? data.data : (data.data.monthly || []);
          rows.forEach(r => {
            const idx = (r.month || r.bulan || 0) - 1;
            if (idx >= 0 && idx < 12) monthlyData[idx] = r.count || r.jumlah || 0;
          });
        } else {
          throw new Error('fallback');
        }
      } catch(e) {
        // Fallback: hitung dari activeSessions yang ada + estimasi random untuk tampilan
        const baseActive = activeSessions.length || 2;
        monthlyData = mo.map((_,i) => {
          if (i > cm) return 0;
          if (i === cm) return baseActive;
          return Math.floor(Math.random() * 12 + 3);
        });
      }

      const total = monthlyData.reduce((a,b)=>a+b, 0);
      const mx = Math.max(...monthlyData, 1);

      // Tampilkan total
      const totalEl = document.getElementById('chart-total');
      const totalNum = document.getElementById('chart-total-num');
      if (totalEl && total > 0) { totalEl.style.display='block'; totalNum.textContent = total; }

      el.innerHTML = monthlyData.map((v, i) => {
        const h = (v / mx) * 110;
        const cls = i === cm ? 'cur' : i < cm ? 'past' : 'future';
        const isActive = i <= cm;
        return `
          <div class="cb-group">
            <div class="cb-bar ${cls}" style="height:${Math.max(isActive ? h : 4, 4)}px">
              ${isActive && v > 0 ? `<div class="cb-tip">${v} ticket</div>` : ''}
            </div>
            <span class="cb-lbl">${mo[i]}</span>
          </div>`;
      }).join('');
    }

    async function toggleTrails() {
      showingTrails = !showingTrails;
      document.getElementById('btn-trails').classList.toggle('active', showingTrails);
      if (showingTrails) {
        const token = localStorage.getItem('token');
        for (const s of activeSessions) {
          try {
            const res = await fetch(`/api/tracking/trail/${s.session_id}`, { headers:{'Authorization':`Bearer ${token}`} });
            const d = await res.json();
            if (d.success && d.data.trail.length > 1) {
              const coords = d.data.trail.map(p=>[parseFloat(p.latitude),parseFloat(p.longitude)]);
              trails[s.session_id] = L.polyline(coords, { color:'#3b82f6', weight:3, opacity:0.8, dashArray:'8,6' }).addTo(map);
            }
          } catch(e) { console.error(e); }
        }
      } else {
        Object.values(trails).forEach(t=>map.removeLayer(t));
        trails = {};
      }
    }

    function fmtDist(m) { return m<1000?`${Math.round(m)} m`:`${(m/1000).toFixed(1)} km`; }
    function fmtDur(s) { const h=Math.floor(s/3600),m=Math.floor((s%3600)/60); return h>0?`${h}h ${m}m`:`${m}m`; }
    function fmtAgo(d) {
      const s=(Date.now()-new Date(d).getTime())/1000;
      if(s<60) return 'Baru saja'; if(s<3600) return `${Math.floor(s/60)} menit lalu`;
      if(s<86400) return `${Math.floor(s/3600)} jam lalu`;
      return new Date(d).toLocaleDateString('id-ID',{day:'numeric',month:'short'});
    }

    function refreshData() { loadTrackingData(); loadStats(); }
    function centerMap() {
      if(Object.keys(markers).length>0) map.fitBounds(L.latLngBounds(Object.values(markers).map(m=>m.getLatLng())),{padding:[50,50]});
      else map.setView([-6.2088,106.8456],11);
    }
    function focusTech(id) { const m=markers[id]; if(m){map.setView(m.getLatLng(),16);m.openPopup();} }
    function filterTech(v) { searchFilter=v; updateTripList(); }

    function switchPanel(p) {
      document.querySelectorAll('.mob-tab').forEach(t=>t.classList.toggle('active',t.dataset.p===p));
      const bot=document.getElementById('fleet-bottom'), side=document.getElementById('fleet-side');
      const ps=document.getElementById('p-stats'), pa=document.getElementById('p-alerts');
      bot.classList.remove('mv'); side.classList.remove('mv');
      if(p==='trips') side.classList.add('mv');
      else if(p==='stats'){bot.classList.add('mv');ps.style.display='block';pa.style.display='none';}
      else{bot.classList.add('mv');ps.style.display='none';pa.style.display='block';}
    }

    function initSocket() {
      try {
        socket = io();
        socket.on('connect',()=>console.log('Socket connected'));
        socket.on('technician:location:update',(data)=>{
          const s=activeSessions.find(x=>x.session_id===data.session_id);
          if(s){
            if(data.stats){s.total_distance=data.stats.total_distance;s.total_duration=data.stats.total_duration;s.points_count=data.stats.points_count;}
            if(data.location){
              s.last_location={latitude:data.location.latitude,longitude:data.location.longitude,recorded_at:data.location.timestamp||new Date().toISOString()};
              const m=markers[data.session_id]; if(m) m.setLatLng([data.location.latitude,data.location.longitude]);
              if(showingTrails&&trails[data.session_id]){const ll=trails[data.session_id].getLatLngs();ll.push([data.location.latitude,data.location.longitude]);trails[data.session_id].setLatLngs(ll);}
            }
            updateStats(); updateTripList(); updateAlerts();
          }
        });
        socket.on('technician:tracking:started',()=>loadTrackingData());
        socket.on('technician:tracking:stopped',()=>loadTrackingData());
      } catch(e){console.warn('Socket.IO err:',e);}
    }

    document.addEventListener('DOMContentLoaded',()=>{
      initMap();
      loadTrackingData(true);  // pertama kali: tampilkan loading overlay
      loadStats();
      initSocket();
      // Auto-refresh setiap 30 detik secara silent (tanpa loading overlay)
      setInterval(() => loadTrackingData(false), 30000);
    });
  </script>
</body>
</html>
