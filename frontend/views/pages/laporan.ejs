<script>
let _view='monthly', _mainChart, _methodChart, _trendChart, _txData=[];
const MET_COLORS={cash:'#1a6ef5',transfer:'#00c896',dana:'#f5365c',ovo:'#6e44ff',gopay:'#00aa5b',qris:'#fb8c00'};
const MET_NAMES={cash:'Cash',transfer:'Transfer Bank',dana:'DANA',ovo:'OVO',gopay:'GoPay',qris:'QRIS'};
const MET_BADGE={cash:{bg:'#f0fdf4',color:'#166534'},transfer:{bg:'#eff6ff',color:'#1d4ed8'},dana:{bg:'#fff0f2',color:'#c0183a'},ovo:{bg:'#f5f3ff',color:'#5b21b6'},gopay:{bg:'#f0fdf4',color:'#065f46'},qris:{bg:'#fff8e6',color:'#b45309'}};
const MONTHS=['','Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];

function renderMasukCats(rows, label){
  (document.getElementById('masuk-cat-title')||{textContent:''}).textContent = label||'';
  var el2 = document.getElementById('masuk-cat-list');
  if(!el2) return;
  // Filter pemasukan, exclude PAY-sync untuk hindari duplikasi dengan kolom pembayaran pelanggan
  var masukRows = rows.filter(function(r){ return r.type==='pemasukan'; });
  if(!masukRows.length){
    el2.innerHTML='<div style="text-align:center;padding:24px;color:var(--d-muted);font-size:12.5px">Tidak ada pemasukan</div>';
    return;
  }
  var grp = {};
  masukRows.forEach(function(r){
    var cat = r.category||'Lain-lain';
    if(!grp[cat]) grp[cat]={total:0,cnt:0};
    grp[cat].total += parseFloat(r.amount)||0;
    grp[cat].cnt++;
  });
  var entries = Object.entries(grp).sort(function(a,b){return b[1].total-a[1].total;});
  var max = Math.max(1, entries[0][1].total);
  var COLORS = ['#16a34a','#2563eb','#0891b2','#d97706','#7c3aed','#db2777','#059669'];
  el2.innerHTML = entries.map(function(e,i){
    var cat=e[0], v=e[1];
    var pct = Math.round(v.total/max*100);
    var col = COLORS[i%COLORS.length];
    return '<div class="cat-item">'+
      '<span style="font-size:12px;flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+cat+
        ' <span style="font-size:10px;color:var(--d-muted)">('+v.cnt+'x)</span></span>'+
      '<div class="cat-bar-bg"><div class="cat-bar-fill" style="width:'+pct+'%;background:'+col+'"></div></div>'+
      '<span style="font-size:11.5px;font-weight:700;font-family:DM Mono,monospace;min-width:70px;text-align:right">'+fmtRpK(v.total)+'</span>'+
    '</div>';
  }).join('');
}

function initSelectors(){
  const now=new Date(), yr=now.getFullYear();
  const years=Array.from({length:6},(_,i)=>yr-i);
  ['sel-year-m','sel-year-y'].forEach(id=>{
    document.getElementById(id).innerHTML=years.map(y=>`<option value="${y}">${y}</option>`).join('');
  });
  document.getElementById('sel-month').value=now.getMonth()+1;
}

function setView(v){
  _view=v;
  ['monthly','yearly'].forEach(x=>{
    document.getElementById('tab-'+x).classList.toggle('active',x===v);
    document.getElementById('sel-'+x).style.display=x===v?'flex':'none';
  });
  (document.getElementById('trend-lbl')||{textContent:''}).textContent=v==='yearly'?'Tren 6 Tahun Terakhir':'Tren 6 Bulan Terakhir';
  loadData();
}

function getParams(){
  const p={view:_view};
  if(_view==='monthly'){p.month=document.getElementById('sel-month').value;p.year=document.getElementById('sel-year-m').value;}
  else{p.year=document.getElementById('sel-year-y').value;}
  return p;
}

function fmtRp(n){return 'Rp '+new Intl.NumberFormat('id-ID').format(n||0);}
function fmtRpK(n){n=n||0;if(n>=1000000)return'Rp '+(n/1000000).toFixed(1)+'jt';if(n>=1000)return'Rp '+Math.round(n/1000)+'rb';return'Rp '+n;}
function fmtDateShort(s){if(!s)return"—";const d=new Date(s);return isNaN(d)?s:d.toLocaleDateString("id-ID",{day:"2-digit",month:"2-digit",year:"numeric"});}
function fmtDate(s){if(!s)return'—';const d=new Date(s);if(isNaN(d))return s;return d.toLocaleDateString('id-ID',{day:'2-digit',month:'2-digit',year:'numeric'});}

async function loadData(){
  const params=getParams();
  const url='/api/laporan/summary?'+new URLSearchParams(params).toString();
  try{
    const token=localStorage.getItem('token');
    const headers={'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'};
    if(token&&token!=='null')headers['Authorization']='Bearer '+token;
    const res=await fetch(url,{headers,credentials:'include'});
    const r=await res.json();
    if(!r.success)throw new Error(r.message);
    renderAll(r.data,params);
  }catch(e){
    console.error('[Laporan] ERROR:', e.message);
    // silent fail - data stays as-is
  }
}

// ── Format helpers ──
function fmtRpSign(n, forceSign=false) {
  const s = fmtRp(Math.abs(n));
  if (n < 0) return '<span style="color:#c0183a">-' + s + '</span>';
  if (forceSign && n > 0) return '<span style="color:#007a5e">+' + s + '</span>';
  return s;
}

function renderLabaRugi(lr, label) {
  // Legacy - diarahkan ke renderLR
  renderLR(lr, label, [], lr.totalPendapatan||0);
}

function renderLR(lr, label, keuRows, trueTotal) {
  if(!lr) return;
  (document.getElementById('lr-title')||{textContent:''}).textContent = label;

  // ── Baris Pembayaran Pelanggan (dari payments) ──
  const ispEl = document.getElementById('lr-recv');
  if(ispEl) ispEl.innerHTML = '<span style="color:#007a5e">+'+fmtRp(lr.pendapatanISP||0)+'</span>';

  // ── Baris manual pemasukan dari keuangan (grouped by category, exclude PAY-sync) ──
  const masukRows = (keuRows||[]).filter(function(r){
    return r.type==='pemasukan' && (r.ref_number||'').toUpperCase().indexOf('PAY-') !== 0;
  });
  const manGrp = {};
  masukRows.forEach(function(r){
    var cat = r.category || 'Lain-lain';
    if(!manGrp[cat]) manGrp[cat] = {total:0, cnt:0};
    manGrp[cat].total += parseFloat(r.amount)||0;
    manGrp[cat].cnt++;
  });
  const manRowsEl = document.getElementById('lr-manual-rows');
  if(manRowsEl){
    var entries = Object.entries(manGrp).sort(function(a,b){return b[1].total-a[1].total;});
    manRowsEl.innerHTML = entries.map(function(e){
      return '<tr><td class="lr-lbl lr-sub">'+e[0]+
        ' <span style="font-size:10px;color:var(--d-muted)">('+e[1].cnt+'x)</span></td>'+
        '<td class="lr-val lr-pos">+'+fmtRp(e[1].total)+'</td></tr>';
    }).join('');
  }

  // ── Total Pendapatan ──
  const totalPend = document.getElementById('lr-total-pend');
  if(totalPend) totalPend.innerHTML = '<span style="color:#007a5e;font-size:13.5px">+'+fmtRp(trueTotal||lr.totalPendapatan||0)+'</span>';

  // ── Pengeluaran ──
  const kelLbl = document.getElementById('lr-kel-lbl');
  if(kelLbl) kelLbl.textContent = 'Operasional ('+(lr.pengeluaranCnt||0)+' item)';
  const penEl = document.getElementById('lr-keluar');
  if(penEl) penEl.innerHTML = (lr.pengeluaran||0)>0
    ? '<span style="color:#c0183a">-'+fmtRp(lr.pengeluaran)+'</span>' : fmtRp(0);
  const totKel = document.getElementById('lr-total-kel');
  if(totKel) totKel.innerHTML = (lr.pengeluaran||0)>0
    ? '<span style="color:#c0183a">-'+fmtRp(lr.pengeluaran)+'</span>' : fmtRp(0);

  // ── Laba / Rugi ──
  const tot = trueTotal||lr.totalPendapatan||0;
  const laba = tot - (lr.pengeluaran||0);
  const labaEl = document.getElementById('lr-laba');
  if(labaEl) labaEl.innerHTML = laba>=0
    ? '<span style="color:#007a5e;font-size:15px">+'+fmtRp(laba)+'</span>'
    : '<span style="color:#c0183a;font-size:15px">-'+fmtRp(Math.abs(laba))+'</span>';

  // ── Profit Margin ──
  const margin = tot>0 ? Math.round(laba/tot*100) : 0;
  (document.getElementById('lr-margin')||{textContent:''}).textContent = margin+'%';
  const mBar = document.getElementById('lr-margin-bar');
  if(mBar){
    mBar.style.width = Math.max(0,Math.min(100,Math.abs(margin)))+'%';
    mBar.style.background = laba>=0
      ? 'linear-gradient(90deg,#00c896,#1a6ef5)'
      : 'linear-gradient(90deg,#f5365c,#fb8c00)';
  }
}

function renderCats(cats, label) {
  (document.getElementById('cat-title')||{textContent:''}).textContent = label;
  const el = document.getElementById('cat-list');
  if (!cats || !cats.length) {
    el.innerHTML = '<div style="text-align:center;padding:24px;color:var(--d-muted);font-size:13px">Tidak ada pengeluaran periode ini</div>';
    return;
  }
  const max = Math.max(1, ...cats.map(c => +c.total||0));
  el.innerHTML = cats.map(cat => {
    const pct = Math.round((+cat.total||0) / max * 100);
    return `<div class="cat-item">
      <span style="font-size:12.5px;flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${cat.category}</span>
      <div class="cat-bar-bg"><div class="cat-bar-fill" style="width:${pct}%"></div></div>
      <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;min-width:72px;text-align:right">${fmtRpK(+cat.total)}</span>
    </div>`;
  }).join('');
}

const KEU_LABEL = {pengeluaran:'Pengeluaran',hutang:'Hutang',piutang:'Piutang',modal:'Modal'};
const KEU_BADGE = {
  pengeluaran:'kb-pengeluaran', hutang:'kb-hutang',
  piutang:'kb-piutang', modal:'kb-modal'
};
const STATUS_LABEL = {lunas:'✓ Lunas', belum_lunas:'⏳ Belum', cicilan:'↺ Cicilan'};

function renderKeuTx(rows, label) {
  const sec = document.getElementById('keu-tx-section');
  if (!rows || !rows.length) { sec.style.display='none'; return; }
  sec.style.display = 'block';
  (document.getElementById('keu-tx-title')||{textContent:''}).textContent = label + ' — Pengeluaran, Hutang & Piutang';
  (document.getElementById('keu-tx-count')||{textContent:''}).textContent = rows.length + ' transaksi';
  const totalKel = rows.filter(r=>r.type==='pengeluaran').reduce((a,r)=>a+(+r.amount||0),0);

  const tbody = document.getElementById('keu-tx-tbody');
  tbody.innerHTML = rows.map(r => {
    const amtColor = r.type==='pengeluaran'||r.type==='hutang' ? '#c0183a' : r.type==='modal' ? '#007a5e' : '#0077b6';
    const statusHtml = r.status
      ? `<span class="mbadge ${r.status==='lunas'?'green':r.status==='cicilan'?'amber':'red'}" style="font-size:10.5px;padding:2px 7px">${STATUS_LABEL[r.status]||r.status}</span>`
      : '<span style="color:#d0d8e8">—</span>';
    return `<tr>
      <td style="white-space:nowrap;font-size:11.5px;color:var(--d-muted)">${fmtDateShort(r.date)}</td>
      <td><span class="keu-badge ${KEU_BADGE[r.type]||''}">${KEU_LABEL[r.type]||r.type}</span></td>
      <td>
        <div style="font-weight:600;font-size:12.5px">${r.description||'—'}</div>
        <div style="font-size:11px;color:var(--d-muted)">${r.category||''}</div>
      </td>
      <td style="font-size:12px;color:var(--d-muted)">${r.party_name||r.ref_number||'—'}</td>
      <td>${statusHtml}</td>
      <td style="text-align:right;font-family:'DM Mono',monospace;font-weight:700;color:${amtColor}">
        ${r.type==='pengeluaran'||r.type==='hutang'?'-':''}${fmtRp(+r.amount)}
      </td>
    </tr>`;
  }).join('');

  document.getElementById('keu-tx-tfoot').innerHTML = `
    <tr style="background:#f4f8ff">
      <td colspan="4" style="padding:10px 12px;font-size:12px;color:var(--d-muted)">${rows.length} transaksi</td>
      <td style="padding:10px 12px;font-size:11.5px;font-weight:600;text-align:right;color:var(--d-muted)">Total Pengeluaran</td>
      <td style="padding:10px 12px;font-size:14px;font-weight:800;font-family:'DM Mono',monospace;color:#c0183a;text-align:right">-${fmtRp(totalKel)}</td>
    </tr>`;
}

function renderAll(d,params){
  let label='';
  if(_view==='monthly')label=MONTHS[+params.month]+' '+params.year;
  else label='Tahun '+params.year;
  (document.getElementById('period-label')||{textContent:''}).textContent=label;

  // totalRecvAll = pembayaran pelanggan + pemasukan manual keuangan
  // Hitung total pemasukan dari keuRows (mencakup sync + manual)
  const keuRows = (d.keuData||{}).keuRows||[];
  const keuTotalMasuk = keuRows
    .filter(function(r){ return r.type==='pemasukan'; })
    .reduce(function(s,r){ return s+(parseFloat(r.amount)||0); }, 0);
  // Ambil nilai terbesar: totalRecvAll (payments+manual) vs keuTotalMasuk (sync+manual)
  const recv = Math.max(d.totalRecvAll||0, d.totalRecv||0, keuTotalMasuk);
  const recvISP = d.totalRecv || 0;
  const collRate = d.collectionRate||0;
  (document.getElementById('card-recv')||{textContent:''}).textContent=fmtRpK(recv);
  const keuPemas = (d.keuData||{})._keuPemasukan||0;
  const recvSubTxt = keuPemas > 0
    ? (d.totalTx||0)+' tx pelanggan + '+fmtRpK(keuPemas)+' manual'
    : (d.totalTx||0)+' transaksi · '+label;
  (document.getElementById('card-recv-sub')||{textContent:''}).textContent = recvSubTxt;
  (document.getElementById('card-recv-bar')||{style:{}}).style.width=Math.min(100,collRate)+'%';
  (document.getElementById('card-recv-pct')||{textContent:''}).textContent=fmtRp(recv)+' total';

  (document.getElementById('card-overdue')||{textContent:''}).textContent=d.totalOverdue||0;
  (document.getElementById('card-overdue-sub')||{textContent:''}).textContent=fmtRpK(d.totalOverdueAmt||0)+' potensi tertunggak';
  const odPct=d.totalActive>0?Math.round((d.totalOverdue||0)/d.totalActive*100):0;
  (document.getElementById('card-overdue-bar')||{style:{}}).style.width=Math.min(100,odPct)+'%';
  (document.getElementById('card-overdue-pct')||{textContent:''}).textContent=odPct+'% dari '+(d.totalActive||0)+' pelanggan aktif';

  (document.getElementById('card-upcoming')||{textContent:''}).textContent=d.totalUpcoming||0;
  (document.getElementById('card-upcoming-sub')||{textContent:''}).textContent=fmtRpK(d.totalUpcomingAmt||0)+' akan masuk';
  const upPct=d.totalActive>0?Math.round((d.totalUpcoming||0)/d.totalActive*100):0;
  (document.getElementById('card-upcoming-bar')||{style:{}}).style.width=Math.min(100,upPct)+'%';

  (document.getElementById('card-rate')||{textContent:''}).textContent=collRate+'%';
  (document.getElementById('card-rate-sub')||{textContent:''}).textContent=fmtRpK(d.potentialRecv||0)+' potensi total';
  (document.getElementById('card-rate-bar')||{style:{}}).style.width=Math.min(100,collRate)+'%';
  (document.getElementById('card-rate-pct')||{textContent:''}).textContent=(d.totalActive||0)+' pelanggan aktif';

  const gb=document.getElementById('growth-badge');
  if(d.growthAmt!==null&&d.growthAmt!==undefined){
    const g=+d.growthAmt;
    gb.style.display='inline-flex';
    gb.className='growth '+(g>0?'up':g<0?'down':'flat');
    gb.textContent=(g>0?'↑':g<0?'↓':'→')+' '+Math.abs(g)+'% vs periode lalu';
  }else{gb.style.display='none';}

  (document.getElementById('chart-title')||{textContent:''}).textContent=label;
  (document.getElementById('chart-total')||{textContent:''}).textContent=fmtRp(recv);
  (document.getElementById('method-title')||{textContent:''}).textContent=label;
  (document.getElementById('tx-title')||{textContent:''}).textContent=label;
  (document.getElementById('tx-count')||{textContent:''}).textContent=(d.paidRows||[]).length+' transaksi';
  (document.getElementById('tx-total')||{textContent:''}).textContent=fmtRp(recv);

  // ── Row 2 KPI cards (keuangan) ──────────────────────────────
  const keu = d.keuData || {};
  const lr  = d.labaRugi || {};

  const kelEl = document.getElementById('card-keluar');
  if(kelEl){
    kelEl.textContent = fmtRpK(keu.pengeluaran||0);
    (document.getElementById('card-keluar-sub')||{textContent:''}).textContent = (keu.pengeluaranCnt||0)+' transaksi · '+label;
  }
  const cfWrap = document.getElementById('card-cashflow-wrap');
  if(cfWrap){
    const cf = lr.cashflow||0;
    (document.getElementById('card-cashflow')||{textContent:''}).textContent = (cf<0?'-':'')+fmtRpK(Math.abs(cf));
    cfWrap.style.background = cf>=0
      ? 'linear-gradient(135deg,#00d4a4,#00a07a,#007a5e)'
      : 'linear-gradient(135deg,#f5365c,#c0183a,#8b0f28)';
    cfWrap.style.boxShadow = cf>=0
      ? '0 8px 32px rgba(0,200,150,.3)'
      : '0 8px 32px rgba(245,54,92,.3)';
  }
  const hutEl = document.getElementById('card-hutang');
  if(hutEl){
    hutEl.textContent = fmtRpK(keu.hutangOutstanding||0);
    (document.getElementById('card-hutang-sub')||{textContent:''}).textContent = 'outstanding belum lunas';
  }

  // ── Laba Rugi ─────────────────────────────────────────────
  const lrTitleEl = document.getElementById('lr-title');
  if(lrTitleEl){
    lrTitleEl.textContent = label;
    document.getElementById('lr-recv').innerHTML = '<span style="color:#007a5e">+'+fmtRp(lr.pendapatanISP||0)+'</span>';

    // Manual pemasukan rows grouped by category
    const manPRows = (keu.keuRows||[]).filter(r=>r.type==='pemasukan');
    const manGrp = {};
    manPRows.forEach(r=>{ if(r.category==='Pembayaran Pelanggan') return; const k=r.category||'Lain-lain'; if(!manGrp[k])manGrp[k]={total:0,cnt:0}; manGrp[k].total+=+r.amount||0; manGrp[k].cnt++; });
    const manRowsEl = document.getElementById('lr-manual-rows');
    if(manRowsEl){
      manRowsEl.innerHTML = Object.entries(manGrp).map(([cat,v])=>
        `<tr><td class="lr-lbl lr-sub">${cat} <span style="font-size:10px;color:var(--d-muted)">(${v.cnt}x)</span></td><td class="lr-val lr-pos">+${fmtRp(v.total)}</td></tr>`
      ).join('');
    }

    // Total Pendapatan = ISP payments + semua manual keuangan
    const manualTotal = Object.values(manGrp).reduce(function(s,v){return s+v.total;},0);
    const trueTotal = (lr.pendapatanISP||0) + manualTotal;
    const lrTotal = Math.max(recv, trueTotal, lr.totalPendapatan||0);
    document.getElementById('lr-total-pend').innerHTML = '<span style="color:#007a5e;font-size:13.5px">+'+fmtRp(lrTotal)+'</span>';
    const kelLbl = document.getElementById('lr-kel-lbl');
    if(kelLbl) kelLbl.textContent = 'Operasional ('+(keu.pengeluaranCnt||0)+' item)';
    const penEl = document.getElementById('lr-keluar');
    if(penEl) penEl.innerHTML = (lr.pengeluaran||0)>0
      ? '<span style="color:#c0183a">-'+fmtRp(lr.pengeluaran)+'</span>'
      : fmtRp(0);
    const totKel = document.getElementById('lr-total-kel');
    if(totKel) totKel.innerHTML = (lr.pengeluaran||0)>0
      ? '<span style="color:#c0183a">-'+fmtRp(lr.pengeluaran)+'</span>'
      : fmtRp(0);
    const laba = lrTotal - (lr.pengeluaran||0);
    const labaEl = document.getElementById('lr-laba');
    if(labaEl) labaEl.innerHTML = laba>=0
      ? '<span style="color:#007a5e;font-size:15px">+'+fmtRp(laba)+'</span>'
      : '<span style="color:#c0183a;font-size:15px">-'+fmtRp(Math.abs(laba))+'</span>';
    const margin = (lr.totalPendapatan||0)>0 ? Math.round(laba/(lr.totalPendapatan)*100) : 0;
    const mEl = document.getElementById('lr-margin');
    if(mEl) mEl.textContent = margin+'%';
    const mBar = document.getElementById('lr-margin-bar');
    if(mBar){
      mBar.style.width = Math.max(0,Math.min(100,margin))+'%';
      mBar.style.background = laba>=0 ? 'linear-gradient(90deg,#00c896,#1a6ef5)' : 'linear-gradient(90deg,#f5365c,#fb8c00)';
    }
  }

  // ── Kategori pengeluaran ──────────────────────────────────
  const catEl = document.getElementById('cat-list');
  const catTitleEl = document.getElementById('cat-title');
  (document.getElementById('masuk-cat-title')||{textContent:''}).textContent = label;
  if(catEl){
    if(catTitleEl) catTitleEl.textContent = label;
    const cats = keu.catRows||[];
    if(!cats.length){
      catEl.innerHTML='<div style="text-align:center;padding:24px;color:var(--d-muted);font-size:13px">Tidak ada pengeluaran periode ini</div>';
    } else {
      const maxC = Math.max(1,...cats.map(x=>+x.total||0));
      catEl.innerHTML = cats.map(cat=>{
        const pct = Math.round((+cat.total||0)/maxC*100);
        return`<div class="cat-item">
          <span style="font-size:12.5px;flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${cat.category}</span>
          <div class="cat-bar-bg"><div class="cat-bar-fill" style="width:${pct}%"></div></div>
          <span style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace;min-width:72px;text-align:right">${fmtRpK(+cat.total)}</span>
        </div>`;
      }).join('');
    }
  }

  // ── Transaksi keuangan ────────────────────────────────────
  const keuSec = document.getElementById('keu-tx-section');
  if(keuSec){
    const keuRows = keu.keuRows||[];
    if(!keuRows.length){ keuSec.style.display='none'; }
    else {
      keuSec.style.display='block';
      const ttlEl = document.getElementById('keu-tx-title');
      if(ttlEl) ttlEl.textContent = label+' — Pengeluaran, Hutang & Piutang';
      const cntEl = document.getElementById('keu-tx-count');
      if(cntEl) cntEl.textContent = keuRows.length+' transaksi';
      const TYPE_LABEL2 = {pengeluaran:'Pengeluaran',hutang:'Hutang',piutang:'Piutang',modal:'Modal'};
      const TYPE_CLR    = {pengeluaran:'kb-pengeluaran',hutang:'kb-hutang',piutang:'kb-piutang',modal:'kb-modal'};
      const ST_LABEL    = {lunas:'✓ Lunas',belum_lunas:'⏳ Belum',cicilan:'↺ Cicilan'};
      const tbody = document.getElementById('keu-tx-tbody');
      if(tbody) tbody.innerHTML = keuRows.map(r=>{
        const ac = r.type==='pengeluaran'||r.type==='hutang'?'#c0183a':r.type==='modal'?'#007a5e':'#0077b6';
        const st = r.status ? `<span class="mbadge ${r.status==='lunas'?'green':r.status==='cicilan'?'amber':'red'}" style="font-size:10.5px;padding:2px 7px">${ST_LABEL[r.status]||r.status}</span>` : '<span style="color:#d0d8e8">—</span>';
        const d2 = r.date ? new Date(r.date).toLocaleDateString('id-ID',{day:'2-digit',month:'2-digit',year:'numeric'}) : '—';
        return`<tr>
          <td style="white-space:nowrap;font-size:11.5px;color:var(--d-muted)">${d2}</td>
          <td><span class="keu-badge ${TYPE_CLR[r.type]||''}">${TYPE_LABEL2[r.type]||r.type}</span></td>
          <td><div style="font-weight:600;font-size:12.5px">${r.description||'—'}</div><div style="font-size:11px;color:var(--d-muted)">${r.category||''}</div></td>
          <td style="font-size:12px;color:var(--d-muted)">${r.party_name||r.ref_number||'—'}</td>
          <td>${st}</td>
          <td style="text-align:right;font-family:'DM Mono',monospace;font-weight:700;color:${ac}">${r.type==='pengeluaran'||r.type==='hutang'?'-':''}${fmtRp(+r.amount)}</td>
        </tr>`;
      }).join('');
      const totalKel = keuRows.filter(r=>r.type==='pengeluaran').reduce((a,r)=>a+(+r.amount||0),0);
      const tfoot = document.getElementById('keu-tx-tfoot');
      if(tfoot) tfoot.innerHTML = `<tr style="background:#f4f8ff">
        <td colspan="4" style="padding:10px 12px;font-size:12px;color:var(--d-muted)">${keuRows.length} transaksi</td>
        <td style="padding:10px 12px;font-size:11.5px;font-weight:600;text-align:right;color:var(--d-muted)">Total Pengeluaran</td>
        <td style="padding:10px 12px;font-size:14px;font-weight:800;font-family:'DM Mono',monospace;color:#c0183a;text-align:right">-${fmtRp(totalKel)}</td>
      </tr>`;
    }
  }

  renderMainChart(d.chartLabels||[],d.chartData||[],d.keuData||{});
  renderMethodChart(d.methodRows||[]);
  renderTrendChart(d.trendData||[]);
  renderPkgList(d.packageRows||[]);
  renderOverdue(d.overdueRows||[],d.totalOverdueAmt||0);
  renderUpcoming(d.upcomingRows||[],d.totalUpcomingAmt||0);
  _txData=d.paidRows||[];
  renderTxTable(_txData);

  // ── Kategori pengeluaran ─────────────────────────────────
  renderCats((d.keuData||{}).catRows||[], label);

  // ── Kategori pemasukan dari keuangan ─────────────────────
  renderMasukCats((d.keuData||{}).keuRows||[], label);

  // ── Laporan Laba Rugi ─────────────────────────────────────
  const keuRows2 = (d.keuData||{}).keuRows||[];
  const lrKeuMasuk = keuRows2
    .filter(function(r){ return r.type==='pemasukan'; })
    .reduce(function(s,r){ return s+(parseFloat(r.amount)||0); }, 0);
  const lrRecv = Math.max(d.totalRecvAll||0, d.totalRecv||0, lrKeuMasuk);
  const lrPengeluaran = (d.keuData||{}).pengeluaran || 0;
  const lrLabaBersih  = lrRecv - lrPengeluaran;
  const lrData = {
    pendapatanISP:    d.totalRecv||0,
    totalPendapatan:  lrRecv,
    pengeluaran:      lrPengeluaran,
    pengeluaranCnt:   (d.keuData||{}).pengeluaranCnt||0,
    labaBersih:       lrLabaBersih,
    cashflow:         lrRecv + ((d.keuData||{}).modal||0) - lrPengeluaran
  };
  renderLR(lrData, label, keuRows2, lrRecv);
}

function renderMainChart(labels,data,keuData){
  var cEl = document.getElementById('mainChart');
  if(!cEl) return;
  if(_mainChart){ try{_mainChart.destroy();}catch(e){} _mainChart=null; }
  cEl.innerHTML='';

  function dateKeys(dateStr){
    if(!dateStr) return [];
    var d   = new Date(dateStr);
    var day = String(d.getDate());
    var mon = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Ags','Sep','Okt','Nov','Des'][d.getMonth()];
    var iso = dateStr.substring(0,10);
    return [day, mon, iso];
  }

  /* ── Build kelData & masukExtra ────────────────────────────
     masukExtra: HANYA pemasukan MANUAL (ref_number kosong/null atau bukan PAY-)
     kelData:    semua pengeluaran dari keuangan
     data:       payments per hari (dari tabel payments) — sudah ada dari backend
     
     Sinkronisasi: payments yang di-sync punya ref_number = "PAY-xxx"
     Kita SKIP pemasukan ber-ref "PAY-" di masukExtra untuk hindari double count
  ── */
  var kelMap    = {};
  var masukMap  = {};  // hanya pemasukan manual (non-PAY)

  if(keuData && keuData.keuRows && keuData.keuRows.length){
    keuData.keuRows.forEach(function(r){
      if(!r.date) return;
      var amt  = parseFloat(r.amount)||0;
      var ref  = (r.ref_number||'').toUpperCase();
      var keys = dateKeys(r.date);

      if(r.type === 'pengeluaran'){
        keys.forEach(function(k){ kelMap[k] = (kelMap[k]||0) + amt; });
      } else if(r.type === 'pemasukan'){
        /* Skip yang berasal dari sync payments (ref_number = "PAY-xxx")
           agar tidak double count dengan data[] yang sudah dari tabel payments */
        if(ref.indexOf('PAY-') === 0) return;
        keys.forEach(function(k){ masukMap[k] = (masukMap[k]||0) + amt; });
      }
    });
  }

  var kelData    = labels.map(function(l){ return kelMap[l]||0; });
  var masukExtra = labels.map(function(l){ return masukMap[l]||0; });

  /* Gabungkan: payments dari tabel payments + pemasukan manual keuangan */
  var masukData = labels.map(function(l,i){
    return (data[i]||0) + (masukExtra[i]||0);
  });

  var hasMasuk = masukData.some(function(v){ return v>0; });
  var hasKel   = kelData.some(function(v){ return v>0; });

  var series = [];
  var colors = [];
  if(hasMasuk){ series.push({ name:'Pemasukan',   data: masukData }); colors.push('#2563eb'); }
  if(hasKel)  { series.push({ name:'Pengeluaran', data: kelData   }); colors.push('#ef4444'); }
  if(!series.length){ series=[{name:'Pemasukan',data:masukData}]; colors=['#2563eb']; }

  function axFmt(v){
    if(v>=1000000000) return 'Rp '+(v/1000000000).toFixed(1)+'M';
    if(v>=1000000)    return 'Rp '+(v/1000000).toFixed(1)+'jt';
    if(v>=1000)       return 'Rp '+Math.round(v/1000)+'rb';
    return v?('Rp '+v):'0';
  }

  var opts = {
    series: series,
    chart:{
      type:'bar', height:220, toolbar:{show:false},
      fontFamily:"DM Sans,sans-serif", background:'transparent',
      animations:{enabled:true, easing:'easeinout', speed:600}
    },
    plotOptions:{
      bar:{ columnWidth:series.length>1?'60%':'42%', borderRadius:4, dataLabels:{position:'top'} }
    },
    colors: colors,
    fill:{ opacity:1 },
    dataLabels:{ enabled:false },
    stroke:{ show:false },
    grid:{
      borderColor:'#f1f5f9', strokeDashArray:4,
      xaxis:{lines:{show:false}},
      padding:{top:0, right:4, bottom:0, left:0}
    },
    xaxis:{
      categories: labels,
      axisBorder:{show:false}, axisTicks:{show:false},
      labels:{
        style:{colors:'#94a3b8', fontSize:'11px', fontWeight:500},
        rotate:0, hideOverlappingLabels:true
      },
      tickAmount: Math.min(labels.length, 12)
    },
    yaxis:{
      labels:{
        style:{colors:'#94a3b8', fontSize:'11px'},
        formatter: axFmt
      },
      tickAmount:4
    },
    tooltip:{
      theme:'light', shared:true, intersect:false,
      y:{ formatter: function(v){ return fmtRp(v); } }
    },
    states:{ hover:{ filter:{type:'darken', value:0.85} } },
    legend:{
      show: series.length>1,
      position:'top', horizontalAlign:'right',
      fontSize:'11.5px', fontFamily:"DM Sans,sans-serif",
      markers:{width:10, height:10, radius:3},
      itemMargin:{horizontal:10}
    }
  };

  _mainChart = new ApexCharts(cEl, opts);
  _mainChart.render();
}

function renderMethodChart(rows){
  if(_methodChart)_methodChart.destroy();
  const list=document.getElementById('method-list');
  if(!rows.length){list.innerHTML='<div style="text-align:center;padding:20px;color:var(--d-muted);font-size:13px">Tidak ada transaksi</div>';return;}
  const total=rows.reduce((a,r)=>a+(+r.total||0),1);
  _methodChart=new Chart(document.getElementById('methodChart'),{
    type:'doughnut',
    data:{labels:rows.map(r=>MET_NAMES[r.method]||r.method),datasets:[{data:rows.map(r=>+r.total||0),backgroundColor:rows.map(r=>MET_COLORS[r.method]||'#6b7fa8'),borderWidth:0,hoverOffset:6}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'68%',plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>c.label+': '+fmtRp(c.raw)}}}}
  });
  list.innerHTML=rows.map(r=>{
    const pct=Math.round((+r.total||0)/total*100),col=MET_COLORS[r.method]||'#6b7fa8';
    return`<div class="met-item"><div class="met-dot" style="background:${col}"></div><span style="font-size:12.5px;flex:1;font-weight:500">${MET_NAMES[r.method]||r.method}</span><div class="met-bar-bg"><div class="met-bar-fill" style="width:${pct}%;background:${col}"></div></div><span style="font-size:11.5px;font-family:'DM Mono',monospace;color:var(--d-muted);min-width:34px;text-align:right">${pct}%</span><span style="font-size:11.5px;font-weight:700;min-width:68px;text-align:right">${fmtRpK(+r.total)}</span></div>`;
  }).join('');
}

function renderTrendChart(trend){
  if(_trendChart){try{_trendChart.destroy();}catch(e){}_trendChart=null;}
  if(!trend.length)return;
  var labels=trend.map(function(t){return t.label;});
  var dataMasuk=trend.map(function(t){return t.pemasukan||t.total||0;});
  var dataKeluar=trend.map(function(t){return t.pengeluaran||0;});
  var dataLaba=trend.map(function(t){return (t.laba!=null)?t.laba:((t.pemasukan||t.total||0)-(t.pengeluaran||0));});
  _trendChart=new Chart(document.getElementById('trendChart'),{
    type:'line',
    data:{labels:labels,datasets:[
      {label:'Pemasukan',data:dataMasuk,borderColor:'#00c896',backgroundColor:'rgba(0,200,150,.08)',fill:true,tension:.4,pointRadius:4,pointBackgroundColor:'#00c896',pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2.5},
      {label:'Pengeluaran',data:dataKeluar,borderColor:'#f43f5e',backgroundColor:'rgba(244,63,94,.06)',fill:true,tension:.4,pointRadius:4,pointBackgroundColor:'#f43f5e',pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2},
      {label:'Laba Bersih',data:dataLaba,borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,.06)',fill:false,tension:.4,pointRadius:4,pointBackgroundColor:'#3b82f6',pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:2,borderDash:[5,4]}
    ]},
    options:{responsive:true,maintainAspectRatio:false,animation:{duration:700},
      plugins:{legend:{display:true,position:'bottom',labels:{usePointStyle:true,pointStyle:'circle',padding:16,font:{size:11,weight:'600'},color:'#64748b'}},
        tooltip:{mode:'index',intersect:false,callbacks:{label:function(c){return c.dataset.label+': '+fmtRp(c.raw);}}}},
      interaction:{mode:'index',intersect:false},
      scales:{x:{grid:{display:false},ticks:{color:'#6b7fa8',font:{size:12}}},y:{grid:{color:'#f0f4ff'},ticks:{color:'#6b7fa8',font:{size:11},callback:function(v){return v>=1000000?(v/1000000).toFixed(1)+'jt':v>=1000?Math.round(v/1000)+'rb':v;}}}}}
  });
}

function renderPkgList(rows){
  const el=document.getElementById('pkg-list');
  if(!rows.length){el.innerHTML='<div style="text-align:center;padding:30px;color:var(--d-muted);font-size:13px">Tidak ada data</div>';return;}
  el.innerHTML=rows.map((p,i)=>{
    const cls=i===0?'gold':i===1?'silver':i===2?'bronze':'';
    return`<div class="pkg-item"><div class="pkg-rank ${cls}">${i+1}</div><div style="flex:1;min-width:0"><div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${p.name||'—'}</div><div style="font-size:11.5px;color:var(--d-muted)">${p.cnt||0} transaksi</div></div><div style="text-align:right"><div style="font-size:12.5px;font-weight:700;font-family:'DM Mono',monospace;color:var(--d-blue1)">${fmtRpK(+p.total)}</div></div></div>`;
  }).join('');
}

function renderOverdue(rows,totalAmt){
  (document.getElementById('overdue-badge')||{textContent:''}).textContent=rows.length;
  (document.getElementById('overdue-count')||{textContent:''}).textContent=rows.length+' pelanggan';
  (document.getElementById('overdue-total-amt')||{textContent:''}).textContent=rows.length?'Total: '+fmtRp(totalAmt):'';
  const tbody=document.getElementById('overdue-tbody');
  if(!rows.length){tbody.innerHTML=`<tr><td colspan="4" style="text-align:center;padding:24px;color:var(--d-muted);font-size:13px">Semua pelanggan sudah bayar ✓</td></tr>`;return;}
  tbody.innerHTML=rows.map(r=>{const d=+r.days_overdue||0;return`<tr><td><div style="font-weight:700;font-size:13px">${r.name||'—'}</div><div style="font-size:11px;color:var(--d-muted)">${r.customer_id||''}</div></td><td style="font-size:12.5px;font-weight:700;font-family:'DM Mono',monospace">${fmtRp(+r.price||0)}</td><td style="font-size:12.5px;white-space:nowrap">${fmtDate(r.due_date)}</td><td><span class="mbadge ${d<=7?'amber':'red'}">${d}h</span></td></tr>`;}).join('');
}

function renderUpcoming(rows,totalAmt){
  (document.getElementById('upcoming-badge')||{textContent:''}).textContent=rows.length;
  (document.getElementById('upcoming-count')||{textContent:''}).textContent=rows.length+' pelanggan';
  (document.getElementById('upcoming-total-amt')||{textContent:''}).textContent=rows.length?'Potensi: '+fmtRp(totalAmt):'';
  const tbody=document.getElementById('upcoming-tbody');
  if(!rows.length){tbody.innerHTML=`<tr><td colspan="4" style="text-align:center;padding:24px;color:var(--d-muted);font-size:13px">Tidak ada yang akan jatuh tempo</td></tr>`;return;}
  tbody.innerHTML=rows.map(r=>{const d=+r.days_left||0;return`<tr><td><div style="font-weight:700;font-size:13px">${r.name||'—'}</div><div style="font-size:11px;color:var(--d-muted)">${r.customer_id||''}</div></td><td style="font-size:12.5px;font-weight:700;font-family:'DM Mono',monospace">${fmtRp(+r.price||0)}</td><td style="font-size:12.5px;white-space:nowrap">${fmtDate(r.due_date)}</td><td><span class="mbadge ${d<=1?'red':d<=3?'amber':'blue'}">${d}h</span></td></tr>`;}).join('');
}

function renderTxTable(rows){
  const tbody=document.getElementById('tx-tbody'),tfoot=document.getElementById('tx-tfoot');
  if(!rows.length){tbody.innerHTML=`<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--d-muted)">Tidak ada pembayaran di periode ini</td></tr>`;tfoot.innerHTML='';return;}
  const totalAmt=rows.reduce((a,r)=>a+(+r.amount||0),0);
  tbody.innerHTML=rows.map((p,i)=>{
    const mc=MET_BADGE[p.payment_method]||{bg:'#f4f8ff',color:'#6b7fa8'};
    const inv=p.payment_id?`<a href="/invoice/${p.payment_id}" target="_blank" style="display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:7px;font-size:11.5px;font-weight:700;background:#eff6ff;color:#1d4ed8;text-decoration:none;border:1px solid #bfdbfe"><svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>${p.invoice_number||'—'}</a>`:`<span style="color:var(--d-muted);font-size:12px">—</span>`;
    return`<tr class="tx-row" data-search="${(p.cust_name||'').toLowerCase()} ${(p.cid||'').toLowerCase()}"><td style="color:var(--d-muted);font-size:12px">${i+1}</td><td><div style="font-weight:700;font-size:13px">${p.cust_name||'—'}</div><div style="font-size:11px;color:var(--d-muted)">${p.cid||''}</div></td><td class="col-hide-sm" style="font-size:12.5px;color:var(--d-muted)">${p.pkg_name||'—'}</td><td><span style="font-size:13px;font-weight:700;font-family:'DM Mono',monospace;color:var(--d-blue1)">${fmtRp(+p.amount)}</span></td><td><span style="display:inline-flex;align-items:center;padding:3px 9px;border-radius:20px;font-size:11.5px;font-weight:700;background:${mc.bg};color:${mc.color}">${MET_NAMES[p.payment_method]||p.payment_method||'—'}</span></td><td class="col-hide-sm" style="font-size:12.5px;white-space:nowrap">${fmtDate(p.payment_date)}</td><td class="col-hide-sm" style="font-size:12.5px;white-space:nowrap;color:#007a5e;font-weight:600">${fmtDate(p.due_date_after)}</td><td>${inv}</td></tr>`;
  }).join('');
  tfoot.innerHTML=`<tr style="background:#f4f8ff"><td colspan="3" style="padding:10px 14px;font-size:12.5px;font-weight:700;color:var(--d-muted)">TOTAL ${rows.length} TRANSAKSI</td><td style="padding:10px 14px;font-size:13.5px;font-weight:800;font-family:'DM Mono',monospace;color:var(--d-blue1)">${fmtRp(totalAmt)}</td><td colspan="4"></td></tr>`;
}

function filterTx(q){
  q=q.toLowerCase().trim();
  document.querySelectorAll('#tx-tbody .tx-row').forEach(r=>{r.style.display=(!q||(r.dataset.search||'').includes(q))?'':'none';});
}

function openPrint(){
  const params=getParams();
  const qs=new URLSearchParams(params).toString();
  window.open('/laporan/print?'+qs,'_blank');
}

function exportCSV(){
  if(!_txData.length){App.showToast('Tidak ada data untuk di-export','warning');return;}
  const rows=[['No','Pelanggan','CID','Paket','Jumlah','Metode','Tgl Bayar','Aktif s/d','Invoice']];
  _txData.forEach((p,i)=>rows.push([i+1,p.cust_name||'',p.cid||'',p.pkg_name||'',p.amount||0,MET_NAMES[p.payment_method]||p.payment_method||'',p.payment_date||'',p.due_date_after||'',p.invoice_number||'']));
  const csv=rows.map(r=>r.map(v=>`"${v}"`).join(',')).join('\n');
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download=`laporan-${(document.getElementById('period-label')||{textContent:''}).textContent.replace(/\s+/g,'-')}.csv`;a.click();
}

document.addEventListener('DOMContentLoaded', () => {
  initSelectors();
  setView('monthly');
});
</script>

<script>
(function(){
  var W=72,H=36,MAX=20,hist={},C={'recv':'#16a34a','overdue':'#dc2626','upcoming':'#d97706','rate':'#0891b2'},IDS={'recv':'card-recv','overdue':'card-overdue','upcoming':'card-upcoming','rate':'card-rate'};
  Object.keys(C).forEach(function(k){hist[k]=[];});
  function sp(v){if(!v||v.length<2)return null;var mn=Math.min.apply(null,v),mx=Math.max.apply(null,v),r=mx-mn||1;var p=v.map(function(n,i){return[(i/(v.length-1))*W,H-((n-mn)/r)*(H-6)-3];});var d=p.reduce(function(a,xy,i){if(!i)return'M'+xy[0].toFixed(1)+','+xy[1].toFixed(1);var px=p[i-1],cx=(px[0]+xy[0])/2;return a+' C'+cx.toFixed(1)+','+px[1].toFixed(1)+' '+cx.toFixed(1)+','+xy[1].toFixed(1)+' '+xy[0].toFixed(1)+','+xy[1].toFixed(1);},'');var lp=p[p.length-1],fp=p[0];return{d:d,fill:d+' L'+lp[0].toFixed(1)+','+H+' L'+fp[0].toFixed(1)+','+H+' Z',dot:lp};}
  function draw(id,v){var s=sp(v);if(!s)return;var f=document.getElementById(id+'-fill'),l=document.getElementById(id+'-line'),d=document.getElementById(id+'-dot');if(f)f.setAttribute('d',s.fill);if(l)l.setAttribute('d',s.d);if(d){d.setAttribute('cx',s.dot[0].toFixed(1));d.setAttribute('cy',s.dot[1].toFixed(1));}}
  function rn(id){var e=document.getElementById(id);return e?parseFloat(e.textContent.replace(/[^\d.]/g,''))||0:0;}
  function upd(){Object.keys(C).forEach(function(k){var v=rn(IDS[k]);hist[k].push(v);if(hist[k].length>MAX)hist[k].shift();draw('sp-'+k,hist[k]);var p=document.getElementById('cp-'+k);if(p)p.textContent=hist[k][hist[k].length-1]||'—';});}
  window._lapUpd=upd;
  Object.values(IDS).forEach(function(id){var e=document.getElementById(id);if(e)new MutationObserver(function(){setTimeout(upd,50);}).observe(e,{childList:true,characterData:true,subtree:true});});
  document.addEventListener('DOMContentLoaded',function(){
    upd();
    var def=document.getElementById('fc-recv');
    if(def){var l=def.querySelector('.sp-line'),f=def.querySelector('.sp-fill'),d=def.querySelector('.sp-dot');if(l)l.style.stroke='rgba(255,255,255,.70)';if(f)f.style.fill='rgba(255,255,255,.12)';if(d)d.style.fill='#fff';}
  });
})();

function lapCardClick(el){
  var COLORS={'fc-recv':'#16a34a','fc-overdue':'#dc2626','fc-upcoming':'#d97706','fc-rate':'#0891b2'};
  var was=el.classList.contains('fc-active');
  document.querySelectorAll('.fin-card[id^="fc-"]').forEach(function(card){
    card.classList.remove('fc-active');
    var col=COLORS[card.id]||'#64748b';
    var l=card.querySelector('.sp-line'),f=card.querySelector('.sp-fill'),d=card.querySelector('.sp-dot');
    if(l)l.style.stroke=col;if(f)f.style.fill=col;if(d)d.style.fill=col;
  });
  if(!was){
    el.classList.add('fc-active');
    var l=el.querySelector('.sp-line'),f=el.querySelector('.sp-fill'),d=el.querySelector('.sp-dot');
    if(l)l.style.stroke='rgba(255,255,255,.70)';if(f)f.style.fill='rgba(255,255,255,.12)';if(d)d.style.fill='#fff';
  }
}
</script>
