        </div>
      </div>

      <!-- ── PPP SECRETS PANEL ── -->
      <div id="secrets-panel">
        <div class="pp-tbl" style="margin-bottom:20px;">
          <div class="pp-tbl-hdr">
            <div class="pp-tbl-title">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--pp-blue)" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              PPP Secrets
              <span class="session-count" id="secretsCount">0 user</span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <div class="search-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="secretsSearch" placeholder="Cari username..." oninput="filterSecrets(this.value)">
              </div>
              <select id="secretsFilterService" onchange="filterSecrets(document.getElementById('secretsSearch').value)" style="padding:7px 10px;border:1.5px solid #e2e8f0;border-radius:9px;font-size:12px;font-family:inherit;background:#f8fafc;outline:none;">
                <option value="">All Services</option>
                <option value="pppoe">PPPoE</option>
                <option value="l2tp">L2TP</option>
                <option value="any">Any</option>
              </select>
              <button class="btn btn-blue btn-sm" onclick="openUserModal(null)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="13" height="13"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Tambah
              </button>
            </div>
          </div>
          <div style="overflow-x:auto;">
            <table class="pp-table">
              <thead>
                <tr>
                  <th>#</th><th>Username</th><th>Service</th><th>Profile</th>
                  <th>Local IP</th><th>Remote IP</th><th>Status</th><th>Comment</th><th>Aksi</th>
                </tr>
              </thead>
              <tbody id="secretsTbody">
                <tr><td colspan="9"><div class="tbl-empty"><p>Memuat secrets...</p></div></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ── MODAL CREATE/EDIT USER PPPOE ── -->
      <div class="pp-modal-overlay" id="userModal">
        <div class="pp-modal">
          <div class="pp-modal-hdr">
            <h3 id="modalTitle">Tambah User PPPoE</h3>
            <button class="pp-modal-close" onclick="closeUserModal()">×</button>
          </div>
          <input type="hidden" id="editSecretId">
          <div class="pp-form-grid">
            <div class="pp-form-group">
              <label class="pp-form-label">Username <span>*</span></label>
              <input class="pp-form-control" id="f-name" placeholder="e.g. user@isp">
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Password <span>*</span></label>
              <div style="position:relative;">
                <input class="pp-form-control" id="f-password" type="password" placeholder="Password" style="padding-right:38px;">
                <button onclick="togglePwd('f-password',this)" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);border:none;background:none;cursor:pointer;color:#94a3b8;font-size:13px;">👁</button>
              </div>
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Service</label>
              <select class="pp-form-control" id="f-service">
                <option value="pppoe">PPPoE</option>
                <option value="l2tp">L2TP</option>
                <option value="pptp">PPTP</option>
                <option value="any">Any</option>
              </select>
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Profile <span id="profile-device-tag" style="font-weight:400;color:#64748b;font-size:11px;"></span></label>
              <select class="pp-form-control" id="f-profile" disabled>
                <option value="">Loading profiles…</option>
              </select>
              <span class="pp-form-hint" id="profile-hint" style="color:#2563eb;"></span>
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Local Address</label>
              <input class="pp-form-control" id="f-local-address" placeholder="e.g. 10.0.0.1">
              <span class="pp-form-hint">Kosongkan = dari pool</span>
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Remote Address</label>
              <input class="pp-form-control" id="f-remote-address" placeholder="e.g. 10.0.0.2">
              <span class="pp-form-hint">Kosongkan = dari pool</span>
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Caller ID (MAC)</label>
              <input class="pp-form-control" id="f-caller-id" placeholder="e.g. AA:BB:CC:DD:EE:FF">
              <span class="pp-form-hint">Opsional — filter MAC address</span>
            </div>
            <div class="pp-form-group">
              <label class="pp-form-label">Status</label>
              <select class="pp-form-control" id="f-disabled">
                <option value="false">Aktif (Enabled)</option>
                <option value="true">Nonaktif (Disabled)</option>
              </select>
            </div>
            <div class="pp-form-group full">
              <label class="pp-form-label">Comment</label>
              <input class="pp-form-control" id="f-comment" placeholder="Keterangan opsional...">
            </div>
          </div>
          <div class="pp-modal-footer">
            <button class="btn-pp-cancel" onclick="closeUserModal()">Batal</button>
            <button class="btn-pp-save" id="btnSaveUser" onclick="saveUser()">
              <span id="saveBtnText">Simpan</span>
            </button>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>
<script src="/js/app.js"></script>
<script src="/js/mikrotik-selector.js"></script>
<script>
(function(){
  'use strict';

  // ══════════════════════════════════════════════════════════════
  // PPPoE Monitor — Clean rewrite (v11) — multi-device aware
  // ══════════════════════════════════════════════════════════════

  // Helper: append ?device_id=N kalau ada selector aktif
  function _withDev(url) {
    return (window.MikrotikSelector && window.MikrotikSelector.withDevice)
      ? window.MikrotikSelector.withDevice(url)
      : url;
  }

  // State
  var _sessions  = [];
  var _secrets   = [];
  var _profiles  = [];
  var _timer     = null;
  var _activeTab = 'sessions';  // 'sessions' | 'secrets'

  // Stat history untuk sparkline
  var _sparkHist = { total: [], pppoe: [], l2tp: [], other: [] };
  var SPARK_W = 72, SPARK_H = 36, SPARK_MAX = 20;
  var SPARK_COLORS = { total:'#2563eb', pppoe:'#16a34a', l2tp:'#d97706', other:'#475569' };

  // ── Utils ───────────────────────────────────────────────────
  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  function showToast(msg, type, dur) {
    var d = document.createElement('div');
    d.style.cssText =
      'position:fixed;bottom:24px;right:24px;z-index:9999;' +
      'padding:12px 20px;border-radius:10px;font-size:13px;font-weight:600;color:#fff;' +
      'background:' + (type==='success' ? '#16a34a' : type==='warn' ? '#d97706' : '#dc2626') + ';' +
      'box-shadow:0 4px 20px rgba(0,0,0,.15);max-width:400px;word-break:break-word;cursor:pointer;';
    d.textContent = msg;
    d.onclick = function(){ d.remove(); };
    document.body.appendChild(d);
    setTimeout(function(){ d.remove(); }, dur || 4000);
  }

  // ── Sparkline ───────────────────────────────────────────────
  function sparkPath(vals) {
    if (!vals || vals.length < 2) return null;
    var mn = Math.min.apply(null, vals), mx = Math.max.apply(null, vals), rng = mx - mn || 1;
    var pts = vals.map(function(v,i){
      return [(i/(vals.length-1))*SPARK_W, SPARK_H-((v-mn)/rng)*(SPARK_H-6)-3];
    });
    var d = pts.reduce(function(a,p,i){
      if (!i) return 'M' + p[0].toFixed(1) + ',' + p[1].toFixed(1);
      var prev = pts[i-1], cx = (prev[0] + p[0])/2;
      return a + ' C' + cx.toFixed(1) + ',' + prev[1].toFixed(1)
                + ' ' + cx.toFixed(1) + ',' + p[1].toFixed(1)
                + ' ' + p[0].toFixed(1) + ',' + p[1].toFixed(1);
    }, '');
    var lp = pts[pts.length-1], fp = pts[0];
    return { d: d, fill: d + ' L' + lp[0].toFixed(1) + ',' + SPARK_H + ' L' + fp[0].toFixed(1) + ',' + SPARK_H + ' Z', dot: lp };
  }

  function drawSpark(id, vals) {
    var sp = sparkPath(vals); if (!sp) return;
    var fill = document.getElementById(id+'-fill');
    var line = document.getElementById(id+'-line');
    var dot  = document.getElementById(id+'-dot');
    if (fill) fill.setAttribute('d', sp.fill);
    if (line) line.setAttribute('d', sp.d);
    if (dot) { dot.setAttribute('cx', sp.dot[0].toFixed(1)); dot.setAttribute('cy', sp.dot[1].toFixed(1)); }
  }

  function updateSparkCards() {
    var vals = {
      total: _sessions.length,
      pppoe: _sessions.filter(function(s){ return (s.service||'').toLowerCase() === 'pppoe'; }).length,
      l2tp:  _sessions.filter(function(s){ return (s.service||'').toLowerCase() === 'l2tp'; }).length,
      other: 0
    };
    vals.other = Math.max(0, vals.total - vals.pppoe - vals.l2tp);

    Object.keys(vals).forEach(function(k){
      _sparkHist[k].push(vals[k]);
      if (_sparkHist[k].length > SPARK_MAX) _sparkHist[k].shift();
      drawSpark('sp-'+k, _sparkHist[k]);
      var pill = document.getElementById('pp-pill-'+k);
      if (pill) pill.textContent = vals[k] + ' sesi';
    });

    // Stat number cards
    document.getElementById('statTotal').textContent = vals.total;
    document.getElementById('statPppoe').textContent = vals.pppoe;
    document.getElementById('statL2tp').textContent  = vals.l2tp;
    document.getElementById('statOther').textContent = vals.other;

    // Tab badge sessions
    var tb = document.getElementById('tb-sessions');
    if (tb) tb.textContent = vals.total;

    // Session count label
    var sc = document.getElementById('sessionCount');
    if (sc) sc.textContent = vals.total + ' sesi';

    // Sidebar badge
    var sbBadge = document.getElementById('pppoe-count');
    if (sbBadge) {
      sbBadge.textContent = vals.total;
      sbBadge.style.display = vals.total ? 'flex' : 'none';
    }
  }

  // ── Filter card click ───────────────────────────────────────
  function pcClick(el) {
    var cards = document.querySelectorAll('.pp-card[data-filter]');
    var wasActive = el.classList.contains('pc-active');

    cards.forEach(function(c){
      c.classList.remove('pc-active');
      var f = c.dataset.filter === 'all' ? 'total' : c.dataset.filter;
      var col = SPARK_COLORS[f] || '#64748b';
      var line = c.querySelector('.sp-line'), fill = c.querySelector('.sp-fill'), dot = c.querySelector('.sp-dot');
      if (line) line.style.stroke = col;
      if (fill) fill.style.fill   = col;
      if (dot)  dot.style.fill    = col;
    });

    var sel = document.getElementById('filterService');
    if (!wasActive) {
      el.classList.add('pc-active');
      var line2 = el.querySelector('.sp-line'), fill2 = el.querySelector('.sp-fill'), dot2 = el.querySelector('.sp-dot');
      if (line2) line2.style.stroke = 'rgba(255,255,255,.70)';
      if (fill2) fill2.style.fill   = 'rgba(255,255,255,.12)';
      if (dot2)  dot2.style.fill    = '#fff';
      var filter = el.dataset.filter;
      if (sel) sel.value = filter === 'all' ? '' : filter;
    } else {
      // Reactivate "Total" card sebagai default
      var totalCard = document.getElementById('pc-total');
      if (totalCard) totalCard.classList.add('pc-active');
      if (sel) sel.value = '';
    }
    renderSessions();
  }
  window.pcClick = pcClick;

  // ── Load Sessions ───────────────────────────────────────────
  async function loadSessions() {
    try {
      var search  = (document.getElementById('searchInput').value || '').trim();
      var service = (document.getElementById('filterService').value || '').trim();
      var params = new URLSearchParams();
      if (search)  params.set('search', search);
      if (service) params.set('service', service);

      var url = '/mikrotik/pppoe/active' + (params.toString() ? '?' + params.toString() : '');
      var data = await App.api(_withDev(url));

      if (data && data.success) {
        _sessions = data.data || [];
        updateSparkCards();
        renderSessions();
        if (data.warning) {
          // Show warning tapi tidak block UI
          console.warn('[PPPoE]', data.warning);
        }
      } else {
        document.getElementById('pppoeTbody').innerHTML =
          '<tr><td colspan="7"><div class="tbl-empty">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>' +
            '<p style="color:#dc2626">' + esc((data && data.message) || 'Gagal memuat sesi') + '</p>' +
          '</div></td></tr>';
      }
    } catch (e) {
      document.getElementById('pppoeTbody').innerHTML =
        '<tr><td colspan="7"><div class="tbl-empty"><p style="color:#dc2626">Error: ' + esc(e.message) + '</p></div></td></tr>';
    }
  }

  function renderSessions() {
    var tbody = document.getElementById('pppoeTbody');
    if (!tbody) return;

    // Filter client-side berdasar search + service (untuk instant feedback, backend juga filter)
    var search  = (document.getElementById('searchInput').value || '').trim().toLowerCase();
    var service = (document.getElementById('filterService').value || '').trim().toLowerCase();

    var list = _sessions.filter(function(s){
      if (service && (s.service||'').toLowerCase() !== service) return false;
      if (search) {
        var hay = ((s.name||'') + ' ' + (s.address||'') + ' ' + (s.callerID||'')).toLowerCase();
        if (!hay.includes(search)) return false;
      }
      return true;
    });

    if (!list.length) {
      tbody.innerHTML =
        '<tr><td colspan="7"><div class="tbl-empty">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>' +
          '<p>' + (_sessions.length ? 'Tidak ada sesi yang cocok dengan filter' : 'Tidak ada sesi aktif') + '</p>' +
        '</div></td></tr>';
      return;
    }

    tbody.innerHTML = list.map(function(s, i){
      var svc = (s.service || 'pppoe').toLowerCase();
      var svcClass = svc === 'pppoe' ? 'svc-pppoe' : svc === 'l2tp' ? 'svc-l2tp' : svc === 'pptp' ? 'svc-pptp' : 'svc-any';
      return '<tr data-session-id="' + esc(s.id) + '" data-session-name="' + esc(s.name) + '">' +
        '<td class="num-cell">' + (i+1) + '</td>' +
        '<td class="username-cell">' + esc(s.name) + '</td>' +
        '<td><span class="svc-badge ' + svcClass + '">' + esc(svc.toUpperCase()) + '</span></td>' +
        '<td><span class="ip-badge">' + (esc(s.address) || '—') + '</span></td>' +
        '<td class="mac-cell">' + (esc(s.callerID) || '—') + '</td>' +
        '<td><span class="uptime-badge">' +
          '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>' +
          esc(s.uptime) +
        '</span></td>' +
        '<td>' +
          '<button class="btn btn-red btn-sm" data-act="disconnect">' +
            '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
            'Disconnect' +
          '</button>' +
        '</td>' +
      '</tr>';
    }).join('');
  }

  async function disconnectSession(id, name) {
    if (!confirm('Disconnect sesi "' + name + '"?')) return;
    try {
      var r = await App.api(_withDev('/mikrotik/pppoe/disconnect/' + encodeURIComponent(id)), { method:'POST' });
      if (r && r.success) {
        showToast('Sesi "' + name + '" terdisconnect', 'success');
        await loadSessions();
      } else {
        showToast((r && r.message) || 'Gagal disconnect', 'error');
      }
    } catch (e) { showToast(e.message, 'error'); }
  }

  // ── Load Secrets ────────────────────────────────────────────
  async function loadSecrets() {
    try {
      var r = await App.api(_withDev('/mikrotik/pppoe/secrets'));
      if (!r || !r.success) {
        showToast((r && r.message) || 'Gagal memuat secrets', 'error');
        return;
      }
      _secrets = r.data || [];
      var tb = document.getElementById('tb-secrets');
      var cnt = document.getElementById('secretsCount');
      if (tb)  tb.textContent = _secrets.length;
      if (cnt) cnt.textContent = _secrets.length + ' user';
      renderSecrets();
    } catch (e) {
      showToast('Error loading secrets: ' + e.message, 'error');
    }
  }

  function renderSecrets() {
    var tbody = document.getElementById('secretsTbody');
    if (!tbody) return;

    var search = (document.getElementById('secretsSearch').value || '').trim().toLowerCase();
    var svcFilter = (document.getElementById('secretsFilterService').value || '').trim().toLowerCase();

    var list = _secrets.filter(function(s){
      if (svcFilter && (s.service||'').toLowerCase() !== svcFilter) return false;
      if (search) {
        var hay = ((s.name||'') + ' ' + (s.comment||'') + ' ' + (s.profile||'')).toLowerCase();
        if (!hay.includes(search)) return false;
      }
      return true;
    });

    if (!list.length) {
      tbody.innerHTML =
        '<tr><td colspan="9"><div class="tbl-empty">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>' +
          '<p>' + (_secrets.length ? 'Tidak ada secret yang cocok' : 'Belum ada secret') + '</p>' +
        '</div></td></tr>';
      return;
    }

    tbody.innerHTML = list.map(function(s, i){
      var svc = (s.service || 'pppoe').toLowerCase();
      var svcClass = svc === 'pppoe' ? 'svc-pppoe' : svc === 'l2tp' ? 'svc-l2tp' : svc === 'pptp' ? 'svc-pptp' : 'svc-any';
      var statusBadge = s.disabled
        ? '<span class="svc-badge" style="background:#fee2e2;color:#dc2626">DISABLED</span>'
        : '<span class="svc-badge" style="background:#dcfce7;color:#16a34a">ENABLED</span>';
      return '<tr data-secret-id="' + esc(s.id) + '" data-secret-name="' + esc(s.name) + '" data-secret-disabled="' + (s.disabled?'1':'0') + '">' +
        '<td class="num-cell">' + (i+1) + '</td>' +
        '<td class="username-cell">' + esc(s.name) + '</td>' +
        '<td><span class="svc-badge ' + svcClass + '">' + esc(svc.toUpperCase()) + '</span></td>' +
        '<td>' + esc(s.profile) + '</td>' +
        '<td class="mac-cell">' + (esc(s.localAddress) || '—') + '</td>' +
        '<td class="mac-cell">' + (esc(s.remoteAddress) || '—') + '</td>' +
        '<td>' + statusBadge + '</td>' +
        '<td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + esc(s.comment) + '">' + (esc(s.comment) || '—') + '</td>' +
        '<td>' +
          '<div style="display:flex;gap:4px;flex-wrap:wrap">' +
            '<button class="btn btn-outline btn-sm" data-act="edit" title="Edit">' +
              '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
            '</button>' +
            '<button class="btn btn-outline btn-sm" data-act="toggle" title="' + (s.disabled?'Enable':'Disable') + '">' +
              (s.disabled
                ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>'
                : '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2.5"><rect x="5" y="4" width="4" height="16"/><rect x="15" y="4" width="4" height="16"/></svg>') +
            '</button>' +
            '<button class="btn btn-red btn-sm" data-act="delete" title="Hapus">' +
              '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>' +
            '</button>' +
          '</div>' +
        '</td>' +
      '</tr>';
    }).join('');
  }

  // ── Secret Actions ──────────────────────────────────────────
  async function toggleSecret(id, enable, name) {
    try {
      var ep = '/mikrotik/pppoe/secrets/' + encodeURIComponent(id) + '/' + (enable ? 'enable' : 'disable');
      var r = await App.api(_withDev(ep), { method:'POST', body: JSON.stringify({}) });
      if (r && r.success) {
        showToast((r.message) || (enable ? 'Diaktifkan' : 'Dinonaktifkan'), 'success');
        await loadSecrets();
      } else {
        showToast((r && r.message) || 'Gagal toggle', 'error');
      }
    } catch (e) { showToast(e.message, 'error'); }
  }

  async function deleteSecret(id, name) {
    if (!confirm('Hapus user "' + name + '"?\n\nTindakan ini tidak dapat dibatalkan.')) return;
    try {
      var r = await App.api(_withDev('/mikrotik/pppoe/secrets/' + encodeURIComponent(id)), { method:'DELETE' });
      if (r && r.success) {
        showToast('User "' + name + '" dihapus', 'success');
        await loadSecrets();
      } else {
        showToast((r && r.message) || 'Gagal hapus', 'error');
      }
    } catch (e) { showToast(e.message, 'error'); }
  }

  // ── Tab Switch ──────────────────────────────────────────────
  function switchTab(tab) {
    _activeTab = tab;
    document.getElementById('tab-sessions').classList.toggle('active', tab === 'sessions');
    document.getElementById('tab-secrets').classList.toggle('active', tab === 'secrets');
    var sp = document.getElementById('secrets-panel');
    var ss = document.getElementById('sessions-panel');
    if (tab === 'secrets') {
      if (ss) ss.style.display = 'none';
      if (sp) sp.style.display = 'block';
      loadSecrets();
    } else {
      if (ss) ss.style.display = '';
      if (sp) sp.style.display = 'none';
    }
  }
  window.switchTab = switchTab;

  // Helper: nama device yang aktif di selector
  function _getActiveDeviceName() {
    var selDev = document.getElementById('mikrotikSelector');
    if (!selDev) return '';
    var opt = selDev.options[selDev.selectedIndex];
    if (!opt) return '';
    // Buang prefix emoji status (🟢/🟡/🔴) dan suffix bintang
    return (opt.textContent || '').replace(/^[^\s]*\s*/, '').replace(/\s*★$/, '').trim();
  }

  // ── Modal Add/Edit ──────────────────────────────────────────
  async function loadProfiles(currentProfile) {
    var sel = document.getElementById('f-profile');
    var hint = document.getElementById('profile-hint');
    var devTag = document.getElementById('profile-device-tag');
    if (!sel) return;

    // Tampilkan device aktif di label
    var devName = _getActiveDeviceName();
    if (devTag) devTag.textContent = devName ? '— dari ' + devName : '';

    // Loading state
    sel.disabled = true;
    sel.innerHTML = '<option value="">Loading profiles…</option>';
    if (hint) { hint.textContent = ''; hint.style.color = '#2563eb'; }

    try {
      var r = await App.api(_withDev('/mikrotik/pppoe/profiles'));
      var profiles = (r && r.success && Array.isArray(r.data)) ? r.data : [];
      _profiles = profiles;

      if (profiles.length) {
        sel.innerHTML = profiles.map(function(p){
          var meta = [];
          if (p.rateLimit) meta.push(p.rateLimit);
          if (p.remoteAddress) meta.push('pool: ' + p.remoteAddress);
          var label = p.name + (meta.length ? '  (' + meta.join(' • ') + ')' : '');
          return '<option value="' + esc(p.name) + '">' + esc(label) + '</option>';
        }).join('');
        sel.disabled = false;

        if (currentProfile && profiles.some(function(p){return p.name === currentProfile;})) {
          sel.value = currentProfile;
        } else {
          sel.value = profiles[0].name;
        }
        if (hint) hint.textContent = profiles.length + ' profile dimuat dari MikroTik';
      } else {
        // MikroTik tidak return profile (atau error connection)
        var warning = (r && r.warning) ? r.warning : 'MikroTik tidak mengembalikan daftar profile';
        sel.innerHTML = '<option value="default">default</option><option value="default-encryption">default-encryption</option>';
        sel.disabled = false;
        if (currentProfile && !sel.querySelector('option[value="' + currentProfile + '"]')) {
          var opt = document.createElement('option');
          opt.value = currentProfile;
          opt.textContent = currentProfile;
          sel.appendChild(opt);
        }
        if (currentProfile) sel.value = currentProfile;
        if (hint) {
          hint.style.color = '#dc2626';
          hint.innerHTML = '⚠ ' + esc(warning) + ' — pakai fallback. <a href="#" id="btnRetryProfiles" style="color:#2563eb;">Coba lagi</a>';
          var retry = document.getElementById('btnRetryProfiles');
          if (retry) retry.addEventListener('click', function(e){ e.preventDefault(); loadProfiles(currentProfile); });
        }
      }
    } catch (e) {
      sel.innerHTML = '<option value="default">default</option>';
      sel.disabled = false;
      if (hint) {
        hint.style.color = '#dc2626';
        hint.textContent = 'Error: ' + e.message;
      }
    }
  }

  function openUserModal(secretId) {
    var modal = document.getElementById('userModal');
    var title = document.getElementById('modalTitle');
    var saveBtn = document.getElementById('saveBtnText');

    // Reset form
    ['f-name','f-password','f-local-address','f-remote-address','f-caller-id','f-comment'].forEach(function(id){
      var el = document.getElementById(id); if (el) el.value = '';
    });
    document.getElementById('f-service').value = 'pppoe';
    document.getElementById('f-disabled').value = 'false';
    document.getElementById('editSecretId').value = '';

    var currentProfile = '';
    var passwordPlaceholder = 'Password';

    if (secretId) {
      var s = _secrets.find(function(x){ return x.id === secretId; });
      if (!s) { showToast('Secret tidak ditemukan', 'error'); return; }
      title.textContent = 'Edit User PPPoE';
      saveBtn.textContent = 'Update';
      document.getElementById('editSecretId').value    = secretId;
      document.getElementById('f-name').value          = s.name || '';
      document.getElementById('f-service').value       = s.service || 'pppoe';
      document.getElementById('f-local-address').value = s.localAddress || '';
      document.getElementById('f-remote-address').value= s.remoteAddress || '';
      document.getElementById('f-caller-id').value     = s.callerId || '';
      document.getElementById('f-comment').value       = s.comment || '';
      document.getElementById('f-disabled').value      = s.disabled ? 'true' : 'false';
      currentProfile = s.profile || '';
      passwordPlaceholder = s.hasPassword ? '(kosongkan jika tidak diganti)' : 'Password';
    } else {
      title.textContent = 'Tambah User PPPoE';
      saveBtn.textContent = 'Simpan';
    }

    document.getElementById('f-password').placeholder = passwordPlaceholder;
    loadProfiles(currentProfile);
    modal.classList.add('show');
    setTimeout(function(){ document.getElementById('f-name').focus(); }, 100);
  }
  window.openUserModal = openUserModal;

  function closeUserModal() {
    document.getElementById('userModal').classList.remove('show');
  }
  window.closeUserModal = closeUserModal;

  async function saveUser() {
    var id = document.getElementById('editSecretId').value;
    var name = document.getElementById('f-name').value.trim();
    var pass = document.getElementById('f-password').value;
    if (!name) { showToast('Username wajib diisi', 'error'); return; }
    if (!id && !pass) { showToast('Password wajib diisi untuk user baru', 'error'); return; }

    var body = {
      name: name,
      service:       (document.getElementById('f-service').value || 'pppoe').toLowerCase(),
      profile:       (document.getElementById('f-profile').value || '').trim() || 'default',
      localAddress:  document.getElementById('f-local-address').value.trim(),
      remoteAddress: document.getElementById('f-remote-address').value.trim(),
      callerId:      document.getElementById('f-caller-id').value.trim(),
      comment:       document.getElementById('f-comment').value.trim(),
      disabled:      document.getElementById('f-disabled').value === 'true'
    };
    // Kirim password hanya kalau diisi (edit mode: biarkan kosong = password lama tetap)
    if (pass) body.password = pass;

    var btn = document.getElementById('btnSaveUser');
    btn.disabled = true;
    document.getElementById('saveBtnText').textContent = id ? 'Menyimpan...' : 'Membuat...';

    try {
      var r = id
        ? await App.api(_withDev('/mikrotik/pppoe/secrets/' + encodeURIComponent(id)), { method:'PUT', body: JSON.stringify(body) })
        : await App.api(_withDev('/mikrotik/pppoe/secrets'), { method:'POST', body: JSON.stringify(body) });
      if (r && r.success) {
        closeUserModal();
        showToast((r.message) || (id ? 'Updated' : 'Dibuat'), 'success');
        switchTab('secrets');
        await loadSecrets();
      } else {
        showToast((r && r.message) || 'Gagal menyimpan', 'error', 6000);
      }
    } catch (e) {
      var msg = e.message && e.message.includes('ECONNRESET')
        ? 'Koneksi ke MikroTik terputus — coba lagi'
        : e.message || 'Error';
      showToast(msg, 'error', 6000);
    }

    btn.disabled = false;
    document.getElementById('saveBtnText').textContent = id ? 'Update' : 'Simpan';
  }
  window.saveUser = saveUser;

  // ── Password toggle ─────────────────────────────────────────
  function togglePwd(id, btn) {
    var el = document.getElementById(id); if (!el) return;
    el.type = el.type === 'password' ? 'text' : 'password';
    btn.textContent = el.type === 'password' ? '👁' : '🙈';
  }
  window.togglePwd = togglePwd;

  // ── Filters (secrets) ───────────────────────────────────────
  function filterSecrets() { renderSecrets(); }
  window.filterSecrets = filterSecrets;

  // ══════════════════════════════════════════════════════════════
  // INIT
  // ══════════════════════════════════════════════════════════════
  // Helper: reload semua data sesuai device aktif (sessions + secrets badge)
  function _reloadAllForDevice() {
    if (_activeTab === 'sessions') loadSessions();
    else if (_activeTab === 'secrets') loadSecrets();
    // Selalu refresh badge count di tab non-aktif juga
    App.api(_withDev('/mikrotik/pppoe/secrets')).then(function(r){
      if (r && r.success) {
        _secrets = r.data || [];
        var tb = document.getElementById('tb-secrets');
        if (tb) tb.textContent = _secrets.length;
      }
    }).catch(function(){});
  }

  document.addEventListener('DOMContentLoaded', function(){
    // Init MikroTik selector — reload data saat user ganti device
    // PENTING: pakai onReady agar initial load TIDAK race dengan selector
    if (window.MikrotikSelector) {
      window.MikrotikSelector.init({
        selectId: 'mikrotikSelector',
        onChange: function(){
          // Reload semua data ke device baru
          _reloadAllForDevice();
          // Kalau modal "Tambah/Edit User" sedang terbuka, refresh juga profile
          // dropdown supaya menyesuaikan profile MikroTik device baru
          var modal = document.getElementById('userModal');
          if (modal && modal.classList.contains('show')) {
            var currentProfile = (document.getElementById('f-profile').value || '').trim();
            loadProfiles(currentProfile);
          }
        },
        onReady: function(){
          // Selector sudah siap — sekarang aman untuk initial load
          _reloadAllForDevice();
        }
      });
    } else {
      // Fallback kalau selector script gagal load
      _reloadAllForDevice();
    }

    // Event: refresh button
    var btnRefresh = document.getElementById('btnRefresh');
    if (btnRefresh) btnRefresh.addEventListener('click', function(){
      if (_activeTab === 'sessions') loadSessions();
      else loadSecrets();
    });

    // Event: search + filter inputs (debounced via instant render)
    var sInp = document.getElementById('searchInput');
    var fSel = document.getElementById('filterService');
    if (sInp) sInp.addEventListener('input', renderSessions);
    if (fSel) fSel.addEventListener('change', renderSessions);

    var sSearch = document.getElementById('secretsSearch');
    var sSvcFilt = document.getElementById('secretsFilterService');
    if (sSearch) sSearch.addEventListener('input', renderSecrets);
    if (sSvcFilt) sSvcFilt.addEventListener('change', renderSecrets);

    // Event delegation: action buttons di sessions table
    var sessTbody = document.getElementById('pppoeTbody');
    if (sessTbody) sessTbody.addEventListener('click', function(e){
      var btn = e.target.closest('button[data-act]');
      if (!btn) return;
      var tr = btn.closest('tr[data-session-id]');
      if (!tr) return;
      var id = tr.getAttribute('data-session-id');
      var nm = tr.getAttribute('data-session-name');
      if (btn.getAttribute('data-act') === 'disconnect') disconnectSession(id, nm);
    });

    // Event delegation: action buttons di secrets table
    var secTbody = document.getElementById('secretsTbody');
    if (secTbody) secTbody.addEventListener('click', function(e){
      var btn = e.target.closest('button[data-act]');
      if (!btn) return;
      var tr = btn.closest('tr[data-secret-id]');
      if (!tr) return;
      var id = tr.getAttribute('data-secret-id');
      var nm = tr.getAttribute('data-secret-name');
      var dis = tr.getAttribute('data-secret-disabled') === '1';
      var act = btn.getAttribute('data-act');
      if (act === 'edit')    openUserModal(id);
      else if (act === 'toggle') toggleSecret(id, dis, nm);  // kalau currently disabled, button = enable
      else if (act === 'delete') deleteSecret(id, nm);
    });

    // Close modal pada klik overlay
    var modal = document.getElementById('userModal');
    if (modal) modal.addEventListener('click', function(e){
      if (e.target === this) closeUserModal();
    });

    // ESC untuk tutup modal
    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape') {
        var m = document.getElementById('userModal');
        if (m && m.classList.contains('show')) closeUserModal();
      }
    });

    // Initial load dipicu oleh onReady selector (lihat di atas).
    // Kalau selector tidak ada, _reloadAllForDevice() sudah dipanggil di fallback.

    // Auto-refresh tiap 10s (hanya tab aktif)
    _timer = setInterval(function(){
      if (_activeTab === 'sessions') loadSessions();
    }, 10000);
  });

  window.addEventListener('beforeunload', function(){
    if (_timer) clearInterval(_timer);
  });
})();
</script>
</body>
</html>
