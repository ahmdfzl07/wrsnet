<script src="/js/work-orders.js"></script>

<script>
(function(){
  const W=72,H=36,MAX=20,hist={},C={'all':'#2563eb','pending':'#d97706','progress':'#0891b2','done':'#16a34a'},IDS={'all':'scTotal','pending':'scPending','progress':'scInProgress','done':'scDone'};
  Object.keys(C).forEach(k=>hist[k]=[]);
  function sp(v){
    if(!v||v.length<2)return null;
    const mn=Math.min(...v),mx=Math.max(...v),r=mx-mn||1;
    const p=v.map((n,i)=>[(i/(v.length-1))*W,H-((n-mn)/r)*(H-6)-3]);
    const d=p.reduce((a,[x,y],i)=>{
      if(!i)return'M'+x.toFixed(1)+','+y.toFixed(1);
      const[px,py]=p[i-1],cx=(px+x)/2;
      return a+' C'+cx.toFixed(1)+','+py.toFixed(1)+' '+cx.toFixed(1)+','+y.toFixed(1)+' '+x.toFixed(1)+','+y.toFixed(1);
    },'');
    const lp=p[p.length-1],fp=p[0];
    return{d,fill:d+' L'+lp[0].toFixed(1)+','+H+' L'+fp[0].toFixed(1)+','+H+' Z',dot:lp};
  }
  function draw(id,v){
    const s=sp(v);if(!s)return;
    const f=document.getElementById(id+'-fill'),l=document.getElementById(id+'-line'),d=document.getElementById(id+'-dot');
    if(f)f.setAttribute('d',s.fill);if(l)l.setAttribute('d',s.d);
    if(d){d.setAttribute('cx',s.dot[0].toFixed(1));d.setAttribute('cy',s.dot[1].toFixed(1));}
  }
  function rn(id){const e=document.getElementById(id);return e?parseFloat(e.textContent.replace(/[^\d.]/g,''))||0:0;}
  function upd(){
    Object.keys(C).forEach(k=>{
      const v=rn(IDS[k]);hist[k].push(v);if(hist[k].length>MAX)hist[k].shift();
      draw('sp-'+k,hist[k]);
      const p=document.getElementById('wo-pill-'+k);if(p)p.textContent=v;
    });
  }
  window._woUpd=upd;
  Object.values(IDS).forEach(id=>{const e=document.getElementById(id);if(e)new MutationObserver(()=>setTimeout(upd,50)).observe(e,{childList:true,characterData:true,subtree:true});});
  document.addEventListener('DOMContentLoaded',upd);
})();
function woCardClick(el){
  const all=document.querySelectorAll('.wo-card[data-filter]');
  const was=el.classList.contains('xc-active');
  const C={'all':'#2563eb','pending':'#d97706','progress':'#0891b2','done':'#16a34a'};
  all.forEach(c=>{
    c.classList.remove('xc-active');
    const col=C[c.dataset.filter]||'#64748b';
    const l=c.querySelector('.sp-line'),f=c.querySelector('.sp-fill'),d=c.querySelector('.sp-dot');
    if(l)l.style.stroke=col;if(f)f.style.fill=col;if(d)d.style.fill=col;
  });
  el.classList.add('xc-active');
  const l=el.querySelector('.sp-line'),f=el.querySelector('.sp-fill'),d=el.querySelector('.sp-dot');
  if(l)l.style.stroke='rgba(255,255,255,.70)';
  if(f)f.style.fill='rgba(255,255,255,.12)';
  if(d)d.style.fill='#fff';
  const fm={'all':'','pending':'pending','progress':'in_progress','done':'done'};
  if(typeof setFilter==='function') setFilter(fm[el.dataset.filter]||'');
}
</script>
