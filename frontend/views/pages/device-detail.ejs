      <!-- Tab: Interfaces -->
      <div class="dd-tab-content" id="tab-interfaces">
        <div class="if-wrap">
          <table class="if-table">
            <thead>
              <tr>
                <th style="width:180px">Interface</th>
                <th>Type</th>
                <th>MAC Address</th>
                <th style="width:130px">RX (live)</th>
                <th style="width:130px">TX (live)</th>
                <th style="width:160px">Total RX / TX</th>
              </tr>
            </thead>
            <tbody id="ifTbody">
              <tr><td colspan="6" class="spin-wrap"><span class="spinner"></span><div>Memuat interfaces...</div></td></tr>
            </tbody>
