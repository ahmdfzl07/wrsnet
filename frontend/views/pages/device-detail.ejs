<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= appName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.45.2/dist/apexcharts.min.js"></script>
  <style>
    :root {
      --dd-blue:#2563eb; --dd-blue-d:#1d4ed8; --dd-blue-l:#eff6ff;
      --dd-green:#16a34a; --dd-green-l:#f0fdf4;
      --dd-red:#dc2626;   --dd-red-l:#fef2f2;
      --dd-amber:#d97706; --dd-amber-l:#fffbeb;
      --dd-teal:#0891b2;  --dd-teal-l:#ecfeff;
      --dd-purple:#7c3aed;
      --border:#e2e8f0; --text:#0f172a; --muted:#64748b; --faint:#94a3b8;
      --rc:16px;
    }
    body { font-family:'Plus Jakarta Sans',sans-serif; }
    .dd { font-family:'Plus Jakarta Sans',sans-serif; }
    .mono { font-family:'JetBrains Mono',monospace; font-weight:500; }

    /* ── BREADCRUMB ── */
    .dd-crumb { display:flex; align-items:center; gap:6px; font-size:12.5px; color:var(--muted); margin-bottom:6px; }
    .dd-crumb a { color:var(--muted); text-decoration:none; display:inline-flex; align-items:center; gap:4px; }
    .dd-crumb a:hover { color:var(--dd-blue); }
    .dd-crumb svg { color:var(--faint); width:11px; height:11px; }

    /* ── HEADER ── */
    .dd-hdr { display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:20px; }
    .dd-hdr-l h1 { font-size:22px; font-weight:800; color:var(--text); margin:0; display:flex; align-items:center; gap:10px; }
    .dd-hdr-l p  { font-size:13px; color:var(--muted); margin:4px 0 0; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .dd-hdr-l p .mono { background:#f1f5f9; padding:2px 8px; border-radius:6px; font-size:12px; }
    .dd-hdr-r    { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }

    .btn { display:inline-flex; align-items:center; gap:6px; padding:9px 16px; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; border:1.5px solid; transition:all .15s; white-space:nowrap; font-family:inherit; background:#fff; }
    .btn svg { flex-shrink:0; }
    .btn-outline { background:#fff; border-color:var(--border); color:#374151; }
    .btn-outline:hover { background:#f8fafc; border-color:#cbd5e1; }
    .btn-blue   { background:var(--dd-blue); border-color:var(--dd-blue); color:#fff; }
    .btn-blue:hover { background:var(--dd-blue-d); }
    .btn-red    { background:var(--dd-red); border-color:var(--dd-red); color:#fff; }
    .btn-red:hover { background:#b91c1c; }
    .btn-teal   { background:var(--dd-teal); border-color:var(--dd-teal); color:#fff; }
    .btn-teal:hover { background:#0e7490; }
    .btn-sm     { padding:6px 12px; font-size:12px; border-radius:8px; }
    .btn:disabled { opacity:.5; cursor:not-allowed; pointer-events:none; }

    /* Status chip */
    .st-chip { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border-radius:20px; font-size:11.5px; font-weight:700; text-transform:uppercase; letter-spacing:.4px; }
    .st-online { background:var(--dd-green-l); color:var(--dd-green); border:1px solid #bbf7d0; }
    .st-offline { background:var(--dd-red-l); color:var(--dd-red); border:1px solid #fecaca; }
    .st-warning { background:var(--dd-amber-l); color:var(--dd-amber); border:1px solid #fde68a; }
    .st-maintenance { background:var(--dd-teal-l); color:var(--dd-teal); border:1px solid #a5f3fc; }
    .st-chip .dot { width:7px; height:7px; border-radius:50%; background:currentColor; }
    .st-online .dot { animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.35;transform:scale(.7)} }

    /* ── OVERVIEW CARDS (top row) ── */
    .dd-overview { display:grid; grid-template-columns: minmax(0,1fr) 340px; gap:16px; margin-bottom:18px; }
    @media(max-width:960px) { .dd-overview { grid-template-columns:1fr; } }

    .info-card { background:#fff; border:1px solid var(--border); border-radius:var(--rc); padding:20px 22px; }
    .info-card-title { font-size:11.5px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:14px; display:flex; align-items:center; gap:6px; }
    .info-card-title svg { color:var(--dd-blue); width:14px; height:14px; }

    .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px 24px; }
    @media(max-width:560px) { .info-grid { grid-template-columns:1fr; } }
    .info-row { }
    .info-row .lbl { font-size:10.5px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:4px; }
    .info-row .val { font-size:13.5px; color:var(--text); font-weight:600; word-break:break-word; }
    .info-row .val.mono { font-family:'JetBrains Mono',monospace; font-weight:500; }
    .info-row .val-muted { color:var(--muted); font-style:italic; font-weight:500; }

    /* Live metrics card */
    .live-card { background:linear-gradient(135deg,#1e40af,#1d4ed8); border-radius:var(--rc); padding:20px 22px; color:#fff; position:relative; overflow:hidden; }
    .live-card-title { font-size:11.5px; font-weight:700; opacity:.85; text-transform:uppercase; letter-spacing:.5px; margin-bottom:16px; display:flex; align-items:center; gap:6px; position:relative; }
    .live-card-title .live-badge { margin-left:auto; display:inline-flex; align-items:center; gap:5px; padding:2px 8px; border-radius:20px; background:rgba(255,255,255,.15); font-size:10px; font-weight:800; letter-spacing:.3px; }
    .live-card-title .live-badge .dot { width:6px; height:6px; border-radius:50%; background:#86efac; animation:pulse 2s infinite; }

    .gauge-row { display:flex; gap:18px; align-items:center; margin-bottom:18px; position:relative; }
    .gauge { position:relative; width:100px; height:100px; flex-shrink:0; }
    .gauge-svg { width:100%; height:100%; transform:rotate(-90deg); }
    .gauge-bg { fill:none; stroke:rgba(255,255,255,.15); stroke-width:8; }
    .gauge-fg { fill:none; stroke:#fff; stroke-width:8; stroke-linecap:round; transition:stroke-dashoffset .6s ease; }
    .gauge-txt { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; }
    .gauge-val { font-size:22px; font-weight:800; letter-spacing:-1px; line-height:1; }
    .gauge-lbl { font-size:10px; opacity:.75; font-weight:600; text-transform:uppercase; letter-spacing:.5px; margin-top:3px; }
    .gauge-info { flex:1; min-width:0; }
    .gauge-info-lbl { font-size:11px; opacity:.75; font-weight:600; margin-bottom:3px; }
    .gauge-info-val { font-size:14px; font-weight:700; word-break:break-word; }
    .gauge-info-sub { font-size:10.5px; opacity:.65; margin-top:2px; font-family:'JetBrains Mono',monospace; }

    .live-uptime { display:flex; align-items:center; gap:10px; background:rgba(255,255,255,.1); border-radius:10px; padding:10px 14px; position:relative; }
    .live-uptime-ico { width:34px; height:34px; border-radius:8px; background:rgba(255,255,255,.12); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .live-uptime-lbl { font-size:10.5px; opacity:.75; font-weight:600; text-transform:uppercase; letter-spacing:.5px; }
    .live-uptime-val { font-size:14px; font-weight:700; margin-top:1px; font-family:'JetBrains Mono',monospace; }

    /* Bandwidth RX/TX */
    .bw-row { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:10px; }
    .bw-card { display:flex; align-items:center; gap:9px; background:rgba(255,255,255,.1); border-radius:10px; padding:10px 12px; min-width:0; }
    .bw-ico { width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .bw-rx { background:rgba(96,165,250,.28); color:#bfdbfe; }
    .bw-tx { background:rgba(251,146,60,.28); color:#fed7aa; }
    .bw-info { min-width:0; flex:1; }
    .bw-lbl { font-size:9.5px; opacity:.75; font-weight:700; text-transform:uppercase; letter-spacing:.4px; }
    .bw-val { font-size:13px; font-weight:800; font-family:'JetBrains Mono',monospace; margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .bw-sub { font-size:10px; opacity:.65; font-family:'JetBrains Mono',monospace; margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* ── TABS ── */
    .dd-tabs { display:flex; gap:2px; background:#fff; border:1px solid var(--border); border-radius:12px; padding:5px; margin-bottom:16px; overflow-x:auto; }
    .dd-tab { padding:9px 18px; font-size:13px; font-weight:700; color:var(--muted); cursor:pointer; border-radius:8px; transition:all .15s; display:inline-flex; align-items:center; gap:6px; white-space:nowrap; background:transparent; border:none; font-family:inherit; }
    .dd-tab:hover { color:var(--text); background:#f8fafc; }
    .dd-tab.active { background:var(--dd-blue); color:#fff; }
    .dd-tab.active:hover { background:var(--dd-blue-d); }
    .dd-tab svg { width:14px; height:14px; }
    .dd-tab-content { display:none; }
    .dd-tab-content.active { display:block; }

    /* ── TAB: Interfaces table ── */
    .if-wrap { background:#fff; border:1px solid var(--border); border-radius:var(--rc); overflow:hidden; }
    .if-table { width:100%; border-collapse:collapse; }
    .if-table th { text-align:left; padding:11px 14px; font-size:11px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.6px; background:#f8fafc; border-bottom:1px solid var(--border); white-space:nowrap; }
    .if-table td { padding:12px 14px; font-size:13px; color:var(--text); border-bottom:1px solid #f1f5f9; vertical-align:middle; }
    .if-table tbody tr:last-child td { border-bottom:none; }
    .if-table tbody tr:hover { background:#fafbff; }

    .if-dot { width:8px; height:8px; border-radius:50%; display:inline-block; margin-right:8px; vertical-align:middle; }
    .if-dot.run { background:var(--dd-green); box-shadow:0 0 0 3px rgba(22,163,74,.18); }
    .if-dot.stop { background:var(--faint); }
    .if-dot.disabled { background:var(--dd-red); }
    .if-name { font-weight:700; color:var(--text); font-size:13px; }
    .if-type { font-size:10.5px; padding:2px 7px; border-radius:20px; background:#f1f5f9; color:var(--muted); font-weight:700; text-transform:uppercase; letter-spacing:.3px; }
    .if-comment { font-size:11px; color:var(--muted); margin-top:2px; font-style:italic; }
    .if-bitrate { font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:600; }
    .if-bitrate.rx { color:var(--dd-blue); }
    .if-bitrate.tx { color:var(--dd-amber); }
    .if-total { font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--muted); font-weight:500; }

    .if-row { cursor:pointer; transition:background .12s; }
    .if-row:hover { background:#eff6ff !important; }
    .if-row:hover .if-name { color:var(--dd-blue); }

    /* ── Interface Detail Modal ── */
    .ifm-overlay {
      display:none; position:fixed; inset:0;
      background:rgba(15,23,42,.55);
      z-index:1000; padding:20px;
      align-items:flex-start; justify-content:center;
      backdrop-filter:blur(4px);
      overflow-y:auto;
    }
    .ifm-overlay.active { display:flex; }
    .ifm-box {
      background:#fff; border-radius:18px;
      width:100%; max-width:880px;
      box-shadow:0 24px 60px rgba(0,0,0,.25);
      overflow:hidden;
      margin:auto;
    }
    .ifm-hdr {
      padding:18px 24px;
      background:linear-gradient(135deg,#1e40af,#1d4ed8);
      color:#fff;
      display:flex; align-items:center; gap:14px;
    }
    .ifm-hdr-ico {
      width:42px; height:42px; border-radius:12px;
      background:rgba(255,255,255,.18);
      display:flex; align-items:center; justify-content:center;
      flex-shrink:0;
    }
    .ifm-hdr-info { flex:1; min-width:0; }
    .ifm-hdr-title { font-size:16px; font-weight:800; margin:0; display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .ifm-hdr-title .live-pill { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:20px; background:rgba(134,239,172,.25); color:#86efac; font-size:10px; font-weight:800; letter-spacing:.3px; }
    .ifm-hdr-title .live-pill .dot { width:5px; height:5px; border-radius:50%; background:#86efac; animation:pulse 1.8s infinite; }
    .ifm-hdr-sub { font-size:12px; opacity:.85; margin-top:2px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
    .ifm-hdr-sub .mono { font-family:'JetBrains Mono',monospace; font-weight:500; }
    .ifm-close {
      background:rgba(255,255,255,.15); border:none; color:#fff;
      width:34px; height:34px; border-radius:10px;
      cursor:pointer; flex-shrink:0;
      display:flex; align-items:center; justify-content:center;
      transition:background .15s;
    }
    .ifm-close:hover { background:rgba(255,255,255,.28); }

    .ifm-body { padding:20px 24px; }

    /* Stat cards inside modal */
    .ifm-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:18px; }
    @media(max-width:700px){ .ifm-stats{ grid-template-columns:repeat(2,1fr); } }
    .ifm-stat {
      background:#f8fafc; border:1px solid var(--border);
      border-radius:12px; padding:12px 14px;
      position:relative; overflow:hidden;
    }
    .ifm-stat-lbl { font-size:10.5px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.4px; display:flex; align-items:center; gap:5px; }
    .ifm-stat-val { font-size:18px; font-weight:800; color:var(--text); font-family:'JetBrains Mono',monospace; letter-spacing:-.5px; margin-top:6px; line-height:1; }
    .ifm-stat-sub { font-size:10.5px; color:var(--muted); margin-top:4px; font-family:'JetBrains Mono',monospace; font-weight:500; }
    .ifm-stat.rx { background:#eff6ff; border-color:#bfdbfe; }
    .ifm-stat.rx .ifm-stat-lbl,
    .ifm-stat.rx .ifm-stat-val { color:#1d4ed8; }
    .ifm-stat.tx { background:#fff7ed; border-color:#fed7aa; }
    .ifm-stat.tx .ifm-stat-lbl,
    .ifm-stat.tx .ifm-stat-val { color:#c2410c; }

    .ifm-chart-wrap {
      background:#fff; border:1px solid var(--border);
      border-radius:14px; padding:16px 18px;
    }
    .ifm-chart-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; flex-wrap:wrap; gap:8px; }
    .ifm-chart-hdr h3 { margin:0; font-size:13px; font-weight:700; color:var(--text); }
    .ifm-chart-hdr p { margin:2px 0 0; font-size:11.5px; color:var(--muted); }
    .ifm-chart-peak {
      display:flex; gap:16px; font-size:11px;
    }
    .ifm-chart-peak .pk-lbl { color:var(--muted); font-weight:600; }
    .ifm-chart-peak .pk-val { font-weight:800; font-family:'JetBrains Mono',monospace; }
    .ifm-chart-peak .rx-pk { color:#1d4ed8; }
    .ifm-chart-peak .tx-pk { color:#c2410c; }
    #ifmChart { min-height:280px; }

    /* ── TAB: Traffic chart ── */
    .chart-wrap { background:#fff; border:1px solid var(--border); border-radius:var(--rc); padding:18px 20px; }
    .chart-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; flex-wrap:wrap; gap:10px; }
    .chart-hdr h3 { margin:0; font-size:14px; font-weight:700; color:var(--text); }
    .chart-hdr p { margin:2px 0 0; font-size:12px; color:var(--muted); }

    /* ── TAB: Logs ── */
    .log-list { background:#fff; border:1px solid var(--border); border-radius:var(--rc); padding:6px 0; max-height:500px; overflow-y:auto; }
    .log-row { padding:10px 18px; border-bottom:1px solid #f1f5f9; display:grid; grid-template-columns:180px 1fr 80px 80px; gap:12px; font-size:12.5px; align-items:center; }
    .log-row:last-child { border-bottom:none; }
    .log-row:hover { background:#fafbff; }
    .log-row .time { color:var(--muted); font-family:'JetBrains Mono',monospace; font-size:11.5px; }
    .log-row .metric { font-weight:600; }
    .log-row .mono { font-family:'JetBrains Mono',monospace; font-weight:500; }

    .empty-state { text-align:center; padding:60px 20px; color:var(--muted); }
    .empty-state svg { color:var(--faint); margin-bottom:14px; }
    .empty-state-title { font-size:15px; font-weight:700; color:var(--text); margin-bottom:4px; }

    .spinner { display:inline-block; width:28px; height:28px; border:3px solid #e2e8f0; border-top-color:var(--dd-blue); border-radius:50%; animation:spin .8s linear infinite; }
    @keyframes spin { to { transform:rotate(360deg); } }
    .spin-wrap { text-align:center; padding:60px 20px; color:var(--muted); font-size:13px; }
    .spin-wrap .spinner { margin-bottom:10px; }

    .err-banner { background:var(--dd-amber-l); border:1px solid #fde68a; border-radius:12px; padding:12px 16px; margin-bottom:14px; display:flex; gap:10px; align-items:flex-start; font-size:12.5px; color:#78350f; }
    .err-banner svg { color:#b45309; flex-shrink:0; margin-top:1px; }
    .err-banner b { color:#78350f; }
  </style>
</head>
<body data-device-id="<%= deviceId %>">
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <main class="page-content dd">

      <!-- Breadcrumb -->
      <div class="dd-crumb">
        <a href="/devices">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="15 18 9 12 15 6"/></svg>
          Devices
        </a>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span id="crumbName">Loading...</span>
      </div>

      <!-- Header -->
      <div class="dd-hdr">
        <div class="dd-hdr-l">
          <h1 id="hdrName">Loading device...</h1>
          <p>
            <span class="mono" id="hdrIp">—</span>
            <span id="hdrType" style="text-transform:capitalize">—</span>
            <span class="st-chip st-offline" id="hdrStatus"><span class="dot"></span>offline</span>
          </p>
        </div>
        <div class="dd-hdr-r">
          <button class="btn btn-outline btn-sm" onclick="loadLiveData()" id="btnRefresh">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
            Refresh
          </button>
          <button class="btn btn-teal btn-sm" onclick="testConnectionNow()" id="btnTest">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h3l3-9 6 18 3-9h5"/></svg>
            Test Koneksi
          </button>
        </div>
      </div>

      <!-- Optional Error Banner -->
      <div id="errBanner" style="display:none"></div>

      <!-- Overview row: Info + Live Metrics -->
      <div class="dd-overview">
        <!-- Left: Device Info -->
        <div class="info-card">
          <div class="info-card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Informasi Device
          </div>
          <div class="info-grid" id="infoGrid">
            <div class="info-row"><div class="lbl">Name</div><div class="val" id="iName">—</div></div>
            <div class="info-row"><div class="lbl">IP Address</div><div class="val mono" id="iIp">—</div></div>
            <div class="info-row"><div class="lbl">Brand / Model</div><div class="val" id="iBrand">—</div></div>
            <div class="info-row"><div class="lbl">Tipe</div><div class="val" id="iType">—</div></div>
            <div class="info-row"><div class="lbl">Identity (MikroTik)</div><div class="val" id="iIdentity">—</div></div>
            <div class="info-row"><div class="lbl">Platform / Board</div><div class="val" id="iBoard">—</div></div>
            <div class="info-row"><div class="lbl">Firmware</div><div class="val mono" id="iFirmware">—</div></div>
            <div class="info-row"><div class="lbl">Monitoring</div><div class="val" id="iMonitoring">—</div></div>
            <div class="info-row"><div class="lbl">Lokasi</div><div class="val" id="iLocation">—</div></div>
            <div class="info-row"><div class="lbl">Polling Terakhir</div><div class="val" id="iLastPolled">—</div></div>
          </div>
        </div>

        <!-- Right: Live Metrics -->
        <div class="live-card">
          <div class="live-card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            Live Metrics
            <span class="live-badge"><span class="dot"></span>LIVE</span>
          </div>

          <div class="gauge-row">
            <div class="gauge">
              <svg class="gauge-svg" viewBox="0 0 100 100">
                <circle class="gauge-bg" cx="50" cy="50" r="42"/>
                <circle class="gauge-fg" id="gaugeCpu" cx="50" cy="50" r="42" stroke-dasharray="264" stroke-dashoffset="264"/>
              </svg>
              <div class="gauge-txt">
                <div class="gauge-val" id="gaugeCpuVal">—</div>
                <div class="gauge-lbl">CPU</div>
              </div>
            </div>
            <div class="gauge-info">
              <div class="gauge-info-lbl">Memory Usage</div>
              <div class="gauge-info-val" id="memVal">—</div>
              <div class="gauge-info-sub" id="memSub">—</div>
            </div>
          </div>

          <div class="live-uptime">
            <div class="live-uptime-ico">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="live-uptime-lbl">Uptime</div>
