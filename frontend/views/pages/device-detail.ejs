          <div class="info-grid">
            <div class="info-row"><div class="lbl">SNMP Community</div><div class="val mono" id="oSnmpCommunity">—</div></div>
            <div class="info-row"><div class="lbl">SNMP Port / Version</div><div class="val mono" id="oSnmpPort">—</div></div>
            <div class="info-row"><div class="lbl">API Username</div><div class="val mono" id="oApiUser">—</div></div>
            <div class="info-row"><div class="lbl">API Port</div><div class="val mono" id="oApiPort">—</div></div>
            <div class="info-row"><div class="lbl">Poll Interval</div><div class="val mono" id="oPollInterval">—</div></div>
            <div class="info-row"><div class="lbl">Status Aktif</div><div class="val" id="oActive">—</div></div>
            <div class="info-row" style="grid-column:1/-1"><div class="lbl">Catatan</div><div class="val" id="oNotes">—</div></div>
