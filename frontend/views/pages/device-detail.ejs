      <!-- Tab: Logs -->
      <div class="dd-tab-content" id="tab-logs">
        <div class="log-list">
          <div style="padding:10px 18px;border-bottom:1px solid var(--border);font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;background:#f8fafc;display:grid;grid-template-columns:180px 1fr 80px 80px;gap:12px">
            <span>Waktu</span>
            <span>Status</span>
            <span style="text-align:right">CPU</span>
            <span style="text-align:right">Memory</span>
          </div>
          <div id="logList">
            <div class="spin-wrap"><span class="spinner"></span><div>Memuat logs...</div></div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

