<script src="/js/app.js"></script>
<script>
  /* eslint-disable */
  var DEVICE_ID = parseInt(document.body.getAttribute('data-device-id')) || 0;
  var _DEVICE_CACHE = null;
  var _LIVE_CACHE   = null;
  var _TRAFFIC_CHART = null;
  var _REFRESH_INT  = null;

  function esc(v) {
    return String(v == null ? '' : v).replace(/[&<>"']/g, c => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    })[c]);
  }

  // Format bytes jadi human-readable
  function fmtBytes(b) {
    if (!b && b !== 0) return '—';
    const n = parseFloat(b);
    if (n < 1024) return n.toFixed(0) + ' B';
    if (n < 1024*1024) return (n/1024).toFixed(1) + ' KB';
    if (n < 1024*1024*1024) return (n/(1024*1024)).toFixed(1) + ' MB';
    if (n < 1024*1024*1024*1024) return (n/(1024*1024*1024)).toFixed(2) + ' GB';
    return (n/(1024*1024*1024*1024)).toFixed(2) + ' TB';
  }

  // Format bitrate jadi bps/Kbps/Mbps
  function fmtBitrate(bps) {
    if (!bps && bps !== 0) return '0 bps';
    const n = parseFloat(bps);
    if (n < 1000) return n.toFixed(0) + ' bps';
    if (n < 1e6) return (n/1000).toFixed(1) + ' Kbps';
    if (n < 1e9) return (n/1e6).toFixed(2) + ' Mbps';
    return (n/1e9).toFixed(2) + ' Gbps';
  }

  function fmtDateTime(d) {
    if (!d) return '—';
    try {
      return new Date(d).toLocaleString('id-ID', {
        day:'2-digit',month:'short',year:'numeric',
        hour:'2-digit',minute:'2-digit',second:'2-digit'
      });
    } catch { return '—'; }
  }

  function timeAgo(d) {
    if (!d) return '—';
    const ms = Date.now() - new Date(d).getTime();
    if (ms < 60000) return 'baru saja';
    if (ms < 3600000) return Math.round(ms/60000) + ' menit lalu';
    if (ms < 86400000) return Math.round(ms/3600000) + ' jam lalu';
    return Math.round(ms/86400000) + ' hari lalu';
  }

  // Load data awal
  async function loadInitial() {
    try {
      const res = await App.api('/devices/' + DEVICE_ID);
      if (!res?.success) throw new Error(res?.message || 'Gagal memuat device');
      _DEVICE_CACHE = res.data;
      renderDeviceInfo();
      renderOverviewTab();
      renderLogsTab();

      // Lanjut ambil live data
      loadLiveData();
    } catch (e) {
      document.getElementById('hdrName').textContent = 'Error';
      document.getElementById('crumbName').textContent = 'Error';
      App.showToast('Gagal memuat: ' + e.message, 'error');
    }
  }

  // Load live data dari MikroTik
  async function loadLiveData() {
    const btn = document.getElementById('btnRefresh');
    btn.disabled = true;
    try {
      const res = await App.api('/devices/' + DEVICE_ID + '/live-data');
      if (res?.success) {
        _LIVE_CACHE = res.data;
        // Update device cache juga (status bisa berubah)
        if (_LIVE_CACHE.device) Object.assign(_DEVICE_CACHE, _LIVE_CACHE.device);

        renderLiveMetrics();
        renderInterfacesTab();
        renderDeviceInfo();  // refresh info setelah live update

        // Tampilkan error banner kalau ada
        const banner = document.getElementById('errBanner');
        if (_LIVE_CACHE.errors && _LIVE_CACHE.errors.length) {
          const msg = _LIVE_CACHE.errors[0].error || 'Tidak bisa mengambil data live';
          banner.style.display = 'block';
          banner.className = 'err-banner';
          banner.innerHTML =
            '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' +
            '<div><b>Live data tidak tersedia.</b> ' + esc(msg) + '</div>';
        } else {
          banner.style.display = 'none';
        }
      }
    } catch (e) {
      console.error('loadLiveData:', e);
    } finally {
      btn.disabled = false;
    }
  }

  function renderDeviceInfo() {
    const d = _DEVICE_CACHE;
    if (!d) return;

    // Header
    document.getElementById('crumbName').textContent = d.name || 'Device';
    document.getElementById('hdrName').textContent   = d.name || '—';
    document.getElementById('hdrIp').textContent     = d.ip_address || '—';
    document.getElementById('hdrType').textContent   = d.type || '—';
    document.title = (d.name || 'Device') + ' - Device Detail - ISP NetOps';

    const st = d.status || 'offline';
    const stChip = document.getElementById('hdrStatus');
    stChip.className = 'st-chip st-' + st;
    stChip.innerHTML = '<span class="dot"></span>' + st;

    // Info grid
    document.getElementById('iName').textContent   = d.name || '—';
    document.getElementById('iIp').textContent     = d.ip_address || '—';
    const brand = [d.brand, d.model].filter(Boolean).join(' · ');
    document.getElementById('iBrand').textContent  = brand || '—';
    document.getElementById('iType').textContent   = d.type || '—';

    const identity = _LIVE_CACHE?.identity || '—';
    document.getElementById('iIdentity').textContent = identity;
    document.getElementById('iBoard').textContent    = _LIVE_CACHE?.resource?.boardName || d.brand || '—';
    document.getElementById('iFirmware').textContent = _LIVE_CACHE?.resource?.version || d.firmware || '—';

    document.getElementById('iMonitoring').textContent =
      d.monitoring_type === 'both' ? 'SNMP + API' :
      d.monitoring_type === 'api'  ? 'API saja' : 'SNMP saja';

    document.getElementById('iLocation').textContent = d.location || '—';

    const lp = d.last_polled;
    document.getElementById('iLastPolled').innerHTML = lp
      ? esc(fmtDateTime(lp)) + '<div style="font-size:10.5px;color:var(--muted);font-weight:500;margin-top:2px">' + timeAgo(lp) + '</div>'
      : '—';
  }

  function renderLiveMetrics() {
    const r = _LIVE_CACHE?.resource;
    if (!r) {
      document.getElementById('gaugeCpuVal').textContent = '—';
      document.getElementById('memVal').textContent = '—';
      document.getElementById('memSub').textContent = '—';
      document.getElementById('uptimeVal').textContent = '—';
      document.getElementById('bwRxVal').textContent = '—';
      document.getElementById('bwRxSub').textContent = '—';
      document.getElementById('bwTxVal').textContent = '—';
      document.getElementById('bwTxSub').textContent = '—';
      setGauge('gaugeCpu', 0);
      return;
    }

    const cpu = r.cpuLoad || 0;
    document.getElementById('gaugeCpuVal').textContent = cpu + '%';
    setGauge('gaugeCpu', cpu);

    const memUsed = r.totalMemory - r.freeMemory;
    const memPct  = r.totalMemory > 0 ? Math.round((memUsed/r.totalMemory)*100) : 0;
    document.getElementById('memVal').textContent = memPct + '%';
    document.getElementById('memSub').textContent = fmtBytes(memUsed) + ' / ' + fmtBytes(r.totalMemory);

    document.getElementById('uptimeVal').textContent = r.uptime || '—';

    // ── Total bandwidth dari semua interface ──
    // Exclude bridge/vlan yang kadang double-count trafik
    const ifaces = (_LIVE_CACHE?.interfaces || []).filter(i =>
      i.running && !['bridge','vlan','vrrp'].includes((i.type||'').toLowerCase())
    );
    const totalRxBps = ifaces.reduce((sum,i) => sum + (i.rxBitsPerSecond || 0), 0);
    const totalTxBps = ifaces.reduce((sum,i) => sum + (i.txBitsPerSecond || 0), 0);
    const totalRxBytes = ifaces.reduce((sum,i) => sum + (i.rxByte || 0), 0);
    const totalTxBytes = ifaces.reduce((sum,i) => sum + (i.txByte || 0), 0);

    document.getElementById('bwRxVal').textContent = fmtBitrate(totalRxBps);
    document.getElementById('bwRxSub').textContent = 'Total ' + fmtBytes(totalRxBytes);
    document.getElementById('bwTxVal').textContent = fmtBitrate(totalTxBps);
    document.getElementById('bwTxSub').textContent = 'Total ' + fmtBytes(totalTxBytes);
  }

  function setGauge(id, pct) {
    const circumference = 2 * Math.PI * 42; // ~264
    const offset = circumference - (circumference * pct / 100);
    const el = document.getElementById(id);
    if (el) el.setAttribute('stroke-dashoffset', offset);
  }

  function renderOverviewTab() {
    const d = _DEVICE_CACHE;
    if (!d) return;
    document.getElementById('oSnmpCommunity').textContent = d.snmp_community || '—';
    document.getElementById('oSnmpPort').textContent      = (d.snmp_port || 161) + ' / v' + (d.snmp_version || 2) + 'c';
    document.getElementById('oApiUser').textContent       = d.api_username || '—';
    document.getElementById('oApiPort').textContent       = d.api_port || '—';
    document.getElementById('oPollInterval').textContent  = (d.poll_interval || 60) + ' detik';

    const activeEl = document.getElementById('oActive');
    if (d.is_active) {
      activeEl.innerHTML = '<span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;background:var(--dd-green-l);color:var(--dd-green);font-size:11px;font-weight:700">● Aktif</span>';
    } else {
      activeEl.innerHTML = '<span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;background:#f1f5f9;color:var(--muted);font-size:11px;font-weight:700">○ Nonaktif</span>';
    }

    const notes = document.getElementById('oNotes');
    if (d.notes) notes.textContent = d.notes;
    else notes.innerHTML = '<span class="val-muted">Tidak ada catatan</span>';
  }

  function renderInterfacesTab() {
    const ifaces = _LIVE_CACHE?.interfaces || [];
    const tbody = document.getElementById('ifTbody');
    const badge = document.getElementById('ifBadge');

    if (!ifaces.length) {
      badge.textContent = '0';
      tbody.innerHTML = `
        <tr><td colspan="6">
          <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            <div class="empty-state-title">Tidak ada data interface</div>
            <div style="font-size:12px">Live data hanya tersedia untuk device MikroTik dengan monitoring API aktif</div>
          </div>
        </td></tr>`;
      return;
    }

    badge.textContent = ifaces.length;
    tbody.innerHTML = ifaces.map(i => {
      let dotCls = 'stop', stateTxt = 'stopped';
      if (i.disabled) { dotCls = 'disabled'; stateTxt = 'disabled'; }
      else if (i.running) { dotCls = 'run'; stateTxt = 'running'; }

      return `
        <tr class="if-row" data-if-name="${esc(i.name)}">
          <td>
            <span class="if-dot ${dotCls}"></span>
            <span class="if-name">${esc(i.name)}</span>
            ${i.comment ? `<div class="if-comment">${esc(i.comment)}</div>` : ''}
          </td>
          <td><span class="if-type">${esc(i.type || 'ether')}</span></td>
          <td><span class="mono" style="font-size:12px;color:var(--muted)">${esc(i.macAddress || '—')}</span></td>
          <td><span class="if-bitrate rx">▼ ${esc(fmtBitrate(i.rxBitsPerSecond))}</span></td>
          <td><span class="if-bitrate tx">▲ ${esc(fmtBitrate(i.txBitsPerSecond))}</span></td>
          <td>
            <div class="if-total">RX ${esc(fmtBytes(i.rxByte))}</div>
            <div class="if-total">TX ${esc(fmtBytes(i.txByte))}</div>
          </td>
        </tr>`;
    }).join('');

    // Event delegation — klik row buka modal
    if (!tbody._ifClickAttached) {
      tbody._ifClickAttached = true;
      tbody.addEventListener('click', (e) => {
        const row = e.target.closest('.if-row[data-if-name]');
        if (!row) return;
        openInterfaceModal(row.getAttribute('data-if-name'));
      });
    }
  }

  function renderLogsTab() {
    const logs = (_DEVICE_CACHE?.logs || []).slice(0, 100);
    const wrap = document.getElementById('logList');
    if (!logs.length) {
      wrap.innerHTML = `
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <div class="empty-state-title">Belum ada log polling</div>
          <div style="font-size:12px">Log akan terisi otomatis saat poller berjalan</div>
        </div>`;
      return;
    }
    wrap.innerHTML = logs.map(l => {
      const cpu = l.cpu_load != null ? Math.round(l.cpu_load) + '%' : '—';
      const mem = l.memory_usage != null ? Math.round(l.memory_usage) + '%' : '—';
      const st = l.status || 'unknown';
      const color = st === 'online' ? 'var(--dd-green)' : st === 'offline' ? 'var(--dd-red)' : 'var(--muted)';
      return `<div class="log-row">
        <span class="time">${esc(fmtDateTime(l.polled_at))}</span>
        <span class="metric" style="color:${color};text-transform:capitalize">● ${esc(st)}</span>
        <span class="mono" style="text-align:right">${cpu}</span>
        <span class="mono" style="text-align:right">${mem}</span>
      </div>`;
    }).join('');
  }

  // ── Tab switch ──
  function switchTab(name, el) {
    document.querySelectorAll('.dd-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.dd-tab-content').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('tab-' + name).classList.add('active');
    if (name === 'traffic') loadTraffic();
  }

  // ── Traffic chart ──
  async function loadTraffic() {
    const hours = document.getElementById('trafficHours').value;
    const chartEl = document.getElementById('trafficChart');
    chartEl.innerHTML = '<div class="spin-wrap"><span class="spinner"></span><div>Memuat chart...</div></div>';

    try {
      const res = await App.api('/devices/' + DEVICE_ID + '/traffic?hours=' + hours);
      const raw = res?.data || [];
      if (!raw.length) {
        chartEl.innerHTML = `
          <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            <div class="empty-state-title">Belum ada data traffic</div>
            <div style="font-size:12px">Data akan terkumpul seiring polling berjalan</div>
          </div>`;
        return;
      }

      // Group by recorded_at → sum RX/TX semua interface
      const grouped = {};
      raw.forEach(r => {
        const t = new Date(r.recorded_at).getTime();
        if (!grouped[t]) grouped[t] = { rx: 0, tx: 0 };
        grouped[t].rx += parseFloat(r.rx_bytes) || 0;
        grouped[t].tx += parseFloat(r.tx_bytes) || 0;
      });

      const times = Object.keys(grouped).sort((a,b) => a-b);
      const rxSeries = times.map(t => ({ x: parseInt(t), y: grouped[t].rx }));
      const txSeries = times.map(t => ({ x: parseInt(t), y: grouped[t].tx }));

      chartEl.innerHTML = '';
      if (_TRAFFIC_CHART) { _TRAFFIC_CHART.destroy(); _TRAFFIC_CHART = null; }

      _TRAFFIC_CHART = new ApexCharts(chartEl, {
        chart: { type:'area', height:340, toolbar:{show:false}, zoom:{enabled:true}, fontFamily:'Plus Jakarta Sans' },
        series: [
          { name:'RX', data: rxSeries },
          { name:'TX', data: txSeries }
        ],
        colors: ['#2563eb', '#f97316'],
        stroke: { curve:'smooth', width:2.5 },
        fill: {
          type:'gradient',
          gradient: { shadeIntensity:1, opacityFrom:.35, opacityTo:.02, stops:[0,100] }
        },
        xaxis: {
          type:'datetime',
          labels:{ datetimeUTC:false, style:{colors:'#64748b',fontSize:'11px'} },
          axisBorder:{show:false}, axisTicks:{show:false}
        },
        yaxis: {
          labels: {
            formatter:(v) => fmtBytes(v),
            style:{colors:'#64748b',fontSize:'11px'}
          }
        },
        grid: { borderColor:'#f1f5f9', strokeDashArray:4 },
        tooltip: {
          x:{ format:'dd MMM HH:mm' },
          y:{ formatter:(v) => fmtBytes(v) }
        },
        legend: { position:'top', horizontalAlign:'right', fontSize:'12px' },
        dataLabels:{enabled:false}
      });
      _TRAFFIC_CHART.render();
    } catch (e) {
      chartEl.innerHTML = '<div class="empty-state" style="color:var(--dd-red)">Error: ' + esc(e.message) + '</div>';
    }
  }

  // ── Test connection ──
  async function testConnectionNow() {
    const btn = document.getElementById('btnTest');
    btn.disabled = true;
    App.showToast('Testing koneksi...', 'info');
    try {
      const res = await App.api('/devices/' + DEVICE_ID + '/test-connection', { method:'POST' });
      if (res?.success) {
        const r = res.data;
        if (r.success) {
          App.showToast('✓ Online — ' + r.ping_ms + 'ms' + (r.identity ? ' (' + r.identity + ')' : ''), 'success');
        } else {
          App.showToast('✕ ' + (r.error || 'Tidak terjangkau'), 'error');
        }
        // Reload data
        const res2 = await App.api('/devices/' + DEVICE_ID);
        if (res2?.success) {
          _DEVICE_CACHE = res2.data;
          renderDeviceInfo();
          renderOverviewTab();
        }
        loadLiveData();
      }
    } catch (e) {
      App.showToast('Error: ' + e.message, 'error');
    } finally {
      btn.disabled = false;
    }
  }

  // ══════════════════════════════════════════════
  // INTERFACE DETAIL MODAL — Live chart 2s polling
  // ══════════════════════════════════════════════
  var _IFM_CHART = null;
  var _IFM_POLL  = null;
  var _IFM_NAME  = null;
  var _IFM_RX_DATA = [];   // rolling window {x,y}
  var _IFM_TX_DATA = [];
  var _IFM_RX_PEAK = 0;
  var _IFM_TX_PEAK = 0;
  var _IFM_PKT_PEAK = 0;
  const IFM_MAX_POINTS = 60; // ~2 menit @ 2s interval

  async function openInterfaceModal(name) {
    _IFM_NAME = name;
    _IFM_RX_DATA = [];
    _IFM_TX_DATA = [];
    _IFM_RX_PEAK = 0;
    _IFM_TX_PEAK = 0;

    // Pre-fill header dari cache interfaces (sementara sebelum fetch live)
    const iface = (_LIVE_CACHE?.interfaces || []).find(i => i.name === name);
    document.getElementById('ifmName').textContent = name;
    document.getElementById('ifmType').textContent = iface?.type || '—';
    document.getElementById('ifmMac').textContent  = iface?.macAddress || '—';

    let stateHtml = '';
    if (iface?.disabled) stateHtml = '<span style="color:#fecaca">● disabled</span>';
    else if (iface?.running) stateHtml = '<span style="color:#86efac">● running</span>';
    else stateHtml = '<span style="opacity:.7">● stopped</span>';
    document.getElementById('ifmState').innerHTML = stateHtml;

    // Reset UI values
    ['ifmRxLive','ifmTxLive','ifmRxTotal','ifmTxTotal','ifmRxPeak','ifmTxPeak'].forEach(id => {
      document.getElementById(id).textContent = '—';
    });
    document.getElementById('ifmRxPps').textContent = '— pps';
    document.getElementById('ifmTxPps').textContent = '— pps';
    document.getElementById('ifmRxPkts').textContent = '— pkts';
    document.getElementById('ifmTxPkts').textContent = '— pkts';

    // Show modal + init chart
    document.getElementById('ifmOverlay').classList.add('active');
    initIfmChart();

    // Immediate fetch, then start polling
    await ifmFetchStats();
    _IFM_POLL = setInterval(ifmFetchStats, 2000);
  }

  function closeInterfaceModal() {
    document.getElementById('ifmOverlay').classList.remove('active');
    if (_IFM_POLL) { clearInterval(_IFM_POLL); _IFM_POLL = null; }
    if (_IFM_CHART) { _IFM_CHART.destroy(); _IFM_CHART = null; }
    _IFM_NAME = null;
  }

  function initIfmChart() {
    const el = document.getElementById('ifmChart');
    el.innerHTML = '';
    if (_IFM_CHART) { try { _IFM_CHART.destroy(); } catch(_) {} }

    _IFM_CHART = new ApexCharts(el, {
      chart: {
        type:'area', height:300, fontFamily:'Plus Jakarta Sans',
        animations: {
          enabled:true, easing:'linear',
          dynamicAnimation:{ speed:600 }
        },
        toolbar:{show:false}, zoom:{enabled:false},
        background:'transparent'
      },
      series: [
        { name:'RX (Download)', data: [] },
        { name:'TX (Upload)',   data: [] }
      ],
      colors: ['#2563eb', '#f97316'],
      stroke: { curve:'smooth', width:2.5 },
      fill: {
        type:'gradient',
        gradient: {
          shadeIntensity:1,
          opacityFrom:.5, opacityTo:.05,
          stops:[0,100]
        }
      },
      markers: {
        size: 0,
        hover: { size: 5 }
      },
      xaxis: {
        type:'datetime',
        range: IFM_MAX_POINTS * 2000,
        labels:{
          datetimeUTC:false,
          style:{colors:'#64748b',fontSize:'10.5px'},
          format:'HH:mm:ss'
        },
        axisBorder:{show:false},
        axisTicks:{show:false}
      },
      yaxis: {
        labels: {
          formatter:(v) => fmtBitrate(v),
          style:{colors:'#64748b',fontSize:'10.5px'}
        },
        min: 0,
        forceNiceScale: true
      },
      grid: { borderColor:'#f1f5f9', strokeDashArray:3, padding:{left:0,right:0} },
      tooltip: {
        x:{ format:'HH:mm:ss' },
        y:{ formatter:(v) => fmtBitrate(v) },
        theme:'light'
      },
      legend: { position:'top', horizontalAlign:'right', fontSize:'12px', fontWeight:600, markers:{width:10,height:10,radius:5} },
      dataLabels:{enabled:false}
    });
    _IFM_CHART.render();
  }

  async function ifmFetchStats() {
    if (!_IFM_NAME) return;
    try {
      const res = await App.api('/devices/' + DEVICE_ID + '/interface-stats?name=' + encodeURIComponent(_IFM_NAME));
      if (!res?.success) return;
      const s = res.data;
      const now = Date.now();

      // Append to rolling window
      _IFM_RX_DATA.push({ x: now, y: s.rxBitsPerSecond });
      _IFM_TX_DATA.push({ x: now, y: s.txBitsPerSecond });
      if (_IFM_RX_DATA.length > IFM_MAX_POINTS) _IFM_RX_DATA.shift();
      if (_IFM_TX_DATA.length > IFM_MAX_POINTS) _IFM_TX_DATA.shift();

      // Update peak
      if (s.rxBitsPerSecond > _IFM_RX_PEAK) _IFM_RX_PEAK = s.rxBitsPerSecond;
      if (s.txBitsPerSecond > _IFM_TX_PEAK) _IFM_TX_PEAK = s.txBitsPerSecond;

      // Update chart
      if (_IFM_CHART) {
        _IFM_CHART.updateSeries([
          { name:'RX (Download)', data: _IFM_RX_DATA },
          { name:'TX (Upload)',   data: _IFM_TX_DATA }
        ], false);
      }

      // Update stat cards
      document.getElementById('ifmRxLive').textContent   = fmtBitrate(s.rxBitsPerSecond);
      document.getElementById('ifmTxLive').textContent   = fmtBitrate(s.txBitsPerSecond);
      document.getElementById('ifmRxPps').textContent    = (s.rxPacketsPerSecond || 0).toLocaleString('id-ID') + ' pps';
      document.getElementById('ifmTxPps').textContent    = (s.txPacketsPerSecond || 0).toLocaleString('id-ID') + ' pps';
      document.getElementById('ifmRxTotal').textContent  = fmtBytes(s.rxByte);
      document.getElementById('ifmTxTotal').textContent  = fmtBytes(s.txByte);
      document.getElementById('ifmRxPkts').textContent   = (s.rxPacket || 0).toLocaleString('id-ID') + ' pkts';
      document.getElementById('ifmTxPkts').textContent   = (s.txPacket || 0).toLocaleString('id-ID') + ' pkts';
      document.getElementById('ifmRxPeak').textContent   = fmtBitrate(_IFM_RX_PEAK);
      document.getElementById('ifmTxPeak').textContent   = fmtBitrate(_IFM_TX_PEAK);

      // Update state kalau berubah
      let stateHtml = '';
      if (s.disabled) stateHtml = '<span style="color:#fecaca">● disabled</span>';
      else if (s.running) stateHtml = '<span style="color:#86efac">● running</span>';
      else stateHtml = '<span style="opacity:.7">● stopped</span>';
      document.getElementById('ifmState').innerHTML = stateHtml;
    } catch (e) {
      // Silent fail — polling terus jalan
      console.warn('ifmFetchStats:', e.message);
    }
  }

  // Close modal pada klik di luar / ESC
  document.getElementById('ifmOverlay').addEventListener('click', (e) => {
    if (e.target.id === 'ifmOverlay') closeInterfaceModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.getElementById('ifmOverlay').classList.contains('active')) {
      closeInterfaceModal();
    }
  });

  // ── Init ──
  document.addEventListener('DOMContentLoaded', () => {
    loadInitial();
    // Auto-refresh live data tiap 15 detik
    _REFRESH_INT = setInterval(loadLiveData, 15000);
  });
  window.addEventListener('beforeunload', () => {
    if (_REFRESH_INT) clearInterval(_REFRESH_INT);
    if (_IFM_POLL) clearInterval(_IFM_POLL);
    if (_TRAFFIC_CHART) _TRAFFIC_CHART.destroy();
    if (_IFM_CHART) _IFM_CHART.destroy();
  });
</script>
</body>
</html>
