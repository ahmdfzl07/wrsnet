            </div>
            <div style="display:flex;gap:8px">
              <select id="trafficHours" onchange="loadTraffic()" style="padding:7px 10px;border:1.5px solid var(--border);border-radius:8px;font-size:12px;font-weight:600;color:var(--text);background:#fff;font-family:inherit;cursor:pointer">
                <option value="1">1 jam terakhir</option>
                <option value="6">6 jam</option>
                <option value="24" selected>24 jam</option>
                <option value="168">7 hari</option>
