<script>
// State
let currentFilters = {
  status: '',
  type: '',
  priority: '',
  search: ''
};

// Init
document.addEventListener('DOMContentLoaded', () => {
  loadStatistics();
  loadTickets();
});

// ═══════════════════════════════════════════════════════
// MODAL FUNCTIONS
// ═══════════════════════════════════════════════════════

function showCreateModal() {
  document.getElementById('createModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}

function closeCreateModal() {
  document.getElementById('createModal').classList.remove('show');
  document.body.style.overflow = 'auto';
  
  // Reset form
  document.getElementById('createTicketForm').reset();
  document.querySelectorAll('.type-card, .priority-card').forEach(c => c.classList.remove('active'));
  clearCustomer();
}

// Type Selection
function selectType(card, value) {
  document.querySelectorAll('.type-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  card.querySelector('input[type="radio"]').checked = true;
}

// Priority Selection
function selectPriority(card, value) {
  document.querySelectorAll('.priority-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  card.querySelector('input[type="radio"]').checked = true;
}

// Close modal on ESC
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    closeCreateModal();
    closeDeleteModal();
  }
});

// ═══════════════════════════════════════════════════════
// DELETE TICKET
// ═══════════════════════════════════════════════════════

let ticketToDelete = null;

function showDeleteModal(ticketId, ticketNumber) {
  ticketToDelete = ticketId;
  document.getElementById('deleteTicketId').textContent = `#${String(ticketNumber || ticketId).padStart(4, '0')}`;
  document.getElementById('deleteModal').classList.add('show');
  document.body.style.overflow = 'hidden';
}

function closeDeleteModal() {
  document.getElementById('deleteModal').classList.remove('show');
  document.body.style.overflow = 'auto';
  ticketToDelete = null;
}

async function confirmDelete() {
  if (!ticketToDelete) return;
  
  try {
    const response = await fetch(`/api/tickets/${ticketToDelete}`, {
      method: 'DELETE',
      headers: {
        'Content-Type': 'application/json'
      }
    });
    
    const result = await response.json();
    
    if (result.success) {
      closeDeleteModal();
      showAlert('Ticket berhasil dihapus!', 'success');
      loadStatistics();
      loadTickets();
    } else {
      showAlert('Error: ' + (result.message || 'Gagal menghapus ticket'), 'error');
    }
  } catch (error) {
    console.error('Error deleting ticket:', error);
    showAlert('Error: ' + error.message, 'error');
  }
}

// ═══════════════════════════════════════════════════════
// CUSTOMER SEARCH
// ═══════════════════════════════════════════════════════

let searchTimeout;

async function searchCustomers(query) {
  clearTimeout(searchTimeout);
  
  const dropdown = document.getElementById('customerDropdown');
  
  if (!query || query.length < 2) {
    dropdown.style.display = 'none';
    dropdown.innerHTML = '';
    return;
  }
  
  searchTimeout = setTimeout(async () => {
    try {
      const response = await fetch(`/api/tickets/customers/search?q=${encodeURIComponent(query)}`);
      const result = await response.json();
      
      if (result.success && result.data.length > 0) {
        dropdown.innerHTML = result.data.map(customer => `
          <div class="cust-item" onclick="selectCustomer(${customer.id}, '${customer.name}', '${customer.phone || ''}', '${customer.address || ''}')">
            <div class="ci-name">${customer.name}</div>
            <div class="ci-sub">${customer.phone || ''} ${customer.address ? '• ' + customer.address : ''}</div>
          </div>
        `).join('');
        dropdown.style.display = 'block';
      } else {
        dropdown.style.display = 'none';
      }
    } catch (error) {
      console.error('Error searching customers:', error);
    }
  }, 300);
}

function selectCustomer(id, name, phone, address) {
  document.getElementById('selectedCustomerId').value = id;
  document.getElementById('customerSearch').value = name;
  document.getElementById('custName').textContent = name;
  document.getElementById('custDetails').textContent = `${phone || ''} ${address ? '• ' + address : ''}`;
  document.getElementById('customerInfo').style.display = 'block';
  document.getElementById('customerDropdown').style.display = 'none';
}

function clearCustomer() {
  document.getElementById('selectedCustomerId').value = '';
  document.getElementById('customerSearch').value = '';
  document.getElementById('customerInfo').style.display = 'none';
  document.getElementById('customerDropdown').style.display = 'none';
}

// ═══════════════════════════════════════════════════════
// SUBMIT TICKET
// ═══════════════════════════════════════════════════════

async function submitTicket(event) {
  event.preventDefault();
  
  const form = event.target;
  const formData = new FormData(form);
  const data = Object.fromEntries(formData.entries());
  
  data.status = 'open';
  
  const customerId = document.getElementById('selectedCustomerId').value;
  if (customerId) {
    data.customer_id = parseInt(customerId);
  }
  
  try {
    const response = await fetch('/api/tickets', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(data)
    });
    
    const result = await response.json();
    
    if (result.success) {
      closeCreateModal();
      showAlert('Ticket berhasil dibuat!', 'success');
      loadStatistics();
      loadTickets();
    } else {
      showAlert('Error: ' + (result.message || 'Gagal membuat ticket'), 'error');
    }
  } catch (error) {
    console.error('Error creating ticket:', error);
    showAlert('Error: ' + error.message, 'error');
  }
}

// ═══════════════════════════════════════════════════════
// LOAD DATA
// ═══════════════════════════════════════════════════════

async function loadStatistics() {
  try {
    const response = await fetch('/api/tickets/stats');
    const result = await response.json();
    
    if (result.success) {
      const stats = result.data;
      const total       = stats.total       || 0;
      const open        = stats.open        || 0;
      const in_progress = stats.in_progress || 0;
      const pending     = stats.pending     || 0;
      const resolved    = stats.resolved    || 0;
      const closed      = stats.closed      || 0;
      // Jika API belum return closed (server lama), hitung dari sisa
      const closedVal = (closed + resolved) > 0
        ? closed + resolved
        : Math.max(0, total - open - in_progress - pending);
      document.getElementById('stat-total').textContent = total;
      document.getElementById('stat-open').textContent = open;
      document.getElementById('stat-in_progress').textContent = in_progress + pending;
      document.getElementById('stat-closed').textContent = closedVal;
    }
  } catch (error) {
    console.error('Error loading statistics:', error);
  }
}

async function loadTickets() {
  const status = document.getElementById('filterStatus').value;
  const type = document.getElementById('filterType').value;
  const priority = document.getElementById('filterPriority').value;
  const search = document.getElementById('filterSearch').value;
  
  const params = new URLSearchParams();
  if (status) params.append('status', status);
  if (type) params.append('type', type);
  if (priority) params.append('priority', priority);
  if (search) params.append('search', search);
  
  try {
    const response = await fetch(`/api/tickets?${params.toString()}`);
    const result = await response.json();
    
    if (result.success) {
      renderTickets(result.data);
      document.getElementById('ticket-count').textContent = result.total || 0;
    }
  } catch (error) {
    console.error('Error loading tickets:', error);
  }
}

function renderTickets(tickets) {
  const tbody = document.getElementById('ticketTableBody');
  
  if (tickets.length === 0) {
    tbody.innerHTML = `
      <tr>
        <td colspan="7" style="text-align:center;padding:40px;color:#94a3b8;">
          Tidak ada ticket ditemukan
        </td>
      </tr>
    `;
    return;
  }
  
  tbody.innerHTML = tickets.map((ticket, index) => `
    <tr onclick="window.location.href='/tickets/${ticket.id}'">
      <td>${index + 1}</td>
      <td style="font-family:monospace;font-weight:700;">#${String(ticket.id).padStart(4, '0')}</td>
      <td style="font-size:12px;color:#64748b;">${formatDateLong(ticket.created_at)}</td>
      <td>${ticket.customer?.name || '-'}</td>
      <td>
        <span class="badge badge-type-${ticket.type || 'gangguan'}" style="font-size:11px;padding:4px 10px;border-radius:20px;font-weight:600;white-space:nowrap;">
          ${typeLabel(ticket.type)}
        </span>
      </td>
      <td>${ticket.title}</td>
      <td>
        <span class="status-pill pill-${ticket.status}">
          ${ticket.status.replace('_', ' ')}
        </span>
      </td>
      <td>
        <div style="display:flex;gap:4px;">
          <button onclick="event.stopPropagation();window.location.href='/tickets/${ticket.id}'" style="padding:4px 10px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;color:#1e40af;font-size:11px;font-weight:600;cursor:pointer;">
            Detail
          </button>
          <button onclick="event.stopPropagation();showDeleteModal(${ticket.id}, ${ticket.id})" class="btn-action-delete">
            Hapus
          </button>
        </div>
      </td>
    </tr>
  `).join('');
}

function quickFilter(status) {
  document.getElementById('filterStatus').value = status;
  loadTickets();
}

// ═══════════════════════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════════════════════

function showAlert(message, type = 'success') {
  const alertArea = document.getElementById('alertAreaTop');
  const icon = type === 'success' 
    ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>'
    : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
  
  const alertId = 'alert-' + Date.now();
  const alertEl = document.createElement('div');
  alertEl.id = alertId;
  alertEl.innerHTML = `
    <div class="alert ${type}">
      ${icon}
      <span class="alert-text">${message}</span>
    </div>
  `;
  alertArea.appendChild(alertEl);
  setTimeout(() => alertEl.remove(), 5000);
}

function formatDate(dateString) {
  if (!dateString) return '—';
  const date = new Date(dateString);
  if (isNaN(date.getTime())) return '—';
  
  const now = new Date();
  const diffMs = now - date;
  const diffMins = Math.floor(diffMs / 60000);
  const diffHours = Math.floor(diffMs / 3600000);
  const diffDays = Math.floor(diffMs / 86400000);

  if (diffMins < 1) return 'Baru saja';
  if (diffMins < 60) return `${diffMins} menit lalu`;
  if (diffHours < 24) return `${diffHours} jam lalu`;
  if (diffDays < 7) return `${diffDays} hari lalu`;

  const day = String(date.getDate()).padStart(2, '0');
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const year = date.getFullYear();
  return `${day}/${month}/${year}`;
}

function formatDateLong(dateString) {
  if (!dateString) return '—';
  const date = new Date(dateString);
  if (isNaN(date.getTime())) return '—';
  
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Oct', 'Nov', 'Des'];
  
  const day = date.getDate();
  const month = months[date.getMonth()];
  const year = date.getFullYear();
  const hours = String(date.getHours()).padStart(2, '0');
  const minutes = String(date.getMinutes()).padStart(2, '0');
  
  return `${day} ${month} ${year}, ${hours}:${minutes}`;
}

function typeLabel(type) {
  const labels = {
    'gangguan': 'Gangguan',
    'request': 'Request',
    'installation': 'Installation',
    'maintenance': 'Maintenance'
  };
  return labels[type] || type;
}
</script>

<script>
(function(){
  const W=72,H=36,MAX=20;
  const hist={all:[],open:[],inprog:[],closed:[]};
  const COLORS={all:'#2563eb',open:'#0891b2',inprog:'#16a34a',closed:'#ea580c'};
  const IDS={all:'stat-total',open:'stat-open',inprog:'stat-in_progress',closed:'stat-closed'};

  function sp(v){
    if(!v||v.length<2)return null;
    const mn=Math.min(...v),mx=Math.max(...v),r=mx-mn||1;
    const p=v.map((n,i)=>[(i/(v.length-1))*W,H-((n-mn)/r)*(H-6)-3]);
    const d=p.reduce((a,[x,y],i)=>{
      if(!i)return'M'+x.toFixed(1)+','+y.toFixed(1);
      const[px,py]=p[i-1],cx=(px+x)/2;
      return a+' C'+cx.toFixed(1)+','+py.toFixed(1)+' '+cx.toFixed(1)+','+y.toFixed(1)+' '+x.toFixed(1)+','+y.toFixed(1);
    },'');
    const lp=p[p.length-1],fp=p[0];
    return{d,fill:d+' L'+lp[0].toFixed(1)+','+H+' L'+fp[0].toFixed(1)+','+H+' Z',dot:lp};
  }
  function draw(id,v){
    const s=sp(v);if(!s)return;
    const f=document.getElementById(id+'-fill'),l=document.getElementById(id+'-line'),d=document.getElementById(id+'-dot');
    if(f)f.setAttribute('d',s.fill);if(l)l.setAttribute('d',s.d);
    if(d){d.setAttribute('cx',s.dot[0].toFixed(1));d.setAttribute('cy',s.dot[1].toFixed(1));}
  }
  function rn(id){const e=document.getElementById(id);return e?parseFloat(e.textContent.replace(/[^\d.]/g,''))||0:0;}
  function upd(){
    Object.keys(IDS).forEach(k=>{
      const v=rn(IDS[k]);
      hist[k].push(v);if(hist[k].length>MAX)hist[k].shift();
      draw('sp-'+k,hist[k]);
      const p=document.getElementById('tc-pill-'+k);if(p)p.textContent=v+' ticket';
    });
  }
  window._tcUpd=upd;
  Object.values(IDS).forEach(id=>{
    const e=document.getElementById(id);
    if(e)new MutationObserver(()=>setTimeout(upd,50)).observe(e,{childList:true,characterData:true,subtree:true});
  });
  document.addEventListener('DOMContentLoaded',upd);
})();

function tcCardClick(el, filter){
  const cards=document.querySelectorAll('.fin-card[data-filter]');
  const COLORS={all:'#2563eb',open:'#0891b2',inprog:'#16a34a',closed:'#ea580c'};
  const KEY_MAP={'':'all','open':'open','in_progress':'inprog','closed':'closed'};

  cards.forEach(c=>{
    c.classList.remove('tc-active');
    const k=KEY_MAP[c.dataset.filter]||'all';
    const col=COLORS[k]||'#64748b';
    const l=c.querySelector('.sp-line'),f=c.querySelector('.sp-fill'),d=c.querySelector('.sp-dot');
    if(l)l.style.stroke=col;if(f)f.style.fill=col;if(d)d.style.fill=col;
  });
  el.classList.add('tc-active');
  const l=el.querySelector('.sp-line'),f=el.querySelector('.sp-fill'),d=el.querySelector('.sp-dot');
  if(l)l.style.stroke='rgba(255,255,255,.70)';
  if(f)f.style.fill='rgba(255,255,255,.12)';
  if(d)d.style.fill='#fff';

  // Trigger filter asli
  if(typeof quickFilter==='function') quickFilter(filter);
}
</script>
