<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Ticketing System' %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <style>
    /* ═══════════════════════════════════════════════════════
       ROOT VARIABLES
    ═══════════════════════════════════════════════════════ */
    :root {
      --ot-blue:#1a6ef5; --ot-blue-d:#0047cc;
      --ot-cyan:#00c2f0; --ot-cyan-d:#0091b8;
      --ot-green:#00d4a4; --ot-green-d:#00a07a;
      --ot-orange:#ff8800; --ot-orange-d:#cc6600;
      --border:#e0e7f3; --text:#0d1b3e; --muted:#6b7fa8;
    }
    
    * { box-sizing:border-box; }
    .ot { font-family:'Plus Jakarta Sans',sans-serif; background:#eef2f9; }

    /* ═══════════════════════════════════════════════════════
       HEADER
    ═══════════════════════════════════════════════════════ */
    .ot-hdr { display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:20px; }
    .ot-hdr-l h1 { font-size:22px; font-weight:800; color:var(--text); margin:0 0 4px; }
    .ot-hdr-l p  { font-size:13px; color:var(--muted); margin:0; }
    .ot-hdr-r    { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }

    /* ═══════════════════════════════════════════════════════
       BUTTONS
    ═══════════════════════════════════════════════════════ */
    .btn { display:inline-flex; align-items:center; gap:6px; padding:9px 16px; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; border:1.5px solid; transition:all .15s; font-family:inherit; }
    .btn svg { width:15px; height:15px; }
    .btn-outline { background:#fff; border-color:var(--border); color:#374151; }
    .btn-outline:hover { background:#f8fafc; }
    .btn-blue  { background:var(--ot-blue); border-color:var(--ot-blue); color:#fff; }
    .btn-blue:hover { background:var(--ot-blue-d); }

    /* ═══════════════════════════════════════════════════════
       STAT CARDS
    ═══════════════════════════════════════════════════════ */
    /* ── STAT CARDS — single strip ── */
    .fin-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      background: #fff; border-radius: 16px;
      border: 1px solid #e8eaed; overflow: hidden; margin-bottom: 20px;
    }
    .fin-card {
      padding: 20px 22px 18px; border-right: 1px solid #e8eaed;
      cursor: pointer; display: flex; flex-direction: column; gap: 0;
      position: relative; overflow: hidden; transition: background .15s;
    }
    .fin-card:last-child { border-right: none; }
    .fin-card:hover { background: #fafbff; }
    .fin-card.tc-active { background: #2563eb; border-color: #2563eb; }
    .fin-card.tc-active:hover { background: #1d4ed8; }
    .fin-card.tc-active .card-lbl  { color: rgba(255,255,255,.70); }
    .fin-card.tc-active .card-val  { color: #fff; }
    .fin-card.tc-active .card-sub  { color: rgba(255,255,255,.60); }
    .fin-card.tc-active .card-pill { background: rgba(255,255,255,.20) !important; color: rgba(255,255,255,.90) !important; }
    .fin-card.tc-active .sp-line   { stroke: rgba(255,255,255,.70) !important; }
    .fin-card.tc-active .sp-fill   { fill: rgba(255,255,255,.12) !important; }
    .fin-card.tc-active .sp-dot    { fill: #fff !important; }
    .card-lbl { font-size:12px; font-weight:500; color:#64748b; margin-bottom:10px; letter-spacing:.1px; transition:color .15s; }
    .card-body { display:flex; align-items:flex-end; justify-content:space-between; gap:8px; }
    .card-left { display:flex; flex-direction:column; min-width:0; }
    .card-val  { font-size:30px; font-weight:800; color:#0f172a; letter-spacing:-1.2px; line-height:1; transition:color .15s; }
    @media(max-width:1400px){ .card-val { font-size:26px; } }
    .card-meta { display:flex; align-items:center; gap:5px; margin-top:6px; flex-wrap:wrap; }
    .card-pill { display:inline-flex; align-items:center; gap:2px; padding:1px 6px; border-radius:100px; font-size:10.5px; font-weight:700; white-space:nowrap; flex-shrink:0; transition:all .15s; }
    .pill-blue   { background:#dbeafe; color:#1d4ed8; }
    .pill-cyan   { background:#cffafe; color:#0e7490; }
    .pill-green  { background:#dcfce7; color:#16a34a; }
    .pill-orange { background:#ffedd5; color:#c2410c; }
    .card-sub  { font-size:11px; color:#94a3b8; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; transition:color .15s; }
    .card-spark { flex-shrink:0; width:72px; height:36px; }
    .card-spark svg { width:72px; height:36px; }
    .sp-fill { transition:fill .3s; }
    .sp-line { stroke-width:1.8; fill:none; stroke-linecap:round; stroke-linejoin:round; }
    .sp-dot  { }
    @media(max-width:700px) {
      .fin-grid { grid-template-columns:repeat(2,1fr); }
      .fin-card { border-right:none; border-bottom:1px solid #e8eaed; }
      .fin-card:nth-child(odd)  { border-right:1px solid #e8eaed; }
      .fin-card:nth-child(even) { border-right:none; }
      .fin-card:nth-last-child(-n+2) { border-bottom:none; }
    }
    @media(max-width:400px) {
      .fin-grid { grid-template-columns:1fr; }
      .fin-card { border-right:none !important; border-bottom:1px solid #e8eaed; }
      .fin-card:last-child { border-bottom:none; }
    }

    /* ═══════════════════════════════════════════════════════
       FILTER & TABLE
    ═══════════════════════════════════════════════════════ */
    .ot-filter-wrap { background:#fff; border:1.5px solid var(--border); border-radius:16px; overflow:hidden; margin-bottom:20px; }
    .ot-filter-hdr { padding:12px 16px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #f1f5f9; }
    .filter-title { font-size:12px; font-weight:700; color:var(--text); display:flex; align-items:center; gap:6px; }
    .filter-title svg { width:14px; height:14px; }
    .ot-filter-body { padding:16px; }
    .filter-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
    @media(max-width:1200px){ .filter-grid { grid-template-columns:repeat(2,1fr); } }
    @media(max-width:600px){ .filter-grid { grid-template-columns:1fr; } }
    
    .filter-col { display:flex; flex-direction:column; gap:6px; }
    .filter-label { font-size:11px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; }
    .filter-input, .filter-select { padding:10px 14px; border:1.5px solid var(--border); border-radius:10px; font-size:13px; font-family:inherit; background:#f8fafc; color:var(--text); outline:none; transition:all .15s; width:100%; }
    .filter-input:focus, .filter-select:focus { border-color:var(--ot-blue); background:#fff; box-shadow:0 0 0 3px rgba(26,110,245,.1); }

    .ot-tbl-wrap { background:#fff; border:1.5px solid var(--border); border-radius:16px; overflow:hidden; }
    .ot-tbl-hdr  { padding:14px 20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #f1f5f9; flex-wrap:wrap; gap:10px; }
    .ot-tbl-title { font-size:14px; font-weight:700; color:var(--text); display:flex; align-items:center; gap:8px; }
    .ot-count { font-size:11px; font-weight:600; background:#f1f5f9; color:var(--muted); padding:2px 9px; border-radius:20px; }

    .ot-table { width:100%; border-collapse:collapse; }
    .ot-table thead tr { background:#f8fafc; }
    .ot-table th { padding:10px 14px; font-size:10.5px; font-weight:700; color:var(--muted); text-transform:uppercase; letter-spacing:.7px; text-align:left; border-bottom:1px solid #f1f5f9; white-space:nowrap; }
    .ot-table tbody tr { border-bottom:1px solid #f8fafc; transition:background .1s; cursor:pointer; }
    .ot-table tbody tr:hover { background:#f8fafc; }
    .ot-table td { padding:10px 14px; font-size:13px; color:#374151; vertical-align:middle; }

    .status-pill { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; white-space:nowrap; border:1px solid; }
    .pill-open { background:#fffbeb; color:#92400e; border-color:#fcd34d; }
    .pill-in_progress { background:#eff6ff; color:#1e40af; border-color:#bfdbfe; }
    .pill-closed { background:#f1f5f9; color:#475569; border-color:#cbd5e1; }

    /* Badge Kategori */
    .badge { display:inline-flex; align-items:center; gap:4px; padding:4px 10px; border-radius:20px; font-size:11px; font-weight:600; white-space:nowrap; }
    .badge-type-gangguan { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
    .badge-type-request { background:#eff6ff; color:#1e40af; border:1px solid #bfdbfe; }
    .badge-type-installation { background:#f0fdf4; color:#166534; border:1px solid #bbf7d0; }
    .badge-type-maintenance { background:#fef3c7; color:#92400e; border:1px solid #fde68a; }

    /* Alert */
    .alert-area-top { margin-bottom:16px; }
    .alert { background:#fff; border-radius:12px; padding:14px 18px; box-shadow:0 8px 24px rgba(0,0,0,.15); border-left:4px solid; display:flex; align-items:center; gap:10px; margin-bottom:12px; }
    .alert.success { border-left-color:#16a34a; background:#f0fdf4; }
    .alert.error { border-left-color:#dc2626; background:#fef2f2; }
    .alert-text { font-size:13px; color:var(--text); font-weight:500; flex:1; }

    /* ═══════════════════════════════════════════════════════
       MODAL STYLING - COMPLETE FIX
    ═══════════════════════════════════════════════════════ */
    #createModal { 
      display:none; 
      position:fixed; 
      inset:0; 
      background:rgba(13,27,62,.65); 
      backdrop-filter:blur(8px); 
      z-index:9999; 
      align-items:center; 
      justify-content:center; 
    }
    #createModal.show { display:flex !important; }
    
    @keyframes slideUp { 
      from{opacity:0;transform:translateY(30px)} 
      to{opacity:1;transform:translateY(0)} 
    }
    
    .modal-box { 
      background:#fff; 
      border-radius:24px; 
      max-width:560px; 
      width:90%; 
      max-height:90vh; 
      overflow:hidden; 
      box-shadow:0 24px 64px rgba(13,27,62,.2); 
      animation:slideUp .4s ease; 
    }
    
    .modal-hdr { 
      background:linear-gradient(135deg, #1a6ef5, #0047cc); 
      padding:24px 28px; 
      position:relative; 
    }
    
    .modal-hdr h2 { 
      font-size:20px; 
      font-weight:800; 
      color:#fff; 
      margin:0; 
      display:flex; 
      align-items:center; 
      gap:10px; 
    }
    
    .modal-hdr h2 svg {
      width:20px;
      height:20px;
      stroke:currentColor;
    }
    
    .modal-close { 
      position:absolute; 
      top:20px; 
      right:20px; 
      background:rgba(255,255,255,.15); 
      width:36px; 
      height:36px; 
      border-radius:10px; 
      display:flex; 
      align-items:center; 
      justify-content:center; 
      cursor:pointer;
      border:none;
      transition:background .2s;
    }
    
    .modal-close:hover {
      background:rgba(255,255,255,.25);
    }
    
    .modal-close svg {
      width:16px;
      height:16px;
      stroke:white;
      stroke-width:2.5;
    }
    
    .modal-body { 
      padding:28px; 
      max-height:calc(90vh - 200px); 
      overflow-y:auto; 
    }
    
    .modal-footer { 
      padding:20px 28px; 
      border-top:1px solid #f1f5f9; 
      display:flex; 
      gap:10px; 
      justify-content:flex-end; 
    }

    /* ═══ FORM ELEMENTS ═══ */
    .form-group { 
      margin-bottom: 20px; 
    }

    .form-label { 
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 12px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .form-label svg {
      width: 14px;
      height: 14px;
      stroke: currentColor;
      flex-shrink: 0;
    }

    /* Input With Icon */
    .input-with-icon {
      position: relative;
      width: 100%;
    }

    .input-with-icon svg {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      width: 16px;
      height: 16px;
      color: #94a3b8;
      pointer-events: none;
    }

    .input-with-icon input {
      padding-left: 42px !important;
    }

    /* Form Input */
    .form-input {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #e0e7f3;
      border-radius: 12px;
      font-size: 13px;
      font-family: inherit;
      background: #f8fafc;
      color: #0f172a;
      outline: none;
      transition: all 0.15s;
    }

    .form-input:focus {
      border-color: #1a6ef5;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(26, 110, 245, 0.1);
    }

    .form-input::placeholder {
      color: #94a3b8;
    }

    /* Form Textarea */
    .form-textarea {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #e0e7f3;
      border-radius: 12px;
      font-size: 13px;
      font-family: inherit;
      background: #f8fafc;
      color: #0f172a;
      outline: none;
      transition: all 0.15s;
      min-height: 120px;
      resize: vertical;
      line-height: 1.6;
    }

    .form-textarea:focus {
      border-color: #1a6ef5;
      background: #fff;
      box-shadow: 0 0 0 3px rgba(26, 110, 245, 0.1);
    }

    .form-textarea::placeholder {
      color: #94a3b8;
    }

    /* ═══ TYPE CARDS ═══ */
    .type-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .type-card {
      border: 2px solid #e0e7f3;
      border-radius: 10px;
      padding: 10px 8px;
      cursor: pointer;
      background: #f8fafc;
      transition: all 0.2s;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }

    .type-card input[type="radio"] {
      display: none;
    }

    .type-card:hover {
      border-color: #1a6ef5;
      background: #eff6ff;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(26, 110, 245, 0.15);
    }

    .type-card.active {
      border-color: #1a6ef5;
      background: #eff6ff;
      box-shadow: 0 0 0 3px rgba(26, 110, 245, 0.1);
    }

    .type-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: #eff6ff;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .type-card:hover .type-icon,
    .type-card.active .type-icon {
      background: #1a6ef5;
    }

    .type-icon svg {
      width: 18px;
      height: 18px;
      stroke: #1a6ef5;
      transition: stroke 0.2s;
    }

    .type-card:hover .type-icon svg,
    .type-card.active .type-icon svg {
      stroke: #fff;
    }

    .type-name {
      font-size: 11px;
      font-weight: 600;
      color: #0f172a;
    }

    /* ═══ PRIORITY CARDS ═══ */
    .priority-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }

    .priority-card {
      border: 2px solid #e0e7f3;
      border-radius: 10px;
      padding: 10px 8px;
      cursor: pointer;
      background: #f8fafc;
      transition: all 0.2s;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }

    .priority-card input[type="radio"] {
      display: none;
    }

    .priority-card:hover {
      border-color: #1a6ef5;
      background: #eff6ff;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(26, 110, 245, 0.15);
    }

    .priority-card.active {
      border-color: #1a6ef5;
      background: #eff6ff;
      box-shadow: 0 0 0 3px rgba(26, 110, 245, 0.1);
    }

    .priority-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: #f8fafc;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
      position: relative;
    }

    .priority-card:hover .priority-icon,
    .priority-card.active .priority-icon {
      background: #1a6ef5;
    }

    .priority-icon svg {
      width: 18px;
      height: 18px;
      transition: all 0.2s;
    }

    .priority-card:hover .priority-icon svg,
    .priority-card.active .priority-icon svg {
      stroke: #fff;
    }

    .priority-name {
      font-size: 11px;
      font-weight: 600;
      color: #0f172a;
      margin-bottom: 2px;
    }

    .priority-desc {
      font-size: 9px;
      color: #64748b;
    }

    /* ═══ CUSTOMER INFO ═══ */
    #customerInfo {
      display: none;
      margin-top: 12px;
      padding: 14px 16px;
      background: #f0fdf4;
      border: 1.5px solid #86efac;
      border-radius: 12px;
    }

    /* ═══ CUSTOMER DROPDOWN ═══ */
    #customerDropdown {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: #fff;
      border: 1.5px solid #e0e7f3;
      border-radius: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      max-height: 280px;
      overflow-y: auto;
      z-index: 1000;
      display: none;
    }

    .cust-item { 
      padding: 12px 14px; 
      cursor: pointer; 
      border-bottom: 1px solid #f1f5f9; 
      transition: background 0.15s;
    }

    .cust-item:last-child { 
      border-bottom: none; 
    }

    .cust-item:hover { 
      background: #f4f8ff; 
    }

    .ci-name { 
      font-weight: 600; 
      color: #0f172a; 
      font-size: 13px; 
      margin-bottom: 3px;
    }

    .ci-sub { 
      font-size: 11px; 
      color: #64748b; 
    }

    /* ═══ MODAL BUTTONS ═══ */
    .btn-modern {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 11px 20px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      border: 2px solid;
      transition: all 0.2s;
      font-family: inherit;
    }

    .btn-modern svg {
      width: 16px;
      height: 16px;
      stroke: currentColor;
      flex-shrink: 0;
    }

    .btn-cancel {
      background: #fff;
      border-color: #e0e7f3;
      color: #374151;
    }

    .btn-cancel:hover {
      background: #f8fafc;
      border-color: #cbd5e1;
    }

    .btn-save {
      background: linear-gradient(135deg, #1a6ef5, #0047cc);
      border-color: #1a6ef5;
      color: #fff;
    }

    .btn-save:hover {
      background: linear-gradient(135deg, #0047cc, #003399);
      border-color: #0047cc;
      box-shadow: 0 4px 12px rgba(26, 110, 245, 0.3);
    }

    /* ═══ DELETE MODAL ═══ */
    #deleteModal { 
      display:none; 
      position:fixed; 
      inset:0; 
      background:rgba(13,27,62,.65); 
      backdrop-filter:blur(8px); 
      z-index:10000; 
      align-items:center; 
      justify-content:center; 
    }
    #deleteModal.show { display:flex !important; }

    .delete-box {
      background: #fff;
      border-radius: 20px;
      max-width: 420px;
      width: 90%;
      padding: 28px;
      animation: slideUp 0.3s ease;
    }

    .delete-icon {
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
      background: #fef2f2;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .delete-icon svg {
      width: 28px;
      height: 28px;
      stroke: #dc2626;
      stroke-width: 2;
    }

    .delete-title {
      font-size: 18px;
      font-weight: 800;
      color: #0f172a;
      text-align: center;
      margin: 0 0 8px;
    }

    .delete-message {
      font-size: 13px;
      color: #64748b;
      text-align: center;
      line-height: 1.6;
      margin: 0 0 24px;
    }

    .delete-message strong {
      color: #0f172a;
      font-weight: 700;
    }

    .delete-actions {
      display: flex;
      gap: 10px;
      justify-content: center;
    }

    .btn-delete {
      background: #dc2626;
      border-color: #dc2626;
      color: #fff;
    }

    .btn-delete:hover {
      background: #b91c1c;
      border-color: #b91c1c;
      box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
    }

    .btn-action-delete {
      padding: 4px 10px;
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 6px;
      color: #dc2626;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
    }

    .btn-action-delete:hover {
      background: #fee2e2;
      border-color: #fca5a5;
    }

    /* ═══ RESPONSIVE ═══ */
    @media (max-width: 600px) {
      .type-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      
      .priority-grid {
        grid-template-columns: 1fr;
      }
      
      .modal-box {
        max-width: 95%;
      }
      
      .btn-modern {
        padding: 10px 16px;
        font-size: 13px;
      }
    }
  </style>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  
  <div class="main-content">
    <%- include('../partials/topbar') %>
    <main class="page-content ot">

