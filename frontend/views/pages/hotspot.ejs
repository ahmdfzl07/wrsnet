/* ═══════════════════════════════════════════════════════════════
   UTILS
═══════════════════════════════════════════════════════════════ */
function x(s){ return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmtB(b){
  if (!b) return '0 B';
  if (b<1024) return b+' B';
  if (b<1048576) return (b/1024).toFixed(1)+' KB';
  if (b<1073741824) return (b/1048576).toFixed(1)+' MB';
  return (b/1073741824).toFixed(2)+' GB';
}
function setText(id,val){ const el=document.getElementById(id); if(el) el.textContent=val; }
function setEl(id,html){ const el=document.getElementById(id); if(el) el.innerHTML=html; }
function loaderHtml(){ return `<div class="loader"><svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>Memuat data...</div>`; }
function emptyHtml(msg){
  return `<div class="empty">
    <div class="empty-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>
    <h3>${x(msg)}</h3><p>Tidak ada data untuk ditampilkan</p>
  </div>`;
}

function openModal(id){ document.getElementById(id).style.display='flex'; document.body.style.overflow='hidden'; }
function closeModal(id){ document.getElementById(id).style.display='none'; document.body.style.overflow=''; }
function bgClose(e,id){ if (e.target===e.currentTarget) closeModal(id); }

function toast(msg, type='info'){
  // Suppress noise — abort errors muncul saat user navigate/reload, bukan masalah.
  const m = String(msg || '');
  if (/stream has been aborted|signal is aborted|user aborted|fetch aborted/i.test(m)) {
    console.warn('[toast suppressed]', m);
    return;
  }
  const el=document.createElement('div');
  const icons={success:'<polyline points="20,6 9,17 4,12"/>',error:'<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',info:'<line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'};
  el.className=`toast toast-${type}`;
  el.innerHTML=`<svg viewBox="0 0 24 24">${icons[type]||icons.info}</svg>${x(msg)}`;
  const tc=document.getElementById('toasts');
  tc.appendChild(el);
  setTimeout(()=>{ el.style.opacity='0'; el.style.transform='translateY(4px)'; el.style.transition='all .2s'; setTimeout(()=>el.remove(),200); },3200);
}

// Keyboard: Esc closes modal
document.addEventListener('keydown', e => {
  if (e.key==='Escape') {
    ['m-add-user','m-add-profile','m-add-binding','m-vouchers'].forEach(id => {
      const el=document.getElementById(id);
      if (el&&el.style.display!=='none') closeModal(id);
    });
  }
});

// ══════════════════════════════════════════════════════════════
//  TRAFFIC INTERFACE CHART — Grafana-style, Real-time
// ══════════════════════════════════════════════════════════════
(function(){
  var MAX_PTS = 60;
  var INTERVAL = 2000;
  var _charts  = { combined: null };
  var _socket  = null;
  var _selIface = '';
  var _buf = { rx:[], tx:[], ts:[] };
  var _restTimer = null;
  var _lastUpd   = 0;

  // ── Format bps ──────────────────────────────────────────────
  function bps(v, dec){
    v = +v||0; dec = dec===undefined?2:dec;
    if(v>=1e9) return (v/1e9).toFixed(dec)+' Gbps';
    if(v>=1e6) return (v/1e6).toFixed(dec)+' Mbps';
    if(v>=1e3) return (v/1e3).toFixed(dec)+' Kbps';
    return v+' bps';
  }
  function bpsShort(v){ return bps(v,1); }

  // ── Stats (avg/max) ─────────────────────────────────────────
  function stats(arr){
    if(!arr.length) return {cur:0,avg:0,max:0};
    var cur=arr[arr.length-1],sum=0,max=0;
    arr.forEach(function(v){sum+=v;if(v>max)max=v;});
    return {cur:cur,avg:sum/arr.length,max:max};
  }

  // ── createGfPanel — clone dari device-monitor ───────────────
  function createCombinedChart(rxData, txData){
    var el = document.getElementById('tc-combined-chart');
    if(!el) return null;
    if(_charts.combined){ try{_charts.combined.destroy();}catch(e){} }
    el.innerHTML = '';

    var now = Date.now();
    function toSeries(arr){
      return arr.map(function(v,i){
        return [now-(arr.length-1-i)*INTERVAL, v];
      });
    }

    var chart = new ApexCharts(el, {
      chart:{
        type:'area', height:180,
        background:'#fff',
        toolbar:{show:false},
        fontFamily:"'Geist Mono', monospace",
        zoom:{enabled:false},
        animations:{enabled:false},
        sparkline:{enabled:false}
      },
      theme:{mode:'light'},
      series:[
        {name:'RX Download', data:toSeries(rxData)},
        {name:'TX Upload',   data:toSeries(txData)}
      ],
      colors:['#4dd0e1','#ff8a65'],
      fill:{
        type:'gradient',
        gradient:{shadeIntensity:1,opacityFrom:0.35,opacityTo:0.02,stops:[0,100]}
      },
      stroke:{curve:'straight',width:[1.5,1.5]},
      dataLabels:{enabled:false},
      legend:{show:false},
      grid:{
        borderColor:'#f0f4f8',strokeDashArray:0,
        xaxis:{lines:{show:false}},
        yaxis:{lines:{show:true}},
        padding:{top:0,right:8,bottom:0,left:0}
      },
      xaxis:{
        type:'datetime',
        labels:{
          style:{fontSize:'9px',colors:'#94a3b8',fontFamily:'DM Sans,sans-serif'},
          datetimeUTC:false,format:'HH:mm:ss'
        },
        axisBorder:{show:false},
        axisTicks:{show:false}
      },
      yaxis:{
        min:0,tickAmount:3,
        labels:{
          style:{fontSize:'9px',colors:'#94a3b8',fontFamily:'DM Sans,sans-serif'},
          formatter:bpsShort
        }
      },
      tooltip:{
        theme:'light',x:{format:'HH:mm:ss'},
        shared:true,intersect:false,
        y:{formatter:bps},
        style:{fontSize:'11px',fontFamily:'DM Sans,sans-serif'}
      },
      markers:{size:0}
    });
    chart.render();
    return chart;
  }

  // ── Push data & update ───────────────────────────────────────
  function pushData(rx, tx){
    var now = Date.now();
    _buf.rx.push(rx); _buf.tx.push(tx); _buf.ts.push(now);
    if(_buf.rx.length>MAX_PTS){ _buf.rx.shift(); _buf.tx.shift(); _buf.ts.shift(); }

    // Update combined chart
    var tsSeries = {
      rx: _buf.rx.map(function(v,i){ return [_buf.ts[i],v]; }),
      tx: _buf.tx.map(function(v,i){ return [_buf.ts[i],v]; })
    };
    if(!_charts.combined){
      _charts.combined = createCombinedChart(_buf.rx, _buf.tx);
    } else {
      _charts.combined.updateSeries([
        {name:'RX Download', data:tsSeries.rx},
        {name:'TX Upload',   data:tsSeries.tx}
      ], false);
    }
    // Update stats
    function upStat(buf, curId, avgId, maxId){
      var s=stats(buf);
      var c2=document.getElementById(curId),a=document.getElementById(avgId),m=document.getElementById(maxId);
      if(c2)c2.textContent=bpsShort(s.cur);
      if(a)a.textContent=bpsShort(s.avg);
      if(m)m.textContent=bpsShort(s.max);
    }
    upStat(_buf.rx,'tc-rx-cur','tc-rx-avg','tc-rx-max');
    upStat(_buf.tx,'tc-tx-cur','tc-tx-avg','tc-tx-max');
  }

  // ── Start/stop monitor ──────────────────────────────────────
  function startMonitor(ifaceName){
    if(!ifaceName) return;
    _selIface = ifaceName;
    _buf = {rx:[],tx:[],ts:[]};
    _charts.combined = null;
    createCombinedChart([0],[0]);

    var badge = document.getElementById('tc-live-badge');
    if(badge) badge.style.display='flex';

    if(_socket){
      _socket.emit('interface:stop_monitor');
      _socket.emit('interface:start_monitor',{interfaces:[ifaceName],interval:INTERVAL});
    }
    startRestPoll(ifaceName);
  }

  function stopMonitor(){
    if(_socket) _socket.emit('interface:stop_monitor');
    stopRestPoll();
    var badge=document.getElementById('tc-live-badge');
    if(badge) badge.style.display='none';
  }

  // ── REST fallback polling ────────────────────────────────────
  function startRestPoll(ifaceName){
    stopRestPoll();
    _restTimer = setInterval(async function(){
      if(Date.now()-_lastUpd < 3500) return;
      try{
        var r=await api('GET','/api/mikrotik/interfaces/monitor-selected?names='+encodeURIComponent(ifaceName));
        if(!r.success||!r.data.length) return;
        var row=r.data.find(function(x){return x.name===ifaceName;})||r.data[0];
        if(!row) return;
        var rx=+(row.rxBitsPerSecond||row['rx-bits-per-second']||0);
        var tx=+(row.txBitsPerSecond||row['tx-bits-per-second']||0);
        _lastUpd=Date.now();
        pushData(rx,tx);
      }catch(e){}
    }, INTERVAL);
  }
  function stopRestPoll(){ if(_restTimer){clearInterval(_restTimer);_restTimer=null;} }

  // ── Time range ─────────────────────────────────────────────
  function setTimeRange(min){
    _timeMin = min;
    MAX_PTS  = Math.ceil(min * 60 * 1000 / INTERVAL);
    // Trim buffer ke MAX_PTS
    while(_buf.rx.length > MAX_PTS){ _buf.rx.shift(); _buf.tx.shift(); _buf.ts.shift(); }
    // Update active button style
    document.querySelectorAll('.tc-time-btn').forEach(function(btn){
      var active = +btn.dataset.min === min;
      btn.style.background = active ? '#2563eb' : 'transparent';
      btn.style.color      = active ? '#fff'    : '#64748b';
    });
    // Redraw chart dengan data yang ada
    if(_buf.rx.length){
      if(_charts.combined){ try{_charts.combined.destroy();}catch(e){} _charts.combined=null; }
      _charts.combined = createCombinedChart(_buf.rx, _buf.tx);
    }
  }

  // ── Load interfaces ─────────────────────────────────────────
  async function loadInterfaces(){
    var sel=document.getElementById('tc-iface-select');
    if(!sel) return;
    try{
      var r=await api('GET','/api/mikrotik/interfaces');
      if(!r.success||!r.data.length) return;
      var ifaces=r.data.filter(function(i){return i.running&&!i.disabled;});
      sel.innerHTML='<option value="">-- Pilih interface --</option>'+
        ifaces.map(function(i){
          var lbl=i.name+(i.comment?' ('+i.comment+')':'');
          return '<option value="'+i.name+'">'+lbl+'</option>';
        }).join('');
      var hs=ifaces.find(function(i){
        var n=i.name.toLowerCase();
        return n.indexOf('hotspot')!==-1||n.indexOf('wlan')!==-1||i.type==='ether';
      });
      if(hs){sel.value=hs.name;startMonitor(hs.name);}
    }catch(e){console.warn('[TrafficChart]',e.message);}
  }

  // ── Init ────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded',function(){
    try{
      _socket=io({transports:['websocket','polling']});
      _socket.on('connect',function(){ if(_selIface) startMonitor(_selIface); });
      _socket.on('interface:traffic_update',function(data){
        // Filter: kalau socket broadcast device_id berbeda dengan device aktif user,
        // skip — mencegah chart device A tertimpa data device B saat multi-MikroTik.
        if (window.MikrotikSelector && window.MikrotikSelector.getSelectedId) {
          var activeId = String(window.MikrotikSelector.getSelectedId() || '');
          var msgId    = String(data && (data.device_id || data.deviceId) || '');
          if (activeId && msgId && activeId !== msgId) return;
        }
        var rows=data.data||[];
        var row=rows.find(function(r){return r.name===_selIface;})||rows[0];
        if(!row) return;
        var rx=+(row.rxBitsPerSecond||row['rx-bits-per-second']||0);
        var tx=+(row.txBitsPerSecond||row['tx-bits-per-second']||0);
        _lastUpd=Date.now();
        pushData(rx,tx);
      });
    }catch(e){console.warn('[TrafficChart] Socket.IO:',e);}

    var sel=document.getElementById('tc-iface-select');
    if(sel) sel.addEventListener('change',function(){
      if(this.value) startMonitor(this.value); else stopMonitor();
    });

    // Time range buttons
    document.querySelectorAll('.tc-time-btn').forEach(function(btn){
      btn.addEventListener('click',function(){
        setTimeRange(+this.dataset.min);
      });
    });

    // Saat user ganti device via selector, reset & reload interface list.
    // Pakai event 'mt-device-change' yang di-broadcast modul selector (kalau ada).
    // Fallback: poll localStorage. Lebih aman: hook MikrotikSelector via opts.onChange
    // — tapi opts.onChange sudah dipakai oleh refreshAll() di blok lain, jadi
    // kita pakai pendekatan: listener storage event (cross-tab) + poll lokal.
    var _lastDeviceId = (window.MikrotikSelector && window.MikrotikSelector.getSelectedId) ? window.MikrotikSelector.getSelectedId() : '';
    setInterval(function(){
      if (!window.MikrotikSelector || !window.MikrotikSelector.getSelectedId) return;
      var curId = window.MikrotikSelector.getSelectedId() || '';
      if (curId !== _lastDeviceId) {
        _lastDeviceId = curId;
        stopMonitor();
        loadInterfaces();
      }
    }, 1000);

    // Tunggu selector siap sebelum loadInterfaces — selector ready event
    // belum ada, jadi tetap call & loadInterfaces akan pakai withDevice() yang
    // baca localStorage. Kalau visit pertama localStorage kosong, fallback OK
    // ke device default; saat onChange device, _lastDeviceId watcher di atas
    // akan trigger reload.
    if (window.MikrotikSelector) {
      // Beri 1 tick agar mikrotik-selector.js sempat fetch list & set activeId
      setTimeout(loadInterfaces, 250);
    } else {
      loadInterfaces();
    }
  });
})();

/* ════════════════════════════════════════════════════════════════════
   TAB: LAPORAN PENJUALAN + HISTORI USER
   ──────────────────────────────────────────────────────────────────
   State sederhana — semua perhitungan di backend, frontend cuma render.
   "Sudah dipakai" ditentukan backend (uptime > 0 atau bytes > 0).
   Harga = mapping profile→harga (disimpan di uploads/hotspot_pricing.json).
   Tanggal penjualan = parse "Generated DD/MM/YYYY" dari comment voucher.
════════════════════════════════════════════════════════════════════ */
(function(){
  'use strict';

  // ── State internal tab Laporan & Histori ────────────────────────
  let _repPricing  = {};        // { profileName: number }
  let _repProfiles = [];        // dari /hotspot/user-profiles (untuk render pricing editor)
  let _repReport   = null;      // hasil /sales-report terakhir
  let _histRows    = [];        // hasil /usage-history terakhir
  let _initialized = false;     // sudah set default date filter belum
  let _pricingLoaded = false;   // pernah fetch pricing dari server?

  // ── Public helper: HotspotPricing ───────────────────────────────
  // Dipakai dari fungsi modal "Tambah/Edit User Profile" yang ada di scope
  // global supaya bisa pre-fill harga + durasi & menyimpannya bersama profile.
  //
  // Struktur internal _repPricing:
  //   { 'profileName': { price: number, limitUptime: string }, ... }
  //
  // API:
  //   await HotspotPricing.fetch()                  → refresh dari server
  //   HotspotPricing.get('1Mbps-1Hari')             → number (harga saja)
  //   HotspotPricing.entry('1Mbps-1Hari')           → { price, limitUptime }
  //   HotspotPricing.limitUptime('1Mbps-1Hari')     → string
  //   HotspotPricing.has('1Mbps-1Hari')             → boolean
  //   await HotspotPricing.set(name, { price, limitUptime })
  //   await HotspotPricing.remove(name)             (rename / delete profile)
  //
  // Backward-compat: HotspotPricing.set(name, 5000) tetap diterima — angka
  // dianggap sebagai price saja, limitUptime tidak diubah.
  window.HotspotPricing = {
    async fetch() {
      try {
        const r = await api('GET', '/api/mikrotik/hotspot/pricing');
        // Server selalu return format baru { name: { price, limitUptime } }
        _repPricing = (r && r.success) ? (r.data || {}) : {};
        _pricingLoaded = true;
        return _repPricing;
      } catch (e) {
        console.warn('HotspotPricing.fetch error:', e);
        return _repPricing;
      }
    },
    async ensureLoaded() {
      if (!_pricingLoaded) await this.fetch();
      return _repPricing;
    },
    entry(profileName) {
      const e = _repPricing[profileName];
      if (!e) return { price: 0, limitUptime: '' };
      if (typeof e === 'number') return { price: e, limitUptime: '' };
      return {
        price: Number(e.price || 0),
        limitUptime: String(e.limitUptime || ''),
      };
    },
    get(profileName) { return this.entry(profileName).price; },
    limitUptime(profileName) { return this.entry(profileName).limitUptime; },
    has(profileName) {
      return Object.prototype.hasOwnProperty.call(_repPricing, profileName);
    },
    snapshot() { return Object.assign({}, _repPricing); },

    // Set entry (replace untuk profile yang dimaksud).
    //   value bisa number  → dianggap { price: N, limitUptime: existing }
    //   value bisa object  → { price, limitUptime }
    // Kalau hasilnya price=0 DAN limitUptime kosong → entry dihapus.
    async set(profileName, value) {
      if (!profileName) return false;
      let nextEntry;
      const cur = this.entry(profileName);
      if (typeof value === 'number') {
        nextEntry = { price: value, limitUptime: cur.limitUptime };
      } else if (value && typeof value === 'object') {
        nextEntry = {
          price: Number(value.price != null ? value.price : cur.price) || 0,
          limitUptime: (value.limitUptime != null ? String(value.limitUptime) : cur.limitUptime).trim(),
        };
      } else {
        nextEntry = { price: 0, limitUptime: '' };
      }

      const next = Object.assign({}, _repPricing);
      if (nextEntry.price > 0 || nextEntry.limitUptime) {
        next[profileName] = nextEntry;
      } else {
        delete next[profileName];
      }
      return await this._persist(next);
    },

    async remove(profileName) {
      if (!profileName || !this.has(profileName)) return true;
      const next = Object.assign({}, _repPricing);
      delete next[profileName];
      return await this._persist(next);
    },

    async _persist(next) {
      try {
        const r = await api('POST', '/api/mikrotik/hotspot/pricing', { pricing: next });
        if (r && r.success) {
          _repPricing = r.data || next;
          // Bila tab Laporan sedang terbuka, refresh editor + report
          const repTab = document.getElementById('tp-reports');
          if (repTab && repTab.classList.contains('active')) {
            try { renderPricingEditor(); } catch(e){}
            try { loadSalesReport(); } catch(e){}
          }
          return true;
        }
        return false;
      } catch (e) {
        console.warn('HotspotPricing._persist error:', e);
        return false;
      }
    },

    // Dipanggil setelah profile dibuat/diubah/dihapus dari modal di luar tab
    // Laporan, supaya editor pricing & sales report ikut up-to-date jika
    // user kemudian membuka tab Laporan (atau sedang membukanya).
    async notifyProfilesChanged() {
      try {
        const r = await api('GET', '/api/mikrotik/hotspot/user-profiles');
        _repProfiles = (r && r.success) ? (r.data || []) : [];
      } catch(e) { /* silent */ }
      const repTab = document.getElementById('tp-reports');
      if (repTab && repTab.classList.contains('active')) {
        try { renderPricingEditor(); } catch(e){}
        try { loadSalesReport(); } catch(e){}
      }
    },
  };

  // Helper format Rupiah
  function fmtRp(n) {
    n = Number(n) || 0;
    if (n === 0) return 'Rp 0';
    return 'Rp ' + n.toLocaleString('id-ID');
  }
  function fmtNum(n) { return (Number(n) || 0).toLocaleString('id-ID'); }
  function fmtBytes(b) {
    b = Number(b) || 0;
    if (b < 1024) return b + ' B';
    const k = 1024, u = ['KB','MB','GB','TB','PB'];
    let i = -1;
    do { b /= k; i++; } while (b >= k && i < u.length - 1);
    return b.toFixed(b >= 100 ? 0 : b >= 10 ? 1 : 2) + ' ' + u[i];
  }
  function toISODate(d) {
    const yy = d.getFullYear(), mm = String(d.getMonth()+1).padStart(2,'0'), dd = String(d.getDate()).padStart(2,'0');
    return yy + '-' + mm + '-' + dd;
  }
  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  // Set default tanggal: 30 hari terakhir (sekali saja per load tab)
  function ensureDefaultDates(prefix) {
    const fromEl = document.getElementById(prefix + '-from');
    const toEl   = document.getElementById(prefix + '-to');
    if (!fromEl || !toEl) return;
    if (!fromEl.value) {
      const t = new Date();
      const f = new Date(t.getTime() - 29 * 86400000);
      fromEl.value = toISODate(f);
      toEl.value   = toISODate(t);
    }
  }

  // ── Preset rentang tanggal untuk tab Laporan ────────────────────
  window.repApplyPreset = function(preset) {
    if (!preset) return;
    const today = new Date();
    let from, to = today;
    if (preset === 'today') {
      from = today;
    } else if (preset === '7') {
      from = new Date(today.getTime() - 6 * 86400000);
    } else if (preset === '30') {
      from = new Date(today.getTime() - 29 * 86400000);
    } else if (preset === 'month') {
      from = new Date(today.getFullYear(), today.getMonth(), 1);
    } else if (preset === 'lastmonth') {
      from = new Date(today.getFullYear(), today.getMonth() - 1, 1);
      to   = new Date(today.getFullYear(), today.getMonth(), 0);
    } else { return; }
    document.getElementById('rep-from').value = toISODate(from);
    document.getElementById('rep-to').value   = toISODate(to);
    loadSalesReport();
  };

  // ── Entry point tab Laporan ─────────────────────────────────────
  window.loadReportsTab = async function() {
    ensureDefaultDates('rep');
    // Load pricing + user profiles (untuk editor) paralel, lalu sales report
    try {
      const [_pric, profRes] = await Promise.all([
        window.HotspotPricing.fetch(),  // ← refresh cache internal
        api('GET', '/api/mikrotik/hotspot/user-profiles'),
      ]);
      _repProfiles = (profRes && profRes.success) ? (profRes.data || []) : [];
      renderPricingEditor();
    } catch(e) { console.warn('loadReportsTab init error:', e); }
    loadSalesReport();
  };

  window.loadSalesReport = async function() {
    const from = document.getElementById('rep-from').value;
    const to   = document.getElementById('rep-to').value;
    const q = [];
    if (from) q.push('from=' + from);
    if (to)   q.push('to='   + to);
    const url = '/api/mikrotik/hotspot/sales-report' + (q.length ? '?' + q.join('&') : '');

    try {
      const r = await api('GET', url);
      if (!r || !r.success) { toast((r && r.message) || 'Gagal memuat laporan', 'error'); return; }
      _repReport = r.data;
      renderSalesReport(r.data);
    } catch(e) {
      toast('Error: ' + e.message, 'error');
    }
  };

  function renderSalesReport(d) {
    if (!d) return;
    const s = d.summary || {};
    document.getElementById('rep-revenue').textContent = fmtRp(s.totalRevenue);
    document.getElementById('rep-sold').textContent    = fmtNum(s.totalSold);
    document.getElementById('rep-sold-sub').textContent = 'dari ' + fmtNum(s.totalUsers) + ' total user';
    document.getElementById('rep-unused').textContent  = fmtNum(s.totalUnused);
    document.getElementById('rep-arpu').textContent    = fmtRp(s.arpu);

    // Range label
    const days = (d.daily || []).length;
    document.getElementById('rep-range-lbl').textContent = days + ' hari periode';
    document.getElementById('rep-chart-meta').textContent = (d.range ? (d.range.from + ' s/d ' + d.range.to) : '');

    // Pricing warning
    const warnN = s.profilesWithoutPrice || 0;
    const warnEl = document.getElementById('rep-pricing-warn');
    if (warnEl) {
      warnEl.style.display = warnN > 0 ? '' : 'none';
      document.getElementById('rep-pricing-warn-n').textContent = warnN;
    }

    // Profile breakdown
    const list = document.getElementById('rep-prof-list');
    const byProf = d.byProfile || [];
    document.getElementById('rep-prof-count').textContent = byProf.length + ' profile';
    if (!byProf.length) {
      list.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">Belum ada data</div>';
    } else {
      list.innerHTML = byProf.map(p => {
        const valClass = p.revenue > 0 ? 'rep-prof-val' : 'rep-prof-val zero';
        const priceLbl = p.price > 0 ? fmtRp(p.price) : '<span style="color:var(--amber)">harga belum di-set</span>';
        const limLbl   = p.limitUptime ? ' &middot; <span style="color:var(--blue)">⏱ ' + esc(p.limitUptime) + '</span>' : '';
        return '<div class="rep-prof-row">' +
          '<div style="min-width:0;flex:1">' +
            '<div class="rep-prof-name">' + esc(p.profile) + '</div>' +
            '<div class="rep-prof-meta">' + priceLbl + limLbl + ' &middot; ' + fmtNum(p.sold) + ' terjual / ' + fmtNum(p.total) + ' total</div>' +
          '</div>' +
          '<div class="' + valClass + '">' + fmtRp(p.revenue) + '</div>' +
        '</div>';
      }).join('');
    }

    // Chart
    renderSalesChart(d.daily || []);
  }

  // Custom SVG bar chart — tidak butuh dependency tambahan, ringan, dan
  // gaya konsisten dengan halaman lain. Sumbu Y otomatis, hover tooltip.
  function renderSalesChart(daily) {
    const host = document.getElementById('rep-chart-host');
    if (!host) return;
    if (!daily.length) {
      host.innerHTML = '<div class="rep-chart-empty">Belum ada data dalam rentang ini</div>';
      return;
    }
    const maxRev = Math.max(1, ...daily.map(x => x.revenue));
    const W = 800, H = 220, padL = 60, padR = 16, padT = 16, padB = 32;
    const innerW = W - padL - padR;
    const innerH = H - padT - padB;
    const n = daily.length;
    const barGap = 2;
    const barW = Math.max(2, (innerW / n) - barGap);

    // Y axis ticks (4 garis grid)
    const ticks = 4;
    let gridLines = '';
    let yLabels = '';
    for (let i = 0; i <= ticks; i++) {
      const y = padT + (innerH * i / ticks);
      const v = maxRev * (1 - i / ticks);
      gridLines += '<line class="grid-line" x1="' + padL + '" y1="' + y.toFixed(1) + '" x2="' + (W - padR) + '" y2="' + y.toFixed(1) + '"/>';
      yLabels   += '<text class="axis-label" x="' + (padL - 6) + '" y="' + (y + 3).toFixed(1) + '" text-anchor="end">' + fmtShortRp(v) + '</text>';
    }

    // Bars
    let bars = '';
    daily.forEach((d, i) => {
      const x = padL + i * (barW + barGap);
      const h = (d.revenue / maxRev) * innerH;
      const y = padT + innerH - h;
      const cls = d.revenue > 0 ? 'bar' : 'bar bar-zero';
      const tip = d.date + ' — ' + fmtRp(d.revenue) + ' (' + fmtNum(d.sold) + ' voucher)';
      bars += '<rect class="' + cls + '" x="' + x.toFixed(1) + '" y="' + y.toFixed(1) +
              '" width="' + barW.toFixed(1) + '" height="' + Math.max(1, h).toFixed(1) + '" rx="2">' +
              '<title>' + esc(tip) + '</title></rect>';
    });

    // X labels — show only ~6 labels (first, last, evenly spaced) untuk hindari overlap
    let xLabels = '';
    const labelCount = Math.min(6, n);
    for (let i = 0; i < labelCount; i++) {
      const idx = Math.round(i * (n - 1) / Math.max(1, labelCount - 1));
      const d = daily[idx];
      const x = padL + idx * (barW + barGap) + barW / 2;
      const lbl = d.date.slice(5); // MM-DD
      xLabels += '<text class="axis-label" x="' + x.toFixed(1) + '" y="' + (H - padB + 14) + '" text-anchor="middle">' + lbl + '</text>';
    }

    host.innerHTML =
      '<svg class="rep-chart-svg" viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="xMidYMid meet">' +
        gridLines + bars + yLabels + xLabels +
      '</svg>';
  }

  function fmtShortRp(n) {
    n = Number(n) || 0;
    if (n >= 1e9) return 'Rp ' + (n / 1e9).toFixed(1) + 'M';
    if (n >= 1e6) return 'Rp ' + (n / 1e6).toFixed(1) + 'jt';
    if (n >= 1e3) return 'Rp ' + (n / 1e3).toFixed(0) + 'rb';
    return 'Rp ' + Math.round(n);
  }

  // ── Pricing editor ──────────────────────────────────────────────
  function renderPricingEditor() {
    const list = document.getElementById('pricing-list');
    if (!list) return;
    if (!_repProfiles.length) {
      list.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">Belum ada user profile di MikroTik ini</div>';
      return;
    }
    list.innerHTML = _repProfiles.map(p => {
      const name = p.name || '';
      const e    = window.HotspotPricing.entry(name);
      const rate = p.rateLimit ? esc(p.rateLimit) : '—';
      return '<div class="pricing-row pricing-row-3">' +
        '<div>' +
          '<div class="pr-name">' + esc(name) + '</div>' +
          '<div class="pr-rate">Rate-limit: ' + rate + '</div>' +
        '</div>' +
        '<div class="pr-input-wrap">' +
          '<span class="pr-prefix">Rp</span>' +
          '<input type="number" min="0" step="1000" data-profile="' + esc(name) + '" data-field="price" value="' + (e.price > 0 ? e.price : '') + '" placeholder="0">' +
        '</div>' +
        '<div class="pr-input-wrap">' +
          '<span class="pr-prefix" style="color:var(--blue)">⏱</span>' +
          '<input type="text" data-profile="' + esc(name) + '" data-field="limitUptime" value="' + esc(e.limitUptime) + '" placeholder="1d / 7d / kosong">' +
        '</div>' +
      '</div>';
    }).join('');
  }

  window.savePricing = async function() {
    const btn = document.getElementById('btn-save-pricing');
    const inputs = document.querySelectorAll('#pricing-list input[data-profile]');
    const pricing = {};
    // Kumpulkan price + limitUptime per profile
    inputs.forEach(inp => {
      const name  = inp.getAttribute('data-profile');
      const field = inp.getAttribute('data-field');
      if (!name) return;
      if (!pricing[name]) pricing[name] = { price: 0, limitUptime: '' };
      if (field === 'price') {
        const val = parseFloat(inp.value);
        pricing[name].price = (Number.isFinite(val) && val >= 0) ? val : 0;
      } else if (field === 'limitUptime') {
        pricing[name].limitUptime = (inp.value || '').trim();
      }
    });

    btn.disabled = true;
    const orig = btn.innerHTML;
    btn.innerHTML = '<svg class="spin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> Menyimpan…';
    try {
      const r = await api('POST', '/api/mikrotik/hotspot/pricing', { pricing });
      if (r && r.success) {
        _repPricing = r.data || pricing;
        toast('Harga & limit tersimpan — me-refresh laporan…', 'success');
        await loadSalesReport();
      } else {
        toast((r && r.message) || 'Gagal menyimpan', 'error');
      }
    } catch(e) { toast('Error: ' + e.message, 'error'); }
    finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  };

  // ── Export CSV per-hari ─────────────────────────────────────────
  window.exportReportCSV = function() {
    if (!_repReport) { toast('Belum ada data untuk di-export', 'info'); return; }
    const rows = [['Tanggal', 'Voucher Terjual', 'Pendapatan (Rp)']];
    (_repReport.daily || []).forEach(d => rows.push([d.date, d.sold, d.revenue]));
    rows.push([]);
    rows.push(['Breakdown per Profile']);
    rows.push(['Profile', 'Harga', 'Terjual', 'Belum Terpakai', 'Total', 'Pendapatan (Rp)']);
    (_repReport.byProfile || []).forEach(p => rows.push([p.profile, p.price, p.sold, p.unused, p.total, p.revenue]));
    downloadCSV(rows, 'laporan-hotspot-' + (_repReport.range?.from || '') + '_' + (_repReport.range?.to || '') + '.csv');
  };

  function downloadCSV(rows, filename) {
    const csv = rows.map(r => r.map(cell => {
      const s = (cell == null ? '' : String(cell));
      return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s;
    }).join(',')).join('\n');
    const blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename;
    document.body.appendChild(a); a.click();
    setTimeout(() => { document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);
  }

  // ════════════════════════════════════════════════════════════════
  //  TAB: HISTORI USER
  // ════════════════════════════════════════════════════════════════
  window.loadHistoryTab = async function() {
    ensureDefaultDates('hist');
    // Populate profile filter dari _repProfiles (kalau sudah ada) atau fetch
    try {
      if (!_repProfiles.length) {
        const r = await api('GET', '/api/mikrotik/hotspot/user-profiles');
        _repProfiles = (r && r.success) ? (r.data || []) : [];
      }
      const sel = document.getElementById('hist-profile');
      // Preserve current value bila ada
      const curVal = sel.value;
      sel.innerHTML = '<option value="">Semua profile</option>' +
        _repProfiles.map(p => '<option value="' + esc(p.name) + '"' + (p.name === curVal ? ' selected' : '') + '>' + esc(p.name) + '</option>').join('');
    } catch(e) { /* silent */ }
    loadUsageHistory();
  };

  window.loadUsageHistory = async function() {
    const from    = document.getElementById('hist-from').value;
    const to      = document.getElementById('hist-to').value;
    const profile = document.getElementById('hist-profile').value;
    const search  = document.getElementById('hist-search').value.trim();

    const q = [];
    if (from)    q.push('from='    + encodeURIComponent(from));
    if (to)      q.push('to='      + encodeURIComponent(to));
    if (profile) q.push('profile=' + encodeURIComponent(profile));
    if (search)  q.push('search='  + encodeURIComponent(search));
    const url = '/api/mikrotik/hotspot/usage-history' + (q.length ? '?' + q.join('&') : '');

    document.getElementById('tbl-history').innerHTML =
      '<div class="loader" style="padding:24px"><svg class="spin" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>Memuat…</div>';

    try {
      const r = await api('GET', url);
      if (!r || !r.success) { toast((r && r.message) || 'Gagal memuat histori', 'error'); return; }
      _histRows = r.data || [];
      renderHistory();
    } catch(e) { toast('Error: ' + e.message, 'error'); }
  };

  function renderHistory() {
    const rows = _histRows;
    // Stat strip
    let totalBytes = 0, revenue = 0, enabled = 0;
    rows.forEach(r => {
      totalBytes += (r.bytesTotal || 0);
      revenue    += (r.price || 0);
      if (!r.disabled) enabled++;
    });
    document.getElementById('hist-stat-total').textContent     = fmtNum(rows.length);
    document.getElementById('hist-stat-bytes').textContent     = fmtBytes(totalBytes);
    document.getElementById('hist-stat-revenue').textContent   = fmtRp(revenue);
    document.getElementById('hist-stat-enabled').textContent   = fmtNum(enabled);
    document.getElementById('hist-count').textContent          = fmtNum(rows.length) + ' user';
    document.getElementById('tb-history').textContent          = fmtNum(rows.length);

    const host = document.getElementById('tbl-history');
    if (!rows.length) {
      host.innerHTML = '<div style="padding:40px;text-align:center;color:var(--text3);font-size:13px">' +
        '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.4;margin-bottom:10px"><path d="M3 12a9 9 0 109-9 9.75 9.75 0 00-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>' +
        '<div>Tidak ada user yang cocok dengan filter</div>' +
        '<div style="font-size:11.5px;margin-top:6px">Coba ubah rentang tanggal atau hapus filter profile</div>' +
      '</div>';
      return;
    }

    host.innerHTML =
      '<table>' +
        '<thead><tr>' +
          '<th>#</th>' +
          '<th>Username</th>' +
          '<th>Profile</th>' +
          '<th>Generated</th>' +
          '<th>Uptime</th>' +
          '<th class="num-r">Bytes</th>' +
          '<th class="num-r">Harga</th>' +
          '<th>Status</th>' +
          '<th>MAC</th>' +
        '</tr></thead>' +
        '<tbody>' +
        rows.map((r, i) => {
          const status = r.disabled
            ? '<span class="badge-soft bs-red">Disabled</span>'
            : '<span class="badge-soft bs-green">Aktif</span>';
          const priceCell = r.price > 0 ? fmtRp(r.price)
            : '<span style="color:var(--text3)">—</span>';
          return '<tr>' +
            '<td style="color:var(--text3);font-size:12px">' + (i+1) + '</td>' +
            '<td style="font-weight:600">' + esc(r.name) + '</td>' +
            '<td><span class="badge-soft bs-blue">' + esc(r.profile) + '</span></td>' +
            '<td style="font-family:var(--fm);font-size:12px">' + (r.generatedAt || '<span style="color:var(--text3)">—</span>') + '</td>' +
            '<td style="font-family:var(--fm);font-size:12px">' + esc(r.uptime || '—') + '</td>' +
            '<td class="num-r">' + fmtBytes(r.bytesTotal) + '</td>' +
            '<td class="num-r">' + priceCell + '</td>' +
            '<td>' + status + '</td>' +
            '<td style="font-family:var(--fm);font-size:11px;color:var(--text2)">' + esc(r.macAddress || '—') + '</td>' +
          '</tr>';
        }).join('') +
        '</tbody>' +
      '</table>';
  }

  window.exportHistoryCSV = function() {
    if (!_histRows.length) { toast('Belum ada data untuk di-export', 'info'); return; }
    const rows = [['Username', 'Profile', 'Generated', 'Uptime', 'Bytes In', 'Bytes Out', 'Total Bytes', 'Harga (Rp)', 'Status', 'MAC', 'Comment']];
    _histRows.forEach(r => rows.push([
      r.name, r.profile, r.generatedAt || '', r.uptime || '',
      r.bytesIn, r.bytesOut, r.bytesTotal, r.price,
      r.disabled ? 'Disabled' : 'Aktif',
      r.macAddress || '', r.comment || ''
    ]));
    downloadCSV(rows, 'histori-user-hotspot-' + toISODate(new Date()) + '.csv');
  };

  // Enter di search input → trigger search
  document.addEventListener('DOMContentLoaded', () => {
    const sInp = document.getElementById('hist-search');
    if (sInp) sInp.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') loadUsageHistory();
    });
  });
})();
</script>
</body>
</html>
