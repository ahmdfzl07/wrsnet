/* ═══════════════════════════════════════════════════════════════
   ACTIVE SESSIONS
═══════════════════════════════════════════════════════════════ */
async function loadActive() {
  setEl('tbl-active', loaderHtml());
  const r = await api('GET','/api/mikrotik/hotspot/active').catch(()=>({}));
  allActive = r.success?r.data:[];
  filtActive=[...allActive];
  document.getElementById('tb-active').textContent=allActive.length;
  renderActive();
}

function renderActive() {
  if (!filtActive.length){ setEl('tbl-active',emptyHtml('Tidak ada sesi aktif')); return; }
  let h=`<table><thead><tr>
    <th><input type="checkbox" class="chk" id="chk-all-a" onchange="checkAllActive()"></th>
    <th>User</th><th>IP Address</th><th>MAC</th><th>Uptime</th><th>↓ Download</th><th>↑ Upload</th><th>Server</th><th>Aksi</th>
  </tr></thead><tbody>`;
  filtActive.forEach(s => {
    h+=`<tr>
      <td><input type="checkbox" class="chk chk-a" value="${x(s.id)}" onchange="updDiscBtn()"></td>
      <td><strong>${x(s.user)}</strong></td>
      <td><span class="td-mono">${x(s.address)}</span></td>
      <td><span class="td-mono" style="font-size:11px">${x(s.macAddress)}</span></td>
      <td><span class="td-mono">${x(s.uptime)}</span></td>
      <td style="font-size:12px">${fmtB(s.bytesIn)}</td>
      <td style="font-size:12px">${fmtB(s.bytesOut)}</td>
      <td style="font-size:12px;color:var(--text2)">${x(s.server)}</td>
      <td><button class="btn btn-danger btn-xs" onclick="disconnectOne('${s.id}','${x(s.user)}')">Putus</button></td>
    </tr>`;
  });
  h+='</tbody></table>';
  setEl('tbl-active',h);
}

function filterActive() {
  const q=document.getElementById('q-active').value.toLowerCase();
  filtActive=allActive.filter(s=>!q||s.user.toLowerCase().includes(q)||s.address.includes(q)||s.macAddress.toLowerCase().includes(q));
  renderActive();
}

function checkAllActive(){ const m=document.getElementById('chk-all-a'); document.querySelectorAll('.chk-a').forEach(c=>c.checked=m.checked); updDiscBtn(); }
