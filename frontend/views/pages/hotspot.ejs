async function loadUserProfiles() {
  setEl('tbl-profiles', loaderHtml());
  // Load profiles + pricing paralel — pricing dipakai untuk kolom Harga + Limit
  const [r, _p] = await Promise.all([
    api('GET','/api/mikrotik/hotspot/user-profiles').catch(()=>({})),
    window.HotspotPricing ? window.HotspotPricing.ensureLoaded() : Promise.resolve({}),
  ]);
  allProfiles=r.success?r.data:[];
  syncProfileDropdowns();
  if (!allProfiles.length){ setEl('tbl-profiles',emptyHtml('Belum ada user profile')); return; }
  let h=`<table><thead><tr>
    <th>Nama</th><th>Rate Limit</th><th>Shared</th><th>Session Timeout</th><th>Idle Timeout</th><th>Limit Voucher</th><th class="num-r">Harga</th><th>Aksi</th>
  </tr></thead><tbody>`;
  allProfiles.forEach(p=>{
    const entry = window.HotspotPricing ? window.HotspotPricing.entry(p.name) : { price: 0, limitUptime: '' };
    const priceCell = entry.price > 0
      ? `<span style="font-family:var(--fm);font-weight:700;color:var(--green)">Rp ${entry.price.toLocaleString('id-ID')}</span>`
      : `<span style="color:var(--text3);font-size:11.5px">belum di-set</span>`;
    const limitCell = entry.limitUptime
      ? `<span style="font-family:var(--fm);font-weight:600;color:var(--blue)">${x(entry.limitUptime)}</span>`
      : `<span style="color:var(--text3);font-size:11.5px">∞ unlimited</span>`;
    h+=`<tr>
      <td><strong>${x(p.name)}</strong></td>
      <td><span class="td-mono">${x(p.rateLimit)||'—'}</span></td>
      <td style="text-align:center">${x(p.sharedUsers)}</td>
      <td style="font-size:12px;color:var(--text2)">${x(p.sessionTimeout)||'<span style="color:var(--text3)">∞</span>'}</td>
      <td style="font-size:12px;color:var(--text2)">${x(p.idleTimeout)||'<span style="color:var(--text3)">∞</span>'}</td>
      <td>${limitCell}</td>
      <td class="num-r">${priceCell}</td>
      <td><div style="display:flex;gap:5px">
        <button class="btn btn-ghost btn-xs" onclick='editProfile(${JSON.stringify(p).replace(/'/g,"&#39;")})'>Edit</button>
        <button class="btn btn-danger btn-xs" onclick="delProfile('${p.id}','${x(p.name)}')">Hapus</button>
      </div></td>
    </tr>`;
  });
  h+='</tbody></table>';
  setEl('tbl-profiles',h);
}

function openAddProfile(){
  // Reset form ke state kosong (penting kalau modal pernah dipakai untuk edit)
  document.getElementById('m-profile-title').textContent='Tambah User Profile';
  document.getElementById('p-id').value='';
  document.getElementById('p-name').value='';
  document.getElementById('p-rate').value='';
  document.getElementById('p-shared').value='1';
  document.getElementById('p-session').value='';
  document.getElementById('p-idle').value='';
  document.getElementById('p-alist').value='';
  const priceInp = document.getElementById('p-price');
  if (priceInp) {
    priceInp.value = '';
    priceInp.removeAttribute('data-original-name');
  }
  const limInp = document.getElementById('p-limit-uptime');
  if (limInp) limInp.value = '';
  openModal('m-add-profile');
}

function editProfile(p){
  document.getElementById('m-profile-title').textContent='Edit Profile: '+p.name;
  document.getElementById('p-id').value=p.id;
  document.getElementById('p-name').value=p.name;
  document.getElementById('p-rate').value=p.rateLimit;
  document.getElementById('p-shared').value=p.sharedUsers;
  document.getElementById('p-session').value=p.sessionTimeout;
  document.getElementById('p-idle').value=p.idleTimeout;
  document.getElementById('p-alist').value=p.addressList;
  // Pre-fill harga + limit uptime dari pricing config (lazy-load)
  const priceInp = document.getElementById('p-price');
  const limInp   = document.getElementById('p-limit-uptime');
  if (window.HotspotPricing) {
    window.HotspotPricing.ensureLoaded().then(() => {
      const entry = window.HotspotPricing.entry(p.name);
      if (priceInp) priceInp.value = entry.price > 0 ? entry.price : '';
      if (limInp)   limInp.value   = entry.limitUptime || '';
    });
  } else {
    if (priceInp) priceInp.value = '';
    if (limInp)   limInp.value   = '';
  }
  // Track nama lama supaya kalau user rename, harga lama bisa dipindah
  priceInp?.setAttribute('data-original-name', p.name);
  openModal('m-add-profile');
}

async function saveProfile(){
  const id=document.getElementById('p-id').value;
  const body={name:document.getElementById('p-name').value.trim(),rateLimit:document.getElementById('p-rate').value,sharedUsers:document.getElementById('p-shared').value,sessionTimeout:document.getElementById('p-session').value,idleTimeout:document.getElementById('p-idle').value,addressList:document.getElementById('p-alist').value};
  if (!body.name) return toast('Nama profile harus diisi','error');

  // Validasi harga (boleh kosong, tapi kalau diisi harus angka ≥ 0)
  const priceRaw = (document.getElementById('p-price').value || '').trim();
  let priceNum = 0;
  if (priceRaw !== '') {
    priceNum = Number(priceRaw);
    if (!Number.isFinite(priceNum) || priceNum < 0) return toast('Harga tidak valid','error');
  }
  // Limit waktu (string MikroTik time format) — boleh kosong = unlimited
  const limitUptime = (document.getElementById('p-limit-uptime').value || '').trim();

  const btn=document.getElementById('btn-save-profile'); btn.disabled=true; btn.textContent='Menyimpan...';
  try {
    // 1) Simpan profile ke MikroTik
    const r = id
      ? await api('PUT',  `/api/mikrotik/hotspot/user-profiles/${id}`, body)
      : await api('POST', '/api/mikrotik/hotspot/user-profiles',       body);

    if (!r.success) { toast(r.message || 'Gagal menyimpan profile','error'); return; }

    // 2) Sinkron harga + limit-uptime ke pricing config (best-effort)
    if (window.HotspotPricing) {
      try {
        const originalName = document.getElementById('p-price').getAttribute('data-original-name');
        if (originalName && originalName !== body.name) {
          await window.HotspotPricing.remove(originalName);
        }
        const ok = await window.HotspotPricing.set(body.name, { price: priceNum, limitUptime });
        if (!ok) toast('Profile tersimpan, tetapi gagal menyimpan harga / limit','warn');
      } catch(e) {
        console.warn('Pricing sync error:', e);
        toast('Profile tersimpan, tetapi gagal menyimpan harga / limit','warn');
      }
    }

    toast(r.message || 'Tersimpan','success');
    closeModal('m-add-profile');
    loadUserProfiles();
    // Refresh state IIFE Laporan (kalau user nanti pindah ke tab Laporan)
    if (window.HotspotPricing) window.HotspotPricing.notifyProfilesChanged();
  } catch(e) {
    toast('Error: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Simpan';
  }
}

async function delProfile(id,name){
  if (!confirm(`Hapus profile "${name}"?`)) return;
  const r=await api('DELETE',`/api/mikrotik/hotspot/user-profiles/${id}`);
  if (r.success){
    // Clean up entry harga (kalau ada) supaya tidak orphan di pricing config
    if (window.HotspotPricing && window.HotspotPricing.has(name)) {
      try { await window.HotspotPricing.remove(name); } catch(e){ /* silent */ }
    }
    toast(r.message,'success');
    loadUserProfiles();
    if (window.HotspotPricing) window.HotspotPricing.notifyProfilesChanged();
  } else toast(r.message,'error');
}

