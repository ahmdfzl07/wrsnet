function dlCSV() {
  if (!lastVouchers.length) return;
  const rows=[['Username','Password','Profile','Server'],...lastVouchers.map(v=>[v.username,v.password,v.profile,v.server])];
  const csv=rows.map(r=>r.map(c=>`"${c}"`).join(',')).join('\n');
  const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(new Blob([csv],{type:'text/csv'})),download:`voucher-${Date.now()}.csv`});
  a.click();
}

