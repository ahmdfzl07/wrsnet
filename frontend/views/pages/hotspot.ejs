async function loadUsers() {
  setEl('tbl-users', loaderHtml());
  // Pastikan pricing ter-load supaya fallback display "Limit" dari profile config bekerja
  const pricingPromise = window.HotspotPricing ? window.HotspotPricing.ensureLoaded() : Promise.resolve();
  const [r, _p] = await Promise.all([
    api('GET', '/api/mikrotik/hotspot/users').catch(()=>({})),
    pricingPromise,
  ]);
  allUsers = r.success ? r.data : [];
  filtUsers = [...allUsers];
  document.getElementById('tb-users').textContent = allUsers.length;
  syncProfileDropdowns();
  renderUsersTable();
}

function renderUsersTable() {
  const start = (pgNum-1)*pgSize;
  const slice = filtUsers.slice(start, start+pgSize);
  if (!slice.length) { setEl('tbl-users', emptyHtml('Tidak ada user')); setEl('pg-users', ''); document.getElementById('pg-users').style.display='none'; return; }

  let h = `<table>
    <thead><tr>
      <th><input type="checkbox" class="chk" id="chk-all" onchange="checkAll()"></th>
      <th>Username</th><th>Profile</th><th>Server</th>
      <th>Limit</th><th>Uptime</th><th>Status</th><th>Aksi</th>
    </tr></thead><tbody>`;
  slice.forEach(u => {
    const used = u.bytesIn + u.bytesOut;
    const limitInfo = u.limitBytesTotal > 0
      ? `<div style="font-size:10.5px;color:var(--text3);margin-top:2px;font-family:var(--fm)">${fmtB(used)} / ${fmtB(u.limitBytesTotal)}</div>`
      : '';
    // Limit cell: pakai field user; kalau kosong, fallback ke profile config (pricing)
    let limitCell;
    if (u.limitUptime) {
      limitCell = `<span style="font-size:12px;font-family:var(--fm)">${x(u.limitUptime)}</span>`;
    } else {
      const cfgLim = window.HotspotPricing ? window.HotspotPricing.limitUptime(u.profile) : '';
      limitCell = cfgLim
        ? `<span style="font-size:12px;color:var(--blue);font-family:var(--fm)" title="Dari profile config">${x(cfgLim)}</span>`
        : `<span style="color:var(--text3)">∞</span>`;
    }
    h += `<tr>
      <td><input type="checkbox" class="chk chk-u" value="${x(u.id)}" onchange="updSelBtn()"></td>
      <td>
        <div style="font-weight:600;font-size:13px">${x(u.name)}</div>
        ${u.comment ? `<div style="font-size:11px;color:var(--text2)">${x(u.comment)}</div>` : ''}
      </td>
      <td><span class="badge b-purple">${x(u.profile)}</span></td>
      <td><span style="font-size:12px;color:var(--text2)">${x(u.server)}</span></td>
      <td>
        ${limitCell}
        ${limitInfo}
      </td>
      <td><span class="td-mono">${u.uptime||'0s'}</span></td>
      <td>${u.disabled
        ? '<span class="badge b-red"><span class="bdot"></span>Off</span>'
        : '<span class="badge b-green"><span class="bdot"></span>On</span>'}</td>
      <td>
        <div style="display:flex;gap:5px">
          <button class="btn btn-ghost btn-xs" onclick='editUser(${JSON.stringify(u).replace(/'/g,"&#39;")})'>Edit</button>
          ${u.disabled
            ? `<button class="btn btn-success btn-xs" onclick="toggleUser('${u.id}',false)">Aktifkan</button>`
            : `<button class="btn btn-ghost btn-xs" onclick="toggleUser('${u.id}',true)" style="color:var(--amber)">Nonaktifkan</button>`}
          <button class="btn btn-danger btn-xs" onclick="delUser('${u.id}','${x(u.name)}')">Hapus</button>
        </div>
      </td>
    </tr>`;
  });
  h += '</tbody></table>';
  setEl('tbl-users', h);
  renderPg();
}

function renderPg() {
  const total = filtUsers.length;
  const pages = Math.ceil(total/pgSize);
  const pg = document.getElementById('pg-users');
  pg.style.display = total ? 'flex' : 'none';
  setText('pg-info', `${Math.min((pgNum-1)*pgSize+1,total)}–${Math.min(pgNum*pgSize,total)} dari ${total}`);
  const btns = document.getElementById('pg-btns');
  btns.innerHTML = '';
  const addBtn = (lbl, p, dis, act) => {
    btns.innerHTML += `<button class="page-btn${act?' active':''}" ${dis?'disabled':''} onclick="goPage(${p})">${lbl}</button>`;
  };
  addBtn('‹', pgNum-1, pgNum<=1, false);
  for (let p=Math.max(1,pgNum-2); p<=Math.min(pages,pgNum+2); p++) addBtn(p,p,false,p===pgNum);
  addBtn('›', pgNum+1, pgNum>=pages, false);
}
function goPage(p){ pgNum=p; renderUsersTable(); }

function syncProfileDropdowns() {
  const profiles = [...new Set(allUsers.map(u=>u.profile))].sort();
  const fp = document.getElementById('fp-users');
  const cur = fp.value;
  fp.innerHTML = '<option value="">Semua Profile</option>';
  profiles.forEach(p => fp.innerHTML += `<option value="${x(p)}">${x(p)}</option>`);
  fp.value = cur;
  ['g-profile','u-profile'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const cv = el.value;
    el.innerHTML = '<option value="default">default</option>';
    allProfiles.forEach(p => {
      if (p.name!=='default') el.innerHTML += `<option value="${x(p.name)}">${x(p.name)}</option>`;
    });
    profiles.forEach(p => {
      if (p!=='default' && !allProfiles.find(ap=>ap.name===p))
        el.innerHTML += `<option value="${x(p)}">${x(p)}</option>`;
    });
    if (cv) el.value = cv;
  });
  // Trigger auto-fill limit waktu untuk profile yang baru aktif di generator
  if (window.HotspotPricing) window.HotspotPricing.ensureLoaded().then(() => { onGenProfileChange(); updateGenSummary(); });
}

// Auto-fill field "Limit Waktu" dari pricing config saat profile dipilih.
// Menghormati input manual: kalau user sudah ketik sesuatu di g-uptime, jangan
// di-overwrite. State dilacak via attribute data-auto pada element.
function onGenProfileChange() {
  const sel = document.getElementById('g-profile');
  const upt = document.getElementById('g-uptime');
  const profInfo = document.getElementById('g-profile-info');
  const uptInfo  = document.getElementById('g-uptime-info');
  if (!sel || !upt) return;

  const profileName = sel.value || 'default';
  const entry = window.HotspotPricing ? window.HotspotPricing.entry(profileName) : { price: 0, limitUptime: '' };
  const lim   = entry.limitUptime || '';

  // Info bar profile (harga + limit ringkas)
  if (profInfo) {
    const bits = [];
    if (entry.price > 0) bits.push(`<span style="color:var(--green);font-weight:600">Rp ${entry.price.toLocaleString('id-ID')}</span>`);
    else                 bits.push('<span style="color:var(--amber)">Harga belum di-set</span>');
    if (lim) bits.push(`<span style="color:var(--blue)">⏱ ${x(lim)}</span>`);
    profInfo.innerHTML = bits.join(' · ');
  }

  // Auto-fill g-uptime kalau:
  //   - field masih kosong, ATAU
  //   - field di-isi sebelumnya oleh auto-fill (data-auto="1")
  const wasAutoFilled = upt.getAttribute('data-auto') === '1';
  const currentEmpty  = !upt.value.trim();
  if (lim && (currentEmpty || wasAutoFilled)) {
    upt.value = lim;
    upt.setAttribute('data-auto', '1');
    if (uptInfo) uptInfo.innerHTML = `Otomatis dari profile: <b>${x(lim)}</b> — edit untuk override`;
  } else if (!lim && wasAutoFilled) {
    // Profile baru tidak punya limit, kosongkan auto-fill sebelumnya
    upt.value = '';
    upt.removeAttribute('data-auto');
    if (uptInfo) uptInfo.innerHTML = 'Profile ini tidak punya limit waktu — kosong = unlimited';
  } else if (uptInfo) {
    uptInfo.innerHTML = lim
      ? `Profile default: ${x(lim)}`
      : 'Kosong = unlimited (tidak ada batas waktu)';
  }
}

// Live summary preview di bawah generate form — total voucher, harga/voucher,
// estimasi pendapatan. Dipanggil setiap kali jumlah atau profile berubah.
function updateGenSummary() {
  const countEl = document.getElementById('g-count');
  const profEl  = document.getElementById('g-profile');
  const totalEl   = document.getElementById('gs-total');
  const priceEl   = document.getElementById('gs-price');
  const revenueEl = document.getElementById('gs-revenue');
  if (!countEl || !totalEl) return;

  const count = parseInt(countEl.value) || 0;
  const profileName = profEl?.value || '';
  const price = (profileName && window.HotspotPricing) ? window.HotspotPricing.get(profileName) : 0;

  totalEl.textContent = count.toLocaleString('id-ID');

  if (price > 0) {
    priceEl.textContent = `Rp ${price.toLocaleString('id-ID')}`;
    priceEl.classList.remove('gs-empty');
    const revenue = price * count;
    revenueEl.textContent = `Rp ${revenue.toLocaleString('id-ID')}`;
    revenueEl.classList.remove('gs-empty');
  } else {
    priceEl.textContent = '—';
    priceEl.classList.add('gs-empty');
    revenueEl.textContent = '—';
    revenueEl.classList.add('gs-empty');
  }
}
window.updateGenSummary = updateGenSummary;

// Versi sama untuk modal Tambah/Edit User Hotspot (manual create).
// Auto-fill u-uptime kalau kosong atau hasil auto-fill sebelumnya.
function onUserProfileChange() {
  const sel = document.getElementById('u-profile');
  const upt = document.getElementById('u-uptime');
  const profInfo = document.getElementById('u-profile-info');
  const uptInfo  = document.getElementById('u-uptime-info');
  if (!sel || !upt) return;

  const profileName = sel.value || 'default';
  const entry = window.HotspotPricing ? window.HotspotPricing.entry(profileName) : { price: 0, limitUptime: '' };
  const lim   = entry.limitUptime || '';

  if (profInfo) {
    if (entry.price > 0 && lim) {
      profInfo.innerHTML = `<span style="color:var(--green);font-weight:600">Rp ${entry.price.toLocaleString('id-ID')}</span> &middot; <span style="color:var(--blue)">⏱ ${x(lim)}</span>`;
    } else if (entry.price > 0) {
      profInfo.innerHTML = `<span style="color:var(--green);font-weight:600">Rp ${entry.price.toLocaleString('id-ID')}</span>`;
    } else if (lim) {
      profInfo.innerHTML = `<span style="color:var(--blue)">⏱ ${x(lim)}</span>`;
    } else {
      profInfo.innerHTML = '<span style="color:var(--text3)">Tidak ada harga / limit di-set untuk profile ini</span>';
    }
  }

  const wasAutoFilled = upt.getAttribute('data-auto') === '1';
  const currentEmpty  = !upt.value.trim();
  if (lim && (currentEmpty || wasAutoFilled)) {
    upt.value = lim;
    upt.setAttribute('data-auto', '1');
    if (uptInfo) uptInfo.innerHTML = `Otomatis dari profile: <b>${x(lim)}</b> — edit untuk override`;
  } else if (!lim && wasAutoFilled) {
    upt.value = '';
    upt.removeAttribute('data-auto');
    if (uptInfo) uptInfo.innerHTML = 'Profile ini tidak punya limit waktu — kosong = unlimited';
  } else if (uptInfo) {
    uptInfo.innerHTML = lim
      ? `Profile default: ${x(lim)} — kosongkan untuk pakai nilai itu`
      : 'Kosong = unlimited';
  }
}

// Detect manual edit pada u-uptime — kalau user ketik, batalkan flag auto.
