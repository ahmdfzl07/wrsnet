function filterUsers() {
  const q = document.getElementById('q-users').value.toLowerCase();
  const fp = document.getElementById('fp-users').value;
  filtUsers = allUsers.filter(u =>
    (!q || u.name.toLowerCase().includes(q) || u.comment.toLowerCase().includes(q)) &&
    (!fp || u.profile===fp));
  pgNum=1; renderUsersTable();
}

function checkAll() {
  const m = document.getElementById('chk-all');
  document.querySelectorAll('.chk-u').forEach(c => c.checked=m.checked);
  updSelBtn();
}
function updSelBtn() {
  const n = [...document.querySelectorAll('.chk-u:checked')].length;
  document.getElementById('btn-del-sel').style.display = n>0?'inline-flex':'none';
}

function openAddUser() {
  // Reset semua field user
  document.getElementById('m-user-title').textContent = 'Tambah User Hotspot';
  document.getElementById('u-id').value     = '';
  document.getElementById('u-name').value   = '';
  document.getElementById('u-pass').value   = '';
  document.getElementById('u-uptime').value = '';
  document.getElementById('u-bytes').value  = '';
  document.getElementById('u-mac').value    = '';
  document.getElementById('u-comment').value= '';
  // Flag u-uptime as auto-fillable (kosong → akan diisi dari profile config)
  const upt = document.getElementById('u-uptime');
  if (upt) upt.setAttribute('data-auto', '1');
  openModal('m-add-user');
  // Trigger info bar + auto-fill berdasar profile pertama
  if (window.HotspotPricing) {
    window.HotspotPricing.ensureLoaded().then(onUserProfileChange);
  }
}

function editUser(u) {
  document.getElementById('m-user-title').textContent = 'Edit User: '+u.name;
  document.getElementById('u-id').value     = u.id;
  document.getElementById('u-name').value   = u.name;
  document.getElementById('u-pass').value   = u.password;
  document.getElementById('u-uptime').value = u.limitUptime||'';
  // Kalau user existing PUNYA limit-uptime, itu nilai eksplisit — tandai sebagai
  // bukan auto-fill supaya tidak ke-overwrite saat onUserProfileChange jalan.
  const upt = document.getElementById('u-uptime');
  if (upt) {
    if (u.limitUptime) upt.removeAttribute('data-auto');
    else upt.setAttribute('data-auto', '1');  // kosong → biarkan auto-fill nanti
  }
  document.getElementById('u-bytes').value  = u.limitBytesTotal||0;
  document.getElementById('u-mac').value    = u.macAddress||'';
  document.getElementById('u-comment').value= u.comment||'';
  setTimeout(()=>{
    const sp=document.getElementById('u-profile'); if(sp) sp.value=u.profile;
    const ss=document.getElementById('u-server');  if(ss) ss.value=u.server;
    // Trigger info bar update setelah profile ter-set
    if (window.HotspotPricing) {
      window.HotspotPricing.ensureLoaded().then(onUserProfileChange);
    }
  },60);
  openModal('m-add-user');
}

async function saveUser() {
  const id   = document.getElementById('u-id').value;
  const body = {
    name:document.getElementById('u-name').value.trim(),
    password:document.getElementById('u-pass').value,
    profile:document.getElementById('u-profile').value,
    server:document.getElementById('u-server').value,
    limitUptime:document.getElementById('u-uptime').value,
    limitBytesTotal:parseInt(document.getElementById('u-bytes').value)||0,
    macAddress:document.getElementById('u-mac').value,
    comment:document.getElementById('u-comment').value,
  };
  if (!body.name) return toast('Username harus diisi','error');
  const btn=document.getElementById('btn-save-user');
  btn.disabled=true; btn.textContent='Menyimpan...';
  const r = id ? await api('PUT',`/api/mikrotik/hotspot/users/${id}`,body)
               : await api('POST','/api/mikrotik/hotspot/users',body);
  if (r.success){ toast(r.message,'success'); closeModal('m-add-user'); loadUsers(); loadSummary(); }
  else toast(r.message,'error');
  btn.disabled=false; btn.textContent='Simpan';
}

async function toggleUser(id,dis) {
  const r = dis ? await api('POST',`/api/mikrotik/hotspot/users/${id}/disable`)
                : await api('POST',`/api/mikrotik/hotspot/users/${id}/enable`);
  if (r.success){ toast(r.message,'success'); loadUsers(); loadSummary(); }
  else toast(r.message,'error');
}

async function delUser(id,name) {
  if (!confirm(`Hapus user "${name}"?`)) return;
  const r = await api('DELETE',`/api/mikrotik/hotspot/users/${id}`);
  if (r.success){ toast(r.message,'success'); loadUsers(); loadSummary(); }
  else toast(r.message,'error');
}

async function deleteSelected() {
  const ids=[...document.querySelectorAll('.chk-u:checked')].map(c=>c.value);
  if (!ids.length) return;
  if (!confirm(`Hapus ${ids.length} user terpilih?`)) return;
  const r = await api('POST','/api/mikrotik/hotspot/users/delete-batch',{ids});
  if (r.success){ toast(r.message,'success'); loadUsers(); loadSummary(); }
  else toast(r.message,'error');
}

/* ═══════════════════════════════════════════════════════════════
   GENERATE VOUCHERS
═══════════════════════════════════════════════════════════════ */
async function generateVouchers() {
  const count=parseInt(document.getElementById('g-count').value);
  if (!count||count<1) return toast('Jumlah minimal 1','error');
  if (count > 5000) return toast('Jumlah maksimal 5000 per generate','error');

  const btn=document.getElementById('btn-gen');
  btn.disabled=true;

  // Loading state — kalau count besar, beri estimasi waktu agar user tidak
  // mengira hang. Estimasi: ~30ms per voucher dengan chunk paralel 8 di backend.
  const estSec = Math.max(2, Math.ceil(count * 0.03));
  const estText = count >= 100
    ? ` (est. ${estSec < 60 ? `${estSec}d` : `${Math.ceil(estSec/60)}m`})`
    : '';
  btn.innerHTML=`<svg class="spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> Generating ${count}${estText}...`;

  // Untuk batch besar, info toast supaya user yakin sedang berjalan
  if (count >= 50) {
    toast(`Membuat ${count} voucher di MikroTik, mohon tunggu${estText}...`, 'info');
  }

  const startTime = Date.now();
  const r = await api('POST','/api/mikrotik/hotspot/generate',{
    count,
    profile:document.getElementById('g-profile').value||'default',
    server:document.getElementById('g-server').value||'all',
    prefix:document.getElementById('g-prefix').value||'vc',
    limitUptime:document.getElementById('g-uptime').value,
    passwordLength:8,
  }).catch(e => ({ success: false, message: e?.message || 'Network error' }));

  const elapsed = Math.round((Date.now() - startTime) / 1000);

  btn.disabled=false;
  btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="13,2 3,14 12,14 11,22 21,10 12,10 13,2"/></svg> Generate';

  if (r && r.success) {
    lastVouchers = r.vouchers || [];
    const okCount   = lastVouchers.length;
    const errCount  = r.errors?.length || 0;
    const requested = r.total || count;
    // Feedback sukses dengan detail
    if (errCount === 0) {
      toast(`✓ ${okCount} voucher berhasil dibuat dalam ${elapsed} detik`, 'success');
    } else if (okCount > 0) {
      toast(`⚠ ${okCount}/${requested} voucher berhasil (${errCount} gagal). ${elapsed} detik`, 'info');
    } else {
      toast(`✗ Semua ${requested} voucher gagal dibuat`, 'error');
    }
    showVouchers(r);
    loadUsers();
    loadSummary();
  } else {
    toast(r?.message || 'Generate gagal — periksa koneksi & konfigurasi MikroTik', 'error');
  }
}

function openLastVouchers() {
  if (!lastVouchers.length) return toast('Generate voucher dulu','info');
  closePrintMenu();
  showVouchers({vouchers:lastVouchers,success:lastVouchers.length});
}

// ─── PRINT SELECTOR (manual selection) ──────────────────
// State internal — voucher yang sedang di-select. Set agar lookup O(1).
let _psAllVouchers = [];        // semua voucher dari allUsers
let _psFiltered    = [];        // hasil filter aktif
const _psSelected  = new Set(); // username yang ter-select

function openPrintSelector() {
  closePrintMenu();
  // Snapshot semua user (yang ada di tab Daftar User saat ini)
  _psAllVouchers = (allUsers || []).map(u => ({
    username: u.name,
    password: u.password,
    profile:  u.profile  || 'default',
    server:   u.server   || 'all',
    limitUptime: u['limit-uptime'] || '',
    disabled: u.disabled === 'true' || u.disabled === true,
    used: (u.uptime && u.uptime !== '0s' && u.uptime !== '0') || u.bytesIn > 0 || u.bytesOut > 0
  }));
  if (!_psAllVouchers.length) {
    return toast('Tidak ada voucher di daftar user', 'error');
  }
  _psSelected.clear();
  // Populate profile dropdown
  const profiles = [...new Set(_psAllVouchers.map(v => v.profile))];
  const psP = document.getElementById('ps-profile');
  psP.innerHTML = '<option value="">Semua profile</option>' +
    profiles.map(p => `<option value="${x(p)}">${x(p)}</option>`).join('');
  document.getElementById('ps-search').value = '';
  document.getElementById('ps-status').value = '';
  document.getElementById('ps-range-start').value = '';
  document.getElementById('ps-range-end').value = '';
  // Initial filter & render
  psApplyFilter();
  openModal('m-print-selector');
}

function psApplyFilter() {
  const q       = (document.getElementById('ps-search').value || '').toLowerCase().trim();
  const profile = document.getElementById('ps-profile').value;
  const status  = document.getElementById('ps-status').value;

  _psFiltered = _psAllVouchers.filter(v => {
    if (profile && v.profile !== profile) return false;
    if (status === 'active'   && v.disabled) return false;
    if (status === 'disabled' && !v.disabled) return false;
    if (status === 'unused'   && v.used) return false;
    if (q) {
      const hay = `${v.username} ${v.password} ${v.profile}`.toLowerCase();
      if (!hay.includes(q)) return false;
    }
    return true;
  });
  psRenderList();
}

function psRenderList() {
  const wrap = document.getElementById('ps-list');
  const total = _psFiltered.length;
  document.getElementById('ps-count-info').textContent =
    `Menampilkan ${total} voucher (dari ${_psAllVouchers.length} total)`;

  if (!total) {
    wrap.innerHTML = '<div style="padding:24px;text-align:center;color:var(--text3);font-size:13px">Tidak ada voucher yang cocok dengan filter</div>';
    psUpdateCount();
    return;
  }

  // Render virtualized-light: kalau lebih dari 500, batasi tampilan
  const display = _psFiltered.slice(0, 1000);
  const truncated = total > 1000;

  let html = `<div style="position:sticky;top:0;background:#f1f5f9;padding:8px 12px;font-size:11px;font-weight:600;color:var(--text2);border-bottom:1px solid var(--border2);display:flex;align-items:center;gap:8px">
    <input type="checkbox" id="ps-master-chk" onchange="psSelectAll(this.checked)" style="cursor:pointer">
    <span>#</span>
    <span style="flex:1">Username · Password</span>
    <span style="width:80px">Profile</span>
    <span style="width:60px;text-align:center">Status</span>
  </div>`;

  html += display.map((v, idx) => {
    const checked = _psSelected.has(v.username) ? 'checked' : '';
    const statusBadge = v.disabled
      ? '<span style="background:#fee2e2;color:#b91c1c;padding:1px 7px;border-radius:4px;font-size:10px;font-weight:600">Nonaktif</span>'
      : v.used
        ? '<span style="background:#fef3c7;color:#a16207;padding:1px 7px;border-radius:4px;font-size:10px;font-weight:600">Terpakai</span>'
        : '<span style="background:#dcfce7;color:#15803d;padding:1px 7px;border-radius:4px;font-size:10px;font-weight:600">Aktif</span>';
    return `<label style="display:flex;align-items:center;gap:10px;padding:6px 12px;border-bottom:1px solid #f1f5f9;cursor:pointer;font-size:12px" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
      <input type="checkbox" class="ps-row-chk" data-user="${x(v.username)}" ${checked} onchange="psToggleOne('${x(v.username)}', this.checked)" style="cursor:pointer">
      <span style="width:32px;color:var(--text3);font-size:11px">${idx+1}</span>
      <span style="flex:1">
        <strong style="color:var(--text)">${x(v.username)}</strong>
        <span style="color:var(--text3);font-family:monospace;margin-left:6px">${x(v.password)}</span>
      </span>
      <span style="width:80px;color:var(--text2);font-size:11px">${x(v.profile)}</span>
      <span style="width:60px;text-align:center">${statusBadge}</span>
    </label>`;
  }).join('');

  if (truncated) {
    html += `<div style="padding:12px;text-align:center;color:var(--text3);font-size:12px;font-style:italic">Hanya menampilkan 1000 baris pertama. Gunakan filter untuk mempersempit.</div>`;
  }
  wrap.innerHTML = html;
  psUpdateCount();
}

function psToggleOne(username, checked) {
  if (checked) _psSelected.add(username);
  else _psSelected.delete(username);
  psUpdateCount();
}

function psSelectAll(checked) {
  if (checked) {
    _psFiltered.forEach(v => _psSelected.add(v.username));
  } else {
    _psFiltered.forEach(v => _psSelected.delete(v.username));
  }
  // Re-render checkbox state (without re-rendering whole list for perf)
  document.querySelectorAll('.ps-row-chk').forEach(chk => {
    chk.checked = _psSelected.has(chk.dataset.user);
  });
  const mc = document.getElementById('ps-master-chk');
  if (mc) mc.checked = checked;
  psUpdateCount();
}

function psSelectRange() {
  const start = parseInt(document.getElementById('ps-range-start').value);
  const end   = parseInt(document.getElementById('ps-range-end').value);
  if (!start || !end || start < 1 || end < start) {
    return toast('Range tidak valid (dari ≥ 1, sampai ≥ dari)', 'error');
  }
  // Apply ke filtered list (1-indexed)
  for (let i = start - 1; i < Math.min(end, _psFiltered.length); i++) {
    _psSelected.add(_psFiltered[i].username);
  }
  psRenderList();
  toast(`${Math.min(end, _psFiltered.length) - start + 1} voucher ditambahkan ke seleksi`, 'success');
}

function psUpdateCount() {
  const n = _psSelected.size;
  document.getElementById('ps-selected-count').textContent = n;
  document.getElementById('ps-btn-print').disabled = n === 0;
}

function psPrintSelected() {
  const selected = _psAllVouchers.filter(v => _psSelected.has(v.username));
  if (!selected.length) return toast('Pilih minimal 1 voucher dulu', 'error');
  closeModal('m-print-selector');
  // Map ke shape yang printVoucherCards expect
  const vouchers = selected.map(v => ({
    username: v.username, password: v.password,
    profile: v.profile, server: v.server,
    limitUptime: v.limitUptime,
    disabled: v.disabled
  }));
  printVoucherCards(vouchers, `Pilihan Manual (${vouchers.length})`, '', '');
}

/* ── Print Dropdown ── */
function togglePrintMenu(e) {
  e.stopPropagation();
  const menu = document.getElementById('print-menu');
  const chevron = document.querySelector('.print-chevron');
  const isOpen = menu.style.display !== 'none';
  if (isOpen) {
    menu.style.display = 'none';
    if (chevron) chevron.style.transform = '';
  } else {
    // Position relative to button using fixed coords
    const btn = e.currentTarget;
    const rect = btn.getBoundingClientRect();
    menu.style.display = 'block';
    menu.style.top  = (rect.bottom + 6) + 'px';
    menu.style.left = rect.left + 'px';
    // Prevent going off right edge
    const menuW = 260;
    if (rect.left + menuW > window.innerWidth - 12) {
      menu.style.left = (rect.right - menuW) + 'px';
    }
    if (chevron) chevron.style.transform = 'rotate(180deg)';
    updatePrintMenuBadges();
  }
}

function closePrintMenu() {
  const menu = document.getElementById('print-menu');
  const chevron = document.querySelector('.print-chevron');
  if (menu) menu.style.display = 'none';
  if (chevron) chevron.style.transform = '';
}

document.addEventListener('click', function(e) {
  const dd = document.getElementById('print-dropdown');
  if (dd && !dd.contains(e.target)) closePrintMenu();
});

function updatePrintMenuBadges() {
  const unused = allUsers.filter(u => (!u.uptime || u.uptime==='0s' || u.uptime==='0') && !u.bytesIn && !u.bytesOut);
  const active = allUsers.filter(u => !u.disabled);
  const setB = (id, val, cls) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = val;
    if (cls) el.className = 'pm-badge ' + cls;
  };
  setB('pm-badge-all',    allUsers.length,       '');
  setB('pm-badge-active', active.length,         'pm-badge-green');
  setB('pm-badge-unused', unused.length,         'pm-badge-amber');
  setB('pm-badge-last',   lastVouchers.length || '—', '');

  // Build profile list
  const profiles = [...new Map(allUsers.map(u => [u.profile, {
    name: u.profile,
    count: allUsers.filter(x => x.profile === u.profile).length
  }])).values()].sort((a,b) => a.name.localeCompare(b.name));

  const container = document.getElementById('pm-profile-list');
  if (!container) return;
  if (!profiles.length) {
    container.innerHTML = '<div style="font-size:11px;color:var(--text3);padding:6px 12px">Tidak ada profile</div>';
    return;
  }
  container.innerHTML = profiles.map(p => `
    <button class="print-menu-item" onclick="printVoucherFilter('profile','${x(p.name)}')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      ${x(p.name)}
      <span class="pm-badge pm-badge-blue">${p.count}</span>
    </button>`).join('');
}

function printVoucherFilter(type, profileName) {
  closePrintMenu();
  let users = [];
  let title = '';

  if (type === 'all') {
    users = [...allUsers];
    title = 'Semua User Hotspot';
  } else if (type === 'active') {
    users = allUsers.filter(u => !u.disabled);
    title = 'User Aktif (On)';
  } else if (type === 'unused') {
    users = allUsers.filter(u =>
      (!u.uptime || u.uptime === '0s' || u.uptime === '0') && !u.bytesIn && !u.bytesOut
    );
    title = 'User Belum Pernah Dipakai';
  } else if (type === 'profile') {
    users = allUsers.filter(u => u.profile === profileName);
    title = `Profile: ${profileName}`;
  }

  if (!users.length) return toast('Tidak ada user untuk filter ini', 'info');

  // Ambil harga dari pricing config — lookup berdasar profile user pertama,
  // atau profile yang dipilih di g-profile (kalau filter "all" tapi user
  // beragam, prefer yang dipilih untuk konsistensi label di print).
  const refProfile = users[0]?.profile || document.getElementById('g-profile')?.value || '';
  const priceNum = (refProfile && window.HotspotPricing) ? window.HotspotPricing.get(refProfile) : 0;
  const price = priceNum > 0 ? `Rp ${priceNum.toLocaleString('id-ID')}` : '';
  const duration = document.getElementById('g-uptime')?.value || '';

  // Konversi format user -> voucher untuk dicetak
  const vouchers = users.map(u => ({
    username: u.name,
    password: u.password,
    profile:  u.profile,
    server:   u.server,
    limitUptime: u.limitUptime || duration,
    disabled: u.disabled,
    uptime:   u.uptime,
    bytesIn:  u.bytesIn,
    bytesOut: u.bytesOut,
  }));

  printVoucherCards(vouchers, title, price, duration);
}

function printVoucherCards(vouchers, title, price, duration) {
  const pa = document.getElementById('print-area');
  pa.style.display = 'block';
  const today = new Date().toLocaleString('id-ID',{dateStyle:'long',timeStyle:'short'});

  // Load template settings dari AppSetting (vtpl_*) — kalau ada, override default
  // Cache di window agar tidak fetch ulang setiap print
  const T = window._voucherTpl || {
    primary_color:'#1565C0', primary_dark:'#0D47A1', accent_color:'#2E7D32',
    company_name:'FLAYNET', tagline:'Voucher Hotspot', logo_url:'',
    label_username:'USERNAME', label_password:'PASSWORD', label_profile:'PAKET',
    label_duration:'DURASI', label_price:'HARGA',
    show_wifi:'1', show_price:'1', show_duration:'1', show_profile:'1', show_footer:'1',
    columns:'5', footer_text:''
  };
  const BLUE = T.primary_color || '#1565C0';
  const BLUE_D = T.primary_dark || '#0D47A1';
  const GREEN = T.accent_color || '#2E7D32';
  const cols = Math.max(2, Math.min(8, parseInt(T.columns) || 5));

  pa.innerHTML = `<style>
    @page { size: A4; margin: 8mm 10mm; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { font-family: Arial, Helvetica, sans-serif; background: #fff; -webkit-print-color-adjust: exact; print-color-adjust: exact; font-size: 10px; }

    /* ── Page header ── */
    .ph { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; padding-bottom:7px; border-bottom:2px solid ${BLUE}; }
    .ph-brand { display:flex; align-items:center; gap:7px; }
    .ph-ico { width:28px; height:28px; border-radius:7px; background:${BLUE}; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .ph-ico svg { width:14px; height:14px; stroke:#fff; fill:none; stroke-width:2; }
    .ph-name { font-size:15px; font-weight:900; color:${BLUE_D}; letter-spacing:-.5px; }
    .ph-sub  { font-size:7px; color:#888; text-transform:uppercase; letter-spacing:.7px; margin-top:1px; }
    .ph-meta { text-align:right; font-size:7.5px; color:#666; line-height:1.7; }
    .ph-meta strong { color:#222; }

    /* ── Summary bar ── */
    .sum-bar { display:flex; gap:6px; margin-bottom:8px; }
    .sum-box { flex:1; background:#f8faff; border-radius:5px; padding:5px 8px; }
    .sum-box.g .sum-val { color:${GREEN}; }
    .sum-box.r .sum-val { color:#C62828; }
    .sum-lbl { font-size:6.5px; font-weight:700; text-transform:uppercase; letter-spacing:.4px; color:#999; margin-bottom:2px; }
    .sum-val { font-size:16px; font-weight:900; color:#111; line-height:1; }

    /* ── Page Sections ──
       Setiap section adalah exactly 1 halaman cetak. Tinggi fixed agar
       browser break tepat di batasnya — page-break-after sendiri tidak
       cukup di Chrome preview. */
    .page {
      page-break-after: always;
      break-after: page;
      /* A4 portrait usable height = 297mm - margins(8+8) = 281mm */
      min-height: 277mm;
      max-height: 277mm;
      overflow: hidden;
      box-sizing: border-box;
    }
    .page:last-child {
      page-break-after: auto;
      break-after: auto;
      min-height: 0;
      max-height: none;
      overflow: visible;
    }
    /* Grid voucher — kolom dari template, row height tetap agar tidak overlap */
    .grid {
      display:grid;
      grid-template-columns:repeat(${cols},1fr);
      grid-auto-rows: 44mm;  /* tinggi tetap per kartu — pakai mm agar print-safe */
      gap:4mm 4px;
      align-content: start;
    }
    /* Kontinyu header di page 2+ (lebih kecil & informatif) */
    .page-hdr-mini { display:flex; align-items:center; justify-content:space-between;
      margin-bottom:6px; padding-bottom:5px; border-bottom:1.5px solid ${BLUE};
      font-size:7px; color:#888; }
    .page-hdr-mini strong { color:#222; }

    /* ── Kartu voucher — tinggi fixed agar grid tidak overflow ── */
    .vc {
      border-radius:7px; overflow:hidden;
      border:1px solid #dde3ef;
      background:#fff;
      break-inside:avoid;
      page-break-inside:avoid;
      display:flex; flex-direction:column;
      height: 44mm;     /* match grid-auto-rows */
      box-sizing: border-box;
    }

    /* Header biru */
    .vh {
      background:${BLUE};
      padding:6px 7px 5px;
      position:relative; overflow:hidden; flex-shrink:0;
    }
    .vh::after { content:''; position:absolute; bottom:-10px; right:-10px; width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,.08); }
    .vh-row { display:flex; align-items:center; gap:5px; position:relative; z-index:1; }
    .vh-av {
      width:22px; height:22px; border-radius:50%;
      background:rgba(255,255,255,.25); border:1px solid rgba(255,255,255,.5);
      display:flex; align-items:center; justify-content:center;
      flex-shrink:0; font-size:8px; font-weight:800; color:#fff;
      font-family:'Courier New',monospace; letter-spacing:-.5px;
    }
    .vh-info { flex:1; min-width:0; }
    .vh-brand { font-size:5.5px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:rgba(255,255,255,.65); margin-bottom:1px; }
    .vh-user  { font-size:8px; font-weight:800; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; letter-spacing:-.2px; }
    .vh-prof  { font-size:6px; color:rgba(255,255,255,.7); margin-top:1px; }
    /* wifi icon */
    .vh-wifi { position:absolute; top:5px; right:6px; opacity:.25; }
    .vh-wifi svg { width:11px; height:11px; stroke:#fff; fill:none; stroke-width:2; }

    /* Body rows */
    .vb { flex:1; }
    .vr { display:flex; align-items:center; justify-content:space-between; padding:3.5px 7px; border-bottom:1px solid #f0f2f8; }
    .vr:last-child { border-bottom:none; }
    .vl { font-size:6px; font-weight:700; text-transform:uppercase; letter-spacing:.3px; color:#b0bac9; }
    .vv { font-weight:700; color:#111; font-size:8px; text-align:right; max-width:65%; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .vv.pw { font-family:'Courier New',monospace; color:${BLUE_D}; font-size:10px; font-weight:900; letter-spacing:1px; max-width:70%; }
    .vv.gn { color:${GREEN}; }
    .s-on  { background:#e8f5e9; color:${GREEN};  padding:1px 4px; border-radius:2px; font-size:6px; font-weight:700; white-space:nowrap; }
    .s-off { background:#ffebee; color:#C62828; padding:1px 4px; border-radius:2px; font-size:6px; font-weight:700; white-space:nowrap; }
  </style>`;

  // Hitung kapasitas per halaman berdasarkan jumlah kolom.
  // Kartu sekarang tinggi tetap 44mm + 4mm gap = 48mm/row.
  // A4 portrait usable ≈ 281mm:
  //   - Page 1: minus header (~25mm) + summary (~15mm) = 241mm → 5 baris (240mm)
  //   - Page 2+: minus mini-header (~10mm) = 271mm → 5 baris (240mm) — pakai 5 untuk safety
  // Pakai 4 untuk page 1 agar pasti tidak overflow.
  const PAGE1_CAP = 4 * cols;
  const PAGEN_CAP = 5 * cols;

  // Bagi vouchers ke pages
  const pages = [];
  let i = 0;
  if (vouchers.length > 0) {
    pages.push(vouchers.slice(i, i + PAGE1_CAP));
    i += PAGE1_CAP;
    while (i < vouchers.length) {
      pages.push(vouchers.slice(i, i + PAGEN_CAP));
      i += PAGEN_CAP;
    }
  }

  // Render voucher card helper
  const renderVoucher = (v) => {
    const av  = (v.password || v.username || '??').substring(0,2).toUpperCase();
    const dur = v.limitUptime || duration || '∞';
    return `<div class="vc">
      <div class="vh">
        <div class="vh-wifi"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="#fff" stroke="none"/></svg></div>
        <div class="vh-row">
          <div class="vh-av">${av}</div>
          <div class="vh-info">
            <div class="vh-brand">${x(T.company_name)}</div>
            <div class="vh-user">${x(v.username)}</div>
            <div class="vh-prof">${x(v.profile)}</div>
          </div>
        </div>
      </div>
      <div class="vb">
        <div class="vr"><span class="vl">Password</span><span class="vv pw">${x(v.password)||'—'}</span></div>
        <div class="vr"><span class="vl">Durasi</span><span class="vv">${x(dur)}</span></div>
        <div class="vr"><span class="vl">Server</span><span class="vv">${x(v.server||'all')}</span></div>
        ${price ? `<div class="vr"><span class="vl">Harga</span><span class="vv gn">${x(price)}</span></div>` : ''}
        <div class="vr"><span class="vl">Status</span><span class="vv"><span class="${v.disabled?'s-off':'s-on'}">${v.disabled?'Nonaktif':'Aktif'}</span></span></div>
      </div>
    </div>`;
  };

  // Build header (page 1 full)
  const fullHeader = `
    <div class="ph">
      <div class="ph-brand">
        ${T.logo_url
          ? `<img src="${x(T.logo_url)}" alt="Logo" class="ph-logo" style="width:32px;height:32px;border-radius:7px;object-fit:contain;background:#fff;border:1px solid #e0e7f3;">`
          : `<div class="ph-ico"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="#fff" stroke="none"/></svg></div>`
        }
        <div><div class="ph-name">${x(T.company_name)}</div><div class="ph-sub">${x(T.tagline)}</div></div>
      </div>
      <div class="ph-meta">
        Filter: <strong>${x(title)}</strong>${price ? ` &nbsp;·&nbsp; Harga: <strong>${x(price)}</strong>` : ''}<br>
        Dicetak: <strong>${today}</strong> &nbsp;·&nbsp; Jumlah: <strong>${vouchers.length} user</strong>
      </div>
    </div>
    <div class="sum-bar">
      <div class="sum-box"><div class="sum-lbl">Total Dicetak</div><div class="sum-val">${vouchers.length}</div></div>
      <div class="sum-box g"><div class="sum-lbl">Aktif</div><div class="sum-val">${vouchers.filter(v=>!v.disabled).length}</div></div>
      <div class="sum-box r"><div class="sum-lbl">Nonaktif</div><div class="sum-val">${vouchers.filter(v=>v.disabled).length}</div></div>
      ${price ? `<div class="sum-box g"><div class="sum-lbl">Nilai per voucher</div><div class="sum-val" style="font-size:11px">${x(price)}</div></div>` : ''}
    </div>`;

  // Mini header untuk halaman 2+ (continuation)
  const miniHeader = (pageNum, total) => `
    <div class="page-hdr-mini">
      <span><strong>${x(T.company_name)}</strong> &nbsp;·&nbsp; ${x(title)}</span>
      <span>Hal. <strong>${pageNum}/${total}</strong> &nbsp;·&nbsp; ${today}</span>
    </div>`;

  // Compose pages
  pa.innerHTML += pages.map((pageVouchers, idx) => {
    const isFirst = idx === 0;
    const hdr = isFirst ? fullHeader : miniHeader(idx + 1, pages.length);
    return `<section class="page">
      ${hdr}
      <div class="grid">${pageVouchers.map(renderVoucher).join('')}</div>
    </section>`;
  }).join('');

  window.print();
  setTimeout(() => pa.style.display = 'none', 800);
}

function showVouchers(r) {
  const vcs = r.vouchers || [];
  const errCount = r.errors?.length || 0;
  const profile = vcs[0]?.profile || '—';
  const duration = document.getElementById('g-uptime')?.value || vcs[0]?.limitUptime || '';
  const durationLabel = duration || 'Unlimited';
  // Harga dari pricing config profile (bukan dari field manual yang sudah dihapus)
  const priceNum = (profile && window.HotspotPricing) ? window.HotspotPricing.get(profile) : 0;
  const price = priceNum > 0 ? `Rp ${priceNum.toLocaleString('id-ID')}` : '';

  // Summary text
  const sub = document.getElementById('vc-summary');
  if (sub) sub.innerHTML =
    `<strong style="color:var(--green)">${vcs.length}</strong> voucher · Profile: <strong>${x(profile)}</strong> · ${new Date().toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'})}` +
    (errCount ? ` · <strong style="color:var(--red)">${errCount} gagal</strong>` : '');

  // Render cards
  document.getElementById('vc-grid').innerHTML = vcs.map(v => {
    const initials = (v.password || '??').substring(0,2).toUpperCase();
    return `<div class="voucher-card">
      <div class="vc-hdr">
        <div class="vc-wifi-ico"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="#fff" stroke="none"/></svg></div>
        <div class="vc-hdr-top">
          <div class="vc-avatar">${initials}</div>
          <div class="vc-hdr-info">
            <div class="vc-isp">${x(T.company_name)} ${x(T.tagline)}</div>
            <div class="vc-user">${x(v.username)}</div>
          </div>
        </div>
      </div>
      <div class="vc-body">
        <div class="vc-row">
