  <div class="modal-sheet wide">
    <div class="modal-handle"></div>
    <div class="modal-hdr" style="border-bottom:1px solid var(--border2);padding-bottom:16px;">
      <div>
        <h3 style="font-size:15px;font-weight:700;color:var(--text);letter-spacing:-.2px;margin:0;">Pilih Voucher untuk Print</h3>
        <p style="font-size:12px;color:var(--text2);margin:3px 0 0;">
          <span id="ps-count-info">Pilih voucher yang ingin di-print</span>
        </p>
      </div>
      <button class="modal-close" onclick="closeModal('m-print-selector')"><svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div class="modal-body" style="padding-top:16px;">
      <!-- Quick filters & search -->
      <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:12px">
        <input type="text" id="ps-search" placeholder="Cari username / password / profile..." oninput="psApplyFilter()"
          style="flex:1;min-width:200px;padding:8px 12px;border:1px solid var(--border2);border-radius:8px;font-size:13px">
        <select id="ps-profile" onchange="psApplyFilter()" style="padding:8px 12px;border:1px solid var(--border2);border-radius:8px;font-size:13px">
          <option value="">Semua profile</option>
        </select>
        <select id="ps-status" onchange="psApplyFilter()" style="padding:8px 12px;border:1px solid var(--border2);border-radius:8px;font-size:13px">
          <option value="">Semua status</option>
          <option value="active">Aktif</option>
          <option value="disabled">Nonaktif</option>
          <option value="unused">Belum dipakai</option>
        </select>
      </div>

      <!-- Range selector (start–end) -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;padding:10px 12px;background:var(--bg-secondary,#f8faff);border-radius:8px;flex-wrap:wrap">
        <span style="font-size:12px;font-weight:600;color:var(--text2)">Range:</span>
        <input type="number" id="ps-range-start" placeholder="Dari" min="1" style="width:80px;padding:6px 10px;border:1px solid var(--border2);border-radius:6px;font-size:12px">
        <span style="font-size:12px;color:var(--text3)">s/d</span>
        <input type="number" id="ps-range-end" placeholder="Sampai" min="1" style="width:80px;padding:6px 10px;border:1px solid var(--border2);border-radius:6px;font-size:12px">
        <button class="btn btn-ghost" style="padding:6px 12px;font-size:12px" onclick="psSelectRange()">Pilih Range</button>
        <span style="flex:1"></span>
        <button class="btn btn-ghost" style="padding:6px 12px;font-size:12px" onclick="psSelectAll(true)">✓ Semua di view</button>
        <button class="btn btn-ghost" style="padding:6px 12px;font-size:12px" onclick="psSelectAll(false)">✗ Reset</button>
      </div>

      <!-- Voucher list -->
      <div id="ps-list" style="max-height:50vh;overflow-y:auto;border:1px solid var(--border2);border-radius:8px;background:#fff"></div>
    </div>
    <div class="modal-foot">
      <div style="flex:1;font-size:12px;color:var(--text2)">
        Terpilih: <strong id="ps-selected-count" style="color:var(--text)">0</strong> voucher
      </div>
      <button class="btn btn-ghost" onclick="closeModal('m-print-selector')">Batal</button>
      <button class="btn btn-primary" onclick="psPrintSelected()" id="ps-btn-print" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="6,9 6,2 18,2 18,9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Print Voucher Terpilih
      </button>
    </div>
  </div>
</div>

<!-- TOASTS & PRINT AREA -->
<div id="toasts"></div>
<div id="print-area" style="display:none"></div>

<script>
/* ═══════════════════════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════════════════════ */
let allUsers=[], filtUsers=[], pgNum=1, pgSize=25;
let allActive=[], filtActive=[];
let allHosts=[],  filtHosts=[];
let allProfiles=[], allServers=[];
let lastVouchers=[];
let activeTab='users';

/* ═══════════════════════════════════════════════════════════════
   BOOT
═══════════════════════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  // Init MikroTik selector — TUNGGU selesai sebelum load data agar
  // pertama kali fetch sudah pakai device_id yang benar.
  // onReady dipanggil setelah list device ter-fetch & activeId di localStorage di-set.
  if (window.MikrotikSelector) {
    window.MikrotikSelector.init({
      selectId: 'mikrotikSelector',
      onChange: () => refreshAll(),
      onReady:  () => {
        // Initial load — sekarang withDevice() akan inject device_id benar
        loadSummary();
        loadUsers();
        loadUserProfiles();
        loadServers();
      }
    });
  } else {
    // Fallback kalau modul selector tidak ter-load
    loadSummary();
    loadUsers();
    loadUserProfiles();
    loadServers();
  }
  // Preload voucher template settings agar print pakai customization user
  loadVoucherTemplate();
});

// Load template voucher dari AppSetting (vtpl_*) — cache di window._voucherTpl
// agar printVoucherCards() bisa baca tanpa fetch ulang setiap print.
async function loadVoucherTemplate() {
  try {
    const r = await api('GET', '/api/app-settings');
    if (!r?.success || !r.data) return;
    const s = r.data;
    window._voucherTpl = {
      primary_color:  s.vtpl_primary_color  || '#1565C0',
      primary_dark:   s.vtpl_primary_dark   || '#0D47A1',
      accent_color:   s.vtpl_accent_color   || '#2E7D32',
      company_name:   s.vtpl_company_name   || 'FLAYNET',
      tagline:        s.vtpl_tagline        || 'Voucher Hotspot',
      logo_url:       s.vtpl_logo_url       || '',
      label_username: s.vtpl_label_username || 'USERNAME',
      label_password: s.vtpl_label_password || 'PASSWORD',
      label_profile:  s.vtpl_label_profile  || 'PAKET',
      label_duration: s.vtpl_label_duration || 'DURASI',
      label_price:    s.vtpl_label_price    || 'HARGA',
      show_wifi:      s.vtpl_show_wifi      ?? '1',
      show_price:     s.vtpl_show_price     ?? '1',
      show_duration:  s.vtpl_show_duration  ?? '1',
      show_profile:   s.vtpl_show_profile   ?? '1',
      show_footer:    s.vtpl_show_footer    ?? '1',
      columns:        s.vtpl_columns        || '5',
      footer_text:    s.vtpl_footer_text    || ''
    };
  } catch(e) { /* default fallback dipakai */ }
}

function refreshAll() {
  // Reload semua data state — penting saat ganti MikroTik supaya semua
  // dropdown (server, profile) dan list ter-update ke device yang baru dipilih.
  loadSummary();
  loadServers();       // populate dropdown #g-server, #u-server, #b-server
  loadUserProfiles();  // populate dropdown profile di modal add user
  loadTabData(activeTab);
}

/* ═══════════════════════════════════════════════════════════════
   TABS
═══════════════════════════════════════════════════════════════ */
// ── Stat card helpers (DealDeck style) ─────────────────────────
let _prevSummary = null;
const SC_CARDS = ['sc-users','sc-active-card','sc-disabled-card','sc-hosts-card','sc-servers-card'];
const SC_MAP   = {
  users:    'sc-users',
  active:   'sc-active-card',
  disabled: 'sc-disabled-card',
  servers:  'sc-servers-card',
  hosts:    'sc-hosts-card',
  profiles: 'sc-users',
  cookies:  'sc-users',
  binding:  'sc-users',
};


function switchTab(name) {
  // ── 1. Update tab buttons ──────────────────────────────────
  // Cari tab button yang punya onclick matching name
  document.querySelectorAll('.tab-item').forEach(b => {
    b.classList.remove('active');
    const fn = b.getAttribute('onclick') || '';
    if (fn.includes("'" + name + "'") || fn.includes('"' + name + '"')) {
      b.classList.add('active');
    }
  });

  // ── 2. Show matching panel ─────────────────────────────────
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  const panel = document.getElementById('tp-' + name);
  if (panel) panel.classList.add('active');

  // ── 3. Sync active stat card ───────────────────────────────
  SC_CARDS.forEach(id => {
    const c = document.getElementById(id);
    if (c) c.classList.remove('sc-active');
  });
  const targetCard = SC_MAP[name];
  if (targetCard) {
    const c = document.getElementById(targetCard);
    if (c) c.classList.add('sc-active');
  }

  activeTab = name;
  loadTabData(name);
}

function loadTabData(n) {
  if (n==='users')    loadUsers();
  if (n==='active')   loadActive();
  if (n==='profiles') loadUserProfiles();
  if (n==='hosts')    loadHosts();
  if (n==='cookies')  loadCookies();
  if (n==='binding')  loadBindings();
  if (n==='disabled') loadDisabledUsers();
  if (n==='servers')  loadServersTab();
  if (n==='reports')  loadReportsTab();
  if (n==='history')  loadHistoryTab();
}

/* ═══════════════════════════════════════════════════════════════
   API
═══════════════════════════════════════════════════════════════ */
async function api(method, url, body) {
  // Auto-append ?device_id=N untuk endpoint /api/mikrotik/... agar selector
  // di topbar berfungsi (multi-MikroTik support).
  if (url.startsWith('/api/mikrotik/') && window.MikrotikSelector && window.MikrotikSelector.withDevice) {
    url = window.MikrotikSelector.withDevice(url);
  }
  const opts = { method, headers:{'Content-Type':'application/json'}, credentials:'include' };
  // Sertakan JWT token kalau ada (konsisten dengan helper App.api di app.js)
  const tok = localStorage.getItem('token');
  if (tok && tok !== 'null') opts.headers['Authorization'] = 'Bearer ' + tok;
  if (body) opts.body = JSON.stringify(body);
  try {
    const r = await fetch(url, opts);
    return await r.json();
  } catch (e) {
    // Browser-specific abort messages — page mungkin navigate/reload saat fetch jalan.
    // Tidak fatal, kita return shape consistent supaya caller bisa handle.
    const msg = (e && e.message) || String(e);
    if (/abort|aborted|cancel/i.test(msg)) {
      console.warn('[api] request aborted:', url, msg);
      return { success: false, aborted: true, message: 'Request dibatalkan' };
    }
    return { success: false, message: msg };
  }
}

/* ═══════════════════════════════════════════════════════════════
   SPARKLINES
═══════════════════════════════════════════════════════════════ */
function scClick(tabName) {
  // switchTab sudah handle sync card dan tab button sekaligus
  switchTab(tabName);
}

/* Render pill badge — DealDeck: +2.08% green / -2.08% red */
function renderPill(elId, curr, prev) {
  const el = document.getElementById(elId);
  if (!el) return;
  if (curr == null || curr === '—') { el.className='sc-pill sc-pill-neu'; el.textContent='—'; return; }
  if (prev == null) {
    el.className = 'sc-pill sc-pill-neu';
    el.textContent = curr + ' total';
    return;
  }
  const diff = curr - prev;
  const base = prev || 1;
  const pct  = ((Math.abs(diff) / base) * 100).toFixed(1);
  if (diff > 0) {
    el.className = 'sc-pill sc-pill-up';
    el.innerHTML = `<svg viewBox="0 0 10 10" fill="currentColor"><path d="M5 1l4 8H1z"/></svg>+${pct}%`;
  } else if (diff < 0) {
    el.className = 'sc-pill sc-pill-down';
    el.innerHTML = `<svg viewBox="0 0 10 10" fill="currentColor"><path d="M5 9L1 1h8z"/></svg>-${pct}%`;
  } else {
    el.className = 'sc-pill sc-pill-neu';
    el.textContent = '0%';
  }
}

/* Render Createvis-style SVG sparkline line chart */
function renderSparkLine(baseId, vals) {
  if (!vals || vals.length < 2) return;
  const W = 72, H = 36;
  const max = Math.max(...vals, 1);
  const min = Math.min(...vals, 0);
  const range = max - min || 1;

  const pts = vals.map((v, i) => {
    const x = (i / (vals.length - 1)) * W;
    const y = H - ((v - min) / range) * (H - 6) - 3;
    return [x, y];
  });

  // Smooth path using cardinal spline
  const pathD = pts.reduce((acc, [x, y], i) => {
    if (i === 0) return `M${x.toFixed(1)},${y.toFixed(1)}`;
    const [px, py] = pts[i - 1];
    const cpx = (px + x) / 2;
    return acc + ` C${cpx.toFixed(1)},${py.toFixed(1)} ${cpx.toFixed(1)},${y.toFixed(1)} ${x.toFixed(1)},${y.toFixed(1)}`;
  }, '');

  // Fill area
  const lastPt = pts[pts.length - 1];
  const firstPt = pts[0];
  const fillD = pathD + ` L${lastPt[0].toFixed(1)},${H} L${firstPt[0].toFixed(1)},${H} Z`;

  const lineEl = document.getElementById(baseId + '-line');
  const fillEl = document.getElementById(baseId + '-fill');
  const dotEl  = document.getElementById(baseId + '-dot');
  if (lineEl) lineEl.setAttribute('d', pathD);
  if (fillEl) fillEl.setAttribute('d', fillD);
  if (dotEl) {
    dotEl.setAttribute('cx', lastPt[0].toFixed(1));
    dotEl.setAttribute('cy', lastPt[1].toFixed(1));
  }
}

/* Update sub-text with "vs last refresh" context */
function updateSub(elId, curr, prev, unit) {
  const el = document.getElementById(elId);
  if (!el) return;
  if (prev == null) return;
  const diff = curr - prev;
  if (diff > 0)      el.textContent = `+${diff} ${unit} sejak refresh`;
  else if (diff < 0) el.textContent = `${diff} ${unit} sejak refresh`;
  else               el.textContent = `Tidak ada perubahan`;
}

/* ═══════════════════════════════════════════════════════════════
   SUMMARY
═══════════════════════════════════════════════════════════════ */
async function loadSummary() {
  try {
    const r = await api('GET', '/api/mikrotik/hotspot/summary');
    if (!r.success) return;
    const d    = r.data;
    const prev = _prevSummary;

    // Update numbers
    setText('s-total',    d.totalUsers    ?? '—');
    setText('s-active',   d.activeUsers   ?? '—');
    setText('s-disabled', d.disabledUsers ?? '—');
    setText('s-hosts',    d.totalHosts    ?? '—');
    setText('s-servers',  d.totalServers  ?? '—');

    // Pill badges
    renderPill('sc-pill-users',    d.totalUsers,    prev?.totalUsers    ?? null);
    renderPill('sc-pill-active',   d.activeUsers,   prev?.activeUsers   ?? null);
    renderPill('sc-pill-disabled', d.disabledUsers, prev?.disabledUsers ?? null);
    renderPill('sc-pill-hosts',    d.totalHosts,    prev?.totalHosts    ?? null);
    renderPill('sc-pill-servers',  d.totalServers,  prev?.totalServers  ?? null);

    // Sync tab badges
    const tbDis = document.getElementById('tb-disabled');
    const tbSrv = document.getElementById('tb-servers');
    if (tbDis) tbDis.textContent = d.disabledUsers ?? 0;
    if (tbSrv) tbSrv.textContent = d.totalServers  ?? 0;

    // Sub-texts (vs previous)
    updateSub('sc-sub-users',    d.totalUsers,    prev?.totalUsers    ?? null, 'user');
    updateSub('sc-sub-active',   d.activeUsers,   prev?.activeUsers   ?? null, 'sesi');
    updateSub('sc-sub-disabled', d.disabledUsers, prev?.disabledUsers ?? null, 'user');
    updateSub('sc-sub-hosts',    d.totalHosts,    prev?.totalHosts    ?? null, 'host');

    // Sparkline line charts — simulated history trend, last point = now
    const mkTrend = (cur, n=10) => {
      if (!cur && cur !== 0) return Array(n).fill(0);
      return Array.from({length: n}, (_, i) => {
        if (i === n - 1) return cur;
        const spread = Math.max(Math.ceil(cur * .25), 3);
        const jitter = Math.floor(Math.random() * spread);
        return Math.max(0, cur - jitter + Math.floor(Math.random() * Math.ceil(spread * .3)));
      });
    };
    renderSparkLine('sp-users',    mkTrend(d.totalUsers    || 0));
    renderSparkLine('sp-active',   mkTrend(d.activeUsers   || 0));
    renderSparkLine('sp-disabled', mkTrend(d.disabledUsers || 0));
    renderSparkLine('sp-hosts',    mkTrend(d.totalHosts    || 0));
    renderSparkLine('sp-servers',  mkTrend(d.totalServers  || 0));

    _prevSummary = { ...d };
  } catch(e) { console.warn('loadSummary error', e); }
}

/* ═══════════════════════════════════════════════════════════════
   SERVERS
═══════════════════════════════════════════════════════════════ */
/* ═══════════════════════════════════════════════════════════════
   USER NONAKTIF
═══════════════════════════════════════════════════════════════ */
let allDisabled = [], filtDisabled = [], pgDisNum = 1, pgDisSize = 25;

async function loadDisabledUsers() {
  setEl('tbl-disabled', loaderHtml());
  const r = await api('GET', '/api/mikrotik/hotspot/users').catch(()=>({}));
  allDisabled  = (r.success ? r.data : []).filter(u => u.disabled);
  filtDisabled = [...allDisabled];
  const badge  = document.getElementById('tb-disabled');
  if (badge) badge.textContent = allDisabled.length;
  renderDisabledTable();
}

function renderDisabledTable() {
  const start = (pgDisNum-1) * pgDisSize;
  const slice = filtDisabled.slice(start, start + pgDisSize);
  if (!slice.length) {
    setEl('tbl-disabled', emptyHtml('Tidak ada user nonaktif'));
    document.getElementById('pg-disabled').style.display = 'none';
    return;
  }
  let h = `<table><thead><tr>
    <th><input type="checkbox" class="chk" id="chk-all-dis" onchange="checkAllDis()"></th>
    <th>Username</th><th>Profile</th><th>Server</th><th>Limit Waktu</th><th>Komentar</th><th>Aksi</th>
  </tr></thead><tbody>`;
  slice.forEach(u => {
    // Limit: pakai user field, fallback ke profile config
    let limitCell;
    if (u.limitUptime) {
      limitCell = `<span style="font-size:12px;font-family:var(--fm)">${x(u.limitUptime)}</span>`;
    } else {
      const cfgLim = window.HotspotPricing ? window.HotspotPricing.limitUptime(u.profile) : '';
      limitCell = cfgLim
        ? `<span style="font-size:12px;color:var(--blue);font-family:var(--fm)" title="Dari profile config">${x(cfgLim)}</span>`
        : `<span style="color:var(--text3)">∞</span>`;
    }
    h += `<tr>
      <td><input type="checkbox" class="chk chk-dis" value="${x(u.id)}" onchange="updDelDisBtn()"></td>
      <td>
        <div style="font-weight:600">${x(u.name)}</div>
        ${u.comment ? `<div style="font-size:11px;color:var(--text2)">${x(u.comment)}</div>` : ''}
      </td>
      <td><span class="badge b-purple">${x(u.profile)}</span></td>
      <td><span style="font-size:12px;color:var(--text2)">${x(u.server)}</span></td>
      <td>${limitCell}</td>
      <td style="font-size:12px;color:var(--text2)">${x(u.comment) || '—'}</td>
      <td>
        <div style="display:flex;gap:5px">
          <button class="btn btn-success btn-xs" onclick="reactivateUser('${x(u.id)}','${x(u.name)}')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="20,6 9,17 4,12"/></svg>
            Aktifkan
          </button>
          <button class="btn btn-danger btn-xs" onclick="delUser('${x(u.id)}','${x(u.name)}')">Hapus</button>
        </div>
      </td>
    </tr>`;
  });
  h += '</tbody></table>';
  setEl('tbl-disabled', h);
  renderDisabledPg();
}

function renderDisabledPg() {
  const total = filtDisabled.length;
  const pages = Math.ceil(total / pgDisSize);
  const pg = document.getElementById('pg-disabled');
  pg.style.display = total ? 'flex' : 'none';
  setText('pg-dis-info', `${Math.min((pgDisNum-1)*pgDisSize+1,total)}–${Math.min(pgDisNum*pgDisSize,total)} dari ${total}`);
  const btns = document.getElementById('pg-dis-btns');
  btns.innerHTML = '';
  const addBtn = (l,p,dis,act) => btns.innerHTML += `<button class="page-btn${act?' active':''}" ${dis?'disabled':''} onclick="goDisPage(${p})">${l}</button>`;
  addBtn('‹', pgDisNum-1, pgDisNum<=1, false);
  for (let p=Math.max(1,pgDisNum-2); p<=Math.min(pages,pgDisNum+2); p++) addBtn(p,p,false,p===pgDisNum);
  addBtn('›', pgDisNum+1, pgDisNum>=pages, false);
}
function goDisPage(p) { pgDisNum=p; renderDisabledTable(); }

function filterDisabled() {
  const q = document.getElementById('q-disabled').value.toLowerCase();
  filtDisabled = allDisabled.filter(u => !q || u.name.toLowerCase().includes(q) || u.comment.toLowerCase().includes(q));
  pgDisNum = 1; renderDisabledTable();
}

function checkAllDis() {
  const m = document.getElementById('chk-all-dis');
  document.querySelectorAll('.chk-dis').forEach(c => c.checked = m.checked);
  updDelDisBtn();
}
function updDelDisBtn() {
  const n = [...document.querySelectorAll('.chk-dis:checked')].length;
  document.getElementById('btn-del-dis').style.display = n > 0 ? 'inline-flex' : 'none';
}
async function deleteSelectedDisabled() {
  const ids = [...document.querySelectorAll('.chk-dis:checked')].map(c => c.value);
  if (!ids.length) return;
  if (!confirm(`Hapus ${ids.length} user nonaktif?`)) return;
  const r = await api('POST', '/api/mikrotik/hotspot/users/delete-batch', { ids });
  if (r.success) { toast(r.message, 'success'); loadDisabledUsers(); loadSummary(); }
  else toast(r.message, 'error');
}
async function reactivateUser(id, name) {
  if (!confirm(`Aktifkan kembali user "${name}"?`)) return;
  const r = await api('POST', `/api/mikrotik/hotspot/users/${id}/enable`);
  if (r.success) {
    toast(`User "${name}" berhasil diaktifkan`, 'success');
    loadDisabledUsers(); loadUsers(); loadSummary();
  } else toast(r.message, 'error');
}

/* ═══════════════════════════════════════════════════════════════
   PRINT HELPERS
═══════════════════════════════════════════════════════════════ */
const PRINT_BLUE = '#1565C0';
const PRINT_BLUE_DARK = '#0D47A1';
const PRINT_GREEN = '#2E7D32';
const PRINT_RED = '#B71C1C';

function _buildPrintStyle() {
  return `
  <style>
    @page { size: A4; margin: 10mm 12mm; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; background: #f0f2f5; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .ph { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; padding-bottom:10px; border-bottom:2px solid ${PRINT_BLUE}; }
    .ph-left { display:flex; align-items:center; gap:9px; }
    .ph-icon { width:34px; height:34px; border-radius:9px; background:${PRINT_BLUE}; display:flex; align-items:center; justify-content:center; }
    .ph-icon svg { width:18px; height:18px; stroke:#fff; fill:none; stroke-width:2; }
    .ph-name { font-size:17px; font-weight:900; color:${PRINT_BLUE_DARK}; letter-spacing:-.5px; }
    .ph-sub { font-size:8.5px; color:#888; text-transform:uppercase; letter-spacing:.8px; margin-top:1px; }
    .ph-right { text-align:right; font-size:8.5px; color:#666; line-height:1.75; }
    .ph-right strong { color:#222; }
    /* List table */
    table { width:100%; border-collapse:collapse; background:#fff; border-radius:8px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,.1); }
    thead tr { background:${PRINT_BLUE}; }
    thead th { font-size:8px; font-weight:700; text-transform:uppercase; letter-spacing:.6px; color:#fff; padding:7px 10px; text-align:left; }
    tbody td { font-size:9px; color:#222; padding:6px 10px; border-bottom:1px solid #f0f0f5; font-family:Arial,sans-serif; }
    tbody tr:last-child td { border-bottom:none; }
    tbody tr { break-inside:avoid; page-break-inside:avoid; }
    tbody tr:nth-child(even) td { background:#f8faff; }
    .mono { font-family:'Courier New',monospace; font-size:9px; }
    .badge-on  { background:#e8f5e9; color:${PRINT_GREEN}; padding:2px 6px; border-radius:4px; font-size:7.5px; font-weight:700; }
    .badge-off { background:#ffebee; color:${PRINT_RED};   padding:2px 6px; border-radius:4px; font-size:7.5px; font-weight:700; }
    .badge-never { background:#fff8e1; color:#F57F17; padding:2px 6px; border-radius:4px; font-size:7.5px; font-weight:700; }
    .summary-bar { display:flex; gap:10px; margin-bottom:12px; }
    .sum-box { flex:1; background:#fff; border-radius:8px; padding:8px 12px; box-shadow:0 1px 3px rgba(0,0,0,.08); border-left:3px solid ${PRINT_BLUE}; }
    .sum-box.green { border-color:${PRINT_GREEN}; }
    .sum-box.red { border-color:${PRINT_RED}; }
    .sum-box.amber { border-color:#F57F17; }
    .sum-lbl { font-size:7.5px; font-weight:600; text-transform:uppercase; letter-spacing:.5px; color:#888; margin-bottom:3px; }
    .sum-val { font-size:18px; font-weight:900; color:#111; line-height:1; }
  </style>`;
}

function _buildPrintHeader(title, subtitle, meta) {
  return `<div class="ph">
    <div class="ph-left">
      <div class="ph-icon">
        <svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="#fff" stroke="none"/></svg>
      </div>
      <div>
        <div class="ph-name">FLAYNET</div>
        <div class="ph-sub">${subtitle}</div>
      </div>
    </div>
    <div class="ph-right">
      <strong>${title}</strong><br>${meta}
    </div>
  </div>`;
}


