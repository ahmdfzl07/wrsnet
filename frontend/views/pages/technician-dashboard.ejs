/* ═══════════════════════════════════════════════════════
   SLA REAL-TIME TICKER
   Update semua .sla-pill di DOM tiap 30 detik tanpa rerender
   ═══════════════════════════════════════════════════════ */
let _slaTicker = null;
function updateSlaPills(){
  document.querySelectorAll('.sla-pill[data-sla]').forEach(pill => {
    const due = new Date(pill.dataset.sla);
    const msLeft = due - new Date();
    const hrLeft = msLeft / 3600000;
    pill.classList.remove('ok','warn','late');
    let label;
    if(msLeft < 0){
      pill.classList.add('late');
      label = 'Overdue ' + fmtDuration(Math.abs(msLeft));
    } else if(hrLeft < 2){
      pill.classList.add('late');
      label = 'SLA ' + fmtDuration(msLeft);
    } else if(hrLeft < 6){
      pill.classList.add('warn');
      label = 'SLA ' + fmtDuration(msLeft);
    } else {
      pill.classList.add('ok');
      label = 'SLA ' + fmtDuration(msLeft);
    }
    // Cari text node terakhir dan update (svg tetap)
    const nodes = pill.childNodes;
    let updated = false;
    for(let i = nodes.length - 1; i >= 0; i--){
      if(nodes[i].nodeType === 3){ nodes[i].textContent = label; updated = true; break; }
    }
    if(!updated) pill.appendChild(document.createTextNode(label));
  });
}
function startSlaTicker(){
  stopSlaTicker();
  updateSlaPills();
  _slaTicker = setInterval(updateSlaPills, 30000);  // tiap 30 detik
}
function stopSlaTicker(){
  if(_slaTicker){ clearInterval(_slaTicker); _slaTicker = null; }
}

/* ═══════════════════════════════════════════════════════
   ONLINE / OFFLINE DETECTION
   ═══════════════════════════════════════════════════════ */
let _lastOnlineTime = Date.now();
function setConnectionState(online){
  const banner = document.getElementById('connBanner');
  const icon = document.getElementById('connIcon');
  const msg = document.getElementById('connMsg');
  const time = document.getElementById('connTime');
  if(!banner) return;

  if(!online){
    banner.className = 'conn-banner offline';
    icon.innerHTML = '<line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.58 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>';
    msg.textContent = 'Offline — cek koneksi internet';
    const mins = Math.round((Date.now() - _lastOnlineTime) / 60000);
    time.textContent = mins > 0 ? mins + 'm yang lalu' : '';
    stopAutoRefresh();
  } else {
    _lastOnlineTime = Date.now();
    banner.className = 'conn-banner back-online';
    icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
    msg.textContent = 'Kembali online';
    time.textContent = '';
    setTimeout(() => { banner.className = 'conn-banner'; }, 2500);
    if(STATE.user){
      doRefresh();
      startAutoRefresh();
    }
  }
}
window.addEventListener('online',  () => setConnectionState(true));
window.addEventListener('offline', () => setConnectionState(false));

/* ═══════════════════════════════════════════════════════
   PULL TO REFRESH (mobile)
   ═══════════════════════════════════════════════════════ */
(function setupPullToRefresh(){
  let startY = 0, pulling = false, triggered = false;
  const ptr = document.getElementById('ptr');
  if(!ptr) return;
  const THRESHOLD = 70;

  document.addEventListener('touchstart', e => {
    if(window.scrollY > 0) return;
    startY = e.touches[0].clientY;
    pulling = true; triggered = false;
  }, { passive: true });

  document.addEventListener('touchmove', e => {
    if(!pulling || window.scrollY > 0) return;
    const dy = e.touches[0].clientY - startY;
    if(dy <= 0){ pulling = false; return; }
    const pull = Math.min(dy, 120);
    ptr.style.transform = `translateX(-50%) translateY(${Math.max(-40, -40 + pull)}px)`;
    ptr.classList.add('visible');
    if(pull >= THRESHOLD) ptr.classList.add('ready');
    else ptr.classList.remove('ready');
  }, { passive: true });

  document.addEventListener('touchend', async () => {
    if(!pulling) return;
    pulling = false;
    const ready = ptr.classList.contains('ready');
    if(ready && !triggered){
      triggered = true;
      ptr.classList.add('spinning');
      if(navigator.vibrate) navigator.vibrate(15);
      try { await doRefresh(); } catch(e){}
      setTimeout(() => {
        ptr.style.transform = 'translateX(-50%) translateY(-40px)';
        ptr.classList.remove('visible','ready','spinning');
        showToast('Data terbaru dimuat');
      }, 400);
    } else {
      ptr.style.transform = 'translateX(-50%) translateY(-40px)';
      setTimeout(() => ptr.classList.remove('visible','ready'), 200);
    }
  });
})();

/* ═══════════════════════════════════════════════════════
   SWIPE TO ACTION (swipe left = resolve, swipe right = open detail)
   ═══════════════════════════════════════════════════════ */
(function setupSwipe(){
  let swStart = null, swItem = null;
  const TRIGGER = 80;

  document.addEventListener('touchstart', e => {
    const item = e.target.closest('.t-item');
    if(!item) return;
    if(e.target.closest('button, a, .t-qbtn')) return;
    swStart = { x: e.touches[0].clientX, y: e.touches[0].clientY };
    swItem = item;
  }, { passive: true });

  document.addEventListener('touchmove', e => {
    if(!swItem || !swStart) return;
    const dx = e.touches[0].clientX - swStart.x;
    const dy = Math.abs(e.touches[0].clientY - swStart.y);
    if(dy > 20 && Math.abs(dx) < 20){ swItem = null; return; }
    if(Math.abs(dx) < 10) return;
    const clamped = Math.max(-140, Math.min(140, dx));
    swItem.classList.add('swiping');
    swItem.style.transform = `translateX(${clamped}px)`;
    if(Math.abs(clamped) > TRIGGER){
      swItem.style.boxShadow = dx > 0 ? '0 0 0 2px #2563eb' : '0 0 0 2px #059669';
    } else {
      swItem.style.boxShadow = '';
    }
  }, { passive: true });

  document.addEventListener('touchend', () => {
    if(!swItem) return;
    const item = swItem;
    const dx = item.style.transform ? parseFloat(item.style.transform.match(/-?\d+\.?\d*/)?.[0] || 0) : 0;
    item.classList.remove('swiping');
    item.style.transform = '';
    item.style.boxShadow = '';
    if(Math.abs(dx) > TRIGGER){
      const tid = item.dataset.tid;
      if(!tid){ swItem = null; return; }
      if(navigator.vibrate) navigator.vibrate(20);
      if(dx < 0){
        if(STATE.ticketTab === 'mine') resolveTicket(+tid);
        else openTicket(+tid);
      } else {
        openTicket(+tid);
      }
    }
    swItem = null; swStart = null;
  });
})();

/* ═══════════════════════════════════════════════════════
   BACKGROUND GPS UPDATER
   Kirim posisi tiap 45 detik kalau ada sesi aktif
   (variables _gpsUpdater & GPS_UPDATE_INTERVAL declared earlier)
   ═══════════════════════════════════════════════════════ */

async function gpsTick(){
  if(!STATE.activeSession || !STATE.activeSession.session_id) return;
  if(document.hidden) return;  // skip kalau tab gak aktif (hemat battery)
  try {
    const pos = await getCurrentPosition({ timeout: 10000, maximumAge: 10000 });
    await api('/api/tracking/update', {
      method: 'POST',
      body: JSON.stringify({
        ticket_id: STATE.activeSession.ticket_id,
        latitude: pos.coords.latitude,
        longitude: pos.coords.longitude,
        accuracy: pos.coords.accuracy,
        speed: pos.coords.speed || 0,
        heading: pos.coords.heading || 0,
        altitude: pos.coords.altitude || null
      })
    });
  } catch(e){
    console.warn('gpsTick', e.message || e);
  }
}

function startGpsUpdater(){
  stopGpsUpdater();
  _gpsUpdater = setInterval(gpsTick, GPS_UPDATE_INTERVAL);
}
function stopGpsUpdater(){
  if(_gpsUpdater){ clearInterval(_gpsUpdater); _gpsUpdater = null; }
}
let _refreshTimer = null;
let _lastRefresh = 0;
const REFRESH_INTERVAL = 60000;       // 60 detik
const MIN_REFRESH_GAP = 15000;        // minimum 15 detik antar fetch (anti-spam)

async function doRefresh(){
  if(!STATE.user) return;
  const gap = Date.now() - _lastRefresh;
  if(gap < MIN_REFRESH_GAP) return;
  _lastRefresh = Date.now();
  try{
    await Promise.all([loadTickets(), loadWO(), loadActiveSession()]);
    updateCheckoutFab();
  }catch(e){ console.error('refresh', e); }
}

function startAutoRefresh(){
  stopAutoRefresh();
  _refreshTimer = setInterval(() => {
    if(document.hidden) return;  // pause saat tab tidak terlihat
    doRefresh();
  }, REFRESH_INTERVAL);
}
function stopAutoRefresh(){
  if(_refreshTimer){ clearInterval(_refreshTimer); _refreshTimer = null; }
}

// Resume saat user balik ke tab
document.addEventListener('visibilitychange', () => {
  if(!document.hidden && STATE.user){
    // Kalau udah lama gak refresh, fetch ulang
    if(Date.now() - _lastRefresh > REFRESH_INTERVAL){
      doRefresh();
    }
  }
});
</script>

