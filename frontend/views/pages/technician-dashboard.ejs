    body: JSON.stringify({ status:'in_progress', started_at: new Date().toISOString() })
  });
  if(r?.success){
    if(navigator.vibrate) navigator.vibrate(20);
    showToast('WO dimulai');
    loadWO();
  } else showError(r?.message || 'Gagal update WO');
}

async function completeWO(id){
  const note = await showConfirm({
    variant: 'success',
    title: 'Tandai WO Selesai?',
    message: 'Tuliskan laporan hasil pekerjaan yang akan disimpan di WO.',
    prompt: true,
    placeholder: 'Contoh: Instalasi OLT-3 port 6 selesai, sudah uji sinyal',
    rows: 3,
    okText: 'Selesaikan'
  });
  if(note === null) return;
  const r = await api('/api/work-orders/'+id, {
    method:'PUT',
    body: JSON.stringify({ status:'done', completed_at: new Date().toISOString(), completion_notes: String(note || '').trim() })
  });
  if(r?.success){
    if(navigator.vibrate) navigator.vibrate([20,40,20]);
    showToast('WO ditandai selesai');
    loadWO();
  } else showError(r?.message || 'Gagal update WO');
}

