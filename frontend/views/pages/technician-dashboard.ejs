  // Calculate counts for all tabs
  const allWo = STATE.workOrders;
  const cToday = allWo.filter(w => w.scheduled_date === today && ['pending','assigned','in_progress'].includes(w.status)).length;
  const cUpcoming = allWo.filter(w => w.scheduled_date && w.scheduled_date > today && ['pending','assigned'].includes(w.status)).length;
  const cProgress = allWo.filter(w => w.status === 'in_progress').length;
  const cDone = allWo.filter(w => w.status === 'done').length;
  const _ct = document.getElementById('cntWoToday'); if(_ct) _ct.textContent = cToday;
  const _cu = document.getElementById('cntWoUpcoming'); if(_cu) _cu.textContent = cUpcoming;
  const _cp = document.getElementById('cntWoProgress'); if(_cp) _cp.textContent = cProgress;
  const _cd = document.getElementById('cntWoDone'); if(_cd) _cd.textContent = cDone;

  if(tab === 'today'){
    list = list.filter(w => w.scheduled_date === today && ['pending','assigned','in_progress'].includes(w.status));
  } else if(tab === 'upcoming'){
    list = list.filter(w => w.scheduled_date && w.scheduled_date > today && ['pending','assigned'].includes(w.status));
  } else if(tab === 'in_progress'){
    list = list.filter(w => w.status === 'in_progress');
  } else if(tab === 'done'){
    list = list.filter(w => w.status === 'done');
  }

  const q = ($('#woSearch')?.value || '').toLowerCase().trim();
  if(q) list = list.filter(w => (w.wo_number||'').toLowerCase().includes(q) || (w.title||'').toLowerCase().includes(q) || (w.customer?.name||'').toLowerCase().includes(q));

  const el = $('#woList');
