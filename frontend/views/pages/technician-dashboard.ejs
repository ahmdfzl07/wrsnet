  // SLA donut
  const withSLA = doneTickets.filter(t => t.due_at);
  const onTime = withSLA.filter(t => new Date(t.resolved_at) <= new Date(t.due_at)).length;
  const total = withSLA.length;
  const pct = total ? Math.round((onTime/total)*100) : 0;
  $('#slaPct').textContent = pct+'%';
  $('#slaOntime').textContent = onTime;
  $('#slaLate').textContent = total - onTime;
  $('#slaTotal').textContent = total;
  const circ = 2 * Math.PI * 40;
  $('#slaArc').setAttribute('stroke-dasharray', circ);
  $('#slaArc').setAttribute('stroke-dashoffset', circ - (circ * pct/100));
}

/* ═══════════════════════════════════════════════════════
   CHECK-IN / CHECK-OUT (GPS Tracking Session)
   ═══════════════════════════════════════════════════════ */

/* GPS updater timer — declared early supaya updateCheckoutFab bisa refer */
let _gpsUpdater = null;
const GPS_UPDATE_INTERVAL = 45000;  // 45 detik

/* Get current position sebagai Promise (wrapper geolocation API) */
function getCurrentPosition(opts = {}){
  return new Promise((resolve, reject) => {
    if(!navigator.geolocation){
      return reject(new Error('Browser tidak mendukung GPS'));
    }
    navigator.geolocation.getCurrentPosition(
      pos => resolve(pos),
      err => reject(err),
      Object.assign({
        enableHighAccuracy: true,
        timeout: 15000,
        maximumAge: 0
      }, opts)
    );
  });
}

/* Fetch active session dari server + simpan ke STATE */
async function loadActiveSession(){
  try {
    const r = await api('/api/tracking/my-session');
    STATE.activeSession = r?.data || null;
  } catch(e){
    STATE.activeSession = null;
  }
}

/* Check-in: minta lokasi, start tracking session, simpan ke STATE */
async function checkIn(ticketId){
  // Kalau sudah ada session aktif dan bukan utk ticket ini, konfirmasi ganti
  if(STATE.activeSession && STATE.activeSession.ticket_id !== ticketId){
    const ok = await showConfirm({
      variant: 'warn',
      title: 'Sesi Tracking Lain Aktif',
      message: 'Anda sedang tracking tiket #' + (STATE.activeSession.ticket?.ticket_number || STATE.activeSession.ticket_id) + '. Check-out dulu sebelum check-in ke tiket baru?',
      okText: 'Check-out & Lanjutkan'
    });
    if(!ok) return null;
    await checkOut(true);  // silent
  } else if(STATE.activeSession && STATE.activeSession.ticket_id === ticketId){
    // Sudah check-in untuk tiket ini, skip
    return STATE.activeSession;
  }

  // Request GPS location
  showToast('Mengambil lokasi GPS...');
  let pos;
  try {
    pos = await getCurrentPosition();
  } catch(e){
    showError('Gagal dapat lokasi GPS: ' + (e.message || 'izin ditolak'));
    return null;
  }

  // Start tracking session di server
  const r = await api('/api/tracking/start', {
    method: 'POST',
    body: JSON.stringify({
      ticket_id: ticketId,
      latitude: pos.coords.latitude,
      longitude: pos.coords.longitude,
      accuracy: pos.coords.accuracy,
      speed: pos.coords.speed || 0,
      heading: pos.coords.heading || 0,
      altitude: pos.coords.altitude || null,
      device_info: navigator.userAgent.substring(0, 200)
    })
  });

  if(!r?.success){
    // Kalau sudah ada session untuk tiket ini, gak fatal
    if(r?.session){
      STATE.activeSession = { ...r.session, ticket_id: ticketId };
      return STATE.activeSession;
    }
    showError(r?.message || 'Gagal memulai tracking');
    return null;
  }

  STATE.activeSession = r.data || r.session || { session_id: r.session_id, ticket_id: ticketId };
  if(navigator.vibrate) navigator.vibrate([15, 30, 15]);
  return STATE.activeSession;
}

/* Check-out: stop tracking session */
async function checkOut(silent = false){
  if(!STATE.activeSession){
    if(!silent) showError('Tidak ada sesi tracking aktif');
    return false;
  }

  if(!silent){
    const ok = await showConfirm({
      variant: 'warn',
      title: 'Check-out Sekarang?',
      message: 'Sesi GPS tracking akan dihentikan untuk tiket ini.',
      okText: 'Check-out'
    });
    if(!ok) return false;
  }

  // Ambil lokasi terakhir (non-blocking — kalau gagal, stop tanpa koordinat)
  let lat = null, lng = null;
  try {
    const pos = await getCurrentPosition({ timeout: 5000 });
    lat = pos.coords.latitude;
    lng = pos.coords.longitude;
  } catch(e){ /* ignore */ }

  const r = await api('/api/tracking/stop', {
    method: 'POST',
    body: JSON.stringify({
      session_id: STATE.activeSession.session_id,
      latitude: lat,
      longitude: lng
    })
  });

  if(r?.success){
    STATE.activeSession = null;
    if(navigator.vibrate) navigator.vibrate(20);
    if(!silent) showToast('Check-out berhasil');
    updateCheckoutFab();
    return true;
  } else {
    if(!silent) showError(r?.message || 'Gagal check-out');
    return false;
  }
}

/* Update floating checkout indicator (chip) + auto start/stop GPS updater */
function updateCheckoutFab(){
  const fab = document.getElementById('checkoutFab');
  const active = STATE.activeSession && STATE.activeSession.ticket_id;
  if(fab){
    if(active){
      fab.style.display = 'flex';
      const label = fab.querySelector('.ck-label');
      const num = STATE.activeSession.ticket?.ticket_number || ('#' + STATE.activeSession.ticket_id);
      if(label) label.textContent = 'Tracking ' + num;
    } else {
      fab.style.display = 'none';
    }
  }
  // Start/stop background GPS updater sesuai status sesi
  if(active && STATE.activeSession.session_id){
    if(typeof startGpsUpdater === 'function' && !_gpsUpdater) startGpsUpdater();
  } else {
    if(typeof stopGpsUpdater === 'function') stopGpsUpdater();
  }
}


/* ═══════════════════════════════════════════════════════
   CUSTOM CONFIRM / PROMPT SYSTEM
   Replaces native confirm/prompt/alert — Promise-based
   ═══════════════════════════════════════════════════════ */
let _cmResolve = null;
function showConfirm(opts){
  return new Promise(resolve => {
    _cmResolve = resolve;
    const modal = document.getElementById('cmModal');
    const icon  = document.getElementById('cmIcon');
    const title = document.getElementById('cmTitle');
    const msg   = document.getElementById('cmMsg');
    const input = document.getElementById('cmInput');
    const okBtn = document.getElementById('cmOkBtn');

    // Setup icon variant
    const variant = opts.variant || 'info';  // info | warn | danger | success
    icon.className = 'cm-icon ' + variant;
    const iconSvg = {
      info:    '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',
      warn:    '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
      danger:  '<circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>',
      success: '<polyline points="20 6 9 17 4 12"/>'
    };
    icon.querySelector('svg').innerHTML = iconSvg[variant] || iconSvg.info;

    title.textContent = opts.title || 'Konfirmasi';
    msg.textContent = opts.message || '';

    // Prompt mode vs Confirm mode
    if(opts.prompt){
      input.style.display = 'block';
      input.value = opts.defaultValue || '';
      input.placeholder = opts.placeholder || '';
      input.rows = opts.rows || 3;
      setTimeout(() => input.focus(), 100);
    } else {
      input.style.display = 'none';
    }

    okBtn.textContent = opts.okText || 'Ya';
    okBtn.className = 'cm-btn cm-btn-ok' + (opts.variant === 'danger' ? ' danger' : opts.variant === 'success' ? ' success' : '');

    modal.classList.add('open');
    // Haptic on open
    if(navigator.vibrate) navigator.vibrate(8);
  });
}
function cmConfirm(){
  const input = document.getElementById('cmInput');
  const value = input.style.display === 'block' ? input.value : true;
  document.getElementById('cmModal').classList.remove('open');
  if(_cmResolve){ _cmResolve(value); _cmResolve = null; }
}
function cmCancel(){
  document.getElementById('cmModal').classList.remove('open');
  if(_cmResolve){ _cmResolve(null); _cmResolve = null; }
}
// Enter to confirm, Escape to cancel (but not in textarea with multiline)
document.addEventListener('keydown', e => {
  if(!document.getElementById('cmModal').classList.contains('open')) return;
  if(e.key === 'Escape') cmCancel();
  if(e.key === 'Enter' && (e.ctrlKey || e.metaKey || document.getElementById('cmInput').style.display !== 'block')) cmConfirm();
});

/* Simple alert-replacement toast for errors (info also uses existing showToast) */
function showError(msg){
  let t = document.getElementById('errToast');
  if(!t){
    t = document.createElement('div');
    t.id = 'errToast';
    t.style.cssText = 'position:fixed;top:16px;left:50%;transform:translateX(-50%);background:#dc2626;color:#fff;padding:11px 18px;border-radius:12px;font-size:13px;font-weight:600;box-shadow:0 10px 30px rgba(220,38,38,.3);z-index:250;opacity:0;transition:opacity .2s;max-width:90vw;text-align:center;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._h);
  t._h = setTimeout(()=>{ t.style.opacity = '0'; }, 3000);
  if(navigator.vibrate) navigator.vibrate([15,50,15]);
}
function closeModal(){ $('#detailModal').classList.remove('open'); }
document.addEventListener('keydown', e => { if(e.key === 'Escape') closeModal(); });

function showToast(msg){
  let t = $('#toast');
  if(!t){
    t = document.createElement('div');
    t.id = 'toast';
    t.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:#0f172a;color:#fff;padding:11px 18px;border-radius:12px;font-size:13px;font-weight:600;box-shadow:0 10px 30px rgba(0,0,0,.3);z-index:200;opacity:0;transition:opacity .2s;';
    document.body.appendChild(t);
  }
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._h);
  t._h = setTimeout(()=>{ t.style.opacity = '0'; }, 2200);
}

async function doLogout(){
  const ok = await showConfirm({
    variant: 'danger',
    title: 'Keluar dari Portal?',
    message: 'Anda akan dikembalikan ke halaman login.',
    okText: 'Logout'
  });
  if(!ok) return;
  try{ await api('/api/auth/logout', { method:'POST' }); }catch(e){}
  localStorage.removeItem('token');
  localStorage.removeItem('refreshToken');
  localStorage.removeItem('user');
  document.cookie = 'token=;path=/;max-age=0';
  location.href = '/login';
}

