<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="theme-color" content="#1e40af">
  <title><%= typeof title !== 'undefined' ? title : 'Portal Teknisi' %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --font:'Plus Jakarta Sans',sans-serif;
      --blue:#2563eb;--blue2:#1d4ed8;--blue3:#1e40af;--blue-dark:#020e2e;
      --blue-light:#dbeafe;--blue-lighter:#eff6ff;
      --teal:#06b6d4;--green:#10b981;--amber:#f59e0b;--orange:#f97316;--red:#ef4444;
      --bg:#f1f5f9;--card:#fff;--border:#e2e8f0;--border2:#f1f5f9;
      --text:#0f172a;--muted:#64748b;--muted2:#94a3b8;
      --radius:16px;--shadow:0 1px 3px rgba(0,0,0,.06);--shadow-lg:0 10px 30px rgba(0,0,0,.08);
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html,body{height:100%;}
    body{
      font-family:var(--font);
      background:var(--bg);color:var(--text);
      min-height:100dvh;
      font-size:14px;
      -webkit-tap-highlight-color:transparent;
    }
    button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
    a{color:inherit;text-decoration:none;}
    ::-webkit-scrollbar{width:6px;height:6px;}
    ::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px;}

    /* ══════════════════════════════════════════════════
       LAYOUT — sidebar desktop / stacked mobile
    ══════════════════════════════════════════════════ */
    .td-app{display:flex;min-height:100dvh;}

    /* ══════════════════════════════════════════════════
       SIDEBAR — style identik admin (white/light)
    ══════════════════════════════════════════════════ */
    .sidebar{
      width:260px;flex-shrink:0;
      background:#fff;
      border-right:1px solid #e2e8f0;
      position:sticky;top:0;height:100dvh;
      display:flex;flex-direction:column;
      z-index:100;
    }

    /* Brand header */
    .sb-brand{
      display:flex;align-items:center;gap:10px;
      padding:20px 20px 16px;
      border-bottom:1px solid #e2e8f0;
    }
    .sb-logo{
      width:32px;height:32px;border-radius:8px;
      background:linear-gradient(135deg,#3b82f6,#38bdf8);
      display:flex;align-items:center;justify-content:center;
    }
    .sb-logo svg{width:18px;height:18px;color:#fff;}
    .sb-brand-text{line-height:1.2;}
    .sb-brand-text .n{font-size:15px;font-weight:700;color:#0f172a;letter-spacing:-.2px;}
    .sb-brand-text .s{font-size:10.5px;color:#94a3b8;font-weight:500;margin-top:1px;}

    /* Nav */
    .sb-menu{flex:1;overflow-y:auto;padding:8px 0;}
    .sb-label{
      font-size:10px;font-weight:700;color:#94a3b8;
      text-transform:uppercase;letter-spacing:1.2px;
      padding:8px 24px 4px;display:block;
    }
    .sb-item{
      display:flex;align-items:center;gap:10px;
      padding:9px 12px;margin:1px 8px;border-radius:8px;
      color:#64748b;font-size:13.5px;font-weight:500;
      transition:all .15s;cursor:pointer;text-decoration:none;
    }
    .sb-item svg{width:18px;height:18px;flex-shrink:0;stroke-width:1.8;}
    .sb-item:hover{background:#f1f5f9;color:#0f172a;}
    .sb-item.active{background:#eff6ff;color:#2563eb;font-weight:600;}
    .sb-item.active svg{color:#2563eb;}
    .sb-item .badge{
      margin-left:auto;background:#ef4444;color:#fff;
      font-size:10px;font-weight:700;padding:1px 7px;
      border-radius:10px;min-width:18px;text-align:center;line-height:1.5;
    }

    /* Profile footer */
    .sb-user{
      padding:12px 16px 16px;
      border-top:1px solid #e2e8f0;
      display:flex;align-items:center;gap:10px;
    }
    .sb-avatar{
      width:36px;height:36px;border-radius:50%;
      background:linear-gradient(135deg,#2563eb,#38bdf8);
      display:flex;align-items:center;justify-content:center;
      color:#fff;font-weight:800;font-size:13px;flex-shrink:0;
      box-shadow:0 0 0 2.5px #2563eb,0 3px 10px rgba(37,99,235,.35);
    }
    .sb-u-info{min-width:0;flex:1;}
    .sb-u-name{font-size:12.5px;font-weight:700;color:#0d1b3e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .sb-u-role{font-size:10.5px;color:#94a3b8;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-transform:capitalize;}
    .sb-logout{
      width:28px;height:28px;display:flex;align-items:center;justify-content:center;
      border-radius:8px;color:#94a3b8;transition:all .15s;flex-shrink:0;
    }
    .sb-logout:hover{background:rgba(245,54,92,.12);color:#ef4444;}

    /* ══════════════════════════════════════════════════
       MAIN CONTENT
    ══════════════════════════════════════════════════ */
    .td-main-wrap{flex:1;min-width:0;display:flex;flex-direction:column;}

    /* ── Desktop topbar ────────────────────────────────────── */
    .td-topbar{
      height:60px;flex-shrink:0;
      background:#fff;border-bottom:1px solid #e2e8f0;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 24px;
      position:sticky;top:0;z-index:50;
    }
    .td-topbar-left{display:flex;align-items:center;gap:12px;}
    .td-topbar-title{font-size:15px;font-weight:700;color:#0f172a;}
    .td-topbar-sub{font-size:12px;color:#94a3b8;margin-top:1px;}
    .td-topbar-right{display:flex;align-items:center;gap:8px;}
    .td-topbar-btn{
      width:36px;height:36px;border-radius:10px;
      display:flex;align-items:center;justify-content:center;
      background:none;border:none;cursor:pointer;color:#64748b;
      transition:all .15s;
    }
    .td-topbar-btn:hover{background:#f1f5f9;color:#2563eb;}
    .td-topbar-btn svg{width:18px;height:18px;}
    .td-status-dot{
      display:flex;align-items:center;gap:6px;
      font-size:12px;font-weight:600;color:#10b981;
      background:#dcfce7;padding:5px 11px;border-radius:20px;
    }
    .td-status-dot::before{content:'';width:6px;height:6px;border-radius:50%;background:#10b981;}

    /* Mobile header (hidden on desktop) */
    .m-header{
      display:none;
      background:linear-gradient(160deg,#1e40af 0%,#2563eb 55%,#0284c7 100%);
      padding:18px 18px 26px;color:#fff;position:relative;overflow:hidden;
    }
    .m-header::after{content:'';position:absolute;top:-40px;right:-30px;width:160px;height:160px;background:radial-gradient(circle,rgba(6,182,212,.35),transparent 70%);border-radius:50%;}
    .m-hdr-row{display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;}
    .m-hi{font-size:12.5px;color:rgba(255,255,255,.8);font-weight:500;}
    .m-name{font-size:20px;font-weight:800;margin-top:2px;letter-spacing:-.3px;}
    .m-hdr-btns{display:flex;gap:8px;}
    .m-hbtn{width:38px;height:38px;border-radius:12px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:#fff;position:relative;}
    .m-hbtn svg{width:18px;height:18px;}
    .m-hbtn .dot{position:absolute;top:8px;right:9px;width:8px;height:8px;border-radius:50%;background:#ef4444;border:2px solid #1e40af;}

    /* Content area */
    .td-content-wrap{padding:24px 28px 32px;flex:1;max-width:1400px;width:100%;}

    /* Page title (desktop) */
    .page-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:12px;}
    .page-title{font-size:22px;font-weight:800;letter-spacing:-.4px;}
    .page-sub{font-size:13px;color:var(--muted);margin-top:3px;}
    .page-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}

    /* Segmented tabs (mobile scrollable, desktop inline) */
    .seg{
      display:flex;gap:6px;background:#fff;border:1px solid var(--border);
      padding:5px;border-radius:13px;overflow-x:auto;scrollbar-width:none;
    }
    .seg::-webkit-scrollbar{display:none;}
    .seg button{
      padding:9px 16px;border-radius:9px;font-size:12.5px;font-weight:700;
      color:var(--muted);white-space:nowrap;transition:all .18s;display:flex;align-items:center;gap:7px;
    }
    .seg button svg{width:14px;height:14px;}
    .seg button.active{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;box-shadow:0 4px 10px rgba(37,99,235,.3);}
    .seg button:not(.active):hover{background:var(--bg);color:var(--text);}
    .seg button .cnt{
      display:inline-flex;align-items:center;justify-content:center;
      min-width:20px;height:20px;padding:0 6px;border-radius:10px;
      font-size:11px;font-weight:800;line-height:1;
    }
    .seg button .cnt{background:#e2e8f0;color:#475569;}
    .seg button.active .cnt{background:rgba(255,255,255,.25);color:#fff;}

    /* ══════════════════════════════════════════════════
       CARDS & COMPONENTS
    ══════════════════════════════════════════════════ */
    .card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;box-shadow:var(--shadow);}
    .card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
    .card-title{font-size:14.5px;font-weight:700;}
    .card-link{font-size:12px;color:var(--blue);font-weight:700;display:inline-flex;align-items:center;gap:3px;}

    /* ── Stat cards — reference style (single container, 4 cols, active solid) ── */
    .stat-grid{
      display:grid; grid-template-columns:repeat(4,1fr);
      gap:0;
      background:#fff; border:1px solid #e8eaed; border-radius:16px;
      overflow:hidden;
      margin-bottom:18px;
      box-shadow:0 1px 3px rgba(0,0,0,.04);
    }
    .stat{
      background:#fff; position:relative;
      padding:18px 20px 16px;
      display:flex; flex-direction:column; justify-content:space-between;
      min-height:120px;
      cursor:pointer; transition:background .2s;
      -webkit-tap-highlight-color:transparent;
      border-right:1px solid #f1f5f9;
    }
    .stat:last-child{ border-right:none; }
    .stat:hover{ background:#fafbfc; }
    .stat:active{ background:#f1f5f9; }

    /* Active variant — solid blue fill (like reference "Total Tickets") */
    .stat.is-active{
      background:linear-gradient(135deg,#2563eb 0%,#1d4ed8 100%);
      color:#fff;
    }
    .stat.is-active:hover{ background:linear-gradient(135deg,#1d4ed8 0%,#1e40af 100%); }
    .stat.is-active .stat-lbl{ color:rgba(255,255,255,.85); }
    .stat.is-active .stat-val{ color:#fff; }
    .stat.is-active .stat-sub{ color:rgba(255,255,255,.8); }
    .stat.is-active .stat-badge{ background:rgba(255,255,255,.2); color:#fff; }

    /* Label (top) */
    .stat-lbl{
      font-size:13px; font-weight:600; color:#64748b;
      letter-spacing:0; text-transform:none;
      margin-bottom:10px;
    }

    /* Big value row: number + sparkline on right */
    .stat-body{
      display:flex; align-items:flex-start; justify-content:space-between;
      gap:12px; flex:1;
    }
    .stat-left{ display:flex; flex-direction:column; gap:6px; min-width:0; }

    .stat-val{
      font-size:30px; font-weight:800; color:#0f172a;
      letter-spacing:-1px; line-height:1;
    }

    /* Bottom row: badge + subtitle */
    .stat-bottom{
      display:flex; align-items:center; gap:8px; margin-top:8px;
      flex-wrap:nowrap; min-width:0; overflow:hidden;
    }
    .stat-badge{
      display:inline-flex; align-items:center; gap:3px;
      padding:3px 9px; border-radius:20px;
      font-size:10.5px; font-weight:700;
      white-space:nowrap; flex-shrink:0;
    }
    .stat-badge.blue  { background:#dbeafe; color:#1d4ed8; }
    .stat-badge.teal  { background:#cffafe; color:#0e7490; }
    .stat-badge.green { background:#d1fae5; color:#047857; }
    .stat-badge.amber { background:#fed7aa; color:#9a3412; }
    .stat-badge.red   { background:#fee2e2; color:#b91c1c; }

    .stat-sub{
      font-size:11.5px; color:#94a3b8; font-weight:500;
      overflow:hidden; text-overflow:ellipsis;
      white-space:nowrap;
      min-width:0; max-width:100%;
      display:block;
    }

    /* Mini sparkline area (right side) */
    .stat-spark{
      width:80px; height:42px; flex-shrink:0;
      margin-top:-4px;
    }
    .stat-spark svg{ width:100%; height:100%; display:block; overflow:visible; }
    .sp-line{ stroke-width:1.8; fill:none; stroke-linecap:round; stroke-linejoin:round; }
    .sp-fill{ fill-opacity:.12; stroke:none; }

    /* Info arrow (top-right) */
    .stat-arrow{
      position:absolute; top:14px; right:14px;
      width:14px; height:14px; color:#cbd5e1; opacity:0;
      transition:opacity .2s;
    }
    .stat:hover .stat-arrow{ opacity:1; }
    .stat.is-active .stat-arrow{ color:rgba(255,255,255,.6); opacity:.7; }

    /* Variant: Progress footer (WO card) — replaces sparkline area */
    .stat-progress-wrap{
      margin-top:8px;
    }
    .stat-progress-row{ display:flex; align-items:center; justify-content:space-between; margin-bottom:5px; font-size:10.5px; }
    .stat-progress-lbl{ color:#64748b; font-weight:600; }
    .stat-progress-pct{ font-weight:800; color:#0f172a; }
    .stat-progress-bar{ height:5px; background:#e8eaed; border-radius:10px; overflow:hidden; }
    .stat-progress-fill{ height:100%; border-radius:10px; background:linear-gradient(90deg,#10b981,#06b6d4); transition:width .6s ease; }
    .stat.is-active .stat-progress-lbl{ color:rgba(255,255,255,.8); }
    .stat.is-active .stat-progress-pct{ color:#fff; }
    .stat.is-active .stat-progress-bar{ background:rgba(255,255,255,.2); }
    .stat.is-active .stat-progress-fill{ background:#fff; }

    /* Variant: Dual-number SLA (ok + late) */
    .stat-dual{
      display:flex; align-items:flex-end; gap:14px; margin-top:2px;
    }
    .stat-dual-item{ display:flex; flex-direction:column; gap:3px; }
    .stat-dual-num{
      font-size:22px; font-weight:800; line-height:1;
      letter-spacing:-.5px;
    }
    .stat-dual-num.ok   { color:#047857; }
    .stat-dual-num.late { color:#dc2626; }
    .stat-dual-lbl{
      font-size:9.5px; font-weight:700; color:#94a3b8;
      text-transform:uppercase; letter-spacing:.4px;
    }
    .stat-dual-divider{
      width:1px; height:28px; background:#e2e8f0;
      align-self:flex-end; margin-bottom:4px;
    }
    .stat.is-active .stat-dual-num.ok   { color:#fff; }
    .stat.is-active .stat-dual-num.late { color:#fecaca; }
    .stat.is-active .stat-dual-lbl{ color:rgba(255,255,255,.75); }
    .stat.is-active .stat-dual-divider{ background:rgba(255,255,255,.25); }

    /* Main grid (desktop: 2 col, mobile: 1 col) */
    .main-grid{display:grid;grid-template-columns:1fr 360px;gap:18px;}

    /* ══════════════════════════════════════════════════
       TICKET / WO LIST
    ══════════════════════════════════════════════════ */
    .list{display:flex;flex-direction:column;gap:10px;}
    .list-empty{padding:40px 20px;text-align:center;color:var(--muted);font-size:13px;}
    .list-empty .ic{width:56px;height:56px;border-radius:50%;background:var(--bg);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;color:var(--muted2);}
    .list-empty .ic svg{width:24px;height:24px;}

    .t-item{
      background:var(--card);border:1px solid var(--border);border-radius:14px;
      padding:14px;display:flex;gap:12px;transition:all .2s;cursor:pointer;position:relative;
    }
    .t-item:hover{border-color:var(--blue);box-shadow:0 4px 14px rgba(37,99,235,.08);transform:translateY(-1px);}
    .t-left{display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0;}
    .t-ic{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;}
    .t-ic svg{width:18px;height:18px;}
    .t-ic.gangguan{background:#fee2e2;color:#b91c1c;}
    .t-ic.request{background:var(--blue-light);color:var(--blue2);}
    .t-ic.installation{background:#d1fae5;color:#047857;}
    .t-ic.maintenance{background:#fef3c7;color:#b45309;}
    .t-ic.dismantle{background:#fce7f3;color:#be185d;}
    .t-ic.survey{background:#ede9fe;color:#7c3aed;}
    .t-ic.repair{background:#fee2e2;color:#b91c1c;}
    .t-body{flex:1;min-width:0;}
    .t-top{display:flex;align-items:center;gap:6px;margin-bottom:4px;flex-wrap:wrap;min-height:22px;}
    .t-num{font-family:'DM Mono',ui-monospace,monospace;font-size:10.5px;color:var(--muted);font-weight:600;}
    .t-prio{font-size:9.5px;font-weight:800;padding:2px 7px;border-radius:20px;text-transform:uppercase;letter-spacing:.3px;}
    .t-prio.low{background:#e0e7ff;color:#4338ca;}
    .t-prio.medium{background:#dbeafe;color:#1e40af;}
    .t-prio.high{background:#fed7aa;color:#9a3412;}
    .t-prio.critical{background:#fecaca;color:#991b1b;}
    .t-title{font-size:13.5px;font-weight:700;line-height:1.35;color:var(--text);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
    .t-meta{display:flex;align-items:center;gap:10px;margin-top:6px;font-size:11.5px;color:var(--muted);flex-wrap:wrap;}
    .t-meta span{display:inline-flex;align-items:center;gap:4px;}
    .t-meta svg{width:12px;height:12px;opacity:.8;}
    .t-status{font-size:9.5px;font-weight:800;padding:3px 8px;border-radius:20px;text-transform:uppercase;letter-spacing:.3px;margin-left:auto;}
    .t-status.open{background:#dbeafe;color:#1e40af;}
    .t-status.in_progress,.t-status.assigned{background:#fed7aa;color:#9a3412;}
    .t-status.pending{background:#fef3c7;color:#b45309;}
    .t-status.resolved,.t-status.done{background:#d1fae5;color:#047857;}
    .t-status.closed,.t-status.cancelled{background:#e2e8f0;color:#475569;}

    .t-actions{display:flex;gap:6px;margin-top:10px;padding-top:10px;border-top:1px dashed var(--border);}
    .btn-sm{padding:7px 12px;border-radius:8px;font-size:11.5px;font-weight:700;transition:all .18s;display:inline-flex;align-items:center;gap:5px;}
    .btn-sm svg{width:12px;height:12px;}
    .btn-sm.primary{background:var(--blue);color:#fff;}
    .btn-sm.primary:hover{background:var(--blue2);}
    .btn-sm.ghost{background:var(--bg);color:var(--text);}
    .btn-sm.ghost:hover{background:var(--border);}
    .btn-sm.success{background:var(--green);color:#fff;}
    .btn-sm.success:hover{background:#059669;}
    .btn-sm.danger{background:#fee2e2;color:#b91c1c;}
    .btn-sm.danger:hover{background:#fecaca;}

    /* ══════════════════════════════════════════════════
       SIDE PANEL (quick actions, upcoming, stats)
    ══════════════════════════════════════════════════ */
    .side-stack{display:flex;flex-direction:column;gap:14px;}

    .quick-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
    .qa{
      background:var(--bg);border:1px solid var(--border);border-radius:12px;
      padding:12px 10px;display:flex;flex-direction:column;align-items:center;gap:6px;
      font-size:11.5px;font-weight:700;color:var(--text);text-align:center;transition:all .2s;
      position:relative;cursor:pointer;
    }
    .qa:hover{background:var(--blue-lighter);border-color:var(--blue);color:var(--blue2);transform:translateY(-1px);}
    .qa:active{transform:translateY(0);}
    .qa-ic{width:34px;height:34px;border-radius:10px;background:var(--blue-lighter);color:var(--blue2);display:flex;align-items:center;justify-content:center;}
    .qa-ic svg{width:16px;height:16px;}
    .qa-badge{
      position:absolute;top:6px;right:6px;
      min-width:18px;height:18px;padding:0 5px;
      background:var(--blue);color:#fff;
      font-size:10px;font-weight:800;line-height:18px;
      border-radius:9px;text-align:center;
      box-shadow:0 2px 6px rgba(37,99,235,.35);
    }

    /* Schedule / upcoming WO */
    .sch-item{
      display:flex;gap:11px;padding:12px;border-radius:12px;background:var(--bg);border:1px solid var(--border2);
    }
    .sch-date{flex-shrink:0;width:46px;text-align:center;padding:6px 4px;border-radius:10px;background:#fff;border:1px solid var(--border);}
    .sch-date .d{font-size:16px;font-weight:800;line-height:1;color:var(--blue2);}
    .sch-date .m{font-size:9.5px;font-weight:700;color:var(--muted);text-transform:uppercase;margin-top:2px;letter-spacing:.5px;}
    .sch-body{min-width:0;flex:1;}
    .sch-t{font-size:13px;font-weight:700;line-height:1.3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
    .sch-m{font-size:11px;color:var(--muted);margin-top:4px;display:flex;align-items:center;gap:5px;}
    .sch-m svg{width:11px;height:11px;}

    /* Donut chart (simple SVG) */
    .donut-wrap{display:flex;align-items:center;gap:14px;}
    .donut{position:relative;width:100px;height:100px;flex-shrink:0;}
    .donut svg{transform:rotate(-90deg);}
    .donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
    .donut-center .v{font-size:20px;font-weight:800;line-height:1;}
    .donut-center .l{font-size:9.5px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-top:2px;}
    .donut-legend{flex:1;display:flex;flex-direction:column;gap:7px;}
    .lg-row{display:flex;align-items:center;gap:8px;font-size:11.5px;}
    .lg-dot{width:10px;height:10px;border-radius:3px;flex-shrink:0;}
    .lg-label{color:var(--muted);font-weight:600;}
    .lg-val{margin-left:auto;font-weight:800;color:var(--text);}

    /* ══════════════════════════════════════════════════
       FILTER BAR
    ══════════════════════════════════════════════════ */
    .filter-bar{display:flex;gap:8px;align-items:center;margin-bottom:14px;flex-wrap:wrap;}
    .search-wrap{position:relative;flex:1;min-width:200px;}
    .search-wrap input{
      width:100%;padding:10px 14px 10px 38px;border:1px solid var(--border);border-radius:11px;
      background:#fff;font-size:13px;font-family:inherit;outline:none;transition:all .18s;
    }
    .search-wrap input:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.1);}
    .search-wrap svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted2);width:16px;height:16px;}
    .chip{padding:8px 12px;border-radius:10px;background:#fff;border:1px solid var(--border);font-size:12px;font-weight:700;color:var(--muted);display:inline-flex;align-items:center;gap:5px;transition:all .18s;}
    .chip svg{width:13px;height:13px;}
    .chip.active{background:var(--blue-lighter);border-color:var(--blue);color:var(--blue2);}
    .chip:hover{border-color:var(--blue);}

    /* ══════════════════════════════════════════════════
       CUSTOM CONFIRM / PROMPT MODAL (replaces native)
    ══════════════════════════════════════════════════ */
    .cm-bg{
      display:none;position:fixed;inset:0;background:rgba(2,14,46,.6);
      backdrop-filter:blur(4px);z-index:200;
      align-items:center;justify-content:center;padding:16px;
      animation:cmFadeIn .2s ease;
    }
    .cm-bg.open{display:flex;}
    @keyframes cmFadeIn{from{opacity:0;}to{opacity:1;}}
    .cm-box{
      background:#fff;border-radius:18px;max-width:420px;width:100%;
      padding:22px 22px 18px;box-shadow:0 30px 60px rgba(0,0,0,.25);
      animation:cmSlideUp .25s cubic-bezier(.4,0,.2,1);
    }
    @keyframes cmSlideUp{from{transform:translateY(16px);opacity:.7;}to{transform:translateY(0);opacity:1;}}
    .cm-icon{
      width:48px;height:48px;border-radius:14px;
      display:flex;align-items:center;justify-content:center;
      margin-bottom:12px;
    }
    .cm-icon svg{width:24px;height:24px;}
    .cm-icon.info{background:#dbeafe;color:#1d4ed8;}
    .cm-icon.warn{background:#fed7aa;color:#9a3412;}
    .cm-icon.danger{background:#fee2e2;color:#b91c1c;}
    .cm-icon.success{background:#d1fae5;color:#047857;}
    .cm-title{font-size:16px;font-weight:800;color:#0f172a;margin-bottom:4px;letter-spacing:-.2px;}
    .cm-msg{font-size:13px;color:#64748b;line-height:1.5;}
    .cm-input{
      width:100%;margin-top:14px;padding:11px 13px;
      border:1px solid #e2e8f0;border-radius:11px;
      font-family:inherit;font-size:13px;resize:none;
      outline:none;transition:border-color .15s,box-shadow .15s;
    }
    .cm-input:focus{border-color:#2563eb;box-shadow:0 0 0 3px rgba(37,99,235,.1);}
    .cm-actions{
      display:flex;gap:8px;margin-top:16px;justify-content:flex-end;
    }
    .cm-btn{
      padding:10px 18px;border-radius:11px;font-size:13px;font-weight:700;
      transition:all .15s;cursor:pointer;
      -webkit-tap-highlight-color:transparent;
    }
    .cm-btn:active{transform:scale(.97);}
    .cm-btn-cancel{background:#f1f5f9;color:#475569;}
    .cm-btn-cancel:hover{background:#e2e8f0;}
    .cm-btn-ok{background:#2563eb;color:#fff;}
    .cm-btn-ok:hover{background:#1d4ed8;}
    .cm-btn-ok.danger{background:#dc2626;}
    .cm-btn-ok.danger:hover{background:#b91c1c;}
    .cm-btn-ok.success{background:#059669;}
    .cm-btn-ok.success:hover{background:#047857;}

    /* ══════════════════════════════════════════════════
       OFFLINE BANNER & CONNECTION STATUS
    ══════════════════════════════════════════════════ */
    .conn-banner{
      position:fixed;top:0;left:0;right:0;z-index:150;
      display:none;align-items:center;gap:10px;
      padding:8px 16px;font-size:12px;font-weight:700;
      animation:slideDown .3s ease;
    }
    @keyframes slideDown{from{transform:translateY(-100%);}to{transform:translateY(0);}}
    .conn-banner.offline{background:#fee2e2;color:#b91c1c;display:flex;}
    .conn-banner.back-online{background:#d1fae5;color:#047857;display:flex;}
    .conn-banner svg{width:14px;height:14px;flex-shrink:0;}
    .conn-banner .conn-time{margin-left:auto;font-weight:500;opacity:.8;font-size:11px;}

    /* ══════════════════════════════════════════════════
       PULL-TO-REFRESH INDICATOR
    ══════════════════════════════════════════════════ */
    .ptr{
      position:absolute;top:0;left:50%;transform:translateX(-50%) translateY(-40px);
      width:34px;height:34px;border-radius:50%;
      background:#fff;border:1px solid #e2e8f0;
      display:flex;align-items:center;justify-content:center;
      box-shadow:0 2px 10px rgba(0,0,0,.1);
      transition:transform .2s;opacity:0;pointer-events:none;z-index:10;
    }
    .ptr svg{width:16px;height:16px;color:#2563eb;transition:transform .2s;}
    .ptr.visible{opacity:1;}
    .ptr.ready svg{transform:rotate(180deg);}
    .ptr.spinning svg{animation:ptrSpin .8s linear infinite;}
    @keyframes ptrSpin{to{transform:rotate(360deg);}}

    /* ══════════════════════════════════════════════════
       TICKET CARD QUICK ACTIONS (call + maps)
    ══════════════════════════════════════════════════ */
    .t-quick{
      display:flex;gap:6px;margin-left:auto;align-self:flex-start;flex-shrink:0;
    }
    .t-qbtn{
      width:34px;height:34px;border-radius:10px;
      display:flex;align-items:center;justify-content:center;
      background:#eff6ff;color:#2563eb;transition:all .15s;
      border:1px solid #dbeafe;
      -webkit-tap-highlight-color:transparent;
    }
    .t-qbtn:hover{background:#dbeafe;}
    .t-qbtn:active{transform:scale(.92);}
    .t-qbtn svg{width:15px;height:15px;}
    .t-qbtn.call{background:#d1fae5;color:#047857;border-color:#a7f3d0;}
    .t-qbtn.call:hover{background:#a7f3d0;}
    .t-qbtn.maps{background:#fef3c7;color:#b45309;border-color:#fde68a;}
    .t-qbtn.maps:hover{background:#fde68a;}

    /* SLA countdown pill (on ticket card) */
    .sla-pill{
      display:inline-flex;align-items:center;gap:4px;
      padding:2px 8px;border-radius:20px;
      font-size:10.5px;font-weight:700;
      white-space:nowrap;
    }
    .sla-pill svg{width:10px;height:10px;}
    .sla-pill.ok   { background:#d1fae5; color:#047857; }
    .sla-pill.warn { background:#fef3c7; color:#b45309; }
    .sla-pill.late { background:#fee2e2; color:#b91c1c; }

    /* ══════════════════════════════════════════════════
       SWIPE HINT (subtle)
    ══════════════════════════════════════════════════ */
    .t-item{
      touch-action:pan-y;  /* allow vertical scroll, capture horizontal */
    }
    .t-item.swiping{
      transition:none;
    }
    .t-item-swipe-bg{
      position:absolute;inset:0;border-radius:14px;
      display:flex;align-items:center;justify-content:space-between;
      padding:0 20px;color:#fff;font-weight:700;font-size:13px;
      pointer-events:none;overflow:hidden;
      z-index:-1;
    }
    .t-item-swipe-bg .left-action{
      background:#059669;padding:0 22px;height:100%;
      display:flex;align-items:center;gap:6px;border-radius:14px 0 0 14px;
    }
    .t-item-swipe-bg .right-action{
      background:#2563eb;padding:0 22px;height:100%;
      display:flex;align-items:center;gap:6px;margin-left:auto;border-radius:0 14px 14px 0;
    }
    .t-item-swipe-bg svg{width:16px;height:16px;}

    /* ══════════════════════════════════════════════════
       STAT CARD SKELETON
    ══════════════════════════════════════════════════ */
    .stat-skel .stat-val-skel{
      height:28px;width:60%;margin-bottom:8px;
      background:linear-gradient(90deg,#e2e8f0 25%,#f1f5f9 50%,#e2e8f0 75%);
      background-size:200% 100%;animation:sk 1.4s infinite;border-radius:6px;
    }
    .stat-skel .stat-sub-skel{
      height:12px;width:70%;
      background:linear-gradient(90deg,#e2e8f0 25%,#f1f5f9 50%,#e2e8f0 75%);
      background-size:200% 100%;animation:sk 1.4s infinite;border-radius:4px;
    }

    /* ══════════════════════════════════════════════════
       RETRY / ERROR STATE
    ══════════════════════════════════════════════════ */
    .err-state{
      padding:30px 20px;text-align:center;color:#64748b;
    }
    .err-state .ic{
      width:48px;height:48px;border-radius:50%;background:#fee2e2;color:#b91c1c;
      display:flex;align-items:center;justify-content:center;margin:0 auto 12px;
    }
    .err-state .ic svg{width:22px;height:22px;}
    .err-state .msg{font-size:13px;margin-bottom:12px;}
    .err-state .retry-btn{
      display:inline-flex;align-items:center;gap:6px;
      padding:8px 16px;border-radius:10px;background:#2563eb;color:#fff;
      font-size:12px;font-weight:700;transition:background .15s;
    }
    .err-state .retry-btn:hover{background:#1d4ed8;}
    .err-state .retry-btn svg{width:13px;height:13px;}

    .t-item.tracked{
      border-color:#10b981;
      box-shadow:0 0 0 2px rgba(16,185,129,.15);
      background:linear-gradient(to right, #f0fdf4 0%, #fff 20%);
    }
    .t-item.tracked::before{
      content:'';
      position:absolute; top:10px; right:10px;
      width:8px; height:8px; border-radius:50%;
      background:#10b981;
      box-shadow:0 0 0 3px rgba(16,185,129,.3);
      animation:trackPulse 1.5s ease-in-out infinite;
      z-index:2;
    }
    @keyframes trackPulse{
      0%,100%{box-shadow:0 0 0 3px rgba(16,185,129,.3);}
      50%{box-shadow:0 0 0 8px rgba(16,185,129,.05);}
    }

    /* Floating Check-out FAB (muncul kalau ada sesi aktif) */
    .checkout-fab{
      display:none;
      position:fixed; left:50%; transform:translateX(-50%);
      bottom:88px; z-index:80;
      align-items:center; gap:10px;
      padding:10px 16px 10px 14px; border-radius:30px;
      background:#059669; color:#fff;
      font-size:12.5px; font-weight:700;
      box-shadow:0 10px 30px rgba(5,150,105,.4);
      cursor:pointer; transition:transform .15s;
      -webkit-tap-highlight-color:transparent;
      animation:fabSlideUp .3s ease;
    }
    @keyframes fabSlideUp{from{transform:translateX(-50%) translateY(16px);opacity:0;}to{transform:translateX(-50%) translateY(0);opacity:1;}}
    .checkout-fab:active{transform:translateX(-50%) scale(.95);}
    .checkout-fab .ck-dot{
      width:8px; height:8px; border-radius:50%; background:#fff;
      animation:trackPulse 1.5s ease-in-out infinite;
      box-shadow:0 0 0 3px rgba(255,255,255,.4);
    }
    @media(min-width:1024px){
      .checkout-fab{bottom:28px; right:28px; left:auto; transform:none;}
      .checkout-fab:active{transform:scale(.95);}
      @keyframes fabSlideUp{from{transform:translateY(16px);opacity:0;}to{transform:translateY(0);opacity:1;}}
    }

    /* ══════════════════════════════════════════════════
       MODAL
    ══════════════════════════════════════════════════ */
    .modal-bg{
      display:none;position:fixed;inset:0;background:rgba(2,14,46,.6);backdrop-filter:blur(4px);
      z-index:100;align-items:center;justify-content:center;padding:16px;
    }
    .modal-bg.open{display:flex;}
    .modal{
      background:#fff;border-radius:20px;max-width:540px;width:100%;
      max-height:90vh;overflow-y:auto;box-shadow:0 30px 60px rgba(0,0,0,.3);
      animation:modalIn .25s ease;
    }
    @keyframes modalIn{from{transform:translateY(20px);opacity:0;}}
    .modal-head{padding:20px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:#fff;z-index:1;border-radius:20px 20px 0 0;}
    .modal-title{font-size:16px;font-weight:800;}
    .modal-body{padding:20px 22px;}
    .modal-foot{padding:14px 22px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end;position:sticky;bottom:0;background:#fff;border-radius:0 0 20px 20px;}
    .modal-close{width:32px;height:32px;border-radius:10px;background:var(--bg);display:flex;align-items:center;justify-content:center;color:var(--muted);}
    .modal-close:hover{background:var(--border);}

    /* Detail rows */
    .det-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px dashed var(--border2);gap:10px;}
    .det-row:last-child{border-bottom:0;}
    .det-label{font-size:12px;color:var(--muted);font-weight:600;}
    .det-val{font-size:13px;font-weight:700;text-align:right;}

    /* ══════════════════════════════════════════════════
       BOTTOM NAV (mobile)
    ══════════════════════════════════════════════════ */
    .btm-nav{
      display:none;position:fixed;bottom:0;left:0;right:0;
      background:#fff;border-top:1px solid var(--border);
      padding:8px 12px 14px;z-index:50;
      box-shadow:0 -4px 20px rgba(0,0,0,.05);
    }
    .btm-nav-inner{display:flex;justify-content:space-around;max-width:480px;margin:0 auto;}
    .bn{
      display:flex;flex-direction:column;align-items:center;gap:3px;
      padding:6px 10px;border-radius:10px;color:var(--muted2);font-size:10.5px;font-weight:700;transition:all .18s;
      flex:1;
    }
    .bn svg{width:20px;height:20px;}
    .bn.active{color:var(--blue);}
    .bn.active svg{color:var(--blue);}
    .bn-icon-wrap{position:relative;display:flex;align-items:center;justify-content:center;}
    .bn-icon-wrap svg{width:20px;height:20px;}
    .bn-badge{
      display:none;position:absolute;top:-4px;right:-10px;
      min-width:16px;height:16px;padding:0 4px;
      background:#ef4444;color:#fff;
      font-size:9px;font-weight:800;line-height:16px;
      border-radius:8px;text-align:center;
      border:2px solid #fff;
    }
    .bn-badge.show{display:block;}
    .bn-fab{
      position:absolute;top:-24px;left:50%;transform:translateX(-50%);
      width:54px;height:54px;border-radius:50%;
      background:linear-gradient(135deg,var(--blue),var(--blue2));
      color:#fff;display:flex;align-items:center;justify-content:center;
      box-shadow:0 10px 24px rgba(37,99,235,.45);border:4px solid #fff;
    }
    .bn-fab svg{width:22px;height:22px;}
    .bn.bn-gps { background: none !important; color: #2563eb; }
    .bn.bn-gps:hover { background: none !important; }
    .bn-fab { background: linear-gradient(135deg,var(--blue),var(--blue2)) !important; }
    .bn-fab svg { color: #fff !important; stroke: #fff !important; }

    /* Tab view container */
    .tab-view{display:none;}
    .tab-view.active{display:block;}

    /* Loading skeleton */
    .skel{background:linear-gradient(90deg,#f1f5f9 25%,#e2e8f0 50%,#f1f5f9 75%);background-size:200% 100%;animation:sk 1.4s infinite;border-radius:8px;}
    @keyframes sk{0%{background-position:200% 0;}100%{background-position:-200% 0;}}
    .skel-row{height:80px;margin-bottom:10px;}

    /* ══════════════════════════════════════════════════
       RESPONSIVE
    ══════════════════════════════════════════════════ */
    @media(max-width:1023px){
      .sidebar{display:none;}
      .td-topbar{display:none;}
      .m-header{display:block;}
      .td-content-wrap{padding:16px 12px 110px;}
      .main-grid{grid-template-columns:1fr;}

      /* Mobile stat grid: 2×2, divider yang proper */
      .stat-grid{
        grid-template-columns:repeat(2,1fr);
        margin-bottom:14px;
        border-radius:14px;
      }
      .stat{
        padding:14px 12px 13px;
        min-height:120px;
        border-right:1px solid #f1f5f9;
        border-bottom:1px solid #f1f5f9;
      }
      /* Divider cleanup: kolom kanan = no right border, baris bawah = no bottom border */
      .stat:nth-child(2n){ border-right:none; }
      .stat:nth-last-child(-n+2){ border-bottom:none; }

      /* Tighter typography di mobile */
      .stat-lbl{ font-size:11px; margin-bottom:8px; font-weight:700; }
      .stat-val{ font-size:26px; }

      /* Body jadi stack vertikal biar gak overflow horizontal */
      .stat-body{ flex-direction:column; gap:6px; align-items:stretch; }
      .stat-left{ width:100%; }

      /* Sparkline di-hide di mobile — hemat ruang, sparkline tipis di kolom sempit jg gak informatif */
      .stat-spark{ display:none; }

      /* Bottom (badge + sub): stack vertikal, truncate sub dgn ellipsis proper */
      .stat-bottom{
        flex-direction:column; align-items:flex-start;
        gap:4px; margin-top:6px;
      }
      .stat-badge{ font-size:10px; padding:2px 8px; }
      .stat-sub{
        font-size:10.5px; line-height:1.3;
        max-width:100%;
      }

      /* Progress wrap: pastikan kelihatan, margin-top lebih kecil */
      .stat-progress-wrap{ margin-top:6px; }
      .stat-progress-row{ font-size:10px; margin-bottom:3px; }
      .stat-progress-bar{ height:4px; }

      /* SLA dual number: kecilkan dan tighten */
      .stat-dual{ gap:10px; margin-top:0; }
      .stat-dual-num{ font-size:22px; }
      .stat-dual-lbl{ font-size:8.5px; letter-spacing:.3px; }
      .stat-dual-divider{ height:24px; margin-bottom:3px; }

      /* Arrow chevron: kasih supaya selalu terlihat di mobile (no hover) */
      .stat-arrow{ opacity:.5; top:12px; right:10px; width:12px; height:12px; }
      .stat.is-active .stat-arrow{ opacity:.8; }

      .page-head{margin-bottom:12px;}
      .page-title{font-size:18px;}
      .btm-nav{display:block;}
      .card{padding:14px;}
    }
    @media(max-width:380px){
      .stat{ padding:12px 11px 11px; min-height:112px; }
      .stat-val{ font-size:22px; }
      .stat-lbl{ font-size:10.5px; margin-bottom:6px; }
      .stat-badge{ font-size:9.5px; padding:2px 6px; }
      .stat-sub{ font-size:10px; }
      .stat-dual-num{ font-size:19px; }
      .stat-dual-lbl{ font-size:8px; }
      .stat-dual{ gap:8px; }
      .stat-dual-divider{ height:22px; }
    }
    @media(max-width:480px){
      .quick-grid{grid-template-columns:repeat(4,1fr);}
      .qa{font-size:10.5px;padding:10px 6px;}
      .qa-ic{width:30px;height:30px;}
      .t-actions{flex-wrap:wrap;}
    }
  </style>
</head>
<body>

<!-- ══════════════════════════════════════════════════
     OFFLINE / ONLINE BANNER
══════════════════════════════════════════════════ -->
<div class="conn-banner" id="connBanner">
  <svg id="connIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></svg>
  <span id="connMsg">Offline — data mungkin tidak ter-update</span>
  <span class="conn-time" id="connTime"></span>
</div>

<!-- ══════════════════════════════════════════════════
     PULL TO REFRESH INDICATOR
══════════════════════════════════════════════════ -->
<div class="ptr" id="ptr">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 5v14M5 12l7-7 7 7"/>
  </svg>
</div>

<!-- ══════════════════════════════════════════════════
     CUSTOM CONFIRM / PROMPT MODAL
══════════════════════════════════════════════════ -->
<div class="cm-bg" id="cmModal" onclick="if(event.target===this)cmCancel()">
  <div class="cm-box">
    <div class="cm-icon" id="cmIcon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <div class="cm-title" id="cmTitle">Konfirmasi</div>
    <div class="cm-msg" id="cmMsg">Lanjutkan aksi ini?</div>
    <textarea class="cm-input" id="cmInput" rows="3" placeholder="" style="display:none;"></textarea>
    <div class="cm-actions">
      <button class="cm-btn cm-btn-cancel" onclick="cmCancel()">Batal</button>
