<script>
/* ═══════════════════════════════════════════════════════
   STATE & CONFIG
   ═══════════════════════════════════════════════════════ */
const STATE = {
  user: null,
  ticketTab: 'mine',       // mine | unassigned | done
  ticketPrio: 'all',
  woTab: 'today',          // today | upcoming | in_progress | done
  tickets: { mine: [], unassigned: [], done: [] },
  workOrders: [],
  activeSession: null,     // Sesi GPS tracking yg sedang berjalan { session_id, ticket_id, ... }
};

// Ambil token dari localStorage (pola admin panel), fallback ke cookie
function getToken(){
  const ls = localStorage.getItem('token');
  if (ls) return ls;
  const m = document.cookie.match(/(?:^|;\s*)token=([^;]+)/);
  return m ? decodeURIComponent(m[1]) : null;
}
function authHeaders(){
  const t = getToken();
  return t ? { 'Authorization':'Bearer '+t, 'Content-Type':'application/json' } : { 'Content-Type':'application/json' };
}
async function api(url, opts={}){
  const r = await fetch(url, { credentials:'include', headers: authHeaders(), ...opts });
  if(r.status === 401){ location.href = '/login'; return null; }
  return r.json().catch(()=>null);
}

/* ═══════════════════════════════════════════════════════
   HELPERS
   ═══════════════════════════════════════════════════════ */
function $(sel, root=document){ return root.querySelector(sel); }
function $$(sel, root=document){ return [...root.querySelectorAll(sel)]; }
function esc(s){ return String(s ?? '').replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function initials(n){ if(!n) return 'T'; return n.split(/\s+/).slice(0,2).map(s=>s[0]).join('').toUpperCase(); }
function fmtDate(d){ if(!d) return '—'; const dt = new Date(d); return dt.toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'}); }
function fmtDateTime(d){ if(!d) return '—'; const dt = new Date(d); return dt.toLocaleString('id-ID',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'}); }
function fmtRelative(d){
  if(!d) return '—';
  const diff = (new Date(d) - Date.now())/1000;
  const abs = Math.abs(diff);
  if(abs < 3600) return Math.round(abs/60)+' menit '+(diff<0?'lalu':'lagi');
  if(abs < 86400) return Math.round(abs/3600)+' jam '+(diff<0?'lalu':'lagi');
  return Math.round(abs/86400)+' hari '+(diff<0?'lalu':'lagi');
}
function todayYMD(){ return new Date().toISOString().slice(0,10); }

/* ═══════════════════════════════════════════════════════
   TAB SWITCHING
   ═══════════════════════════════════════════════════════ */
function switchTab(tab){
  $$('.tab-view').forEach(v => v.classList.toggle('active', v.id === 'view-'+tab));
  $$('.sb-item[data-tab]').forEach(i => i.classList.toggle('active', i.dataset.tab === tab));
  $$('.bn[data-tab]').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  window.scrollTo(0,0);

  // Lazy load
  if(tab === 'tickets' && !STATE.tickets.mine.length) loadTickets();
  if(tab === 'workorders' && !STATE.workOrders.length) loadWO();
  if(tab === 'profile') loadProfileStats();
}
$$('.sb-item[data-tab], .bn[data-tab]').forEach(el=>{
  el.addEventListener('click', e => { e.preventDefault(); switchTab(el.dataset.tab); });
});

/* ═══════════════════════════════════════════════════════
   INIT — load user info
   ═══════════════════════════════════════════════════════ */
async function init(){
  $('#todayDate').textContent = new Date().toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  const _tbd = document.getElementById('topbarDate'); if(_tbd) _tbd.textContent = new Date().toLocaleDateString('id-ID',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});

  // Get current user (pakai endpoint existing /api/auth/profile)
  const meRes = await api('/api/auth/profile');
  if(!meRes || !meRes.success){
    location.href = '/login';
    return;
  }
  STATE.user = meRes.data || meRes.user || meRes;

  // Verify role
  const roleName = STATE.user?.role?.name || STATE.user?.role || '';
  // (admin boleh lihat untuk QA, tapi warn kalau bukan technician)
  // if(!/technician/i.test(roleName)){ alert('Akses ditolak: hanya untuk teknisi'); location.href = '/'; return; }

  // Fill UI
  const name = STATE.user.name || 'Teknisi';
  $('#sbUserName').textContent = name;
  $('#mHeaderName').textContent = name.split(' ')[0];
  $('#sbAvatar').textContent = initials(name);
  $('#pfAvatar').textContent = initials(name);
  $('#pfName').textContent = name;
  $('#pfEmail').textContent = STATE.user.email || '—';
  $('#pfPhone').textContent = STATE.user.phone || '—';
  $('#pfJoined').textContent = fmtDate(STATE.user.created_at || STATE.user.createdAt);

  // Load initial data
  await Promise.all([loadTickets(), loadWO(), loadActiveSession()]);
  _lastRefresh = Date.now();
  renderOverview();
  updateCheckoutFab();

  // Mulai auto-refresh smart (pause saat hidden)
  startAutoRefresh();
}

/* ═══════════════════════════════════════════════════════
   TICKETS
   ═══════════════════════════════════════════════════════ */
async function loadTickets(){
  if(!STATE.user) return;
  const uid = STATE.user.id;
  try{
    const [mineRes, unaRes, doneRes, closedRes] = await Promise.all([
      api('/api/tickets?assigned_to='+uid+'&limit=50'),
      api('/api/tickets?status=open&limit=50'),
      api('/api/tickets?assigned_to='+uid+'&status=resolved&limit=100'),
      api('/api/tickets?assigned_to='+uid+'&status=closed&limit=50')
    ]);
    STATE.tickets.mine = (mineRes?.data?.tickets || mineRes?.data || mineRes?.tickets || [])
      .filter(t => t.assigned_to === uid && !['resolved','closed'].includes(t.status));
    STATE.tickets.unassigned = (unaRes?.data?.tickets || unaRes?.data || unaRes?.tickets || [])
      .filter(t => !t.assigned_to);
    // Gabungkan resolved + closed untuk SLA historical yang akurat
    const resolvedList = (doneRes?.data?.tickets || doneRes?.data || doneRes?.tickets || [])
      .filter(t => t.assigned_to === uid);
    const closedList = (closedRes?.data?.tickets || closedRes?.data || closedRes?.tickets || [])
      .filter(t => t.assigned_to === uid);
    STATE.tickets.done = [...resolvedList, ...closedList];

    STATE._ticketsLoaded = true;
    STATE._ticketsError = false;

    $('#cntMine').textContent = STATE.tickets.mine.length;
    $('#cntUnassigned').textContent = STATE.tickets.unassigned.length;
    $('#sbBadgeTickets').textContent = STATE.tickets.mine.length + STATE.tickets.unassigned.length;

    const _bnT = document.getElementById('bnBadgeTickets');
    if(_bnT){
      const tc = STATE.tickets.mine.length;
      _bnT.textContent = tc; _bnT.classList.toggle('show', tc > 0);
    }

    renderTickets();
    renderOverview();
    startSlaTicker();  // mulai (atau restart) ticker setelah render
  }catch(e){
    console.error('loadTickets', e);
    STATE._ticketsError = true;
    renderTicketsError();
  }
}

function renderTicketsError(){
  const el = $('#ticketList');
  if(!el) return;
  el.innerHTML = `<div class="err-state">
    <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
    <div class="msg">Gagal memuat data tiket. Cek koneksi Anda.</div>
    <button class="retry-btn" onclick="loadTickets()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      Coba Lagi
    </button>
  </div>`;
}

function setTicketTab(tab){
  STATE.ticketTab = tab;
  STATE._overdueFilter = false;  // reset overdue filter saat ganti tab
  $$('#ticketSeg button').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
  renderTickets();
}
function setPrioFilter(p, el){
  STATE.ticketPrio = p;
  STATE._overdueFilter = false;  // reset overdue filter saat ganti prio
  $$('.filter-bar .chip').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  renderTickets();
}
function renderTicketsEmpty(msg){
  $('#ticketList').innerHTML = `<div class="list-empty"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/></svg></div>${esc(msg)}</div>`;
}

function typeIcon(t){
  const map = {
    gangguan:'<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
    request:'<path d="M21.2 15A2 2 0 0 1 22 17v3a1 1 0 0 1-1 1c-9.4 0-17-7.6-17-17a1 1 0 0 1 1-1h3a2 2 0 0 1 2 .8"/>',
    installation:'<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
    maintenance:'<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
    dismantle:'<polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>',
    survey:'<circle cx="12" cy="10" r="3"/><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>',
    repair:'<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
    other:'<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'
  };
  return map[t] || map.other;
}

function ticketCard(t, opts={}){
  const mine = opts.mine === true;
  const claim = opts.claim === true;
  const done = opts.done === true;

  const now = new Date();
  const due = t.due_at ? fmtRelative(t.due_at) : null;
  const overdue = t.due_at && new Date(t.due_at) < now && !['resolved','closed'].includes(t.status);

  // SLA pill real-time — hitung sisa waktu
  let slaPill = '';
  if(t.due_at && !['resolved','closed'].includes(t.status)){
    const msLeft = new Date(t.due_at) - now;
    const hrLeft = msLeft / 3600000;
    let cls = 'ok', icon = '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>', label;
    if(msLeft < 0){
      cls = 'late';
      icon = '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>';
      label = 'Overdue ' + fmtDuration(Math.abs(msLeft));
    } else if(hrLeft < 2){
      cls = 'late'; label = 'SLA ' + fmtDuration(msLeft);
    } else if(hrLeft < 6){
      cls = 'warn'; label = 'SLA ' + fmtDuration(msLeft);
    } else {
      cls = 'ok';   label = 'SLA ' + fmtDuration(msLeft);
    }
    slaPill = `<span class="sla-pill ${cls}" data-sla="${esc(t.due_at)}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icon}</svg>${esc(label)}</span>`;
  }

  // Quick-action buttons (call + maps) — hanya utk mine/claim, bukan done
  let quickActions = '';
  if(!done){
    const phone = t.customer?.phone;
    const lat = t.latitude || t.customer?.latitude;
    const lng = t.longitude || t.customer?.longitude;
    const btns = [];
    if(phone){
      btns.push(`<a class="t-qbtn call" href="tel:${esc(phone)}" onclick="event.stopPropagation();" title="Telepon pelanggan" aria-label="Telepon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>`);
    }
    if(lat && lng){
      btns.push(`<a class="t-qbtn maps" onclick="event.stopPropagation();openMapsNav(${lat},${lng})" title="Navigasi ke lokasi" aria-label="Navigasi">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
      </a>`);
    }
    if(btns.length) quickActions = `<div class="t-quick">${btns.join('')}</div>`;
  }

  let actions = '';
  if(mine){
    // Cek apakah tiket ini yang sedang di-track
    const isTrackedNow = STATE.activeSession && STATE.activeSession.ticket_id === t.id;

    actions = `
      <div class="t-actions">
        <button class="btn-sm primary" onclick="event.stopPropagation();openTicket(${t.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Detail
        </button>
        ${isTrackedNow
          ? `<button class="btn-sm danger" onclick="event.stopPropagation();checkOut()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17l5-5-5-5"/><path d="M15 12H3"/><path d="M19 5v14"/></svg>
              Check-out
            </button>`
          : `<button class="btn-sm ghost" onclick="event.stopPropagation();startGps(${t.id})">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Tracking
            </button>`
        }
        ${t.status !== 'resolved' ? `<button class="btn-sm success" onclick="event.stopPropagation();resolveTicket(${t.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Selesai
        </button>` : ''}
      </div>`;
  } else if(claim){
    actions = `
      <div class="t-actions">
        <button class="btn-sm primary" onclick="event.stopPropagation();claimTicket(${t.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
          Ambil Tiket
        </button>
        <button class="btn-sm ghost" onclick="event.stopPropagation();openTicket(${t.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          Detail
        </button>
      </div>`;
  } else if(done){
    actions = `<div class="t-actions"><button class="btn-sm ghost" onclick="event.stopPropagation();openTicket(${t.id})">Detail</button></div>`;
  }

  const trackedClass = (STATE.activeSession && STATE.activeSession.ticket_id === t.id) ? ' tracked' : '';

  return `
    <div class="t-item${trackedClass}" data-tid="${t.id}" onclick="openTicket(${t.id})">
      <div class="t-left">
        <div class="t-ic ${esc(t.type)}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${typeIcon(t.type)}</svg>
        </div>
      </div>
      <div class="t-body">
        <div class="t-top">
          <span class="t-num">${esc(t.ticket_number || '#'+t.id)}</span>
          <span class="t-prio ${esc(t.priority)}">${esc(t.priority)}</span>
          <span class="t-status ${esc(t.status)}">${esc((t.status||'').replace('_',' '))}</span>
          ${quickActions}
        </div>
        <div class="t-title">${esc(t.title)}</div>
        <div class="t-meta">
          ${t.customer?.name ? `<span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>${esc(t.customer.name)}</span>` : ''}
          ${slaPill}
          ${(t.latitude || t.customer?.latitude) ? `<span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>Lokasi</span>` : ''}
        </div>
        ${actions}
      </div>
    </div>`;
}

/* ═══════════════════════════════════════════════════════
   FORMATTING HELPERS
   ═══════════════════════════════════════════════════════ */
function fmtDuration(ms){
  const s = Math.floor(ms / 1000);
  if(s < 60) return s + 'd';
  const m = Math.floor(s / 60);
  if(m < 60) return m + 'm';
  const h = Math.floor(m / 60);
  const rm = m % 60;
  if(h < 24) return h + 'j' + (rm ? ' ' + rm + 'm' : '');
  const d = Math.floor(h / 24);
  const rh = h % 24;
  return d + 'h' + (rh ? ' ' + rh + 'j' : '');
}

/* ═══════════════════════════════════════════════════════
   NAVIGATION HELPERS (Maps + Dialer)
   ═══════════════════════════════════════════════════════ */
function openMapsNav(lat, lng){
  // Coba geolocation buat turn-by-turn; fallback ke peta biasa
  if(!navigator.geolocation){
    window.open(`https://www.google.com/maps/search/?api=1&query=${lat},${lng}`, '_blank');
    return;
  }
  // Langsung pakai directions dgn origin=current
  const url = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}&travelmode=driving`;
  window.open(url, '_blank');
  showToast('Membuka navigasi ke lokasi');
  // Haptic
  if(navigator.vibrate) navigator.vibrate(15);
}

function renderTickets(){
  const tab = STATE.ticketTab;
  let list = [...(STATE.tickets[tab] || [])];

  // Sort by priority + overdue (overdue dulu, lalu critical/high/medium/low)
  const now = new Date();
  list.sort((a, b) => {
    const aOv = a.due_at && new Date(a.due_at) < now ? 0 : 1;
    const bOv = b.due_at && new Date(b.due_at) < now ? 0 : 1;
    if(aOv !== bOv) return aOv - bOv;
    const aP = PRIO_RANK[a.priority] ?? 99;
    const bP = PRIO_RANK[b.priority] ?? 99;
    if(aP !== bP) return aP - bP;
    return new Date(b.created_at || 0) - new Date(a.created_at || 0);
  });

  // Overdue-only filter (dari quick action)
  if(STATE._overdueFilter && tab === 'mine'){
    list = list.filter(t => t.due_at && new Date(t.due_at) < now && !['resolved','closed'].includes(t.status));
  }

  const q = ($('#ticketSearch')?.value || '').toLowerCase().trim();
  if(q){
    list = list.filter(t =>
      (t.ticket_number||'').toLowerCase().includes(q) ||
      (t.title||'').toLowerCase().includes(q) ||
      (t.customer?.name||'').toLowerCase().includes(q)
    );
  }
  if(STATE.ticketPrio !== 'all'){
    list = list.filter(t => t.priority === STATE.ticketPrio);
  }

  const el = $('#ticketList');
  if(!list.length){
    let emptyHtml;
    if(STATE._overdueFilter){
      emptyHtml = `<div class="list-empty"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>Tidak ada tiket overdue 🎉</div>`;
    } else if(tab === 'mine'){
      emptyHtml = `<div class="list-empty">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
        Belum ada tiket ditugaskan ke Anda
        ${STATE.tickets.unassigned.length > 0 ? `<div style="margin-top:10px;"><button class="btn-sm primary" onclick="setTicketTab('unassigned')">Lihat ${STATE.tickets.unassigned.length} tiket menunggu</button></div>` : ''}
      </div>`;
    } else if(tab === 'unassigned'){
      emptyHtml = `<div class="list-empty"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>Tidak ada tiket yang menunggu</div>`;
    } else {
      emptyHtml = `<div class="list-empty"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg></div>Belum ada tiket selesai bulan ini</div>`;
    }
    el.innerHTML = emptyHtml;
    return;
  }
  const opts = { mine: tab==='mine', claim: tab==='unassigned', done: tab==='done' };
  el.innerHTML = list.map(t => ticketCard(t, opts)).join('');
}

/* ═══════════════════════════════════════════════════════
   TICKET ACTIONS
   ═══════════════════════════════════════════════════════ */
async function claimTicket(id){
  const ok = await showConfirm({
    variant: 'info',
    title: 'Ambil Tiket?',
    message: 'Tiket ini akan ditugaskan ke Anda, status jadi "in progress", dan GPS tracking akan otomatis dimulai.',
    okText: 'Ambil & Check-in'
  });
  if(!ok) return;

  // 1) Update ticket
  const r = await api('/api/tickets/'+id, {
    method:'PUT',
    body: JSON.stringify({ assigned_to: STATE.user.id, status:'in_progress' })
  });
  if(!r?.success){
    showError(r?.message || 'Gagal mengambil tiket');
    return;
  }

  if(navigator.vibrate) navigator.vibrate(20);
  showToast('Tiket berhasil diambil');

  // 2) Auto check-in (GPS)
  const session = await checkIn(id);
  if(!session){
    // Check-in gagal (user tolak GPS, timeout, dll) — tiket tetap ter-claim
    loadTickets();
    return;
  }

  // 3) Refresh data + update FAB
  loadTickets();
  updateCheckoutFab();

  // 4) Tawarkan pilihan: tetap di sini atau buka peta
  const ticket = STATE.tickets.mine.find(t => t.id === id)
    || STATE.tickets.unassigned.find(t => t.id === id)
    || { id };
  const lat = ticket.latitude || ticket.customer?.latitude;
  const lng = ticket.longitude || ticket.customer?.longitude;

  const goMaps = await showConfirm({
    variant: 'success',
    title: 'Check-in Berhasil 📍',
    message: (lat && lng)
      ? 'GPS tracking aktif. Mau buka navigasi ke lokasi pelanggan sekarang?'
      : 'GPS tracking aktif. Koordinat pelanggan tidak tersedia — Anda bisa lanjut dari halaman tracking.',
    okText: (lat && lng) ? 'Buka Peta' : 'Buka Tracking'
  });

  if(goMaps){
    if(lat && lng){
      openMapsNav(lat, lng);
    } else {
      location.href = '/technician-tracking?ticket=' + id;
    }
  }
  // Kalau user pilih "Batal" → tetap di dashboard, session sudah aktif
}

async function resolveTicket(id){
  // Kalau tiket ini sedang di-track, kasih info bahwa akan auto check-out
  const isTracked = STATE.activeSession && STATE.activeSession.ticket_id === id;
  const note = await showConfirm({
    variant: 'success',
    title: 'Tandai Tiket Selesai?',
    message: (isTracked ? '🛑 GPS tracking akan otomatis di-check-out. ' : '')
      + 'Tuliskan catatan penyelesaian (opsional) yang akan ditambahkan ke timeline.',
    prompt: true,
    placeholder: 'Contoh: Kabel FO diganti, sinyal stabil -24 dBm',
    rows: 3,
    okText: 'Selesaikan'
  });
  if(note === null) return;

  // 1) Auto check-out kalau sedang tracking tiket ini
  if(isTracked){
    await checkOut(true);  // silent
  }

  // 2) Update ticket
  const r = await api('/api/tickets/'+id, {
    method:'PUT',
    body: JSON.stringify({ status:'resolved', resolved_at: new Date().toISOString() })
  });
  if(r?.success){
    if(note && String(note).trim()){
      await api('/api/tickets/'+id+'/timeline', {
        method:'POST',
        body: JSON.stringify({ type:'resolution', content: String(note).trim() })
      });
    }
    if(navigator.vibrate) navigator.vibrate([20,40,20]);
    showToast(isTracked ? 'Tiket selesai, check-out berhasil' : 'Tiket ditandai selesai');
    loadTickets();
    updateCheckoutFab();
  } else {
    showError(r?.message || 'Gagal update tiket');
  }
}

function openTicket(id){
  // Navigate ke halaman detail ticket teknisi (standalone page)
  location.href = '/technician/ticket/' + id;
}

function startGps(ticketId){
  sessionStorage.setItem('tracking_ticket_id', ticketId);
  location.href = '/technician-tracking?ticket='+ticketId;
}

