   OVERVIEW RENDERING
   ═══════════════════════════════════════════════════════ */

/* ── Smooth sparkline (SVG line + fill area) dari data riil 7 hari ──
   Menggambar line smooth dengan quadratic bezier, plus area fill tipis.
   Mirip style di referensi gambar (kurva halus tipis di kanan kartu).
*/
function drawSparkline(lineId, fillId, items, dateField){
  const lineEl = document.getElementById(lineId);
  const fillEl = document.getElementById(fillId);
  if(!lineEl) return;

  // Build 7 hari terakhir
  const days = [];
  const now = new Date();
  for(let i = 6; i >= 0; i--){
    const d = new Date(now.getFullYear(), now.getMonth(), now.getDate() - i);
    const ymd = d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
    days.push({ ymd, count: 0 });
  }

  (items || []).forEach(it => {
    const raw = it[dateField] || it.resolved_at || it.completed_at || it.updated_at;
    if(!raw) return;
    const dt = new Date(raw);
    if(isNaN(dt)) return;
    const ymd = dt.getFullYear()+'-'+String(dt.getMonth()+1).padStart(2,'0')+'-'+String(dt.getDate()).padStart(2,'0');
    const slot = days.find(d => d.ymd === ymd);
    if(slot) slot.count++;
  });

  // Scale ke viewBox 80×42 (match CSS)
  const W = 80, H = 42, padX = 2, padY = 4;
  const max = Math.max(1, ...days.map(d => d.count));
  const xs = days.map((_, i) => padX + (i / (days.length - 1)) * (W - padX * 2));
  const ys = days.map(d => H - padY - (d.count / max) * (H - padY * 2));

  // Build smooth path via quadratic bezier (mid-point smoothing)
  let d = `M ${xs[0]},${ys[0]}`;
  for(let i = 1; i < xs.length; i++){
    const mx = (xs[i-1] + xs[i]) / 2;
    const my = (ys[i-1] + ys[i]) / 2;
    d += ` Q ${xs[i-1]},${ys[i-1]} ${mx},${my}`;
  }
  d += ` L ${xs[xs.length-1]},${ys[ys.length-1]}`;

  lineEl.setAttribute('d', d);
  if(fillEl){
    fillEl.setAttribute('d', d + ` L ${xs[xs.length-1]},${H} L ${xs[0]},${H} Z`);
  }
}

/* ── Priority rank utk sort ───────────────────────────────────── */
const PRIO_RANK = { critical:0, high:1, medium:2, low:3 };

function renderOverview(){
  const now = new Date();
  const today = todayYMD();
  const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);

  // ── Card 1: Tiket Aktif ─────────────────────────────────────────
  const activeTickets = STATE.tickets.mine.filter(t => ['open','in_progress','pending','assigned'].includes(t.status));
  const _ta = activeTickets.length;
  $('#statTicketActive').textContent = _ta;
  const _bT = document.getElementById('badgeTicketVal');
  if(_bT) _bT.textContent = _ta;
  // Sparkline dari gabungan mine + done (histori created_at 7 hari terakhir)
  drawSparkline('spTicketLine','spTicketFill',
    [...STATE.tickets.mine, ...STATE.tickets.done], 'created_at');

  // ── Card 2: WO Hari Ini ──────────────────────────────────────────
  const woToday = STATE.workOrders.filter(w => w.scheduled_date === today);
  const woTodayCount = woToday.length;
  $('#statWoToday').textContent = woTodayCount;
  const woDone = woToday.filter(w => ['done','completed'].includes(w.status)).length;
  const woPct = woTodayCount > 0 ? Math.round(woDone / woTodayCount * 100) : 0;
  const _pctEl = document.getElementById('woProgressPct');
  const _fillEl = document.getElementById('woProgressFill');
  const _noteEl = document.getElementById('woProgressNote');
  const _bWVal = document.getElementById('badgeWoVal');
  if(_pctEl) _pctEl.textContent = woPct + '%';
  if(_fillEl) _fillEl.style.width = woPct + '%';
  if(_bWVal) _bWVal.textContent = woDone;
  if(_noteEl) _noteEl.textContent = woTodayCount > 0
    ? 'dari ' + woTodayCount + ' WO'
    : 'Belum ada';

  // ── Card 3: Selesai Bulan Ini ────────────────────────────────────
  const doneTicketsMonth = STATE.tickets.done.filter(t => new Date(t.resolved_at || t.updated_at || 0) >= monthStart);
  const doneWOMonth = STATE.workOrders.filter(w => w.status==='done' && new Date(w.completed_at || w.updated_at || 0) >= monthStart);
  const doneCount = doneTicketsMonth.length + doneWOMonth.length;
  $('#statDoneMonth').textContent = doneCount;
  const _bDVal = document.getElementById('badgeDoneVal');
  if(_bDVal) _bDVal.textContent = doneCount;
  const _subD = document.getElementById('subDone');
  if(_subD) _subD.textContent = doneTicketsMonth.length + ' tiket · ' + doneWOMonth.length + ' WO';
  // Sparkline dari gabungan selesai 7 hari terakhir
  const doneCombined = [
    ...STATE.tickets.done.map(t => ({ date: t.resolved_at || t.updated_at })),
    ...STATE.workOrders.filter(w => w.status==='done').map(w => ({ date: w.completed_at || w.updated_at }))
  ];
  drawSparkline('spDoneLine','spDoneFill', doneCombined, 'date');

  // ── Card 4: Status SLA ───────────────────────────────────────────
  // Hitung SLA gabungan: historical (tiket selesai) + aktif (tiket berjalan)
  // → memberi gambaran kinerja SLA yang utuh, bukan cuma "saat ini"
  const mine = STATE.tickets.mine;
  const doneAll = STATE.tickets.done;

  // Active tickets — tepat waktu vs overdue (yg masih berjalan)
  const activeOverdue = mine.filter(t => t.due_at && new Date(t.due_at) < now).length;
  const activeOk      = mine.filter(t => t.due_at && new Date(t.due_at) >= now).length;

  // Resolved tickets — tepat waktu vs terlambat (historical)
  const doneWithSla   = doneAll.filter(t => t.due_at && (t.resolved_at || t.closed_at));
  const doneOnTime    = doneWithSla.filter(t => new Date(t.resolved_at || t.closed_at) <= new Date(t.due_at)).length;
  const doneLate      = doneWithSla.length - doneOnTime;

  // Totals (gabungan)
  const totalOk       = activeOk + doneOnTime;
  const totalLate     = activeOverdue + doneLate;
  const totalSla      = totalOk + totalLate;

  // Display: kalau sama sekali tidak ada data SLA (gak ada tiket dgn due_at),
  // fallback ke total tiket mine apa adanya (biar angka tidak 0/0 tanpa konteks)
  let showOk, showLate;
  if(totalSla > 0){
    showOk = totalOk;
    showLate = totalLate;
  } else {
    // Tidak ada tiket yang punya due_at sama sekali — tampilkan jumlah tiket mine + no overdue
    showOk = mine.length;
    showLate = 0;
  }
  $('#statOverdue').textContent = showLate;
  const _slaOkEl = document.getElementById('statSlaOk');
  if(_slaOkEl) _slaOkEl.textContent = showOk;

  // Update badge + sub berdasarkan kondisi
  const _bSla = document.getElementById('badgeSla');
  const _subSla = document.getElementById('subSla');
  if(_bSla && _subSla){
    if(activeOverdue > 0){
      // Ada yang overdue sekarang — prioritas merah
      _bSla.className = 'stat-badge red';
      _bSla.textContent = activeOverdue + ' overdue';
      _subSla.textContent = 'Perlu tindakan';
    } else if(totalSla > 0){
      // Ada data historis/aktif dgn SLA — tampilkan persentase
      const pct = Math.round((totalOk / totalSla) * 100);
      if(pct >= 90){
        _bSla.className = 'stat-badge green';
        _bSla.textContent = pct + '% on-time';
        _subSla.textContent = 'Performa bagus';
      } else if(pct >= 70){
        _bSla.className = 'stat-badge amber';
        _bSla.textContent = pct + '% on-time';
        _subSla.textContent = 'Perlu ditingkatkan';
      } else {
        _bSla.className = 'stat-badge red';
        _bSla.textContent = pct + '% on-time';
        _subSla.textContent = 'Perhatian khusus';
      }
    } else if(mine.length > 0){
      // Ada tiket aktif tapi belum ada yang punya SLA due_at
      _bSla.className = 'stat-badge green';
      _bSla.textContent = 'Aman';
      _subSla.textContent = mine.length + ' tiket aktif';
    } else {
      // Benar-benar kosong
      _bSla.className = 'stat-badge amber';
      _bSla.textContent = 'SLA Monitor';
      _subSla.textContent = 'Belum ada tiket';
    }
  }
  // Simpan overdue utk Quick Actions
  const overdue = activeOverdue;

  // ── Quick Actions badges ─────────────────────────────────────────
  const _qaUn = document.getElementById('qaBadgeUnassigned');
  const _qaOv = document.getElementById('qaBadgeOverdue');
  if(_qaUn){
    const n = STATE.tickets.unassigned.length;
    _qaUn.textContent = n;
    _qaUn.style.display = n > 0 ? 'block' : 'none';
  }
  if(_qaOv){
    _qaOv.textContent = overdue;
    _qaOv.style.display = overdue > 0 ? 'block' : 'none';
  }

  // ── Preview ticket list ──────────────────────────────────────────
  // Sort: overdue dulu → prioritas critical/high → terbaru
  const prev = [...STATE.tickets.mine].sort((a, b) => {
    const aOv = a.due_at && new Date(a.due_at) < now ? 0 : 1;
    const bOv = b.due_at && new Date(b.due_at) < now ? 0 : 1;
    if(aOv !== bOv) return aOv - bOv;
    const aP = PRIO_RANK[a.priority] ?? 99;
    const bP = PRIO_RANK[b.priority] ?? 99;
    if(aP !== bP) return aP - bP;
    return new Date(b.created_at || 0) - new Date(a.created_at || 0);
  }).slice(0, 4);

  if(prev.length){
    $('#ovTicketList').innerHTML = prev.map(t => ticketCard(t, {mine:true})).join('');
  } else {
    $('#ovTicketList').innerHTML = `<div class="list-empty"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>Semua beres! Tidak ada tugas aktif.</div>`;
  }

  // ── Schedule preview ─────────────────────────────────────────────
  // FIX: sort pakai Date object, bukan string concat
  const upcoming = STATE.workOrders
    .filter(w => w.scheduled_date && w.scheduled_date >= today && ['pending','assigned','in_progress'].includes(w.status))
    .map(w => ({
      ...w,
      _sortKey: new Date(w.scheduled_date + 'T' + (w.scheduled_time || '00:00:00')).getTime()
    }))
    .sort((a,b) => a._sortKey - b._sortKey)
    .slice(0, 3);

  if(upcoming.length){
    $('#ovSchedule').innerHTML = upcoming.map(w => {
      const d = new Date(w.scheduled_date);
      const isToday = w.scheduled_date === today;
      return `
        <div class="sch-item" onclick="openWO(${w.id})" style="cursor:pointer;${isToday?'border-color:#bfdbfe;background:#eff6ff;':''}">
          <div class="sch-date"${isToday?' style="background:var(--blue);border-color:var(--blue);"':''}>
            <div class="d"${isToday?' style="color:#fff;"':''}>${d.getDate()}</div>
            <div class="m"${isToday?' style="color:rgba(255,255,255,.85);"':''}>${d.toLocaleDateString('id-ID',{month:'short'})}</div>
          </div>
          <div class="sch-body">
            <div class="sch-t">${esc(w.title)}</div>
            <div class="sch-m">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              ${w.scheduled_time ? esc(w.scheduled_time.slice(0,5)) : '—'} · ${esc(w.customer?.name || w.technician_name || w.type || '')}
            </div>
          </div>
        </div>`;
    }).join('');
  } else {
    $('#ovSchedule').innerHTML = `<div class="list-empty" style="padding:20px 12px;font-size:12px;">Tidak ada jadwal mendatang</div>`;
  }
}

