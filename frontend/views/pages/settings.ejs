function _pushStatusLabel(status) {
  // Status label tanpa emoji — hanya text, warna dihandle CSS badge
  return {
    sent:      'Terkirim',
    scheduled: 'Terjadwal',
    failed:    'Gagal',
    cancelled: 'Dibatalkan',
    pending:   'Pending'
  }[status] || status;
}

async function loadPushHistory() {
  const status = document.getElementById('pushHistFilter').value;
  const search = document.getElementById('pushHistSearch').value.trim();
  const qs = [];
  if (status) qs.push('status='+encodeURIComponent(status));
  if (search) qs.push('search='+encodeURIComponent(search));
  qs.push('limit=50');
  const container = document.getElementById('pushHistoryList');
  container.innerHTML = '<div style="padding:28px;text-align:center;color:var(--d-muted);font-size:13px">Memuat...</div>';

  try {
    const d = await App.api('/push-notif/list?'+qs.join('&'));
    let list = d?.data || [];
    // Tab Riwayat hanya tampilkan notif yang BUKAN scheduled (itu ada di tab khusus)
    list = list.filter(n => n.status !== 'scheduled' && n.status !== 'pending');

    if (!list.length) {
      container.innerHTML = '<div style="padding:28px;text-align:center;color:var(--d-muted);font-size:13px">Belum ada riwayat pengiriman.</div>';
      return;
    }
    container.innerHTML = list.map(n => {
      const statusLabel = _pushStatusLabel(n.status);
      const when = n.sent_at ? 'Dikirim: ' + new Date(n.sent_at).toLocaleString('id-ID')
                 : n.scheduled_at ? 'Dijadwalkan: ' + new Date(n.scheduled_at).toLocaleString('id-ID')
                 : 'Dibuat: ' + new Date(n.created_at || n.createdAt).toLocaleString('id-ID');

      let actions = '';
      if (n.status === 'sent' || n.status === 'failed') {
        actions += '<button class="push-mini-btn" onclick="retryPush('+n.id+')" style="background:#dbeafe;color:#1e40af;border-color:#bfdbfe">'+SVG_ICON.retry+'Kirim Ulang</button>';
      }
      actions += '<button class="push-mini-btn" onclick="deletePush('+n.id+')" style="background:#fee2e2;color:#991b1b;border-color:#fecaca">'+SVG_ICON.trash+'Hapus</button>';

      return '<div class="push-hist-card">' +
        '<div class="push-hist-head">' +
          '<div style="font-size:22px">'+(n.icon||'🔔')+'</div>' +
          '<div class="push-hist-title">'+escapeHtmlSt(n.title)+'</div>' +
          '<span class="push-status-badge push-status-'+n.status+'">'+statusLabel+'</span>' +
        '</div>' +
        '<div class="push-hist-body">'+escapeHtmlSt(n.body)+'</div>' +
        '<div class="push-hist-meta">' +
          '<span>'+SVG_ICON.target+'Target: <b>'+n.target_count+'</b></span>' +
          (n.status === 'sent' ? '<span>'+SVG_ICON.sent+'Terkirim: <b style="color:#059669">'+n.sent_count+'</b></span>' : '') +
          (n.failed_count > 0 ? '<span style="color:#dc2626">'+SVG_ICON.warning+'Gagal: <b>'+n.failed_count+'</b></span>' : '') +
          '<span>'+SVG_ICON.clock+when+'</span>' +
          (n.error_message ? '<span style="color:#dc2626;flex-basis:100%">'+SVG_ICON.warning+escapeHtmlSt(n.error_message.substring(0,120))+'</span>' : '') +
        '</div>' +
        (actions ? '<div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">'+actions+'</div>' : '') +
      '</div>';
    }).join('');
  } catch(e) {
    container.innerHTML = '<div style="padding:28px;text-align:center;color:#dc2626;font-size:13px">Gagal: '+e.message+'</div>';
  }
}

// ── TAB: SCHEDULED — notifikasi yang masih menunggu waktu kirim ──
async function loadPushScheduled() {
  const container = document.getElementById('pushScheduledList');
  container.innerHTML = '<div style="padding:28px;text-align:center;color:var(--d-muted);font-size:13px">Memuat...</div>';

  try {
    const d = await App.api('/push-notif/list?status=scheduled&limit=100');
    const list = d?.data || [];

    if (!list.length) {
      container.innerHTML =
        '<div style="padding:40px 20px;text-align:center;color:var(--d-muted);font-size:13px;background:#f8faff;border:1.5px dashed var(--d-border);border-radius:12px">' +
          '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="display:block;margin:0 auto 10px;opacity:.4"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
          'Tidak ada notifikasi terjadwal.<br>' +
          '<span style="font-size:11.5px">Buat jadwal dari tab <b>Kirim Notifikasi</b> &rarr; centang "Jadwalkan kirim nanti".</span>' +
        '</div>';
      return;
    }

    // Sort by scheduled_at ASC (yang paling dekat di atas)
    list.sort((a, b) => new Date(a.scheduled_at) - new Date(b.scheduled_at));

    const now = Date.now();
    container.innerHTML = list.map(n => {
      const schedTime = n.scheduled_at ? new Date(n.scheduled_at) : null;
      const ms = schedTime ? schedTime.getTime() - now : 0;
      const schedStr = schedTime ? schedTime.toLocaleString('id-ID', {
        weekday: 'short', day: '2-digit', month: 'short', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      }) : '—';

      // Countdown badge
      let countdown = '';
      let countdownColor = '#1e40af';
      let countdownBg = '#dbeafe';
      if (ms < 0) {
        countdown = 'Terlewat';
        countdownColor = '#991b1b';
        countdownBg = '#fee2e2';
      } else if (ms < 60*1000) {
        countdown = 'Sebentar lagi';
        countdownColor = '#854d0e';
        countdownBg = '#fef3c7';
      } else if (ms < 60*60*1000) {
        const mins = Math.round(ms / 60000);
        countdown = mins + ' menit lagi';
      } else if (ms < 24*60*60*1000) {
        const hrs = Math.round(ms / 3600000);
        countdown = hrs + ' jam lagi';
      } else {
        const days = Math.round(ms / 86400000);
        countdown = days + ' hari lagi';
      }

      return '<div class="push-hist-card" style="border-left:1px solid #e0e7f3">' +
        '<div class="push-hist-head">' +
          '<div style="font-size:22px">'+(n.icon||'🔔')+'</div>' +
          '<div class="push-hist-title">'+escapeHtmlSt(n.title)+'</div>' +
          '<span style="padding:3px 10px;border-radius:20px;font-size:10.5px;font-weight:800;background:'+countdownBg+';color:'+countdownColor+'">'+countdown+'</span>' +
        '</div>' +
        '<div class="push-hist-body">'+escapeHtmlSt(n.body)+'</div>' +
        '<div class="push-hist-meta">' +
          '<span style="font-weight:700;color:#1e40af">'+SVG_ICON.calendar+schedStr+'</span>' +
          '<span>'+SVG_ICON.target+'Target: <b>'+n.target_count+'</b></span>' +
        '</div>' +
        '<div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">' +
          '<button class="push-mini-btn" onclick="cancelPush('+n.id+')" style="background:#fef3c7;color:#854d0e;border-color:#fde68a">'+SVG_ICON.cancel+'Batalkan</button>' +
        '</div>' +
      '</div>';
    }).join('');
  } catch(e) {
    container.innerHTML = '<div style="padding:28px;text-align:center;color:#dc2626;font-size:13px">Gagal: '+e.message+'</div>';
  }
}

async function retryPush(id) {
  if (!confirm('Kirim ulang notifikasi ini ke target yang sama?')) return;
  const d = await App.api('/push-notif/'+id+'/retry', { method:'POST' });
  if (d?.success) { App.showToast(d.message || 'Berhasil', 'success'); loadPushHistory(); loadPushStats(); }
  else App.showToast(d?.message || 'Gagal', 'error');
}

async function cancelPush(id) {
  if (!confirm('Batalkan notifikasi yang dijadwalkan?')) return;
  const d = await App.api('/push-notif/'+id+'/cancel', { method:'POST' });
  if (d?.success) {
    App.showToast('Dibatalkan', 'success');
    loadPushScheduled();
    loadPushHistory();
    loadPushStats();
  } else App.showToast(d?.message || 'Gagal', 'error');
}

async function deletePush(id) {
  if (!confirm('Hapus log notifikasi ini secara permanen?')) return;
  const d = await App.api('/push-notif/'+id, { method:'DELETE' });
  if (d?.success) { App.showToast('Dihapus', 'success'); loadPushHistory(); }
  else App.showToast(d?.message || 'Gagal', 'error');
}

// Close modal on backdrop click
document.getElementById('annModal').addEventListener('click', function(e) {
  if (e.target === this) closeAnnModal();
});
</script>
</body></html>
