<script>
function showSection(id, el) {
  document.querySelectorAll('.st-section').forEach(s => s.classList.remove('show'));
  document.querySelectorAll('.st-nav-item').forEach(i => i.classList.remove('active'));
  document.getElementById('sec-' + id)?.classList.add('show');
  el.classList.add('active');

  // Lazy-load section data
  if (id === 'gateway' && typeof loadGatewaySettings === 'function') {
    loadGatewaySettings();
  }
}

function selectBrand(mode, el) {
  document.querySelectorAll('.brand-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('brandMode').value = mode;
  // Show/hide tagline + logo fields
  document.getElementById('taglineField').style.opacity = mode === 'name_tagline' ? '1' : '.4';
  document.getElementById('logoField').style.display    = mode === 'name_tagline' ? 'none' : 'block';
  updatePreview();
}



async function saveBrandSettings() {
  const data = {
    brand_mode:  document.getElementById('brandMode').value,
    app_name:    document.getElementById('appName')?.value,
    app_tagline: document.getElementById('appTagline')?.value,
    logo_url:    document.getElementById('logoUrl')?.value,
  };
  const d = await App.api('/app-settings', { method:'POST', body: JSON.stringify(data) });
  if (d?.success) { App.showToast('Pengaturan disimpan! Halaman akan direfresh...', 'success'); setTimeout(() => location.reload(), 1200); }
  else App.showToast(d?.message || 'Gagal menyimpan', 'error');
}

// ══════════════════════════════════════════════════════════════
// PPN / TAX SETTINGS handlers
// ══════════════════════════════════════════════════════════════
function _fmtRpId(n) {
  const v = Math.round(Number(n) || 0);
  return 'Rp ' + v.toLocaleString('id-ID');
}

function _computeTaxPreview(price, rate, mode) {
  const p = Math.max(0, parseFloat(price) || 0);
  const r = Math.max(0, parseFloat(rate) || 0);
  if (r <= 0) return { subtotal: p, tax: 0, total: p };
  if (mode === 'inclusive') {
    const total = p;
    const tax = Math.round(p * r / (100 + r));
    return { subtotal: total - tax, tax, total };
  }
  const subtotal = p;
  const tax = Math.round(p * r / 100);
  return { subtotal, tax, total: subtotal + tax };
}

function updateTaxPreview() {
  const enabled = document.getElementById('taxEnabled')?.checked;
  const rateEl  = document.getElementById('taxRate');
  const modeEl  = document.getElementById('taxMode');
  const labelEl = document.getElementById('taxLabel');
  const baseEl  = document.getElementById('taxPreviewBase');
  if (!rateEl || !modeEl || !baseEl) return;

  const rate  = enabled ? parseFloat(rateEl.value) || 0 : 0;
  const mode  = modeEl.value;
  const label = (labelEl?.value || 'PPN').trim() || 'PPN';
  const base  = parseFloat(baseEl.value) || 0;

  const calc = _computeTaxPreview(base, rate, mode);
  document.getElementById('taxPrevSubtotal').textContent = _fmtRpId(calc.subtotal);
  document.getElementById('taxPrevTax').textContent      = _fmtRpId(calc.tax);
  document.getElementById('taxPrevTotal').textContent    = _fmtRpId(calc.total);
  document.getElementById('taxPrevTaxLbl').textContent   = enabled && rate > 0
    ? (label + ' ' + (Number.isInteger(rate) ? rate : rate.toFixed(2)) + '%')
    : 'Tidak aktif';
}

function setTaxRate(v) {
  const el = document.getElementById('taxRate');
  if (!el) return;
  el.value = v;
  updateTaxPreview();
}

async function onTaxEnabledChange() {
  const cb = document.getElementById('taxEnabled');
  const lbl = document.getElementById('taxEnabledLbl');
  const body = document.getElementById('taxCardBody');
  if (!cb) return;

  // Update UI dulu biar responsif
  if (lbl)  lbl.textContent = cb.checked ? 'Aktif' : 'Nonaktif';
  if (body) body.classList.toggle('tax-disabled', !cb.checked);
  updateTaxPreview();

  // Skip auto-save saat init paint (DOMContentLoaded) — supaya tidak hit endpoint
  // ketika halaman pertama kali render. Kita pakai flag _taxInited yang di-set
  // setelah listener pertama kali siap.
  if (!window._taxInited) return;

  // Auto-save: kirim hanya tax_enabled ke server (rate/mode/label tidak diubah)
  const value = cb.checked ? '1' : '0';
  try {
    const d = await App.api('/app-settings', { method:'POST', body: JSON.stringify({ tax_enabled: value }) });
    if (d?.success) {
      App.showToast(cb.checked ? 'PPN diaktifkan' : 'PPN dinonaktifkan', 'success');
    } else {
      App.showToast(d?.message || 'Gagal menyimpan status PPN', 'error');
      // Rollback toggle ke state sebelumnya
      cb.checked = !cb.checked;
      if (lbl)  lbl.textContent = cb.checked ? 'Aktif' : 'Nonaktif';
      if (body) body.classList.toggle('tax-disabled', !cb.checked);
      updateTaxPreview();
    }
  } catch (err) {
    App.showToast('Gagal menyimpan status PPN: ' + (err?.message || 'network error'), 'error');
    cb.checked = !cb.checked;
    if (lbl)  lbl.textContent = cb.checked ? 'Aktif' : 'Nonaktif';
    if (body) body.classList.toggle('tax-disabled', !cb.checked);
    updateTaxPreview();
  }
}

async function saveTaxSettings() {
  const enabled = document.getElementById('taxEnabled')?.checked ? '1' : '0';
  const rateRaw = document.getElementById('taxRate')?.value;
  const rate    = parseFloat(rateRaw);
  if (rateRaw === '' || isNaN(rate) || rate < 0 || rate > 100) {
    App.showToast('Tarif PPN tidak valid (harus 0–100%)', 'error');
    return;
  }
  const mode  = document.getElementById('taxMode')?.value || 'exclusive';
  const label = (document.getElementById('taxLabel')?.value || 'PPN').trim() || 'PPN';
  const data = {
    tax_enabled: enabled,
    tax_rate:    String(rate),
    tax_mode:    mode,
    tax_label:   label
  };
  const d = await App.api('/app-settings', { method:'POST', body: JSON.stringify(data) });
  if (d?.success) {
    App.showToast('PPN tersimpan. Tagihan baru akan menggunakan tarif ini.', 'success');
  } else {
    App.showToast(d?.message || 'Gagal menyimpan PPN', 'error');
  }
}

// ══════════════════════════════════════════════════════════════
// RECALCULATE PPN — apply current setting ke invoice unpaid/overdue
// Dipakai ketika user mengubah tarif PPN atau menonaktifkan PPN dan
// ingin invoice yang masih outstanding ikut mengikuti setting baru.
// Invoice yang sudah 'paid' atau 'cancelled' TIDAK disentuh (audit safety).
// ══════════════════════════════════════════════════════════════
async function recalculateInvoiceTax() {
  const btn = document.getElementById('recalcTaxBtn');
  const enabled = document.getElementById('taxEnabled')?.checked;
  const rate    = document.getElementById('taxRate')?.value || '0';
  const label   = document.getElementById('taxLabel')?.value || 'PPN';

  // Konfirmasi pakai modal sederhana — pakai pola showBillConfirm kalau ada,
  // fallback ke window.confirm()
  const msg = enabled
    ? `Terapkan tarif <b>${label} ${rate}%</b> ke seluruh invoice yang masih unpaid/overdue?<br><br><span style="font-size:12px;color:#64748b;">Invoice yang sudah lunas tidak akan diubah. Pastikan tarif sudah disimpan dulu.</span>`
    : `Hapus PPN dari seluruh invoice yang masih unpaid/overdue?<br><br><span style="font-size:12px;color:#64748b;">Kolom tax akan di-set 0 dan total = subtotal. Invoice yang sudah lunas tidak akan diubah. Pastikan setting <b>Nonaktif</b> sudah disimpan dulu.</span>`;

  const proceed = (typeof showBillConfirm === 'function')
    ? new Promise(resolve => {
        showBillConfirm('Recalculate PPN', msg, '#0d9488', () => resolve(true));
        // Jika user batal, modal akan di-remove tapi promise tidak resolve.
        // Untuk kasus ini cukup — operasi tidak jalan sampai user klik confirm.
      })
    : Promise.resolve(window.confirm(msg.replace(/<[^>]+>/g, '')));

  const ok = await proceed;
  if (!ok) return;

  if (btn) {
    btn.disabled = true;
    btn.style.opacity = '.6';
    btn.style.cursor = 'wait';
    btn.dataset._origHtml = btn.innerHTML;
    btn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite;"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9"/></svg> Memproses…';
  }

  try {
    const d = await App.api('/billing/recalculate-tax', { method:'POST', body: JSON.stringify({}) });
    if (d?.success) {
      const upd = d.data?.updated || 0;
      const skp = d.data?.skipped || 0;
      App.showToast(`Recalculate selesai: ${upd} invoice di-update, ${skp} sudah sesuai`, 'success');
    } else {
      App.showToast(d?.message || 'Gagal recalculate PPN', 'error');
    }
  } catch (err) {
    App.showToast('Error: ' + (err?.message || 'network error'), 'error');
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor = 'pointer';
      if (btn.dataset._origHtml) {
        btn.innerHTML = btn.dataset._origHtml;
        delete btn.dataset._origHtml;
      }
    }
  }
}

// init preview state on first paint (jaga-jaga sebelum user interact)
document.addEventListener('DOMContentLoaded', () => {
  if (document.getElementById('taxRate')) {
    onTaxEnabledChange();
    // Mark sudah init — mulai sekarang setiap perubahan toggle akan auto-save.
    // Flag ini harus di-set SETELAH onTaxEnabledChange() pertama dipanggil supaya
    // render awal tidak men-trigger POST /app-settings yang tidak perlu.
    window._taxInited = true;
  }
});

