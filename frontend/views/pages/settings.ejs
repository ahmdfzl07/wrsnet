function escapeHtmlSt(s){ return String(s==null?'':s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }

async function loadPayAccounts() {
  const container = document.getElementById('payAcctList');
  try {
    const d = await App.api('/payment-accounts');
    const list = (d && d.data) || [];
    if (!list.length) {
      container.innerHTML = '<div style="padding:28px;text-align:center;color:var(--d-muted);font-size:13px">Belum ada metode pembayaran. Klik <b>Tambah</b> untuk menambahkan.</div>';
      window._PA_CACHE = [];
      return;
    }
    const typeLabels = { bank:'Bank', ewallet:'E-Wallet', qris:'QRIS' };
    const typeColors = { bank:'#2563eb', ewallet:'#8b5cf6', qris:'#f59e0b' };
    container.innerHTML = list.map(function(it, idx) {
      const active = it.is_active !== false;
      const label = (it.provider || '').toUpperCase();
      const badge = typeLabels[it.type] || it.type;
      const color = typeColors[it.type] || '#64748b';
      return '<div style="display:flex;align-items:center;gap:12px;padding:12px 14px;border:1px solid var(--d-border);border-radius:12px;margin-bottom:8px;background:#fff">' +
        '<div style="width:36px;height:36px;border-radius:9px;background:'+color+'22;color:'+color+';display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0">'+(it.type==='qris'?'QR':label.substring(0,3))+'</div>' +
        '<div style="flex:1;min-width:0">' +
          '<div style="font-size:13px;font-weight:700;color:var(--d-text);display:flex;align-items:center;gap:8px;flex-wrap:wrap">' +
            '<span>'+escapeHtmlSt(label||'—')+'</span>' +
            '<span style="padding:1px 7px;background:'+color+'15;color:'+color+';border-radius:20px;font-size:9.5px;font-weight:800;text-transform:uppercase;letter-spacing:.4px">'+badge+'</span>' +
            (active ? '' : '<span style="padding:1px 7px;background:#f1f5f9;color:#64748b;border-radius:20px;font-size:9.5px;font-weight:700">Nonaktif</span>') +
          '</div>' +
          '<div style="font-size:12px;color:var(--d-muted);margin-top:3px;font-family:\'DM Mono\',monospace">'+escapeHtmlSt(it.account_number||'—')+'</div>' +
          (it.account_owner ? '<div style="font-size:11px;color:var(--d-muted);margin-top:1px">a.n. '+escapeHtmlSt(it.account_owner)+'</div>' : '') +
        '</div>' +
        '<button onclick="editPayAcct('+idx+')" style="padding:7px 10px;border-radius:8px;background:#eff6ff;color:var(--d-blue1);border:1px solid #bfdbfe;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit">Edit</button>' +
        '<button onclick="deletePayAcct('+idx+')" style="padding:7px 10px;border-radius:8px;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit">Hapus</button>' +
      '</div>';
    }).join('');
    window._PA_CACHE = list;
  } catch(e) {
    container.innerHTML = '<div style="padding:24px;text-align:center;color:#dc2626;font-size:12px">Gagal memuat: '+e.message+'</div>';
  }
}

function openPayAcctModal(preset) {
  document.getElementById('payAcctModalTitle').textContent = preset ? 'Edit Metode Pembayaran' : 'Tambah Metode Pembayaran';
  document.getElementById('paId').value       = preset ? preset._idx : '';
  document.getElementById('paType').value     = preset ? (preset.type||'bank') : 'bank';
  onPaTypeChange();
  if (preset && preset.provider) {
    const providerSel = document.getElementById('paProvider');
    let found = false;
    for (let i = 0; i < providerSel.options.length; i++) {
      if (providerSel.options[i].value === preset.provider) { found = true; break; }
    }
    if (!found && preset.type !== 'qris') {
      const opt = document.createElement('option');
      opt.value = preset.provider; opt.textContent = preset.provider.toUpperCase();
      providerSel.appendChild(opt);
    }
    providerSel.value = preset.provider;
  }
  document.getElementById('paNumber').value   = preset ? (preset.account_number||'') : '';
  document.getElementById('paOwner').value    = preset ? (preset.account_owner||'') : '';
  document.getElementById('paActive').checked = preset ? (preset.is_active !== false) : true;

  // Logo: show preview if preset has logo_url
  const logoUrl = preset ? (preset.logo_url||'') : '';
  document.getElementById('paLogoUrl').value = logoUrl;
  if (logoUrl) {
    document.getElementById('paLogoPreviewImg').src = logoUrl;
    document.getElementById('paLogoFileName').textContent = logoUrl.split('/').pop();
    document.getElementById('paLogoPreview').style.display = 'block';
    document.getElementById('paLogoDropText').style.display = 'none';
  } else {
    clearPayLogoPreview();
  }
  document.getElementById('paLogoFile').value = ''; // reset file input

  document.getElementById('payAcctModal').style.display = 'flex';
}

function clearPayLogoPreview() {
  document.getElementById('paLogoPreview').style.display = 'none';
  document.getElementById('paLogoDropText').style.display = 'block';
  document.getElementById('paLogoPreviewImg').src = '';
  document.getElementById('paLogoFileName').textContent = '—';
}

function clearPayLogo(e) {
  if (e) { e.stopPropagation(); e.preventDefault(); }
  document.getElementById('paLogoUrl').value = '';
  document.getElementById('paLogoFile').value = '';
  clearPayLogoPreview();
}

async function handlePayLogoFile(file) {
  if (!file) return;

  // Validasi client-side
  const allowed = ['image/png','image/jpeg','image/svg+xml','image/webp'];
  if (!allowed.includes(file.type)) {
    App.showToast('Format tidak didukung. Gunakan PNG/JPG/SVG/WebP', 'error');
    document.getElementById('paLogoFile').value = '';
    return;
  }
  if (file.size > 2 * 1024 * 1024) {
    App.showToast('File terlalu besar (max 2MB)', 'error');
    document.getElementById('paLogoFile').value = '';
    return;
  }

  // Tampilkan preview segera (pakai FileReader) supaya responsive
  const reader = new FileReader();
  reader.onload = (e) => {
    document.getElementById('paLogoPreviewImg').src = e.target.result;
    document.getElementById('paLogoFileName').textContent = file.name + ' · uploading...';
    document.getElementById('paLogoPreview').style.display = 'block';
    document.getElementById('paLogoDropText').style.display = 'none';
  };
  reader.readAsDataURL(file);

  // Upload ke server
  try {
    const fd = new FormData();
    fd.append('logo', file);

    // Auth pakai App.token (konsisten dengan App.api pattern)
    const authHeaders = {};
    if (App && App.token && App.token !== 'null') {
      authHeaders['Authorization'] = 'Bearer ' + App.token;
    }

    const res = await fetch('/api/upload/payment-logo', {
      method: 'POST',
      headers: authHeaders,
      credentials: 'include',
      body: fd
    });
    const data = await res.json();

    if (data.success && data.url) {
      document.getElementById('paLogoUrl').value = data.url;
      document.getElementById('paLogoFileName').textContent = file.name;
      App.showToast('Logo terupload', 'success');
    } else {
      App.showToast(data.message || 'Gagal upload', 'error');
      clearPayLogo();
    }
  } catch (err) {
    App.showToast('Gagal upload: ' + err.message, 'error');
    clearPayLogo();
  }
}
function closePayAcctModal(){ document.getElementById('payAcctModal').style.display = 'none'; }

function onPaTypeChange() {
  const type = document.getElementById('paType').value;
  const providerSel   = document.getElementById('paProvider');
  const providerWrap  = document.getElementById('paProviderWrap');
  const providerLabel = document.getElementById('paProviderLabel');
  const numberWrap    = document.getElementById('paNumberWrap');
  const numberLabel   = document.getElementById('paNumberLabel');
  const logoLabel     = document.getElementById('paLogoLabel');
  const logoHint      = document.getElementById('paLogoHint');

  if (type === 'bank') {
    providerWrap.style.display = '';
    providerLabel.textContent  = 'Bank';
    providerSel.innerHTML = PA_BANK_OPTIONS.map(o => '<option value="'+o.v+'">'+o.l+'</option>').join('');
    numberWrap.style.display  = '';
    numberLabel.textContent   = 'Nomor Rekening';
    logoLabel.textContent     = 'Logo Bank (Opsional)';
    logoHint.innerHTML        = 'Opsional. Kalau kosong, akan tampil singkatan nama bank (mis. "BCA").';
  } else if (type === 'ewallet') {
    providerWrap.style.display = '';
    providerLabel.textContent  = 'E-Wallet';
    providerSel.innerHTML = PA_EWALLET_OPTIONS.map(o => '<option value="'+o.v+'">'+o.l+'</option>').join('');
    numberWrap.style.display  = '';
    numberLabel.textContent   = 'Nomor HP / ID E-Wallet';
    logoLabel.textContent     = 'Logo E-Wallet (Opsional)';
    logoHint.innerHTML        = 'Opsional. Kalau kosong, akan tampil nama e-wallet (mis. "DANA").';
  } else if (type === 'qris') {
    providerWrap.style.display = 'none';
    numberWrap.style.display  = 'none';
    logoLabel.textContent     = 'Gambar QR Code *';
    logoHint.innerHTML        = '<b>Wajib diisi.</b> Upload file gambar QR statis Anda (PNG/JPG).';
  }
}

function editPayAcct(idx) {
  const list = window._PA_CACHE || [];
  const item = list[idx];
  if (!item) return;
  item._idx = idx;
  openPayAcctModal(item);
}

async function deletePayAcct(idx) {
  if (!confirm('Hapus metode pembayaran ini?')) return;
  const list = (window._PA_CACHE || []).slice();
  list.splice(idx, 1);
  const d = await App.api('/payment-accounts', { method:'PUT', body: JSON.stringify({ accounts: list }) });
  if (d?.success) { App.showToast('Dihapus', 'success'); loadPayAccounts(); }
  else App.showToast(d?.message || 'Gagal menghapus', 'error');
}

async function savePayAcct() {
  const type     = document.getElementById('paType').value;
  const provider = type === 'qris' ? 'qris' : document.getElementById('paProvider').value;
  const number   = document.getElementById('paNumber').value.trim();
  const owner    = document.getElementById('paOwner').value.trim();
  const logoUrl  = document.getElementById('paLogoUrl').value.trim();
  const active   = document.getElementById('paActive').checked;
  const editIdx  = document.getElementById('paId').value;

  if (type !== 'qris' && !number) return App.showToast('Nomor rekening wajib diisi', 'error');
  if (type !== 'qris' && !owner)  return App.showToast('Atas nama wajib diisi', 'error');
  if (type === 'qris' && !logoUrl) return App.showToast('URL gambar QR wajib diisi', 'error');

  const entry = {
    type: type,
    provider: provider,
    account_number: number,
    account_owner: owner,
    logo_url: logoUrl,
    is_active: active
  };

  const list = (window._PA_CACHE || []).slice();
  if (editIdx !== '' && editIdx !== undefined && editIdx !== null) {
    list[parseInt(editIdx)] = entry;
  } else {
    list.push(entry);
  }

  const d = await App.api('/payment-accounts', { method:'PUT', body: JSON.stringify({ accounts: list }) });
  if (d?.success) {
    App.showToast('Tersimpan', 'success');
    closePayAcctModal();
    loadPayAccounts();
  } else {
    App.showToast(d?.message || 'Gagal menyimpan', 'error');
  }
}

// Logo file handling
let _logoFile = null;

function handleLogoFile(file) {
  if (!file) return;
  _logoFile = file;
  // Show preview thumb
  const reader = new FileReader();
  reader.onload = (e) => {
    document.getElementById('logoThumbImg').src = e.target.result;
