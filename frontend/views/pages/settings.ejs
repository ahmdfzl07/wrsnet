];
var PA_EWALLET_OPTIONS = [
  { v:'dana',      l:'DANA' },
  { v:'ovo',       l:'OVO' },
  { v:'gopay',     l:'GoPay' },
  { v:'shopeepay', l:'ShopeePay' },
