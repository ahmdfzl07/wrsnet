async function loadPushTemplates() {
  const container = document.getElementById('pushTemplateList');
  container.innerHTML = '<div style="padding:28px;text-align:center;color:var(--d-muted);font-size:13px">Memuat...</div>';
  try {
    const d = await App.api('/push-notif/templates');
    const list = d?.data || [];
    if (!list.length) {
      container.innerHTML = '<div style="padding:28px;text-align:center;color:var(--d-muted);font-size:13px">Belum ada template. Klik <b>Tambah Template</b>.</div>';
      return;
    }
    window._PUSH_TPL_CACHE = list;
    container.innerHTML = list.map((t, idx) => {
      const meta = _CAT_META[t.category] || _CAT_META.other;
      return '<div class="push-tpl-card">' +
        '<div class="push-tpl-icon" style="background:'+meta.color+'22;color:'+meta.color+'">'+(t.icon || meta.icon)+'</div>' +
        '<div class="push-tpl-info">' +
          '<div class="push-tpl-name">' +
            '<span>'+escapeHtmlSt(t.name)+'</span>' +
            '<span class="push-tpl-badge" style="background:'+meta.color+'22;color:'+meta.color+'">'+meta.label+'</span>' +
          '</div>' +
          '<div class="push-tpl-title">'+escapeHtmlSt(t.title)+'</div>' +
          '<div class="push-tpl-body">'+escapeHtmlSt(t.body)+'</div>' +
        '</div>' +
        '<div style="display:flex;flex-direction:column;gap:5px">' +
          '<button class="push-mini-btn" onclick="useTemplateFromList('+idx+')" style="background:#dcfce7;color:#166534;border-color:#bbf7d0">Pakai</button>' +
          '<button class="push-mini-btn" onclick="editTemplateFromList('+idx+')">Edit</button>' +
          '<button class="push-mini-btn" onclick="deleteTemplateFromList('+idx+')" style="background:#fee2e2;color:#991b1b;border-color:#fecaca">Hapus</button>' +
        '</div>' +
      '</div>';
    }).join('');
  } catch(e) {
    container.innerHTML = '<div style="padding:28px;text-align:center;color:#dc2626;font-size:13px">Gagal: '+e.message+'</div>';
  }
}

function useTemplateFromList(idx) {
  const tpl = (window._PUSH_TPL_CACHE || [])[idx];
  if (!tpl) return;
  applyTemplate(tpl);
  // Pindah ke tab Kirim
  const tabs = document.querySelectorAll('.push-tab');
  if (tabs[0]) tabs[0].click();
}

function editTemplateFromList(idx) {
  const tpl = (window._PUSH_TPL_CACHE || [])[idx];
  if (!tpl) return;
  openTemplateModal(tpl);
}

async function deleteTemplateFromList(idx) {
  const tpl = (window._PUSH_TPL_CACHE || [])[idx];
  if (!tpl) return;
  if (!confirm('Hapus template "'+tpl.name+'"?')) return;
  const d = await App.api('/push-notif/templates/'+tpl.id, { method:'DELETE' });
  if (d?.success) { App.showToast('Dihapus', 'success'); loadPushTemplates(); }
  else App.showToast(d?.message || 'Gagal', 'error');
}

function openTemplateModal(tpl) {
  document.getElementById('pushTplModalTitle').textContent = tpl ? 'Edit Template' : 'Tambah Template';
  document.getElementById('tplId').value       = tpl ? tpl.id : '';
  document.getElementById('tplName').value     = tpl ? (tpl.name||'') : '';
  document.getElementById('tplCategory').value = tpl ? (tpl.category||'info') : 'info';
  document.getElementById('tplIcon').value     = tpl ? (tpl.icon||'') : '';
  document.getElementById('tplTitle').value    = tpl ? (tpl.title||'') : '';
  document.getElementById('tplBody').value     = tpl ? (tpl.body||'') : '';
  document.getElementById('tplUrl').value      = tpl ? (tpl.url||'') : '';
  document.getElementById('pushTplModal').style.display = 'flex';
}
function closeTemplateModal() { document.getElementById('pushTplModal').style.display = 'none'; }

async function saveTemplate() {
  const id = document.getElementById('tplId').value;
  const payload = {
    name:     document.getElementById('tplName').value.trim(),
    category: document.getElementById('tplCategory').value,
    icon:     document.getElementById('tplIcon').value.trim(),
    title:    document.getElementById('tplTitle').value.trim(),
    body:     document.getElementById('tplBody').value.trim(),
    url:      document.getElementById('tplUrl').value.trim()
  };
  if (!payload.name || !payload.title || !payload.body) {
    return App.showToast('Nama, judul, isi wajib diisi', 'error');
  }
  const url = id ? '/push-notif/templates/'+id : '/push-notif/templates';
  const method = id ? 'PUT' : 'POST';
  const d = await App.api(url, { method, body: JSON.stringify(payload) });
  if (d?.success) {
    App.showToast('Tersimpan', 'success');
    closeTemplateModal();
    loadPushTemplates();
  } else {
    App.showToast(d?.message || 'Gagal', 'error');
  }
}

