function _renderPortalHeroPreview() {
  const box = document.getElementById('portalHeroPreview');
  if (!box) return;
  if (_portalHeroUrl) {
    const ov = parseFloat(document.getElementById('portalHeroOverlay')?.value || '0.55');
    box.style.border = 'none';
    box.innerHTML =
      '<img src="' + _portalHeroUrl + '" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">' +
      '<div style="position:absolute;inset:0;background:linear-gradient(155deg,rgba(11,30,79,' + Math.min(1, ov+0.3).toFixed(2) + ') 0%,rgba(30,64,175,' + ov.toFixed(2) + ') 45%,rgba(37,99,235,' + Math.max(0, ov-0.15).toFixed(2) + ') 100%);"></div>' +
      '<div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;text-align:center;padding:10px;">' +
        '<div style="font-size:20px;font-weight:900;letter-spacing:-.3px;text-shadow:0 2px 8px rgba(0,0,0,.3);">Customer Portal</div>' +
        '<div style="font-size:11px;font-weight:500;opacity:.85;margin-top:4px;">Akses layanan internet Anda</div>' +
      '</div>';
  } else {
    box.style.border = '1.5px dashed var(--d-border)';
    box.innerHTML =
      '<div style="text-align:center;color:var(--d-muted);font-size:12.5px;padding:20px">' +
        '<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="opacity:.4;margin-bottom:6px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>' +
        '<div>Belum ada foto hero</div>' +
        '<div style="font-size:11px;margin-top:4px;opacity:.7;">Portal login akan pakai gradient biru default</div>' +
      '</div>';
  }
}

async function loadPortalHeroSettings() {
  try {
    const d = await App.api('/app-settings');
    if (!d?.success) return;
    const s = d.data || {};
    _portalHeroUrl = s.portal_hero_image || '';
    const overlayEl = document.getElementById('portalHeroOverlay');
    if (overlayEl) {
      overlayEl.value = s.portal_hero_overlay || '0.55';
      document.getElementById('portalHeroOverlayVal').textContent = overlayEl.value;
      overlayEl.addEventListener('input', _renderPortalHeroPreview);
    }
    const tEl = document.getElementById('portalWelcomeTitle');
    const sEl = document.getElementById('portalWelcomeSub');
    if (tEl) tEl.value = s.portal_welcome_title || '';
    if (sEl) sEl.value = s.portal_welcome_sub || '';
    _renderPortalHeroPreview();
  } catch(e) { console.error('loadPortalHeroSettings:', e); }
}

async function onPortalHeroPicked(ev) {
  const file = ev.target?.files?.[0];
  if (!file) return;
  if (file.size > 4 * 1024 * 1024) {
    App.showToast('Ukuran file max 4MB', 'error');
    ev.target.value = '';
    return;
  }
  const fd = new FormData();
  fd.append('hero', file);
  App.showToast('Mengupload...', 'info');
  try {
    const token = (window.App && App.token) || localStorage.getItem('token') || '';
    const r = await fetch('/api/upload/portal-hero', {
      method: 'POST',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {},
      body: fd
    });
    const j = await r.json();
    if (!j.success) {
      App.showToast(j.message || 'Upload gagal', 'error');
      return;
    }
    _portalHeroUrl = j.url;
    _renderPortalHeroPreview();
    App.showToast('Foto hero berhasil diupload', 'success');
  } catch(e) {
    App.showToast('Upload error: ' + e.message, 'error');
  } finally {
    ev.target.value = '';
  }
}

async function deletePortalHero() {
  if (!_portalHeroUrl) { App.showToast('Tidak ada foto untuk dihapus', 'info'); return; }
  if (!confirm('Hapus foto hero portal? Portal login akan kembali pakai gradient biru default.')) return;
  try {
    const token = (window.App && App.token) || localStorage.getItem('token') || '';
    const r = await fetch('/api/upload/portal-hero', {
      method: 'DELETE',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {}
    });
    const j = await r.json();
    if (j?.success) {
      _portalHeroUrl = '';
      _renderPortalHeroPreview();
      App.showToast('Foto hero dihapus', 'success');
    } else App.showToast(j?.message || 'Gagal', 'error');
  } catch(e) { App.showToast('Error: ' + e.message, 'error'); }
}

async function savePortalHeroSettings() {
  const data = {
    portal_hero_overlay:  document.getElementById('portalHeroOverlay')?.value || '0.55',
