// ══════════════════════════════════════════════════════════════
// PAYMENT GATEWAY — Midtrans / Xendit / Duitku configuration
// ══════════════════════════════════════════════════════════════
var GW_CURRENT_PROVIDER = 'midtrans';

function selectGwProvider(provider) {
  GW_CURRENT_PROVIDER = provider;

  // Toggle radio + selected card class untuk semua provider
  ['midtrans','xendit','duitku'].forEach(function(p){
    var capName = p.charAt(0).toUpperCase() + p.slice(1);
    var radio = document.getElementById('gwProvRadio' + capName);
    var card  = document.getElementById('gwProvCard-' + p);
    if (radio) radio.checked = (provider === p);
    if (card)  card.classList.toggle('selected', provider === p);
  });

  // Toggle field visibility per-provider
  document.getElementById('gwClientKeyWrap').style.display      = (provider === 'midtrans') ? '' : 'none';
  document.getElementById('gwCallbackTokenWrap').style.display  = (provider === 'xendit')   ? '' : 'none';
  var mcWrap = document.getElementById('gwMerchantCodeWrap');
  if (mcWrap) mcWrap.style.display = (provider === 'duitku') ? '' : 'none';

  // Toggle setup guide per-provider
  document.getElementById('setupGuideMidtrans').style.display   = (provider === 'midtrans') ? '' : 'none';
  document.getElementById('setupGuideXendit').style.display     = (provider === 'xendit')   ? '' : 'none';
  var dukGuide = document.getElementById('setupGuideDuitku');
  if (dukGuide) dukGuide.style.display = (provider === 'duitku') ? '' : 'none';

  // Update key label, hint, & placeholder per-provider
  if (provider === 'midtrans') {
    document.getElementById('gwKeyLabel').textContent = 'Server Key';
    document.getElementById('gwKeyHint').innerHTML = 'Ambil dari dashboard Midtrans → Settings → Access Keys';
    document.getElementById('gwServerKey').placeholder = 'SB-Mid-server-XXXXXXXXX (sandbox) atau Mid-server-XXXX (prod)';
  } else if (provider === 'xendit') {
    document.getElementById('gwKeyLabel').textContent = 'Secret API Key';
    document.getElementById('gwKeyHint').innerHTML = 'Ambil dari dashboard Xendit → Settings → Developers → API Keys (perlu permission Money-in)';
    document.getElementById('gwServerKey').placeholder = 'xnd_development_XXXXXXXXX atau xnd_production_XXXXXXXXX';
  } else if (provider === 'duitku') {
    document.getElementById('gwKeyLabel').textContent = 'API Key';
    document.getElementById('gwKeyHint').innerHTML = 'Ambil dari dashboard Duitku → Project → Project Setting → API Key (32 karakter hex)';
    document.getElementById('gwServerKey').placeholder = 'XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX (32 char hex)';
  }

  updateWebhookUrl();
}

function updateWebhookUrl() {
  var base = window.location.origin;
  var url  = base + '/portal/webhook/' + GW_CURRENT_PROVIDER;
  document.getElementById('webhookUrlText').textContent = url;
}

function copyWebhookUrl() {
  var url = document.getElementById('webhookUrlText').textContent;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(function(){
      App.showToast('Webhook URL disalin', 'success');
    });
  } else {
    var ta = document.createElement('textarea');
    ta.value = url; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
    App.showToast('Webhook URL disalin', 'success');
  }
}

function updateGwBadge(enabled, env) {
  var b = document.getElementById('gwStatusBadge');
  if (!b) return;
  if (!enabled) {
    b.style.background = '#f1f5f9'; b.style.color = '#64748b';
    b.textContent = 'NONAKTIF';
  } else if (env === 'production') {
    b.style.background = '#d1fae5'; b.style.color = '#047857';
    b.textContent = 'AKTIF · LIVE';
  } else {
    b.style.background = '#fef3c7'; b.style.color = '#b45309';
    b.textContent = 'AKTIF · SANDBOX';
  }
}

async function loadGatewaySettings() {
  try {
    const d = await App.api('/app-settings');
    if (!d?.success) return;
    const s = d.data || {};

    document.getElementById('gwEnabled').checked       = (s.payment_gateway_enabled === 'true' || s.payment_gateway_enabled === '1');
    document.getElementById('gwEnv').value             = s.payment_gateway_env || 'sandbox';
    document.getElementById('gwServerKey').value       = s.payment_gateway_server_key || '';
    document.getElementById('gwClientKey').value       = s.payment_gateway_client_key || '';
    document.getElementById('gwCallbackToken').value   = s.payment_gateway_callback_token || '';
    var mc = document.getElementById('gwMerchantCode');
    if (mc) mc.value = s.payment_gateway_merchant_code || '';

    selectGwProvider(s.payment_gateway_provider || 'midtrans');
    updateGwBadge(
      document.getElementById('gwEnabled').checked,
      s.payment_gateway_env || 'sandbox'
    );
  } catch (e) {
    console.error('loadGatewaySettings error:', e);
  }
}

async function saveGatewaySettings() {
  const enabled  = document.getElementById('gwEnabled').checked;
  const provider = GW_CURRENT_PROVIDER;
  const env      = document.getElementById('gwEnv').value;
  const srvKey   = (document.getElementById('gwServerKey').value || '').trim();
  const cliKey   = (document.getElementById('gwClientKey').value || '').trim();
  const cbToken  = (document.getElementById('gwCallbackToken').value || '').trim();
  const mcEl     = document.getElementById('gwMerchantCode');
  const merchant = mcEl ? (mcEl.value || '').trim() : '';

  // Validasi minimal kalau gateway diaktifkan
  if (enabled) {
    if (!srvKey) {
      var keyLabel = (provider === 'midtrans') ? 'Server Key'
                   : (provider === 'duitku')   ? 'API Key'
                   : 'Secret API Key';
      App.showToast(keyLabel + ' wajib diisi', 'error');
      return;
    }
    if (provider === 'midtrans' && !cliKey) {
      App.showToast('Client Key wajib diisi untuk Midtrans', 'error');
      return;
    }
    if (provider === 'xendit' && !cbToken) {
      App.showToast('Callback Token wajib diisi untuk Xendit (untuk verifikasi webhook)', 'error');
      return;
    }
    if (provider === 'duitku' && !merchant) {
      App.showToast('Merchant Code wajib diisi untuk Duitku', 'error');
      return;
    }
    if (provider === 'duitku' && !/^[A-Z0-9]{3,15}$/i.test(merchant)) {
      App.showToast('Merchant Code Duitku harus alfanumerik 3-15 karakter (contoh: DXXXXX)', 'error');
      return;
    }
  }

  const data = {
    payment_gateway_enabled:        enabled ? 'true' : 'false',
    payment_gateway_provider:       provider,
    payment_gateway_env:            env,
    payment_gateway_server_key:     srvKey,
    payment_gateway_client_key:     cliKey,
    payment_gateway_callback_token: cbToken,
    payment_gateway_merchant_code:  merchant,
  };

  const d = await App.api('/app-settings', { method:'POST', body: JSON.stringify(data) });
  if (d?.success) {
    App.showToast('Pengaturan payment gateway disimpan', 'success');
    updateGwBadge(enabled, env);
  } else {
    App.showToast(d?.message || 'Gagal menyimpan', 'error');
  }
}

async function testGatewayConfig() {
  const enabled = document.getElementById('gwEnabled').checked;
  const srvKey  = (document.getElementById('gwServerKey').value || '').trim();

  if (!enabled) {
    App.showToast('Aktifkan dulu payment gateway, lalu simpan, baru test', 'error');
    return;
  }
  if (!srvKey) {
    App.showToast('Isi Server Key dulu, lalu klik Simpan sebelum test', 'error');
    return;
  }

  // Panggil endpoint test (validasi format + auth ke server provider)
  App.showToast('Sedang verifikasi…', 'info');
  try {
    const d = await App.api('/app-settings/payment-gateway/test', { method: 'POST' });
    _showGatewayTestResult(d);
  } catch (e) {
    App.showToast('Gagal panggil endpoint test: ' + e.message, 'error');
  }
}

function _showGatewayTestResult(d) {
  // Buat modal sederhana untuk tampilkan hasil check
  let modal = document.getElementById('gwTestResultModal');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'gwTestResultModal';
    modal.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1100;align-items:center;justify-content:center;padding:20px;';
    modal.innerHTML = '<div style="background:#fff;border-radius:16px;max-width:520px;width:100%;max-height:85vh;overflow-y:auto;">' +
      '<div style="padding:18px 22px;border-bottom:1px solid var(--d-border);display:flex;align-items:center;justify-content:space-between;">' +
        '<div id="gwTestTitle" style="font-size:15px;font-weight:700;color:var(--d-text);">Hasil Test Konfigurasi</div>' +
        '<button onclick="document.getElementById(\'gwTestResultModal\').style.display=\'none\'" style="background:none;border:none;cursor:pointer;color:var(--d-muted);padding:4px;">' +
          '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
        '</button>' +
      '</div>' +
      '<div id="gwTestBody" style="padding:18px 22px;"></div>' +
    '</div>';
    document.body.appendChild(modal);
  }

  const success = !!d?.success;
  const data = d?.data || {};
  const checks = data.checks || [];

  const headerColor = success ? '#16a34a' : '#dc2626';
  const statusIcon = success
    ? '<svg width="32" height="32" fill="none" stroke="#16a34a" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
    : '<svg width="32" height="32" fill="none" stroke="#dc2626" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>';

  let html = '<div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;padding:14px;background:' + (success ? '#f0fdf4' : '#fef2f2') + ';border-radius:10px;">' +
    statusIcon +
    '<div><div style="font-weight:700;color:' + headerColor + ';font-size:14px;">' + (d?.message || (success ? 'OK' : 'Ada masalah')) + '</div>' +
    '<div style="font-size:11.5px;color:var(--d-muted);margin-top:2px;">Provider: <b>' + (data.provider || '-') + '</b> · Env: <b>' + (data.env || '-') + '</b></div></div></div>';

  if (checks.length) {
    html += '<div style="font-size:12px;font-weight:700;color:var(--d-muted);margin-bottom:8px;letter-spacing:.5px;text-transform:uppercase;">Detail Pemeriksaan</div>';
    checks.forEach(c => {
      const ico = c.pass
        ? '<svg width="16" height="16" fill="none" stroke="#16a34a" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>'
        : '<svg width="16" height="16" fill="none" stroke="#dc2626" stroke-width="3" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
      html += '<div style="display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:8px;margin-bottom:6px;background:' + (c.pass ? '#f0fdf4' : '#fef2f2') + ';">' +
        '<div style="flex-shrink:0;margin-top:1px;">' + ico + '</div>' +
        '<div style="flex:1;min-width:0;"><div style="font-size:13px;font-weight:600;color:var(--d-text);">' + _esc(c.label) + '</div>' +
        '<div style="font-size:11.5px;color:var(--d-muted);margin-top:2px;word-break:break-all;">' + _esc(c.detail || '') + '</div></div>' +
      '</div>';
    });
  }

  if (!success) {
    html += '<div style="margin-top:14px;padding:12px 14px;background:#fffbeb;border:1px solid #fde68a;border-radius:10px;font-size:12px;color:#78350f;line-height:1.6;">' +
      '<b>Tips:</b><br>' +
      '• Cek key di dashboard provider, copy ulang tanpa spasi<br>' +
      '• Pastikan environment (Sandbox/Production) cocok dengan prefix key<br>' +
      '• Jangan lupa klik <b>Simpan Pengaturan</b> dulu sebelum test' +
    '</div>';
  }

  document.getElementById('gwTestBody').innerHTML = html;
  document.getElementById('gwTestTitle').textContent = success ? '✓ Konfigurasi OK' : '⚠ Ada Masalah';
  modal.style.display = 'flex';
}

function _esc(s) {
  return String(s == null ? '' : s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

