  if (file) handleLogoFile(file);
}

async function uploadLogo() {
  if (!_logoFile) return;
  const btn = document.getElementById('btnUploadLogo');
  btn.textContent = 'Uploading...'; btn.disabled = true;
  const form = new FormData();
  form.append('logo', _logoFile);
  try {
    const token = document.cookie.match(/token=([^;]+)/)?.[1] || localStorage.getItem('token') || '';
    const res = await fetch('/api/upload/logo', {
      method: 'POST',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {},
      body: form
    });
    const d = await res.json();
    if (d.success) {
      // d.url sudah include cache-bust (?v=timestamp) dari server.
      document.getElementById('logoUrl').value = d.url;
      // Refresh thumbnail di settings dengan URL final (bukan dataURL preview).
      document.getElementById('logoThumbImg').src = d.url;
      // Refresh logo di sidebar tanpa reload page penuh.
      document.querySelectorAll('#sidebarBrand img').forEach(img => { img.src = d.url; });

      App.showToast('Logo berhasil diupload!', 'success');
      updatePreview();
      btn.textContent = '✓ Uploaded';
      btn.style.background = 'linear-gradient(135deg,#00c896,#00a07a)';
      // Reset state setelah 1.5 dtk supaya bisa upload ulang
      setTimeout(() => {
        btn.textContent = 'Upload Logo';
        btn.style.background = '';
        btn.disabled = false;
        _logoFile = null;
      }, 1500);
    } else {
      App.showToast(d.message || 'Upload gagal', 'error');
      btn.textContent = 'Upload'; btn.disabled = false;
    }
  } catch(err) {
    App.showToast('Error: ' + err.message, 'error');
    btn.textContent = 'Upload'; btn.disabled = false;
  }
}

// ── Favicon Handlers ──────────────────────────────────────────────
let _faviconFile = null;

function handleFaviconFile(file) {
  if (!file) return;
  // Validasi ukuran
  if (file.size > 1024 * 1024) {
    App.showToast('Ukuran favicon maksimal 1MB', 'error');
    return;
  }
  // Validasi format
  const allowed = ['image/x-icon', 'image/vnd.microsoft.icon', 'image/png', 'image/svg+xml', 'image/jpeg', 'image/jpg'];
  const allowedExt = ['.ico', '.png', '.svg', '.jpg', '.jpeg'];
  const ext = '.' + (file.name.split('.').pop() || '').toLowerCase();
  if (!allowed.includes(file.type) && !allowedExt.includes(ext)) {
    App.showToast('Format tidak didukung. Gunakan ICO/PNG/SVG/JPG', 'error');
    return;
  }
  _faviconFile = file;
  // Preview thumbnail
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('faviconThumbImg').src = e.target.result;
    document.getElementById('faviconPreviewThumb').style.display = 'block';
    document.getElementById('faviconDropText').style.display = 'none';
    document.getElementById('btnUploadFavicon').style.display = 'inline-block';
    document.getElementById('btnUploadFavicon').textContent = 'Upload Favicon';
    document.getElementById('btnUploadFavicon').disabled = false;
  };
  reader.readAsDataURL(file);
}

function handleFaviconDrop(e) {
  e.preventDefault();
  e.currentTarget.style.borderColor = '';
  const file = e.dataTransfer.files[0];
  if (file) handleFaviconFile(file);
}

async function uploadFavicon() {
  if (!_faviconFile) return;
  const btn = document.getElementById('btnUploadFavicon');
  btn.textContent = 'Uploading...'; btn.disabled = true;
  const form = new FormData();
  form.append('favicon', _faviconFile);
  try {
    const token = document.cookie.match(/token=([^;]+)/)?.[1] || localStorage.getItem('token') || '';
    const res = await fetch('/api/upload/favicon', {
      method: 'POST',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {},
      body: form
    });
    const d = await res.json();
    if (d.success) {
      App.showToast(d.message || 'Favicon berhasil diupload!', 'success');

      // Refresh thumbnail di settings dengan URL final (bukan dataURL preview).
      document.getElementById('faviconThumbImg').src = d.url;
      document.getElementById('faviconPreviewThumb').style.display = 'block';
      document.getElementById('faviconDropText').style.display = 'none';
      document.getElementById('btnResetFavicon').style.display = 'inline-block';

      btn.textContent = '✓ Uploaded';
      btn.style.background = 'linear-gradient(135deg,#00c896,#00a07a)';

      // Force browser reload favicon di tab.
      // Hapus semua <link rel*="icon"> lama dulu, baru inject yang baru.
      // Pakai URL favicon langsung (d.url sudah include ?v=cache-bust),
      // BUKAN /favicon.ico karena route /favicon.ico di-cache 1 jam oleh server.
      document.querySelectorAll("link[rel*='icon']").forEach(el => el.remove());
      const link = document.createElement('link');
      link.rel  = 'icon';
      link.href = d.url;
      // Set type berdasarkan ekstensi
      const ext = (d.url.split('?')[0].split('.').pop() || '').toLowerCase();
      const mimeMap = { ico:'image/x-icon', png:'image/png', svg:'image/svg+xml', jpg:'image/jpeg', jpeg:'image/jpeg' };
      if (mimeMap[ext]) link.type = mimeMap[ext];
      document.head.appendChild(link);

      // Reset state setelah 1.5 dtk supaya bisa upload ulang
      setTimeout(() => {
        btn.textContent = 'Upload Favicon';
        btn.style.background = '';
        btn.disabled = false;
        _faviconFile = null;
      }, 1500);
    } else {
      App.showToast(d.message || 'Upload gagal', 'error');
      btn.textContent = 'Upload Favicon'; btn.disabled = false;
    }
  } catch(err) {
    App.showToast('Error: ' + err.message, 'error');
    btn.textContent = 'Upload Favicon'; btn.disabled = false;
  }
}

async function resetFavicon() {
  if (!confirm('Reset favicon ke default? File yang sudah diupload akan dihapus.')) return;
  try {
    const token = document.cookie.match(/token=([^;]+)/)?.[1] || localStorage.getItem('token') || '';
    const res = await fetch('/api/upload/favicon', {
      method: 'DELETE',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {}
    });
    const d = await res.json();
    if (d.success) {
      App.showToast(d.message || 'Favicon dikembalikan ke default', 'success');
      // Reset UI
      document.getElementById('faviconPreviewThumb').style.display = 'none';
      document.getElementById('faviconDropText').style.display = 'block';
      document.getElementById('btnResetFavicon').style.display = 'none';
      document.getElementById('btnUploadFavicon').style.display = 'none';
      _faviconFile = null;
      // Force browser reload favicon
      setTimeout(() => location.reload(), 800);
    } else {
      App.showToast(d.message || 'Gagal reset', 'error');
    }
  } catch(err) {
    App.showToast('Error: ' + err.message, 'error');
  }
}

function imgError(el) { el.style.display='none'; var n=el.nextSibling; if(n) n.style.display='block'; }

function updatePreview(dataUrl) {
  const mode    = document.getElementById('brandMode').value;
  const name    = document.getElementById('appName')?.value || 'DIGSnet';
  const tagline = document.getElementById('appTagline')?.value || '';
  const logo    = dataUrl || document.getElementById('logoUrl')?.value || '';
  const prev    = document.getElementById('brandPreview');

  // Sinkronkan 3 kartu Mode Tampilan supaya ikut nama/tagline yang sedang diketik
  updateBrandOptionsPreview(name, tagline);

  if (!prev) return;

  if (mode === 'logo_only' && logo) {
    prev.innerHTML = '<img src="' + logo + '" alt="logo" style="height:36px;object-fit:contain;" onerror="imgError(this)"><span style="display:none;font-size:12px;color:#dc2626;">&#10060; Logo tidak terbaca</span>';
  } else if (mode === 'name_logo' && logo) {
    prev.innerHTML = '<img src="' + logo + '" alt="logo" style="height:30px;object-fit:contain;flex-shrink:0;" onerror="imgError(this)"> <span style="font-size:14px;font-weight:800;color:#0d1b3e;">' + name + '</span>';
  } else {
    prev.innerHTML = '<div style="width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#1a6ef5,#0047cc);display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg></div>' +
      '<div style="display:flex;flex-direction:column;line-height:1.2;">' +
        '<span style="font-size:15px;font-weight:800;color:#0d1b3e;">' + name + '</span>' +
        (mode === 'name_tagline' && tagline ? '<span style="font-size:9.5px;color:#94a3b8;">' + tagline + '</span>' : '') +
      '</div>';
  }
}

// Refresh teks di 3 kartu Mode Tampilan (Nama+Tagline / Logo+Nama / Logo Only)
// Dipanggil dari updatePreview() saat user mengetik di field nama atau tagline.
function updateBrandOptionsPreview(name, tagline) {
  const n = (name || '').trim() || 'DIGSnet';
  const t = (tagline || '').trim() || 'ISP Management';
  const n1 = document.getElementById('bopt1Name');
  const t1 = document.getElementById('bopt1Tag');
  const n2 = document.getElementById('bopt2Name');
  if (n1) n1.textContent = n;
  if (t1) t1.textContent = t;
  if (n2) n2.textContent = n;
}
// Init
document.addEventListener('DOMContentLoaded', () => {
  const mode = document.getElementById('brandMode')?.value || 'name_tagline';
  document.getElementById('taglineField').style.opacity = mode === 'name_tagline' ? '1' : '.4';
  document.getElementById('logoField').style.display    = mode === 'name_tagline' ? 'none' : 'block';
  // Show existing logo thumb if URL exists
  const existingLogo = document.getElementById('logoUrl')?.value;
  if (existingLogo) {
    const thumb = document.getElementById('logoThumbImg');
    const wrap  = document.getElementById('logoPreviewThumb');
    const text  = document.getElementById('logoDropText');
    if (thumb) { thumb.src = existingLogo; wrap.style.display = 'block'; text.style.display = 'none'; }
  }
  updatePreview();
});
</script>

<!-- ═══ MODAL: Announcement ═══ -->
<div id="annModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;display:none;align-items:center;justify-content:center;padding:20px">
  <div style="background:#fff;border-radius:20px;padding:28px;width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <div style="font-size:16px;font-weight:800;color:#0d1b3e" id="annModalTitle">Tambah Pengumuman</div>
      <button onclick="closeAnnModal()" style="background:none;border:none;font-size:18px;cursor:pointer;color:#6b7fa8;padding:4px">✕</button>
    </div>
    <div style="margin-bottom:14px">
      <label class="pf-label">Jenis</label>
      <select class="pf-select" id="annType">
        <option value="gangguan">⚠️ Gangguan Jaringan</option>
        <option value="maintenance">🔧 Maintenance</option>
        <option value="info" selected>ℹ️ Informasi</option>
        <option value="promo">🎁 Promo</option>
      </select>
    </div>
    <div style="margin-bottom:14px">
      <label class="pf-label">Judul *</label>
      <input type="text" class="pf-input" id="annTitle" placeholder="Contoh: Gangguan Jaringan Area Depok" maxlength="200">
    </div>
    <div style="margin-bottom:14px">
      <label class="pf-label">Isi / Detail (opsional)</label>
      <textarea class="pf-input" id="annContent" rows="3" style="resize:vertical" placeholder="Penjelasan lebih lengkap..."></textarea>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
      <div>
        <label class="pf-label">Tampil Mulai (kosongkan = sekarang)</label>
        <input type="datetime-local" class="pf-input" id="annFrom">
      </div>
      <div>
        <label class="pf-label">Tampil Sampai (kosongkan = selamanya)</label>
        <input type="datetime-local" class="pf-input" id="annUntil">
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px">
      <input type="checkbox" id="annActive" checked style="width:16px;height:16px;accent-color:#1a6ef5">
      <label for="annActive" style="font-size:13px;font-weight:600;color:#0d1b3e;cursor:pointer">Aktif (tampil di portal pelanggan)</label>
    </div>
    <div style="display:flex;gap:10px">
      <button onclick="saveAnn()" id="btnSaveAnn" style="flex:1;padding:11px;border:none;border-radius:10px;background:linear-gradient(135deg,#1a6ef5,#0047cc);color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit">Simpan</button>
      <button onclick="closeAnnModal()" style="padding:11px 18px;border:1.5px solid #e0e7f3;border-radius:10px;background:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;color:#6b7fa8">Batal</button>
    </div>
  </div>
</div>

<script>
// ── Announcement CRUD ──────────────────────────────────────────
var _annEditId = null;
var _typeColors = { gangguan:'#fee2e2', maintenance:'#fef3c7', info:'#eff6ff', promo:'#f0fdf4' };
var _typeBorder = { gangguan:'#fca5a5', maintenance:'#fde68a', info:'#bfdbfe', promo:'#86efac' };
var _typeLabel  = { gangguan:'⚠️ Gangguan', maintenance:'🔧 Maintenance', info:'ℹ️ Info', promo:'🎁 Promo' };

async function loadAnnList() {
  try {
    var r = await fetch('/api/announcements', { headers: { 'Content-Type': 'application/json' } });
    var j = await r.json();
    var el = document.getElementById('annList');
    if (!j.data || !j.data.length) {
      el.innerHTML = '<div style="padding:32px;text-align:center;color:#6b7fa8;font-size:13px">Belum ada pengumuman</div>';
      return;
    }
    var html = '<table style="width:100%;border-collapse:collapse">' +
      '<thead><tr style="background:#f8faff;font-size:11px;font-weight:700;color:#6b7fa8;text-transform:uppercase">' +
      '<th style="padding:10px 16px;text-align:left">Judul</th>' +
      '<th style="padding:10px 8px;text-align:center">Jenis</th>' +
      '<th style="padding:10px 8px;text-align:center">Status</th>' +
      '<th style="padding:10px 8px;text-align:center">Sampai</th>' +
      '<th style="padding:10px 12px;text-align:right">Aksi</th>' +
      '</tr></thead><tbody>';
    j.data.forEach(function(a) {
      var now = new Date();
      var expired = a.show_until && new Date(a.show_until) < now;
      var statusBg = a.is_active && !expired ? '#dcfce7' : '#f1f5f9';
      var statusColor = a.is_active && !expired ? '#16a34a' : '#6b7fa8';
      var statusText = expired ? 'Expired' : (a.is_active ? 'Aktif' : 'Nonaktif');
      var untilText = a.show_until ? new Date(a.show_until).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}) : '—';
      html += '<tr style="border-top:1px solid #f0f4ff">' +
        '<td style="padding:11px 16px;font-size:13px;font-weight:600;color:#0d1b3e;max-width:200px">' +
          '<div style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + escHtml(a.title) + '</div>' +
          (a.content ? '<div style="font-size:11px;color:#6b7fa8;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + escHtml(a.content.substring(0,60)) + '</div>' : '') +
        '</td>' +
        '<td style="padding:11px 8px;text-align:center"><span style="font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;background:' + (_typeColors[a.type]||'#f1f5f9') + ';border:1px solid ' + (_typeBorder[a.type]||'#e2e8f0') + '">' + (_typeLabel[a.type]||a.type) + '</span></td>' +
        '<td style="padding:11px 8px;text-align:center">' +
          '<button onclick="toggleAnn(' + a.id + ')" style="font-size:10px;font-weight:700;padding:3px 10px;border-radius:20px;border:none;cursor:pointer;background:' + statusBg + ';color:' + statusColor + '">' + statusText + '</button>' +
        '</td>' +
        '<td style="padding:11px 8px;text-align:center;font-size:11px;color:#6b7fa8">' + untilText + '</td>' +
        '<td style="padding:11px 12px;text-align:right;white-space:nowrap">' +
          '<button onclick="editAnn(' + JSON.stringify(a).replace(/"/g,'&quot;') + ')" style="padding:5px 10px;border-radius:8px;border:1.5px solid #e0e7f3;background:#fff;font-size:11px;font-weight:700;cursor:pointer;margin-right:4px;color:#1a6ef5">Edit</button>' +
          '<button onclick="deleteAnn(' + a.id + ')" style="padding:5px 10px;border-radius:8px;border:1.5px solid #fca5a5;background:#fff;font-size:11px;font-weight:700;cursor:pointer;color:#dc2626">Hapus</button>' +
        '</td>' +
        '</tr>';
    });
    html += '</tbody></table>';
    el.innerHTML = html;
  } catch(e) { document.getElementById('annList').innerHTML = '<div style="padding:24px;text-align:center;color:#dc2626;font-size:13px">Gagal memuat</div>'; }
}

function escHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function openAnnModal(data) {
  _annEditId = null;
  document.getElementById('annModalTitle').textContent = 'Tambah Pengumuman';
  document.getElementById('annType').value = 'info';
  document.getElementById('annTitle').value = '';
  document.getElementById('annContent').value = '';
  document.getElementById('annFrom').value = '';
  document.getElementById('annUntil').value = '';
  document.getElementById('annActive').checked = true;
  document.getElementById('annModal').style.display = 'flex';
}

function editAnn(a) {
  _annEditId = a.id;
  document.getElementById('annModalTitle').textContent = 'Edit Pengumuman';
  document.getElementById('annType').value = a.type || 'info';
  document.getElementById('annTitle').value = a.title || '';
  document.getElementById('annContent').value = a.content || '';
  document.getElementById('annFrom').value = a.show_from ? a.show_from.substring(0,16) : '';
  document.getElementById('annUntil').value = a.show_until ? a.show_until.substring(0,16) : '';
  document.getElementById('annActive').checked = !!a.is_active;
  document.getElementById('annModal').style.display = 'flex';
}

function closeAnnModal() { document.getElementById('annModal').style.display = 'none'; }

async function saveAnn() {
  var title = document.getElementById('annTitle').value.trim();
  if (!title) { alert('Judul wajib diisi'); return; }
  var btn = document.getElementById('btnSaveAnn');
  btn.disabled = true; btn.textContent = 'Menyimpan...';
  try {
    var body = {
      title, type: document.getElementById('annType').value,
      content: document.getElementById('annContent').value.trim() || null,
      show_from: document.getElementById('annFrom').value || null,
      show_until: document.getElementById('annUntil').value || null,
      is_active: document.getElementById('annActive').checked
    };
    var url = _annEditId ? '/api/announcements/' + _annEditId : '/api/announcements';
    var method = _annEditId ? 'PUT' : 'POST';
    var r = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    var j = await r.json();
    if (j.success) { closeAnnModal(); loadAnnList(); } else { alert(j.message || 'Gagal'); }
  } catch(e) { alert('Error: ' + e.message); }
  finally { btn.disabled = false; btn.textContent = 'Simpan'; }
}

async function toggleAnn(id) {
  try {
    var r = await fetch('/api/announcements/' + id + '/toggle', { method: 'PATCH', headers: {'Content-Type':'application/json'} });
    var j = await r.json();
    if (j.success) loadAnnList();
  } catch(e) {}
}

async function deleteAnn(id) {
  if (!confirm('Hapus pengumuman ini?')) return;
  try {
    await fetch('/api/announcements/' + id, { method: 'DELETE', headers: {'Content-Type':'application/json'} });
    loadAnnList();
  } catch(e) {}
}

// Load saat section announcement / payment / push dibuka
var _origShowSection = showSection;
showSection = function(id, el) {
  _origShowSection(id, el);
  if (id === 'announcements') loadAnnList();
  if (id === 'payment' && !window._PA_LOADED) {
    window._PA_LOADED = true;
    loadPayAccounts();
  }
  if (id === 'push' && !window._PUSH_LOADED) {
    window._PUSH_LOADED = true;
    initPushNotifSection();
  }
};

// ══════════════════════════════════════════════════════════════
// PUSH NOTIFICATION — Kirim, Template, Riwayat
// ══════════════════════════════════════════════════════════════
var _PUSH_PICKED = new Map();   // id → { id, name, customer_id, phone }
var _CAT_META = {
  promo:      { icon:'🎉', color:'#f59e0b', label:'PROMO' },
  info:       { icon:'ℹ️', color:'#3b82f6', label:'INFO' },
  maintenance:{ icon:'🔧', color:'#64748b', label:'MAINTENANCE' },
  warning:    { icon:'⚠️', color:'#ef4444', label:'WARNING' },
  greeting:   { icon:'🙏', color:'#8b5cf6', label:'GREETING' },
  other:      { icon:'📌', color:'#475569', label:'LAINNYA' }
};

async function initPushNotifSection() {
  loadPushStats();
  loadPackageOptions();
  updatePushPreview();
  updateManualPickCount(); // tampilkan hint initial
  // Default tab: Kirim — sudah active
}

async function loadPushStats() {
  try {
    const d = await App.api('/push-notif/stats');
    if (!d?.success) return;
    const s = d.data;
    document.getElementById('pushStatSubs').textContent  = s.total_subscribers;
    document.getElementById('pushStatToday').textContent = s.total_today;
    document.getElementById('pushStatMonth').textContent = s.total_month;
    document.getElementById('pushStatSched').textContent = s.total_scheduled;

    // Badge di tab Schedule
    const tabBadge = document.getElementById('pushSchedBadge');
    if (tabBadge) {
      if (s.total_scheduled > 0) {
        tabBadge.style.display = 'inline-flex';
        tabBadge.innerHTML = '<span style="padding:1px 7px;background:#dbeafe;color:#1e40af;border-radius:10px;font-size:10px;font-weight:800;margin-left:2px">' + s.total_scheduled + '</span>';
      } else {
        tabBadge.style.display = 'none';
      }
    }

    // Badge status VAPID
    const badge = document.getElementById('pushReadyBadge');
    if (!s.push_ready) {
      badge.style.display = 'block';
      badge.innerHTML = '<span style="padding:4px 10px;background:#fee2e2;color:#991b1b;border-radius:20px;font-size:10.5px;font-weight:700;display:inline-flex;align-items:center;gap:5px">' +
        '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>' +
        'VAPID belum dikonfigurasi</span>';
    } else {
      badge.style.display = 'block';
      badge.innerHTML = '<span style="padding:4px 10px;background:#dcfce7;color:#166534;border-radius:20px;font-size:10.5px;font-weight:700;display:inline-flex;align-items:center;gap:5px">' +
        '<span style="width:7px;height:7px;border-radius:50%;background:#10b981;animation:pushPulse 1.5s infinite"></span>' +
        'Aktif</span>';
    }
  } catch(e) { console.error('loadPushStats:', e); }
}

async function loadPackageOptions() {
  try {
    const d = await App.api('/packages');
    const list = d?.data || d?.packages || (Array.isArray(d) ? d : []);
    const container = document.getElementById('pushFilterPackages');
    if (!list.length) {
      container.innerHTML = '<div style="color:var(--d-muted);font-size:12px;padding:4px">Belum ada paket.</div>';
      return;
    }
    container.innerHTML = list.map(p =>
      '<label style="display:flex;align-items:center;gap:8px;padding:6px 6px;cursor:pointer;border-radius:6px" onmouseover="this.style.background=\'#f8faff\'" onmouseout="this.style.background=\'\'">' +
        '<input type="checkbox" class="push-fpkg" value="'+p.id+'" style="width:14px;height:14px;cursor:pointer;margin:0">' +
        '<span style="font-size:12.5px;color:var(--d-text);font-weight:600;flex:1">'+escapeHtmlSt(p.name||'?')+'</span>' +
        '<span style="font-size:11px;color:var(--d-muted);font-family:\'DM Mono\',monospace">'+(p.speed_down||0)+'Mbps</span>' +
      '</label>'
    ).join('');
  } catch(e) {
    document.getElementById('pushFilterPackages').innerHTML = '<div style="color:#dc2626;font-size:12px;padding:4px">Gagal memuat paket: '+e.message+'</div>';
  }
}

function switchPushTab(tab, el) {
  document.querySelectorAll('.push-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.push-tab-content').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('push-tab-'+tab).classList.add('active');
  if (tab === 'scheduled')     loadPushScheduled();
  else if (tab === 'template') loadPushTemplates();
  else if (tab === 'history')  loadPushHistory();
}

function collectPushFilters() {
  const packages = Array.from(document.querySelectorAll('.push-fpkg:checked')).map(i => parseInt(i.value));
  const bill_status = Array.from(document.querySelectorAll('.push-fbill:checked')).map(i => i.value);
  const customer_status = Array.from(document.querySelectorAll('.push-fcust:checked')).map(i => i.value);
  const isolir_checked = document.querySelectorAll('.push-fisol:checked');
  const isolir_status = Array.from(isolir_checked).map(i => i.value);
  const area = document.getElementById('pushFilterArea').value.trim();

  const filters = {};
  if (packages.length)        filters.packages = packages;
  if (bill_status.length)     filters.bill_status = bill_status;
  if (customer_status.length) filters.customer_status = customer_status;
  if (isolir_status.length)   filters.isolir_status = isolir_status;
  if (area)                   filters.area = area;
  if (_PUSH_PICKED.size)      filters.customer_ids = Array.from(_PUSH_PICKED.keys());

  return filters;
}

async function calcPushTargets() {
  const filters = collectPushFilters();
  const el = document.getElementById('pushPreviewText');
  el.innerHTML = '<span style="color:var(--d-muted)">Menghitung...</span>';
  try {
    const d = await App.api('/push-notif/preview-targets', {
      method: 'POST', body: JSON.stringify({ filters })
    });
    if (!d?.success) { el.innerHTML = '<span style="color:#dc2626">Gagal: '+(d?.message||'error')+'</span>'; return; }
    const s = d.data;
    el.innerHTML =
      '<div style="font-size:18px;font-weight:800;color:var(--d-blue1);margin-bottom:2px">' + s.total_subscribed + ' pelanggan</div>' +
      '<div style="font-size:11.5px;color:var(--d-muted)">' +
        'Match filter: <b>' + s.total_matched + '</b> · ' +
        'Subscribe push: <b>' + s.total_subscribed + '</b>' +
        (s.total_unsubscribed > 0 ? ' · <span style="color:#b45309">Belum subscribe: '+s.total_unsubscribed+'</span>' : '') +
      '</div>';
  } catch(e) {
    el.innerHTML = '<span style="color:#dc2626">Error: '+e.message+'</span>';
  }
}

let _custSearchTimer = null;
window._PUSH_CUST_CACHE = {}; // id → customer data (cache hasil search)

function debouncedCustSearch() {
  clearTimeout(_custSearchTimer);
  _custSearchTimer = setTimeout(loadCustomerPicker, 300);
}

async function loadCustomerPicker() {
  const search = document.getElementById('pushCustSearch').value.trim();
  const container = document.getElementById('pushCustList');
  if (!search) {
    container.style.display = 'none';
    container.innerHTML = '';
    return;
  }
  container.style.display = 'block';
  container.innerHTML = '<div style="padding:10px;color:var(--d-muted);text-align:center">Mencari...</div>';
  try {
    const d = await App.api('/push-notif/customers?search='+encodeURIComponent(search)+'&limit=30');
    const list = d?.data || [];
    if (!list.length) {
      container.innerHTML = '<div style="padding:10px;color:var(--d-muted);text-align:center">Tidak ada pelanggan yang cocok.</div>';
      return;
    }

    // Cache data tiap customer supaya bisa diambil by ID saat diklik
    list.forEach(c => {
      window._PUSH_CUST_CACHE[c.id] = {
        id: c.id,
        name: c.name || '',
        customer_id: c.customer_id || '',
        phone: c.phone || ''
      };
    });

    container.innerHTML = list.map(c => {
      const picked = _PUSH_PICKED.has(c.id);
      // Pakai data-id attribute saja — tidak ada JSON di inline onclick
      return '<div class="push-cust-row'+(picked?' picked':'')+'" data-cust-id="'+c.id+'">' +
        '<input type="checkbox" '+(picked?'checked':'')+' tabindex="-1" style="pointer-events:none">' +
        '<span class="push-cust-sub'+(c.subscribed?'':' off')+'" title="'+(c.subscribed?'Subscribe aktif':'Belum subscribe push')+'"></span>' +
        '<span class="push-cust-name">'+escapeHtmlSt(c.name||'—')+'</span>' +
        '<span class="push-cust-meta">'+escapeHtmlSt(c.customer_id||'')+(c.phone?' · '+escapeHtmlSt(c.phone):'')+'</span>' +
      '</div>';
    }).join('');

    // Pasang event delegation SEKALI saja (idempotent)
    _attachCustPickerListener();
  } catch(e) {
    container.innerHTML = '<div style="padding:10px;color:#dc2626;text-align:center">Error: '+e.message+'</div>';
  }
}

// Attach event listener ke container (event delegation, idempotent)
function _attachCustPickerListener() {
  const container = document.getElementById('pushCustList');
  if (!container || container._pushListenerAttached) return;
  container._pushListenerAttached = true;
  container.addEventListener('click', function(e) {
    const row = e.target.closest('.push-cust-row[data-cust-id]');
    if (!row) return;
    e.preventDefault();
    e.stopPropagation();
    const id = parseInt(row.getAttribute('data-cust-id'));
    if (!id) return;
    togglePickCustomer(id);
  });
}

function togglePickCustomer(id) {
  if (_PUSH_PICKED.has(id)) {
    _PUSH_PICKED.delete(id);
  } else {
    const data = window._PUSH_CUST_CACHE[id] || { id, name: 'ID '+id };
    _PUSH_PICKED.set(id, data);
  }
  // Update visual state semua row yang visible
  document.querySelectorAll('#pushCustList .push-cust-row').forEach(r => {
    const rowId = parseInt(r.getAttribute('data-cust-id'));
    const isChecked = _PUSH_PICKED.has(rowId);
    const cb = r.querySelector('input[type=checkbox]');
    if (cb) cb.checked = isChecked;
    r.classList.toggle('picked', isChecked);
  });
  renderPickedChips();
  updateManualPickCount();
}

function renderPickedChips() {
  const wrap = document.getElementById('pushPickedChips');
  if (!_PUSH_PICKED.size) {
    wrap.style.display = 'none';
    wrap.innerHTML = '';
    return;
  }
  wrap.style.display = 'flex';
  const chips = [];
  for (const [id, data] of _PUSH_PICKED) {
    const name = escapeHtmlSt(data.name || ('ID '+id));
    const meta = data.customer_id ? ' · ' + escapeHtmlSt(data.customer_id) : '';
    chips.push(
      '<div style="display:inline-flex;align-items:center;gap:6px;padding:5px 4px 5px 10px;background:#fff;border:1px solid #bfdbfe;border-radius:20px;font-size:11.5px;font-weight:600;color:var(--d-text)">' +
        '<span style="display:inline-flex;align-items:center;gap:4px"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'+name+'<span style="color:var(--d-muted);font-weight:400">'+meta+'</span></span>' +
        '<button type="button" data-remove-id="'+id+'" style="width:18px;height:18px;border-radius:50%;background:#ef4444;color:#fff;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;line-height:1;padding:0" title="Hapus dari daftar">×</button>' +
      '</div>'
    );
  }
  wrap.innerHTML = chips.join('');
  // Pasang listener chip remove (event delegation, idempotent)
  if (!wrap._pushChipListenerAttached) {
    wrap._pushChipListenerAttached = true;
    wrap.addEventListener('click', function(e) {
      const btn = e.target.closest('[data-remove-id]');
      if (!btn) return;
      e.preventDefault();
      const id = parseInt(btn.getAttribute('data-remove-id'));
      if (id) removePickedCustomer(id);
    });
  }
}

function removePickedCustomer(id) {
  _PUSH_PICKED.delete(id);
  renderPickedChips();
  updateManualPickCount();
  // Kalau search result masih tampil, sync visual state row-nya
  document.querySelectorAll('#pushCustList .push-cust-row').forEach(r => {
    const rowId = parseInt(r.getAttribute('data-cust-id'));
    if (rowId === id) {
      const cb = r.querySelector('input[type=checkbox]');
      if (cb) cb.checked = false;
      r.classList.remove('picked');
    }
  });
}

function updateManualPickCount() {
  const el = document.getElementById('pushManualCount');
  if (_PUSH_PICKED.size) {
    el.innerHTML = '<b style="color:var(--d-blue1)">' + _PUSH_PICKED.size + ' pelanggan</b> dipilih manual (override filter di atas)';
  } else {
    el.innerHTML = 'Ketik nama/ID/telepon lalu klik pada pelanggan untuk menambahkan ke daftar.';
  }
}

function clearManualPick() {
  _PUSH_PICKED.clear();
  document.getElementById('pushCustSearch').value = '';
  document.getElementById('pushCustList').innerHTML = '';
  document.getElementById('pushCustList').style.display = 'none';
  renderPickedChips();
  updateManualPickCount();
}

function pickEmoji(e) {
  document.getElementById('pushIcon').value = e;
  updatePushPreview();
}

function updatePushPreview() {
  const icon  = document.getElementById('pushIcon').value || '🔔';
  const title = document.getElementById('pushTitle').value || '(judul notifikasi)';
  const body  = document.getElementById('pushBody').value  || '(isi pesan)';
  document.querySelector('#pushPreview .pp-icon').textContent = icon;
  document.getElementById('ppTitle').textContent = title;
  document.getElementById('ppBody').textContent  = body;
  document.getElementById('pushTitleCount').textContent = document.getElementById('pushTitle').value.length;
  document.getElementById('pushBodyCount').textContent  = document.getElementById('pushBody').value.length;
}

function toggleSchedule() {
  const on = document.getElementById('pushScheduleToggle').checked;
  document.getElementById('pushScheduleWrap').style.display = on ? 'block' : 'none';
  document.getElementById('btnSendPushLabel').textContent = on ? 'Jadwalkan' : 'Kirim Sekarang';
  if (on) {
    // default +5 menit (aman dari edge case: user butuh waktu isi form, gap cron 1 menit)
    const d = new Date(Date.now() + 5*60*1000);
    const pad = n => String(n).padStart(2,'0');
    const v = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()) + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    document.getElementById('pushScheduledAt').value = v;
  }
}

async function sendPushNotif() {
  const title = document.getElementById('pushTitle').value.trim();
  const body  = document.getElementById('pushBody').value.trim();
  if (!title || !body) return App.showToast('Judul dan isi pesan wajib diisi', 'error');

  const payload = {
    title,
    body,
    icon: document.getElementById('pushIcon').value.trim() || null,
    url: document.getElementById('pushUrl').value.trim() || '/portal',
    filters: collectPushFilters()
  };

  const scheduleOn = document.getElementById('pushScheduleToggle').checked;
  if (scheduleOn) {
    const sched = document.getElementById('pushScheduledAt').value;
    if (!sched) return App.showToast('Pilih tanggal & jam jadwal', 'error');

    // Validasi client: minimal 2 menit dari sekarang
    // (buffer untuk: request latency + cron granularity 1 menit + clock skew)
    const schedMs = new Date(sched).getTime();
    const nowMs = Date.now();
    const minScheduleMs = nowMs + 2 * 60 * 1000;
    if (schedMs < minScheduleMs) {
      const minTime = new Date(minScheduleMs);
      const hh = String(minTime.getHours()).padStart(2,'0');
      const mm = String(minTime.getMinutes()).padStart(2,'0');
      return App.showToast('Jadwal terlalu dekat. Minimal 2 menit dari sekarang (paling cepat jam ' + hh + ':' + mm + ')', 'error');
    }

    payload.scheduled_at = new Date(sched).toISOString();
  }

  const btn = document.getElementById('btnSendPush');
  btn.disabled = true;
  const lbl = document.getElementById('btnSendPushLabel');
  const origLabel = lbl.textContent;
  lbl.textContent = scheduleOn ? 'Menjadwalkan...' : 'Mengirim...';

  try {
    const d = await App.api('/push-notif/send', { method:'POST', body: JSON.stringify(payload) });
    if (d?.success) {
      App.showToast(d.message || 'Berhasil', 'success');
      resetPushForm();
      loadPushStats();
      // Refresh tab terkait
      if (d.mode === 'scheduled') loadPushScheduled();
      else if (d.mode === 'sent') loadPushHistory();
    } else {
      App.showToast(d?.message || 'Gagal', 'error');
    }
  } catch(e) {
    App.showToast('Error: '+e.message, 'error');
  } finally {
    btn.disabled = false;
    lbl.textContent = origLabel;
  }
}

function resetPushForm() {
  document.getElementById('pushTitle').value = '';
  document.getElementById('pushBody').value  = '';
  document.getElementById('pushIcon').value  = '';
  document.getElementById('pushUrl').value   = '/portal';
  document.getElementById('pushFilterArea').value = '';
  document.getElementById('pushScheduleToggle').checked = false;
  toggleSchedule();
  document.querySelectorAll('.push-fpkg, .push-fbill, .push-fcust, .push-fisol').forEach(i => i.checked = false);
  clearManualPick();
  updatePushPreview();
  document.getElementById('pushPreviewText').innerHTML = 'Klik <b>Hitung Target</b> untuk melihat jumlah pelanggan.';
}

// ── Template picker (dari tab Kirim) ──
async function openTemplatePicker() {
  try {
    const d = await App.api('/push-notif/templates');
    const list = d?.data || [];
    if (!list.length) {
      return App.showToast('Belum ada template. Buat dulu di tab Template.', 'error');
    }
    // Simple picker pakai prompt list
    const choice = prompt('Pilih template (ketik nomor):\n\n' +
      list.map((t,i) => (i+1)+'. '+(t.icon||'')+' '+t.name+' — '+t.title.substring(0,40)).join('\n'));
    if (!choice) return;
    const idx = parseInt(choice) - 1;
    const tpl = list[idx];
    if (!tpl) return App.showToast('Nomor tidak valid', 'error');
    applyTemplate(tpl);
  } catch(e) { App.showToast('Error: '+e.message, 'error'); }
}

function applyTemplate(tpl) {
  document.getElementById('pushIcon').value  = tpl.icon || '';
  document.getElementById('pushTitle').value = tpl.title || '';
  document.getElementById('pushBody').value  = tpl.body || '';
  if (tpl.url) document.getElementById('pushUrl').value = tpl.url;
  updatePushPreview();
  App.showToast('Template "'+tpl.name+'" dipakai', 'success');
}

