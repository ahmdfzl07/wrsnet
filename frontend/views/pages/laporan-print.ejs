<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title : 'Laporan Keuangan' %> - <%= appName %></title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;color:#1a1a2e;background:#f0f4f8;font-size:13px;line-height:1.5}

@page{size:A4;margin:14mm 16mm 14mm 16mm}
@media print{
  body{background:#fff!important;print-color-adjust:exact;-webkit-print-color-adjust:exact}
  .no-print{display:none!important}
  .page-break{page-break-before:always}
  .avoid-break{page-break-inside:avoid}
  .page-wrap{padding:0!important;max-width:100%!important}
  .doc{box-shadow:none!important;border:none!important;border-radius:0!important}
  .keu-tbl tfoot tr:nth-child(2) td{background:#f0fdf4!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .keu-tbl tfoot tr:nth-child(3) td{background:#1e3a8a!important;color:#fff!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .keu-tbl tfoot tr:nth-child(3) td *{color:#fff!important;}
  table{border-collapse:collapse!important}
  .keu-tbl{width:100%!important;font-size:11px!important}
  .keu-tbl thead tr{background:#1a1a2e!important;-webkit-print-color-adjust:exact;print-color-adjust:exact;}
  .keu-tbl thead th{color:rgba(255,255,255,.85)!important}
}

/* ── Toolbar ── */
.toolbar{background:#0d1b3e;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.toolbar-title{color:#fff;font-size:14px;font-weight:700;display:flex;align-items:center;gap:10px}
.toolbar-btns{display:flex;gap:8px}
.btn{padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;text-decoration:none;transition:opacity .15s}
.btn:hover{opacity:.85}
.btn-primary{background:#1a6ef5;color:#fff}
.btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2)}

/* ── Wrap ── */
.page-wrap{max-width:860px;margin:24px auto;padding:0 20px 40px}

/* ── Doc ── */
.doc{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 40px rgba(0,0,0,.12)}

/* ────────────── HEADER ────────────── */
.doc-header{background:linear-gradient(90deg,#1a3ef0 0%,#1a6ef5 40%,#2e9bfc 75%,#5ab8ff 100%);padding:30px 36px 24px;color:#fff;position:relative;overflow:hidden}
/* orbs removed */

.hd-top{display:flex;align-items:flex-start;justify-content:space-between;position:relative;z-index:1;margin-bottom:22px}
.hd-left{}
.hd-logo-wrap{width:52px;height:52px;border-radius:14px;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;overflow:hidden;margin-bottom:12px;border:1.5px solid rgba(255,255,255,.2)}
.hd-logo-wrap img{width:100%;height:100%;object-fit:contain}
.hd-logo-wrap svg{width:28px;height:28px;stroke:white;fill:none}
.hd-company{font-size:24px;font-weight:800;letter-spacing:-.03em;line-height:1}
.hd-tagline{font-size:12px;color:rgba(255,255,255,.55);margin-top:3px;font-weight:400}

.hd-right{text-align:right}
.hd-badge{display:inline-block;padding:4px 12px;border-radius:20px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:8px}
.hd-period-type{font-size:20px;font-weight:800;color:#fff;line-height:1;margin-bottom:4px}
.hd-period-name{font-size:14px;font-weight:600;color:rgba(255,255,255,.8)}
.hd-period-sub{font-size:11.5px;color:rgba(255,255,255,.5);margin-top:2px}

.hd-divider{height:1px;background:rgba(255,255,255,.12);margin:0 0 18px;position:relative;z-index:1}

.hd-meta{display:flex;gap:28px;position:relative;z-index:1;flex-wrap:wrap}
.hd-meta-item{min-width:100px}
.hd-meta-item label{font-size:9.5px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.45);display:block;margin-bottom:3px;font-weight:700}
.hd-meta-item span{font-size:12.5px;color:rgba(255,255,255,.9);font-weight:600}
.growth-chip{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:10px;font-size:11.5px;font-weight:700}
.growth-up{background:rgba(0,200,150,.25);color:#6ee7c4}
.growth-down{background:rgba(245,54,92,.25);color:#fca5a5}

/* ────────────── BODY ────────────── */
.doc-body{padding:28px 36px}
.section{margin-bottom:26px}
.section-title{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:#6b7fa8;margin-bottom:14px;display:flex;align-items:center;gap:10px}
.section-title .s-num{width:22px;height:22px;border-radius:6px;background:#0d1b3e;color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0}
.section-title::after{content:'';flex:1;height:1px;background:#eef2f9}

/* ── KPI cards ── */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.kpi{border-radius:12px;padding:16px;border:1.5px solid #e8eaf0}
.kpi.blue{background:linear-gradient(135deg,#1a6ef5,#0047cc);border-color:transparent;color:#fff}
.kpi.green{background:#f0fdf9;border-color:#a7f3d0}
.kpi.red{background:#fff5f5;border-color:#fecaca}
.kpi.amber{background:#fffbf0;border-color:#fde68a}
.kpi.gray{background:#f8faff;border-color:#e8eaf0}
.kpi-lbl{font-size:9.5px;text-transform:uppercase;letter-spacing:.1em;font-weight:700;color:#8899b0;margin-bottom:6px}
.kpi.blue .kpi-lbl{color:rgba(255,255,255,.6)}
.kpi-val{font-size:20px;font-weight:800;letter-spacing:-.03em;font-family:'DM Mono',monospace;line-height:1;color:#0d1b3e}
.kpi.blue .kpi-val{color:#fff}
.kpi.green .kpi-val{color:#065f46}
.kpi.red   .kpi-val{color:#c0183a}
.kpi.amber .kpi-val{color:#92400e}
.kpi-sub{font-size:11px;color:#8899b0;margin-top:5px}
.kpi.blue .kpi-sub{color:rgba(255,255,255,.6)}
.kpi-bar{height:4px;background:rgba(255,255,255,.2);border-radius:2px;overflow:hidden;margin-top:10px}
.kpi-bar-f{height:100%;border-radius:2px;background:rgba(255,255,255,.75);transition:width .6s}

/* ── Two col ── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:22px}

/* ── Box ── */
.box{background:#f8faff;border:1.5px solid #eef2f9;border-radius:12px;padding:18px}
.box-title{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#8899b0;margin-bottom:12px}

/* ── Financial summary table ── */
.fin-table{width:100%;border-collapse:collapse}
.fin-table tr{border-bottom:1px solid #f0f4fa}
.fin-table td{padding:8px 0;font-size:12.5px;color:#374151;font-weight:400}
.fin-table .lbl{color:#374151}
.fin-table .val{text-align:right;font-weight:500;font-family:'DM Mono',monospace;color:#374151}
/* Section header */
.fin-table .lr-sec-hdr td{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#8899b0;padding-top:14px;padding-bottom:3px;border:none;background:none}
/* Detail rows */
.fin-table .lr-detail td{font-size:12.5px;color:#374151;font-weight:400;padding:7px 0}
.fin-table .lr-detail .lbl{padding-left:12px;color:#4b5563}
.fin-table .lr-detail td:last-child{text-align:right;font-family:'DM Mono',monospace;font-weight:500}
/* Subtotal rows */
.fin-table .lr-subtotal td{font-size:13px;font-weight:700;color:#111827;background:#f4f8ff;padding:9px 4px;border-top:1px solid #e0e7f3;border-bottom:none}
.fin-table .lr-subtotal td:last-child{text-align:right;font-family:'DM Mono',monospace}
/* Grand total */
.fin-table .lr-grand td{font-size:14px;font-weight:800;border-top:2px solid #0d1b3e!important;border-bottom:none!important;padding-top:12px;color:#0d1b3e;background:none}
.fin-table .lr-grand td:last-child{color:#1a6ef5;font-size:15px;text-align:right;font-family:'DM Mono',monospace}
/* Remove any inherited thick border from tr:last-child */
.fin-table tr{border-bottom:1px solid #f0f4fa!important}
.fin-table .lr-grand{border-bottom:none!important}
.fin-table .lr-sec-hdr{border-bottom:none!important}
/* Color helpers */
.lr-pos{color:#065f46!important}.lr-neg{color:#c0183a!important}
.positive{color:#065f46}
.negative{color:#c0183a}

/* ── Method bars ── */
.meth-item{margin-bottom:12px}
.meth-item:last-child{margin-bottom:0}
.meth-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px}
.meth-badge{display:inline-flex;align-items:center;gap:5px;padding:2px 9px;border-radius:20px;font-size:10.5px;font-weight:700}
.meth-cash{background:#e6fff7;color:#065f46}
.meth-transfer{background:#eff6ff;color:#1d4ed8}
.meth-dana{background:#fff0f2;color:#c0183a}
.meth-ovo{background:#f5f0ff;color:#5b21b6}
.meth-gopay{background:#f0fdf4;color:#065f46}
.meth-qris{background:#fffbeb;color:#92400e}
.meth-other{background:#f4f8ff;color:#6b7fa8}
.bar-bg{height:6px;background:#e8eaf0;border-radius:3px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px}

/* ── Package rank ── */
.pkg-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #f0f4fa}
.pkg-item:last-child{border-bottom:none}
.pkg-rank{width:22px;height:22px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:800;flex-shrink:0}
.rank-1{background:#fef3c7;color:#b45309}
.rank-2{background:#f1f5f9;color:#475569}
.rank-3{background:#fff5f0;color:#c2410c}
.rank-n{background:#f4f8ff;color:#8899b0}
.pkg-bar-bg{flex:1;height:5px;background:#eef2f9;border-radius:3px;overflow:hidden}
.pkg-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#1a6ef5,#60a5fa)}

/* ── Trend ── */
.trend-item{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid #f0f4fa}
.trend-item:last-child{border-bottom:none}
.trend-bar-bg{flex:1;height:5px;background:#eef2f9;border-radius:3px;overflow:hidden}
.trend-bar-fill{height:100%;border-radius:3px}

/* ── Main payments table ── */
.pay-table{width:100%;border-collapse:collapse;font-size:12px}
.pay-table thead tr{background:#0d1b3e}
.pay-table thead th{padding:9px 11px;text-align:left;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:rgba(255,255,255,.75)}
.pay-table thead th:first-child{border-radius:8px 0 0 0}
.pay-table thead th:last-child{border-radius:0 8px 0 0}
.pay-table tbody tr:nth-child(even) td{background:#f8faff}
.pay-table tbody td{padding:8px 11px;border-bottom:1px solid #f0f4fa;vertical-align:middle}
.pay-table tbody tr:last-child td{border-bottom:none}
.pay-table tfoot td{padding:10px 11px;background:#eef2f9;font-weight:700}
.pay-table .amt{text-align:right;font-family:'DM Mono',monospace;font-weight:700;color:#1a6ef5}
.pay-table .amt-total{font-size:14px;color:#1a6ef5}

/* ── Laba rugi enhanced ── */
.lr-sec-hdr td{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#8899b0;padding-top:14px;padding-bottom:3px;border-bottom:none!important;background:none}
.lr-subtotal td{background:#f4f8ff;font-size:13px;font-weight:700;padding:9px 0;border-top:1px solid #e0e7f3;border-bottom:none}
.lr-subtotal td:last-child{text-align:right;font-family:'DM Mono',monospace}
.lr-grand td{font-size:14px;font-weight:800;border-top:2px solid #0d1b3e!important;border-bottom:none!important;padding-top:12px}
.lr-grand .lbl{color:#0d1b3e}.lr-grand .val{color:#1a6ef5;font-size:15px}
.lr-pos{color:#065f46!important}.lr-neg{color:#c0183a!important}
.margin-bar-bg{height:6px;background:#e8eaf0;border-radius:3px;overflow:hidden;margin-top:8px}
.margin-bar-fill{height:100%;border-radius:3px;transition:width .5s}
/* ── Keuangan table ── */
.keu-tbl{width:100%;border-collapse:collapse;font-size:12px}
.keu-tbl thead tr{background:#1a1a2e}
.keu-tbl thead th{padding:8px 11px;text-align:left;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.75)}
.keu-tbl tbody tr:nth-child(even) td{background:#f8faff}
.keu-tbl tbody td{padding:7px 11px;border-bottom:1px solid #f0f4fa;vertical-align:middle}
.keu-tbl tbody tr:last-child td{border-bottom:none}
.keu-tbl tfoot td{padding:9px 11px;background:#eef2f9;font-weight:700}
.keu-tbl tfoot tr.tfoot-recv td{background:#f0fdf4!important;print-color-adjust:exact;}
.keu-tbl tfoot tr.tfoot-laba td{background:#1e3a8a!important;color:#fff!important;print-color-adjust:exact;}
.keu-tbl tfoot tr.tfoot-laba td *{color:#fff!important;}
.kb{display:inline-block;padding:2px 7px;border-radius:10px;font-size:10.5px;font-weight:700}
.kb-pengeluaran{background:#fff0f2;color:#c0183a}
.kb-hutang{background:#fff8e6;color:#b45309}
.kb-piutang{background:#e0f4ff;color:#0077b6}
.kb-modal{background:#eff6ff;color:#1d4ed8}
/* ── Category bar ── */
.cat-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid #f0f4fa}
.cat-row:last-child{border-bottom:none}
.cat-bar-bg{flex:1;height:5px;background:#e8eaf0;border-radius:3px;overflow:hidden}
.cat-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#f5365c,#ff8fa3)}

/* ── Overdue table ── */
.od-table{width:100%;border-collapse:collapse;font-size:12px}
.od-table thead tr{background:#7f1d1d}
.od-table thead th{padding:9px 11px;text-align:left;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:rgba(255,255,255,.8)}
.od-table tbody tr:nth-child(even) td{background:#fff5f5}
.od-table tbody td{padding:8px 11px;border-bottom:1px solid #fee2e2;vertical-align:middle}
.od-table tbody tr:last-child td{border-bottom:none}
.od-table tfoot td{padding:10px 11px;background:#fef2f2;font-weight:700}
.days-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10.5px;font-weight:700}
.days-warn{background:#fef3c7;color:#92400e}
.days-crit{background:#fee2e2;color:#c0183a}

/* ── Sign section ── */
.sign-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-top:16px}
.sign-box{text-align:center}
.sign-role{font-size:11px;color:#8899b0;margin-bottom:52px}
.sign-line{width:120px;border-top:1.5px solid #1a1a2e;margin:0 auto 6px}
.sign-name{font-size:12px;font-weight:700;color:#0d1b3e}
.sign-title{font-size:10.5px;color:#8899b0}

/* ── Notice box ── */
.notice{background:#f8faff;border:1.5px solid #e8eaf0;border-left:4px solid #1a6ef5;border-radius:0 10px 10px 0;padding:14px 18px}
.notice p{font-size:12px;color:#6b7fa8;line-height:1.8}

/* ── Footer ── */
.doc-footer{background:#f8faff;border-top:2px solid #e8eaf0;padding:14px 36px;display:flex;align-items:center;justify-content:space-between}
.ft-left{font-size:11px;color:#8899b0;line-height:1.7}
.ft-right{font-size:11px;color:#8899b0;text-align:right;line-height:1.7}

/* ── Loading state ── */
#loading{position:fixed;inset:0;background:#0d1b3e;display:flex;align-items:center;justify-content:center;z-index:9999;flex-direction:column;gap:14px}
#loading svg{animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
#loading p{color:rgba(255,255,255,.7);font-size:14px}
</style>
</head>
<body>

<!-- Loading overlay -->
<div id="loading">
  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#1a6ef5" stroke-width="2.5"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
  <p>Memuat laporan keuangan...</p>
</div>

<!-- Toolbar (no print) -->
<div class="toolbar no-print">
  <div class="toolbar-title">
    <svg width="18" height="18" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    <span id="toolbar-title">Laporan Keuangan</span>
  </div>
  <div class="toolbar-btns">
    <a href="/laporan" class="btn btn-ghost">← Kembali</a>
    <button onclick="window.print()" class="btn btn-primary">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
      Print / Simpan PDF
    </button>
  </div>
</div>

<!-- Document -->
<div class="page-wrap">
<div class="doc" id="doc-content" style="display:none">

  <!-- ── HEADER ── -->
  <div class="doc-header">
    <div class="hd-top">
      <div class="hd-left">
        <div class="hd-company" id="hd-company">ISP NetOps</div>
        <div class="hd-tagline" id="hd-tagline">Internet Service Provider</div>
      </div>
      <div class="hd-right">
        <div class="hd-badge">Laporan Keuangan</div>
        <div class="hd-period-type" id="hd-period-type">Bulanan</div>
        <div class="hd-period-name" id="hd-period-name">—</div>
        <div class="hd-period-sub" id="hd-period-sub">—</div>
      </div>
    </div>
    <div class="hd-divider"></div>
    <div class="hd-meta">
      <div class="hd-meta-item"><label>Dicetak</label><span id="meta-printed">—</span></div>
      <div class="hd-meta-item"><label>Oleh</label><span id="meta-by"><%= user?.name || 'Admin' %></span></div>
      <div class="hd-meta-item"><label>Total Transaksi</label><span id="meta-tx">—</span></div>
      <div class="hd-meta-item"><label>Periode Sebelumnya</label><span id="meta-prev">—</span></div>
      <div class="hd-meta-item"><label>Pertumbuhan</label><span id="meta-growth">—</span></div>
    </div>
  </div>

  <!-- ── BODY ── -->
  <div class="doc-body">

    <!-- 1. RINGKASAN EKSEKUTIF -->
    <div class="section avoid-break">
      <div class="section-title"><span class="s-num">1</span> Ringkasan Eksekutif</div>
      <div class="kpi-grid">
        <div class="kpi blue">
          <div class="kpi-lbl">Total Penerimaan</div>
          <div class="kpi-val" id="kpi-recv" style="font-size:17px">—</div>
          <div class="kpi-sub" id="kpi-recv-sub">—</div>
          <div class="kpi-bar"><div class="kpi-bar-f" id="kpi-recv-bar" style="width:0%"></div></div>
        </div>
        <div class="kpi" id="kpi-overdue-box">
          <div class="kpi-lbl">Belum Bayar</div>
          <div class="kpi-val" id="kpi-overdue">—</div>
          <div class="kpi-sub" id="kpi-overdue-sub">—</div>
        </div>
        <div class="kpi green">
          <div class="kpi-lbl">Collection Rate</div>
          <div class="kpi-val" id="kpi-rate">—</div>
          <div class="kpi-sub" id="kpi-rate-sub">—</div>
        </div>
        <div class="kpi amber">
          <div class="kpi-lbl">Rata-rata / Transaksi</div>
          <div class="kpi-val" id="kpi-avg" style="font-size:16px">—</div>
          <div class="kpi-sub" id="kpi-avg-sub">—</div>
        </div>
      </div>
    </div>

    <!-- 2. ANALISIS PENDAPATAN & LABA RUGI -->
    <div class="section avoid-break">
      <div class="section-title"><span class="s-num">2</span> Analisis Pendapatan & Laba Rugi</div>
      <div class="two-col">
        <!-- Laba Rugi Lengkap -->
        <div class="box">
          <div class="box-title">Laporan Laba Rugi</div>
          <table class="fin-table">
            <tr class="lr-sec-hdr"><td colspan="2">PENDAPATAN</td></tr>
            <tr class="lr-detail"><td class="lbl">Pembayaran Pelanggan</td><td class="lr-pos" id="fin-recv">—</td></tr>
            <tbody id="fin-manual-rows"></tbody>
            <tr class="lr-subtotal"><td class="lbl">Total Pendapatan</td><td class="val lr-pos" id="fin-total-pend">—</td></tr>
            <tr class="lr-sec-hdr"><td colspan="2">PENGELUARAN</td></tr>
            <tr class="lr-detail"><td class="lbl" id="fin-kel-lbl">Operasional</td><td class="lr-neg" id="fin-keluar">—</td></tr>
            <tr class="lr-subtotal"><td class="lbl">Total Pengeluaran</td><td class="val lr-neg" id="fin-total-kel">—</td></tr>
            <tr class="lr-sec-hdr"><td colspan="2">RINGKASAN</td></tr>
            <tr class="lr-detail"><td class="lbl">Periode Sebelumnya</td><td id="fin-prev">—</td></tr>
            <tr class="lr-detail"><td class="lbl">Selisih vs Lalu</td><td id="fin-diff">—</td></tr>
            <tr class="lr-grand"><td class="lbl">LABA / RUGI BERSIH</td><td class="val" id="fin-laba">—</td></tr>
          </table>
          <div style="margin-top:14px">
            <div style="display:flex;justify-content:space-between;font-size:11px;color:#8899b0;margin-bottom:5px">
              <span>Profit Margin</span><span id="fin-margin" style="font-weight:700">—</span>
            </div>
            <div class="margin-bar-bg"><div class="margin-bar-fill" id="fin-margin-bar" style="width:0%"></div></div>
          </div>
        </div>
        <!-- Metode + Kategori pengeluaran -->
        <div style="display:flex;flex-direction:column;gap:16px">
          <div class="box">
            <div class="box-title">Metode Pembayaran</div>
            <div id="method-breakdown"><div style="color:#8899b0;font-size:12px;padding:16px 0;text-align:center">Tidak ada data</div></div>
          </div>
          <div class="box" id="cat-box" style="display:none">
            <div class="box-title">Pengeluaran per Kategori</div>
            <div id="cat-breakdown"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- 3. PERFORMA PAKET & TREN -->
    <div class="section avoid-break">
      <div class="section-title"><span class="s-num">3</span> Performa Paket & Tren</div>
      <div class="two-col">
        <div class="box">
          <div class="box-title">Top Paket Berdasarkan Penerimaan</div>
          <div id="pkg-list"><div style="color:#8899b0;font-size:12px;text-align:center;padding:16px">Tidak ada data</div></div>
        </div>
        <div class="box">
          <div class="box-title" id="trend-box-title">Tren 6 Bulan Terakhir</div>
          <div id="trend-list"><div style="color:#8899b0;font-size:12px;text-align:center;padding:16px">Tidak ada data</div></div>
        </div>
      </div>
    </div>

    <!-- 4. DAFTAR PEMBAYARAN -->
    <div class="section page-break">
      <div class="section-title"><span class="s-num">4</span> Daftar Pemasukan <span id="sec4-period" style="font-weight:400;text-transform:none;font-size:11px;color:#8899b0;letter-spacing:0;margin-left:4px"></span></div>
      <div id="payments-table-wrap">
        <div style="text-align:center;padding:30px;color:#8899b0">Memuat...</div>
      </div>
    </div>

    <!-- 4b. TRANSAKSI PENGELUARAN -->
    <div class="section avoid-break" id="keu-section" style="display:none">
      <div class="section-title"><span class="s-num" id="keu-sec-num">5</span> Pengeluaran, Hutang & Piutang <span id="keu-sec-period" style="font-weight:400;text-transform:none;font-size:11px;color:#8899b0;letter-spacing:0;margin-left:4px"></span></div>
      <div id="keu-table-wrap"></div>
    </div>

    <!-- 5. PELANGGAN BELUM BAYAR -->
    <div class="section avoid-break" id="overdue-section" style="display:none">
      <div class="section-title"><span class="s-num">5</span> Daftar Pelanggan Belum Bayar (Overdue)</div>
      <div id="overdue-table-wrap"></div>
    </div>

    <!-- 6. PENGESAHAN -->
    <div class="section avoid-break" style="margin-top:32px">
      <div class="section-title"><span class="s-num" id="sign-num">6</span> Pengesahan Laporan</div>
      <div class="notice">
        <p id="notice-text">Laporan keuangan ini dibuat secara otomatis oleh sistem pada — untuk periode —. Data yang tersaji merupakan rekapitulasi pembayaran pelanggan yang tercatat dalam sistem. Laporan ini bersifat internal dan digunakan untuk keperluan manajemen keuangan perusahaan.</p>
      </div>
      <div class="sign-grid">
        <div class="sign-box">
          <div class="sign-role">Dibuat oleh,</div>
          <div class="sign-line"></div>
          <div class="sign-name" id="sign-name"><%= user?.name || 'Admin' %></div>
          <div class="sign-title">Operator Sistem</div>
        </div>
        <div class="sign-box">
          <div class="sign-role">Diperiksa oleh,</div>
          <div class="sign-line"></div>
          <div class="sign-name">_______________</div>
          <div class="sign-title">Manajer Keuangan</div>
        </div>
        <div class="sign-box">
          <div class="sign-role">Disetujui oleh,</div>
          <div class="sign-line"></div>
          <div class="sign-name">_______________</div>
          <div class="sign-title">Direktur</div>
        </div>
      </div>
    </div>

  </div><!-- /.doc-body -->

  <!-- ── FOOTER ── -->
  <div class="doc-footer">
    <div class="ft-left">
      <strong id="ft-company">ISP NetOps</strong> · Laporan Keuangan <span id="ft-period">—</span><br>
      Dicetak: <span id="ft-printed">—</span>
    </div>
    <div class="ft-right">
      Dokumen ini digenerate otomatis<br>
      oleh sistem manajemen ISP
    </div>
  </div>

</div><!-- /.doc -->
</div><!-- /.page-wrap -->

<script>
const MET_NAMES  = {cash:'Cash',transfer:'Transfer Bank',dana:'DANA',ovo:'OVO',gopay:'GoPay',qris:'QRIS'};
const MET_COLORS = {cash:'#059669',transfer:'#1d4ed8',dana:'#c0183a',ovo:'#5b21b6',gopay:'#065f46',qris:'#b45309'};
const MET_BG     = {cash:'#e6fff7',transfer:'#eff6ff',dana:'#fff0f2',ovo:'#f5f0ff',gopay:'#f0fdf4',qris:'#fffbeb'};
const MONTHS_ID  = ['','Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
const MONTHS_SH  = ['','Jan','Feb','Mar','Apr','Mei','Jun','Jul','Ags','Sep','Okt','Nov','Des'];

function fmtRp(n){ return 'Rp '+new Intl.NumberFormat('id-ID').format(n||0); }
function fmtRpK(n){ n=n||0; if(n>=1000000)return'Rp '+(n/1000000).toFixed(2).replace(/\.?0+$/,'')+'jt'; if(n>=1000)return'Rp '+Math.round(n/1000)+'rb'; return'Rp '+n; }
function fmtDate(s){ if(!s)return'—'; const d=new Date(s); return isNaN(d)?s:d.toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'}); }
function fmtDateShort(s){ if(!s)return'—'; const d=new Date(s); return isNaN(d)?s:d.toLocaleDateString('id-ID',{day:'2-digit',month:'2-digit',year:'numeric'}); }
function el(id){ return document.getElementById(id); }

async function init(){
  const params = new URLSearchParams(window.location.search);
  const view   = params.get('view')  || 'monthly';
  const month  = parseInt(params.get('month')) || (new Date().getMonth()+1);
  const year   = parseInt(params.get('year'))  || new Date().getFullYear();

  try {
    // Load app settings & API data in parallel
    const token = localStorage.getItem('token');
    const headers = {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'};
    if(token && token!=='null') headers['Authorization']='Bearer '+token;

    const [apiRes, settingsRes] = await Promise.all([
      fetch(`/api/laporan/summary?view=${view}&month=${month}&year=${year}`,{headers,credentials:'include'}),
      fetch(`/api/app-settings`,{headers,credentials:'include'})
    ]);
    const api      = await apiRes.json();
    // /api/app-settings returns data as a plain object {key: value}
    const settingsRaw = settingsRes.ok ? await settingsRes.json() : {success:false,data:{}};
    const settings = {data: settingsRaw.data||{}};

    if(!api.success) throw new Error(api.message||'Gagal memuat data');

    render(api.data, {view, month, year}, settings.data||{});

    el('loading').style.display='none';
    el('doc-content').style.display='block';
  } catch(e) {
    el('loading').innerHTML = `<p style="color:#fca5a5;font-size:14px">❌ Error: ${e.message}</p><a href="/laporan" style="color:#60a5fa;margin-top:12px;display:block">← Kembali</a>`;
  }
}

function render(d, params, settings){
  const {view, month, year} = params;
  // totalRecvAll = pembayaran pelanggan + pemasukan manual
  const keuRowsAll = (d.keuData||{}).keuRows||[];
  const keuTotalMasuk = keuRowsAll
    .filter(function(r){return r.type==='pemasukan';})
    .reduce(function(s,r){return s+(parseFloat(r.amount)||0);},0);
  const recv    = Math.max(d.totalRecvAll||0, d.totalRecv||0, keuTotalMasuk);
  const recvISP = d.totalRecv || 0;

  // Period labels
  let periodType='Bulanan', periodName='', periodSub='';
  if(view==='monthly'){
    periodName = MONTHS_ID[month]+' '+year;
    periodSub  = `01 ${MONTHS_SH[month]} ${year} s/d ${new Date(year,month,0).getDate()} ${MONTHS_SH[month]} ${year}`;
  } else {
    periodType='Tahunan'; periodName='Tahun '+year; periodSub=`01 Jan ${year} s/d 31 Des ${year}`;
  }

  // Company info
  const companyName = settings.app_name || 'ISP NetOps';
  const companyTag  = settings.app_tagline || 'Internet Service Provider';
  const logoUrl     = settings.logo_url || '';
  const now = new Date().toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'});

  // Header
  el('toolbar-title').textContent = `Laporan Keuangan — ${periodName}`;
  el('hd-company').textContent = companyName;
  el('hd-tagline').textContent  = companyTag;
  el('hd-period-type').textContent = periodType;
  el('hd-period-name').textContent = periodName;
  el('hd-period-sub').textContent  = periodSub;
  el('meta-printed').textContent = now;
  const keuPemas2 = (d.keuData||{})._keuPemasukan||0;
  el('meta-tx').textContent = keuPemas2 > 0
    ? (d.totalTx||0)+' tx + manual'
    : (d.totalTx||0)+' pembayaran';
  el('meta-prev').textContent = fmtRp(d.prevRecv||0);

  // Growth chip
  const g = d.growthAmt;
  if(g!==null && g!==undefined){
    const cls = +g>=0?'growth-up':'growth-down';
    el('meta-growth').innerHTML = `<span class="growth-chip ${cls}">${+g>=0?'↑':'↓'} ${Math.abs(g)}%</span>`;
  } else { el('meta-growth').textContent='—'; }

  // KPI cards
  const rate = d.collectionRate||0;
  el('kpi-recv').textContent = fmtRpK(recv); // totalRecvAll
  el('kpi-recv-sub').textContent = `${d.totalTx||0} transaksi · ${periodName}`;
  el('kpi-recv-bar').style.width = Math.min(100,rate)+'%';

  const od = d.totalOverdue||0;
  const odBox = el('kpi-overdue-box');
  odBox.className = 'kpi '+(od>0?'red':'green');
  el('kpi-overdue').textContent = od;
  el('kpi-overdue-sub').textContent = fmtRpK(d.totalOverdueAmt||0)+' tertunggak';

  el('kpi-rate').textContent = rate+'%';
  el('kpi-rate-sub').textContent = 'Dari '+fmtRpK(d.potentialRecv||0)+' potensi';

  const avg = d.totalTx>0 ? Math.round(recv/d.totalTx) : 0;
  el('kpi-avg').textContent = fmtRpK(avg);
  el('kpi-avg-sub').textContent = (d.totalActive||0)+' pelanggan aktif';

  // ── Financial summary (enhanced with keuangan data) ──
  const keu = d.keuData || {};
  const lr  = d.labaRugi || {};
  const diff = recv - (d.prevRecv||0);

  const keuPemas = (d.keuData||{})._keuPemasukan||0;
  el('fin-recv').innerHTML = '<span class="lr-pos">+'+fmtRp(recvISP)+'</span>';

  // Manual pemasukan rows (grouped by category)
  const keuPRows2 = ((d.keuData||{}).keuRows||[]).filter(r=>r.type==='pemasukan');
  const manualGrp = {};
  keuPRows2.forEach(r=>{
    if((r.ref_number||'').toUpperCase().indexOf('PAY-')===0) return; // skip PAY-sync
    const k = r.category||'Lain-lain';
    if(!manualGrp[k]) manualGrp[k]={total:0,cnt:0};
    manualGrp[k].total += +r.amount||0;
    manualGrp[k].cnt++;
  });
  const manRows = el('fin-manual-rows');
  if(manRows){
    manRows.innerHTML = Object.entries(manualGrp).map(([cat,v])=>
      `<tr class="lr-detail"><td class="lbl">${cat} <span style="font-size:10px;color:#8899b0">(${v.cnt}x)</span></td><td class="lr-pos">+${fmtRp(v.total)}</td></tr>`
    ).join('');
  }

  const finTotalPend = el('fin-total-pend');
  if(finTotalPend) finTotalPend.innerHTML = '<span class="lr-pos">+'+fmtRp(recv)+'</span>';
  el('fin-kel-lbl').textContent = 'Operasional ('+(keu.pengeluaranCnt||0)+' item)';
  el('fin-keluar').innerHTML    = (keu.pengeluaran||0)>0
    ? '<span class="lr-neg">-'+fmtRp(keu.pengeluaran||0)+'</span>'
    : fmtRp(0);
  el('fin-total-kel').innerHTML = (keu.pengeluaran||0)>0
    ? '<span class="lr-neg">-'+fmtRp(keu.pengeluaran||0)+'</span>'
    : fmtRp(0);
  el('fin-prev').textContent    = fmtRp(d.prevRecv||0);
  el('fin-diff').innerHTML      = `<span class="${diff>=0?'positive':'negative'}">${diff>=0?'+':''}${fmtRp(diff)}</span>`;

  const laba = recv - (keu.pengeluaran||0);
  el('fin-laba').innerHTML = laba>=0
    ? '<span style="color:#065f46;font-size:15px">+'+fmtRp(laba)+'</span>'
    : '<span style="color:#c0183a;font-size:15px">-'+fmtRp(Math.abs(laba))+'</span>';

  const margin = recv>0 ? Math.round(laba/recv*100) : 0;
  el('fin-margin').textContent  = margin+'%';
  el('fin-margin-bar').style.width      = Math.max(0,Math.min(100,margin))+'%';
  el('fin-margin-bar').style.background = laba>=0
    ? 'linear-gradient(90deg,#00c896,#1a6ef5)'
    : 'linear-gradient(90deg,#f5365c,#fb8c00)';

  // ── Kategori pengeluaran ──
  const cats = keu.catRows||[];
  if(cats.length){
    el('cat-box').style.display='block';
    const maxC = Math.max(1,...cats.map(x=>+x.total||0));
    el('cat-breakdown').innerHTML = cats.map(cat=>{
      const pct=Math.round((+cat.total||0)/maxC*100);
      return`<div class="cat-row">
        <span style="font-size:12px;flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${cat.category}</span>
        <div class="cat-bar-bg"><div class="cat-bar-fill" style="width:${pct}%"></div></div>
        <span style="font-size:11.5px;font-weight:700;font-family:'DM Mono',monospace;min-width:68px;text-align:right">${fmtRpK(+cat.total)}</span>
      </div>`;
    }).join('');
  }

  // ── Transaksi keuangan (pengeluaran dll) - exclude pemasukan ──
  const keuRows = (keu.keuRows||[]).filter(r=>r.type!=='pemasukan');
  const keuSec  = el('keu-section');
  if(keuRows.length && keuSec){
    keuSec.style.display='block';
    el('keu-sec-period').textContent = '— '+periodName;
    const TYPE_LBL = {pengeluaran:'Pengeluaran',hutang:'Hutang',piutang:'Piutang',modal:'Modal'};
    const TYPE_CLS = {pengeluaran:'kb-pengeluaran',hutang:'kb-hutang',piutang:'kb-piutang',modal:'kb-modal'};
    const ST_LBL   = {lunas:'✓ Lunas',belum_lunas:'⏳ Belum',cicilan:'↺ Cicilan'};
    const totalKel = keuRows.filter(r=>r.type==='pengeluaran').reduce((a,r)=>a+(+r.amount||0),0);
    el('keu-table-wrap').innerHTML = `
    <table class="keu-tbl">
      <thead><tr>
        <th style="width:80px">Tgl</th><th>Tipe</th><th>Deskripsi / Kategori</th>
        <th>Pihak / Ref</th><th>Status</th><th style="text-align:right">Jumlah</th>
      </tr></thead>
      <tbody>${keuRows.map(r=>{
        const ac = r.type==='pengeluaran'||r.type==='hutang'?'#c0183a':r.type==='modal'?'#065f46':'#0077b6';
        const st = r.status ? `<span class="kb ${r.status==='lunas'?'':'kb-pengeluaran'}" style="${r.status==='lunas'?'background:#e6fff7;color:#065f46':''}">${ST_LBL[r.status]||r.status}</span>` : '—';
        const dt = r.date ? new Date(r.date).toLocaleDateString('id-ID',{day:'2-digit',month:'2-digit',year:'numeric'}) : '—';
        return`<tr>
          <td style="white-space:nowrap;font-size:11px;color:#8899b0">${dt}</td>
          <td><span class="kb ${TYPE_CLS[r.type]||''}">${TYPE_LBL[r.type]||r.type}</span></td>
          <td><div style="font-weight:600">${r.description||'—'}</div><div style="font-size:10.5px;color:#8899b0">${r.category||''}</div></td>
          <td style="font-size:11px;color:#8899b0">${r.party_name||r.ref_number||'—'}</td>
          <td style="font-size:11px">${st}</td>
          <td style="text-align:right;font-weight:700;font-family:'DM Mono',monospace;color:${ac}">${r.type==='pengeluaran'||r.type==='hutang'?'-':''}${fmtRp(+r.amount)}</td>
        </tr>`;
      }).join('')}</tbody>
      <tfoot>
        <tr>
          <td colspan="4" style="font-size:11px;color:#8899b0">${keuRows.length} transaksi</td>
          <td style="text-align:right;font-size:11.5px;color:#374151;font-weight:600;">Total Pengeluaran</td>
          <td style="text-align:right;font-size:13.5px;font-weight:800;font-family:'DM Mono',monospace;color:#c0183a;">-${fmtRp(totalKel)}</td>
        </tr>
        <tr class="tfoot-recv">
          <td colspan="4" style="font-size:11px;color:#16a34a;">${keuRowsAll.filter(r=>r.type==='pemasukan'&&(r.ref_number||'').toUpperCase().indexOf('PAY-')!==0).length} pemasukan manual</td>
          <td style="text-align:right;font-size:11.5px;color:#16a34a;font-weight:600;">Total Pendapatan</td>
          <td style="text-align:right;font-size:13.5px;font-weight:800;font-family:'DM Mono',monospace;color:#15803d;">+${fmtRp(recv)}</td>
        </tr>
        <tr class="tfoot-laba">
          <td colspan="4" style="font-size:11px;color:rgba(255,255,255,.6);padding:11px;">Pendapatan − Pengeluaran</td>
          <td style="text-align:right;font-size:11.5px;color:rgba(255,255,255,.8);font-weight:600;">${(recv-totalKel)>=0?'Laba Bersih':'Rugi Bersih'}</td>
          <td style="text-align:right;font-size:14px;font-weight:800;font-family:'DM Mono',monospace;color:#fff;">${(recv-totalKel)>=0?'+':'-'}${fmtRp(Math.abs(recv-totalKel))}</td>
        </tr>
      </tfoot>
    </table>`;
  }

  // Method breakdown
  const methods = d.methodRows||[];
  if(methods.length){
    const totalMet = Math.max(1, methods.reduce((a,r)=>a+(+r.total||0),0));
    el('method-breakdown').innerHTML = methods.map(m=>{
      const pct = Math.round((+m.total||0)/totalMet*100);
      const col = MET_COLORS[m.method]||'#6b7fa8';
      const bg  = MET_BG[m.method]||'#f4f8ff';
      return`<div class="meth-item">
        <div class="meth-row">
          <span style="display:inline-flex;align-items:center;gap:6px">
            <span style="width:8px;height:8px;border-radius:2px;background:${col};flex-shrink:0"></span>
            <span class="meth-badge" style="background:${bg};color:${col}">${MET_NAMES[m.method]||m.method}</span>
            <span style="font-size:11px;color:#8899b0">${m.cnt} tx</span>
          </span>
          <span style="text-align:right">
            <span style="font-size:12.5px;font-weight:700;font-family:'DM Mono',monospace">${fmtRp(+m.total)}</span>
            <span style="font-size:10.5px;color:#8899b0;margin-left:5px">${pct}%</span>
          </span>
        </div>
        <div class="bar-bg"><div class="bar-fill" style="width:${pct}%;background:${col}"></div></div>
      </div>`;
    }).join('');
  }

  // Package list
  const pkgs = d.packageRows||[];
  if(pkgs.length){
    const maxP = Math.max(1,...pkgs.map(p=>+p.total||0));
    el('pkg-list').innerHTML = pkgs.map((p,i)=>{
      const cls = i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-n';
      const pct = Math.round((+p.total||0)/maxP*100);
      return`<div class="pkg-item">
        <div class="pkg-rank ${cls}">${i+1}</div>
        <div style="flex:1;min-width:0">
          <div style="font-size:12.5px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${p.name||'—'}</div>
          <div class="pkg-bar-bg" style="margin-top:4px"><div class="pkg-bar-fill" style="width:${pct}%"></div></div>
        </div>
        <div style="text-align:right;flex-shrink:0;margin-left:10px">
          <div style="font-size:12px;font-weight:700;font-family:'DM Mono',monospace">${fmtRpK(+p.total)}</div>
          <div style="font-size:10.5px;color:#8899b0">${p.cnt} tx</div>
        </div>
      </div>`;
    }).join('');
  }

  // Trend
  const trend = d.trendData||[];
  if(trend.length){
    el('trend-box-title').textContent = view==='yearly'?'Tren 5 Tahun Terakhir':'Tren 6 Bulan Terakhir';
    const maxT = Math.max(1,...trend.map(t=>+t.total||0));
    const curLabel = view==='yearly'?String(year):(d.paidRows?.length ? new Date(d.paidRows[0].payment_date).toLocaleDateString('id-ID',{month:'short'}) : '');
    el('trend-list').innerHTML = trend.map(t=>{
      const pct = Math.round((+t.total||0)/maxT*100);
      const isCur = view==='yearly'?t.label===String(year):false;
      return`<div class="trend-item">
        <span style="font-size:11.5px;width:52px;flex-shrink:0;font-weight:${isCur?700:400};color:${isCur?'#1a6ef5':'#6b7fa8'}">${t.label}</span>
        <div class="trend-bar-bg"><div class="trend-bar-fill" style="width:${pct}%;background:${isCur?'#1a6ef5':'#93c5fd'}"></div></div>
        <span style="font-size:11.5px;font-weight:700;font-family:'DM Mono',monospace;width:70px;text-align:right;flex-shrink:0;color:${isCur?'#1a6ef5':'#0d1b3e'}">${fmtRpK(+t.total)}</span>
      </div>`;
    }).join('');
  }

  // Payments table
  el('sec4-period').textContent = '— '+periodName;

  // Gabungkan: pemasukan dari payments + pemasukan manual keuangan
  const paid     = d.paidRows||[];
  const keuPRows = (d.keuData||{}).keuRows||[];
  const manualIn = keuPRows.filter(r=>r.type==='pemasukan'); // pemasukan manual

  // Build combined rows: payments first, then manual
  const allInRows = [
    ...paid.map(p=>({
      _src:        'payment',
      tgl:         p.payment_date,
      desc:        p.cust_name||'—',
      sub:         p.cid||'',
      detail:      p.pkg_name||'—',
      metode:      MET_NAMES[p.payment_method]||p.payment_method||'Cash',
      metBg:       MET_BG[p.payment_method]||'#f0fdf4',
      metColor:    MET_COLORS[p.payment_method]||'#065f46',
      ref:         p.invoice_number||'—',
      amount:      +p.amount||0
    })),
    ...manualIn.map(r=>({
      _src:        'manual',
      tgl:         r.date,
      desc:        r.description||'—',
      sub:         r.category||'',
      detail:      'Pemasukan Manual',
      metode:      r.category||'Manual',
      metBg:       '#f0fdf4',
      metColor:    '#065f46',
      ref:         r.ref_number||'—',
      amount:      +r.amount||0
    }))
  ].sort((a,b)=>new Date(a.tgl)-new Date(b.tgl));

  if(!allInRows.length){
    el('payments-table-wrap').innerHTML='<div style="text-align:center;padding:24px;color:#8899b0;font-size:12.5px">Tidak ada pemasukan di periode ini</div>';
  } else {
    const totalIn = allInRows.reduce((a,r)=>a+r.amount,0);
    el('payments-table-wrap').innerHTML=`
    <table class="pay-table">
      <thead><tr>
        <th style="width:28px">#</th>
        <th>Keterangan</th>
        <th>Detail / Paket</th>
        <th>Sumber</th>
        <th>Tanggal</th>
        <th>Ref / Invoice</th>
        <th style="text-align:right">Jumlah</th>
      </tr></thead>
      <tbody>${allInRows.map((p,i)=>`<tr>
          <td style="color:#8899b0;font-size:11px">${i+1}</td>
          <td><div style="font-weight:600;font-size:12.5px">${p.desc}</div><div style="font-size:10.5px;color:#8899b0">${p.sub}</div></td>
          <td style="color:#6b7fa8;font-size:12px">${p.detail}</td>
          <td><span class="meth-badge" style="background:${p.metBg};color:${p.metColor}">${p.metode}</span></td>
          <td style="white-space:nowrap;font-size:12px">${fmtDateShort(p.tgl)}</td>
          <td style="font-size:11px;color:#8899b0">${p.ref}</td>
          <td class="amt">${fmtRp(p.amount)}</td>
        </tr>`).join('')}</tbody>
      <tfoot><tr>
        <td colspan="5" style="font-size:11px;color:#6b7fa8">${allInRows.length} pemasukan · ${periodName}</td>
        <td style="font-size:11px;color:#6b7fa8;text-align:right;font-weight:600">TOTAL</td>
        <td class="amt amt-total">${fmtRp(totalIn)}</td>
      </tr></tfoot>
    </table>`;
  }

  // Overdue section
  const overdue = d.overdueRows||[];
  if(overdue.length){
    el('overdue-section').style.display='block';
    el('sign-num').textContent='6';
    el('overdue-table-wrap').innerHTML=`
    <table class="od-table">
      <thead><tr>
        <th style="width:28px">#</th><th>Pelanggan</th><th>Paket</th>
        <th>Jatuh Tempo</th><th>Keterlambatan</th><th style="text-align:right">Tagihan</th>
      </tr></thead>
      <tbody>${overdue.map((r,i)=>{
        const days=+r.days_overdue||0;
        return`<tr>
          <td style="color:#8899b0;font-size:11px">${i+1}</td>
          <td><div style="font-weight:600;font-size:12.5px">${r.name||'—'}</div><div style="font-size:10.5px;color:#8899b0">${r.customer_id||''}</div></td>
          <td style="color:#6b7fa8;font-size:12px">—</td>
          <td style="color:#c0183a;font-weight:600;font-size:12px">${fmtDateShort(r.due_date)}</td>
          <td><span class="days-badge ${days>7?'days-crit':'days-warn'}">${days} hari</span></td>
          <td style="text-align:right;font-weight:700;font-family:'DM Mono',monospace;color:#c0183a;font-size:12.5px">${fmtRp(+r.price||0)}</td>
        </tr>`;
      }).join('')}</tbody>
      <tfoot><tr>
        <td colspan="5" style="font-size:11px;color:#6b7fa8">${overdue.length} pelanggan overdue</td>
        <td style="text-align:right;font-family:'DM Mono',monospace;font-size:14px;color:#c0183a">${fmtRp(d.totalOverdueAmt||0)}</td>
      </tr></tfoot>
    </table>`;
  }

  // ── Dynamic section numbers ──
  let secNum = 5;
  if(keuRows.length){ secNum++; const kn=el('keu-sec-num'); if(kn) kn.textContent=secNum-1; }
  if((d.overdueRows||[]).length){ secNum++; }
  const signNum = el('sign-num'); if(signNum) signNum.textContent = secNum;

  // Notice & footer
  el('notice-text').innerHTML = `Laporan keuangan ini mencakup penerimaan pelanggan, pengeluaran operasional, dan laba rugi periode <strong>${periodName}</strong>. Dibuat otomatis oleh sistem <strong>${companyName}</strong> pada <strong>${now}</strong> untuk periode <strong>${periodName}</strong>. Data yang tersaji merupakan rekapitulasi pembayaran pelanggan yang tercatat dalam sistem. Laporan ini bersifat internal dan digunakan untuk keperluan manajemen keuangan perusahaan.`;
  el('ft-company').textContent = companyName;
  el('ft-period').textContent  = periodName;
  el('ft-printed').textContent = now;
}

init();
</script>
</body>
</html>
