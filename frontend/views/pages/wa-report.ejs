            <textarea id="reportTemplate" rows="16"
              style="width:100%;box-sizing:border-box;border:1.5px solid var(--d-border);border-radius:10px;padding:11px 12px;font-family:'DM Mono',monospace;font-size:12px;line-height:1.7;resize:vertical;outline:none;background:#fdfdff;color:#0d1b3e;transition:border-color .15s;"
              onfocus="this.style.borderColor='#1a6ef5'"
