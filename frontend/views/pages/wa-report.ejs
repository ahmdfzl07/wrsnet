            <div style="font-size:11px;color:#94a3b8;margin-top:5px;">Gunakan *teks* untuk <strong>bold</strong>, _teks_ untuk <em>italic</em> di WA</div>
          </div>

          <!-- Jadwal otomatis -->
          <div class="w-card">
            <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--d-muted);margin-bottom:14px;">Jadwal Otomatis</div>
            <div id="schedGrid">
              <div style="text-align:center;color:#94a3b8;padding:20px;">Memuat jadwal...</div>
            </div>
            <button class="pay-btn" onclick="saveSchedules()" style="margin-top:14px;">
              <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
