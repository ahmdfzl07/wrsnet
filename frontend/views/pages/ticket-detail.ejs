    <a href="https://wa.me/62${(c.phone||'').replace(/^0/,'')}" target="_blank" style="background:linear-gradient(135deg,#25d366,#128c7e);"><i class="fab fa-whatsapp"></i> Hubungi</a>
    </div></div>`:'<div style="padding:12px;font-size:13px;">Lokasi Ticket</div>';
  L.marker([lat,lng],{icon:mkI}).addTo(leafMap).bindPopup(ph,{maxWidth:260}).openPopup();
  setTimeout(addMapLayerControl,100);
}
function addMapLayerControl(){
  const m=$('map');const ex=m.querySelector('.map-layer-control');if(ex)ex.remove();
  m.insertAdjacentHTML('beforeend',`<div class="map-layer-control">
    <button class="map-layer-btn active" id="mbS" onclick="swMap('streets')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Map
    </button>
    <button class="map-layer-btn" id="mbSat" onclick="swMap('sat')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20"/><path d="M2 12h20"/></svg>Satelit
    </button>
  </div>`);
}
function swMap(type){
  if(!leafMap)return;
  leafMap.removeLayer(window._ml[window._mc]);leafMap.addLayer(window._ml[type]);window._mc=type;
  $('mbS').classList.toggle('active',type==='streets');$('mbSat').classList.toggle('active',type==='sat');
}

// Status Modal
function openStatusModal(){
  if(!tkData)return;
  const cur=tkData.status;selStatus=cur;$('statusNote').value='';
  $('statusGrid').innerHTML=SSTEPS.map(s=>`<div class="stop ${s.key===cur?'sel':''}" onclick="pickStatus('${s.key}',this)">
    <div class="stop-ico">${s.ico}</div>
    <div class="stop-txt">
      <div class="stop-lbl">${s.lbl}</div>
      <div class="stop-desc">${SD[s.key]||''}</div>
    </div>
  </div>`).join('');
  openM('mStatus');
}
function pickStatus(key,el){
  selStatus=key;
  document.querySelectorAll('.stop').forEach(e=>e.classList.remove('sel'));el.classList.add('sel');
}
async function submitStatus(){
  if(!selStatus||selStatus===tkData.status){showToast('Pilih status yang berbeda','warn');return;}
  try{
    const note=$('statusNote').value.trim();
    const j=await fetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:selStatus})}).then(r=>r.json());
    if(j.success){
      if(note)await fetch('/api/tickets/'+TID+'/timeline',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({content:note,type:'comment'})});
      closeM('mStatus');showToast('Status berhasil diupdate!','success');await loadTicket();
    }else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}

// Assign
function openAssignModal(){$('assNote').value='';openM('mAss');}
async function submitAssign(){
  const uid=$('assUid').value;if(!uid){showToast('Pilih teknisi!','warn');return;}
  try{
    const note=$('assNote').value.trim();
    const j=await fetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({assigned_to:uid,status:'in_progress'})}).then(r=>r.json());
    if(j.success){
      if(note)await fetch('/api/tickets/'+TID+'/timeline',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({content:note,type:'comment'})});
      closeM('mAss');showToast('Teknisi ditugaskan!','success');await loadTicket();
    }else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}

// Edit
function openEditModal(){
  if(!tkData)return;
  $('eTitle').value=tkData.title||'';$('eType').value=tkData.type||'gangguan';
  $('ePrio').value=tkData.priority||'medium';$('eDesc').value=tkData.description||'';
  openM('mEdit');
}
async function submitEdit(){
  const ti=$('eTitle').value.trim();if(!ti){showToast('Judul wajib!','warn');return;}
  try{
    const j=await fetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({title:ti,type:$('eType').value,priority:$('ePrio').value,description:$('eDesc').value.trim()||null})}).then(r=>r.json());
    if(j.success){closeM('mEdit');showToast('Ticket diupdate!','success');await loadTicket();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}

// Quick Close
async function quickClose(){
  if(!confirm('Tutup ticket ini?'))return;
  try{
    const j=await fetch('/api/tickets/'+TID,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status:'closed'})}).then(r=>r.json());
    if(j.success){showToast('Ticket ditutup','success');await loadTicket();}
    else showToast(j.message||'Error','error');
  }catch(e){showToast(e.message,'error');}
}

async function loadUsers(){
  try{
    const j=await fetch('/api/users?limit=100').then(r=>r.json());
    const us=j.data||j.users||[];const sel=$('assUid');
    us.forEach(u=>{const o=document.createElement('option');o.value=u.id;o.textContent=u.name+(u.role?` (${u.role})`:''  );sel.appendChild(o);});
  }catch(e){}
}

function showToast(msg,type='info'){
  const COL={success:'#15803d',error:'#dc2626',warn:'#d97706',info:'#1d4ed8'};
  const t=document.createElement('div');
  t.style.cssText=`position:fixed;bottom:20px;right:20px;z-index:99999;padding:11px 18px;border-radius:9px;background:${COL[type]||'#1d4ed8'};color:#fff;font-size:13px;font-weight:700;box-shadow:0 4px 20px rgba(0,0,0,.2);animation:mIn .25s ease-out;max-width:300px;`;
  t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),3000);
}
function openLb(src){$('lbi').src=src;$('lb').classList.add('show');}
function openM(id){$(id).classList.add('show');}
function closeM(id){$(id).classList.remove('show');}
document.querySelectorAll('.mover').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('show');}));
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){['mStatus','mAss','mEdit'].forEach(closeM);$('lb').classList.remove('show');}
  if(e.ctrlKey&&e.key==='Enter')sendComment();
});
</script>
</body>
</html>
