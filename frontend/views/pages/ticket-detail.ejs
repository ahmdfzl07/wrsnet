// ASIGN ODP
// ─────────────────────────────────────────────────────────────
var pendingLat = null;
var pendingLng = null;
var map = null;
var odpEventBound = false;

function getTicketIdFromUrl() {
  const path = window.location.pathname;
  const parts = path.split("/").filter(Boolean);
  return parts[parts.length - 1];
}

document.addEventListener("DOMContentLoaded", async function () {
  updateCoordPreview(null, null);

  try {
    const ticketId = window.location.pathname.split("/").pop();

    const response = await fetch(`/api/tickets/${ticketId}`);

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}`);
    }

    const res = await response.json();

    const btnAssignOdp = document.getElementById("btnAssignOdp");
    const btnCekOdp = document.getElementById("btnCekOdp");

    const role = window.currentUser?.role;

    // if (role === "technician") {
    //   btnAssignOdp.style.display = "inline-flex";
    // } else {
    //   btnAssignOdp.style.display = "none";
    // }

    if (res.odp && res.odp.id) {
      btnAssignOdp.style.display = "none";
      btnCekOdp.style.display = "inline-flex";
      window.currentOdp = res.odp;
    } else {
      btnCekOdp.style.display = "none";

      if (role === "technician") {
        btnAssignOdp.style.display = "inline-flex";
      }
    }

  } catch (err) {
    console.error("Gagal memuat data ticket:", err);
  }

  document.addEventListener("input", function (e) {
    if (e.target.id === "manualLat" || e.target.id === "manualLng") {
      applyManualCoord();
    }
  });

  const latInput = document.getElementById("manualLat");
  const lngInput = document.getElementById("manualLng");

  if (latInput) latInput.setAttribute("readonly", true);
  if (lngInput) lngInput.setAttribute("readonly", true);
});

function initMapOdp() {
  if (typeof L === "undefined") return;

  map = L.map("map").setView([-6.2, 106.8], 13);

  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

  map.on("click", function (e) {
    const lat = e.latlng.lat;
    const lng = e.latlng.lng;

    pendingLat = lat;
    pendingLng = lng;

    document.getElementById("manualLat").value = lat.toFixed(6);
    document.getElementById("manualLng").value = lng.toFixed(6);

    updateCoordPreview(lat, lng);
  });
}

async function openAssignOdpModal() {
  const ticketId = getTicketIdFromUrl();

  if (!ticketId) {
    alert("ID ticket tidak ditemukan");
    return;
  }

  try {
    const res = await fetch(`/api/tickets/${ticketId}`);
    if (!res.ok) return;

    const result = await res.json();
    const ticket = result.data;

    if (!ticket) return;

    const lat =
      ticket.customerRegistration?.latitude ??
      ticket.customer?.latitude ??
      ticket.latitude ??
      null;

    const lng =
      ticket.customerRegistration?.longitude ??
      ticket.customer?.longitude ??
      ticket.longitude ??
      null;

    pendingLat = lat;
    pendingLng = lng;

    document.getElementById("manualLat").value = lat ?? "";
    document.getElementById("manualLng").value = lng ?? "";

    updateCoordPreview(lat, lng);

    if (lat && lng && map && typeof map.setView === "function") {
      map.setView([lat, lng], 15);
    }

    await loadParentSelects(ticket);
    updateOdpButton(ticket);

    document.getElementById("infraModal").style.display = "flex";

    if (!odpEventBound) {
      odpEventBound = true;

      document.addEventListener("click", function (e) {
        const btn = e.target.closest("#odp-upload-btn");

        if (btn) {
          const input = document.getElementById("odp-photo-input");
          if (input) {
            input.value = "";
            input.click();
          }
        }

        const removeBtn = e.target.closest("#odp-photo-remove");
        if (removeBtn) {
          removeOdpPhoto();
        }

        if (e.target.id === "odp-photo-preview" && e.target.src) {
          window.open(e.target.src, "_blank");
        }
      });

      document.addEventListener("change", function (e) {
        if (e.target.id !== "odp-photo-input") return;

        const file = e.target.files && e.target.files[0];
        if (!file) return;

        const prev = document.getElementById("odp-photo-preview");
        const remBtn = document.getElementById("odp-photo-remove");
        const btn = document.getElementById("odp-upload-btn");

        const reader = new FileReader();

        reader.onload = (ev) => {
          if (prev) {
            prev.src = ev.target.result;
            prev.style.display = "block";
          }

          if (remBtn) remBtn.style.display = "inline-block";

          if (btn) {
            btn.innerHTML =
              '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg> ' +
              (file.name.length > 20
                ? file.name.slice(0, 18) + "…"
                : file.name);
          }
        };

        reader.readAsDataURL(file);
      });
    }
  } catch (err) {
    console.error(err);
  }
}

function openCekOdp() {
  const modal = document.getElementById("cekOdpModal");
  const odp = window.currentOdp;

  if (!modal || !odp) return;

  // document.getElementById("odpUsed").innerText = odp.used_ports || 0;
  // document.getElementById("odpCapacity").innerText = odp.capacity || 0;

  const percent = odp.capacity
    ? (odp.used_ports / odp.capacity) * 100
    : 0;

  // document.getElementById("odpProgress").style.width = percent + "%";

  document.getElementById("odpNotes").innerText = odp.notes || "-";

  const img = document.getElementById("odpImage");

  if (odp.metadata?.photo_url) {
    img.src = odp.metadata.photo_url;
  }

  modal.style.display = "flex";
}

function navigateOdp() {
  const odp = window.currentOdp;
  if (!odp) return;

  const lat = odp.latitude;
  const lng = odp.longitude;

  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition((pos) => {
      const origin = `${pos.coords.latitude},${pos.coords.longitude}`;
      const destination = `${lat},${lng}`;

      const url = `https://www.google.com/maps/dir/?api=1&origin=${origin}&destination=${destination}&travelmode=driving`;

      window.open(url, "_blank");
    });
  } else {
    const url = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}&travelmode=driving`;
    window.open(url, "_blank");
  }
}

function updateOdpButton(ticket) {
  const infra = ticket.infraPoint;

  const assignBtn = document.getElementById("btnAssignOdp");
  const cekBtn = document.getElementById("btnCekOdp");

  const hasOdp = infra && infra.ticket_id;

  if (hasOdp) {
    if (assignBtn) assignBtn.style.display = "none";
    if (cekBtn) cekBtn.style.display = "inline-flex";
  } else {
    if (assignBtn) assignBtn.style.display = "inline-flex";
    if (cekBtn) cekBtn.style.display = "none";
  }
}

async function loadParentSelects(ticket) {
  const odcSel = document.getElementById("odp-parent");
  if (!odcSel) return;

  try {
    const res = await fetch("/api/infrastructure?type=odc");
    const result = await res.json();

    const list = Array.isArray(result)
      ? result
      : result?.data || [];

    odcSel.innerHTML = `<option value="">-- Tidak ada --</option>`;

    list.forEach((item) => {
      odcSel.innerHTML += `<option value="${item.id}">${item.name}</option>`;
    });

    const parentId =
      ticket.customerRegistration?.parent_id ??
      ticket.customer?.parent_id ??
      null;

    if (parentId) odcSel.value = parentId;

  } catch (e) {
    console.error("loadParentSelects error:", e);
  }
}

function removeOdpPhoto() {
  const prev = document.getElementById("odp-photo-preview");
  const urlEl = document.getElementById("odp-photo-url");
  const input = document.getElementById("odp-photo-input");
  const remBtn = document.getElementById("odp-photo-remove");
  const btn = document.getElementById("odp-upload-btn");

  if (prev) {
    prev.src = "";
    prev.style.display = "none";
  }

  if (urlEl) urlEl.value = "";
  if (input) input.value = "";
  if (remBtn) remBtn.style.display = "none";

  if (btn) {
    btn.innerHTML = `
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
        <polyline points="17,8 12,3 7,8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
      Upload Foto
    `;
  }
}

function applyManualCoord() {
  const lat = parseFloat(document.getElementById("manualLat").value);
  const lng = parseFloat(document.getElementById("manualLng").value);

  if (
    !isNaN(lat) &&
    !isNaN(lng) &&
    lat >= -90 &&
    lat <= 90 &&
    lng >= -180 &&
    lng <= 180
  ) {
    pendingLat = lat;
    pendingLng = lng;

    updateCoordPreview(lat, lng);

    if (map) {
      map.setView([lat, lng], map.getZoom ? map.getZoom() : 13);
    }
  }
}

function updateCoordPreview(lat, lng) {
  const el = document.getElementById("coordPreview");
  const dot = document.getElementById("coordDot");

  if (!el) return;

  if (lat !== null && lng !== null) {
    el.innerHTML = `<strong>${(+lat).toFixed(6)}</strong>, <strong>${(+lng).toFixed(6)}</strong>`;
    if (dot) dot.style.background = "#22c55e";
  } else {
    el.innerHTML = "Belum ada koordinat";
    if (dot) dot.style.background = "#e2e8f0";
  }
}

function closeModal() {
  document.getElementById("infraModal").style.display = "none";
}

function closeCekOdp() {
  document.getElementById("cekOdpModal").style.display = "none";
}

async function uploadOdpPhoto(file) {
  const btn = document.getElementById("odp-upload-btn");
  const preview = document.getElementById("odp-photo-preview");
  const urlEl = document.getElementById("odp-photo-url");

  if (btn) btn.innerHTML = "⏳ Mengupload...";

  const form = new FormData();
  form.append("photo", file);

  const token = localStorage.getItem("token");
  const headers = {};

  if (token && token !== "null") {
    headers["Authorization"] = "Bearer " + token;
  }

  try {
    const res = await fetch("/api/upload/infra-photo", {
      method: "POST",
      headers,
      credentials: "include",
      body: form,
    });

    const data = await res.json();

    if (!data.success) throw new Error(data.message || "Upload gagal");

    if (urlEl) urlEl.value = data.url;
    if (preview) preview.src = data.url;

    if (btn) {
      btn.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 6L9 17l-5-5"/>
        </svg> Terupload
      `;
    }

    return data.url;
  } catch (err) {
    if (btn) {
      btn.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
          <polyline points="17,8 12,3 7,8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg> Upload Foto
      `;
    }

    throw err;
  }
}

async function savePoint() {
  const ticketId = getTicketIdFromUrl();
  if (pendingLat === null || pendingLng === null) {
    const infraModal = document.getElementById("infraModal");

    showToast("Klik peta untuk memilih koordinat lokasi", "warning");
    enterPlaceMode(activeTab);
    return;
  }

  const infraModal = document.getElementById("infraModal");

  const btn = document.getElementById("saveBtn");
  btn.textContent = "Menyimpan...";
  btn.disabled = true;

  let payload = {
    latitude: pendingLat,
    longitude: pendingLng,
  };

  try {
    const name = document.getElementById("odp-name")?.value?.trim();
    if (!name) {
      alert("Nama ODP wajib");
      return;
    }
    if (!ticketId) {
      alert("ID Ticket tidak ditemukan");
      return;
    }

    const photoFile = document.getElementById("odp-photo-input")?.files?.[0];
    const photoUrlEl = document.getElementById("odp-photo-url");

    let finalPhotoUrl = photoUrlEl?.value || "";

    if (photoFile) {
      finalPhotoUrl = await uploadOdpPhoto(photoFile);
    }

    let existMeta = {};
    try {
      existMeta = photoUrlEl?.dataset?.existMeta
        ? JSON.parse(photoUrlEl.dataset.existMeta)
        : {};
    } catch (e) {
      existMeta = {};
    }

    const metadata = {
      ...existMeta,
      photo_url: finalPhotoUrl || undefined,
    };

    if (!metadata.photo_url) delete metadata.photo_url;

    payload = {
      ...payload,
      type: "odp",
      name,
      capacity:
        parseInt(document.getElementById("odp-capacity")?.value) || null,
      used_ports: parseInt(document.getElementById("odp-used")?.value) || 0,
      parent_id: document.getElementById("odp-parent")?.value
        ? parseInt(document.getElementById("odp-parent").value)
        : null,
      address: document.getElementById("odp-address")?.value || "",
      status: document.getElementById("odp-status")?.value || "active",
      notes: document.getElementById("odp-notes")?.value || "",
      metadata: Object.keys(metadata).length ? metadata : null,
      ticket_id: Number(ticketId),
    };

    const customerCoordPromise = payload._customerCoordPromise;
    delete payload._customerCoordPromise;

    const request = fetch("/api/infrastructure", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(payload),
    }).then(async (res) => {
      const data = await res.json();
      return data;
    });

    const tasks = [request];

    if (customerCoordPromise) {
      tasks.push(customerCoordPromise);
    }

    const [res] = await Promise.all(tasks);

    if (res?.success) {
      showToast("ODP berhasil dibuat", "success");
      closeModal();
    } else {
      alert("Gagal: " + (res?.message || "Error"));
    }
  } catch (e) {
    console.error(e);
    alert("Gagal menyimpan: " + (e?.message || "Network error"));
  } finally {
    btn.textContent = "Simpan";
    btn.disabled = false;
  }
}

