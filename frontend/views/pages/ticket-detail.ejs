                Update Status
              </button>
              <button class="qab qab-primary" id="tugaskanBtn" onclick="openAssignModal()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                Tugaskan Teknisi
              </button>
              <!-- <button class="qab qab-info" id="btnAssignOdp" onclick="openAssignOdpModal()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="8" x2="12" y2="16"/>
                  <line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
                Assign ODP
              </button>

              <button class="qab qab-success" id="btnCekOdp" onclick="openCekOdp()" style="display:none;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                Cek ODP
              </button> -->
              <button class="qab qab-warning" id="editPelangganBtn" onclick="openEditModalPelanggan()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Informasi Pelanggan
              </button>
              <button class="qab qab-warning" onclick="openEditModal()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Detail
              </button>
              <button class="qab qab-success" id="closeBtn" onclick="quickClose()" style="display:none;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                Close Ticket
              </button>
              <hr style="border:none;border-top:1px solid #f0f0f0;margin:2px 0;">
              <a href="/tickets" class="qab qab-gray">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Kembali
              </a>
            </div>
          </div>

          <!-- Status Progress -->
          <div class="sidebar-card">
            <h4 class="sidebar-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              Status Progress
            </h4>
            <div class="sflow" id="sflow"></div>
          </div>
        </div>
      </div>
    </main>

    <!-- Loading -->
    <div id="loadingDiv" style="display:flex;align-items:center;justify-content:center;min-height:60vh;">
      <div style="text-align:center;color:#718096;">
        <i class="fas fa-spinner fa-pulse" style="font-size:36px;color:var(--nv);margin-bottom:16px;display:block;"></i>
        <div>Memuat detail ticket...</div>
      </div>
    </div>

    <%- include('../partials/footer') %>
  </div>
</div>

<!-- Lightbox -->
<div class="lb" id="lb" onclick="this.classList.remove('show')">
