  </div>
</div>

<script>const TID='<%= ticketId %>';</script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
'use strict';
let tkData=null,leafMap=null,selFiles=[],selStatus=null;
const $=id=>document.getElementById(id);
const esc=s=>String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
const fd=d=>d?new Date(d).toLocaleString('id-ID',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}):'—';
const fd2=d=>d?new Date(d).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}):'—';

const TC={gangguan:'#dc2626',request:'#1d4ed8',installation:'#16a34a',maintenance:'#d97706'};
const TL={gangguan:'Gangguan',request:'Request',installation:'Instalasi',maintenance:'Maintenance'};
const PL={critical:'Critical',high:'Tinggi',medium:'Sedang',low:'Rendah'};
const PC={critical:'p-crit',high:'p-high',medium:'p-med',low:'p-low'};
const SL={open:'Open',in_progress:'In Progress',pending:'Pending',resolved:'Resolved',closed:'Closed'};
const SC={open:'s-open',in_progress:'s-prog',pending:'s-pend',resolved:'s-res',closed:'s-cls'};
const SI={open:'',in_progress:'',pending:'⏳',resolved:'',closed:''};
const SD={open:'Menunggu penanganan',in_progress:'Sedang ditangani',pending:'Menunggu / on hold',resolved:'Masalah diselesaikan',closed:'Ticket ditutup'};

const svgI=d=>`<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;
const SICONS={
  plus:'<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>',
  assign:'<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>',
  change:'<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>',
  msg:'<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  img:'<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>',
  cog:'<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
};
const TLICON={created:SICONS.plus,assigned:SICONS.assign,assignment:SICONS.assign,reassigned:SICONS.change,status_change:SICONS.change,status_changed:SICONS.change,comment:SICONS.msg,photo:SICONS.img,system:SICONS.cog};
const TLCOLOR={created:'#16a34a',assigned:'#d97706',assignment:'#d97706',reassigned:'#7c3aed',status_change:'#1d4ed8',status_changed:'#1d4ed8',comment:'#0891b2',photo:'#0891b2',system:'#6b7280'};
const TLLBL={created:'Dibuat',assigned:'Ditugaskan',assignment:'Ditugaskan',reassigned:'Dialihkan',status_change:'Status Update',status_changed:'Status Update',comment:'Komentar',photo:'Foto',system:'Sistem'};

document.addEventListener('DOMContentLoaded',()=>{loadTicket();loadUsers();});

async function loadTicket(){
  try{
    const j=await fetch('/api/tickets/'+TID).then(r=>r.json());
    if(!j.success){$('loadingDiv').innerHTML=`<div style="text-align:center;color:#dc2626;padding:40px;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-bottom:12px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><div style="font-weight:700;">Ticket tidak ditemukan</div><a href="/tickets" style="color:var(--nv);font-weight:700;margin-top:8px;display:inline-block;">← Kembali</a></div>`;return;}
    tkData=j.data;renderTicket(tkData);
    $('loadingDiv').style.display='none';$('mainContent').style.display='block';
  }catch(e){$('loadingDiv').innerHTML=`<div style="text-align:center;color:#dc2626;padding:40px;">Error: ${e.message}</div>`;}
}

function renderTicket(t){
  // Header card
  $('hNum').textContent='Ticket #'+String(t.id).padStart(4,'0');
  $('hTitle').textContent=t.title;
  const tc=TC[t.type]||'#666';
  const PC2={'critical':'#ef4444','high':'#f97316','medium':'#eab308','low':'#22c55e'};
  const SC2={'open':'#f59e0b','in_progress':'#3b82f6','pending':'#8b5cf6','resolved':'#22c55e','closed':'#9ca3af'};
  const pc=PC2[t.priority]||'rgba(255,255,255,.3)';
  const sc=SC2[t.status]||'rgba(255,255,255,.3)';
  const dateStr=fd2(t.created_at);
  $('hMeta').innerHTML=`
    ${dateStr&&dateStr!=='—'?`<span class="meta-item"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ${dateStr}</span>`:''}
    <span class="meta-item" style="background:${tc}28;border-color:${tc}50;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg> ${TL[t.type]||t.type}</span>
    <span class="meta-item" style="background:${pc}28;border-color:${pc}55;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${pc}" stroke-width="2.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg> ${PL[t.priority]||t.priority}</span>
    <span class="meta-item" style="background:${sc}28;border-color:${sc}55;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${sc}" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ${SI[t.status]||''} ${SL[t.status]||t.status}</span>`;

  // Customer
  if(t.customer){
    const c=t.customer;$('custCard').style.display='block';
    $('custGrid').innerHTML=`
      <div class="info-item" style="grid-column:1/-1;"><div class="info-label">ID PELANGGAN</div><div class="info-value">${esc(c.customer_id||'—')}</div></div>
      <div class="info-item"><div class="info-label">NAMA LENGKAP</div><div class="info-value">${esc(c.name)}</div></div>
      <div class="info-item"><div class="info-label">NO. WHATSAPP</div><div class="info-value"><a href="https://wa.me/62${(c.phone||'').replace(/^0/,'')}" target="_blank"><i class="fab fa-whatsapp" style="color:#25d366;"></i> ${esc(c.phone||'—')}</a></div></div>
      <div class="info-item"><div class="info-label">EMAIL</div><div class="info-value">${esc(c.email||'—')}</div></div>
      <div class="info-item" style="grid-column:1/-1;"><div class="info-label">ALAMAT LENGKAP</div><div class="info-value">${esc(c.address||'—')}</div></div>`;
  } else {
    const c=t.customerRegistration;$('custCard').style.display='block';
    $('custGrid').innerHTML=`
      <div class="info-item"><div class="info-label">NAMA LENGKAP</div><div class="info-value">${esc(c.name)}</div></div>
      <div class="info-item"><div class="info-label">NO. WHATSAPP</div><div class="info-value"><a href="https://wa.me/62${(c.phone||'').replace(/^0/,'')}" target="_blank"><i class="fab fa-whatsapp" style="color:#25d366;"></i> ${esc(c.phone||'—')}</a></div></div>
      <div class="info-item"><div class="info-label">EMAIL</div><div class="info-value">${esc(c.email||'—')}</div></div>
      <div class="info-item" style="grid-column:1/-1;"><div class="info-label">ALAMAT LENGKAP</div><div class="info-value">${esc(c.address||'—')}</div></div>`;
  }

  // Detail grid
  $('detailGrid').innerHTML=`
    <div class="info-item"><div class="info-label">KATEGORI</div><div class="info-value">${TL[t.type]||t.type}</div></div>
    <div class="info-item"><div class="info-label">PRIORITAS</div><div class="info-value">${PL[t.priority]||t.priority}</div></div>
    <div class="info-item"><div class="info-label">STATUS</div><div class="info-value">${SI[t.status]||''} ${SL[t.status]||t.status}</div></div>
    <div class="info-item"><div class="info-label">TEKNISI</div><div class="info-value">${t.assignee?esc(t.assignee.name):'<span style="color:#e65100;">Belum ditugaskan</span>'}</div></div>
    <div class="info-item"><div class="info-label">DIBUAT</div><div class="info-value">${fd(getCreatedAt(t))}</div></div>
    <div class="info-item"><div class="info-label">DUE DATE</div><div class="info-value">${t.due_at?fd(t.due_at):'—'}</div></div>
    ${t.resolved_at?`<div class="info-item"><div class="info-label">DISELESAIKAN</div><div class="info-value">${fd(t.resolved_at)}</div></div>`:''}
    ${t.closed_at?`<div class="info-item"><div class="info-label">DITUTUP</div><div class="info-value">${fd(t.closed_at)}</div></div>`:''}
    ${t.location_note?`<div class="info-item" style="grid-column:1/-1;"><div class="info-label">CATATAN LOKASI</div><div class="info-value">${esc(t.location_note)}</div></div>`:''}`;
  if(t.description){$('descSection').style.display='block';$('descBox').textContent=t.description;}

  // Close btn
  if(!['resolved','closed'].includes(t.status)) $('closeBtn').style.display='flex';
  else $('closeBtn').style.display='none';

  renderSLA(t);
  renderStatusFlow(t.status);

  // Map
  const lat=parseFloat(t.latitude||t.customer?.latitude||t.infraPoint?.latitude);
  const lng=parseFloat(t.longitude||t.customer?.longitude||t.infraPoint?.longitude);
  if(!isNaN(lat)&&!isNaN(lng)){
    $('mapCard').style.display='block';
    setTimeout(()=>initMap(lat,lng,t),300);
    if(t.customer){
      const c=t.customer;
      $('mapBtns').innerHTML=`<a href="https://www.google.com/maps?q=${lat},${lng}" target="_blank" class="btn btn-primary" style="width:auto;margin-bottom:0;"><i class="fas fa-map"></i> Maps</a>${c.phone?`<a href="https://wa.me/62${(c.phone).replace(/^0/,'')}" target="_blank" class="btn btn-success" style="width:auto;margin-bottom:0;"><i class="fab fa-whatsapp"></i> Hubungi</a>`:''}`;
    }
  }

  renderTimeline(t.timelines||[]);
}

let slaChart = null;

/* Ambil created_at dengan fallback lengkap
   — field camelCase / snake_case / timestamp pertama dari timeline */
function getCreatedAt(t){
  if(!t) return null;
  return t.created_at
      || t.createdAt
      || t.created
      || (Array.isArray(t.timelines) && t.timelines.length
            ? (t.timelines[0].created_at || t.timelines[0].createdAt)
            : null);
}

/* Format durasi ms → teks natural Indonesia */
function fmtResolutionTime(ms){
  if(ms < 0) ms = 0;
  const s = Math.floor(ms / 1000);
  if(s < 60) return s + ' detik';
  const m = Math.floor(s / 60);
  if(m < 60) return m + ' menit';
  const h = Math.floor(m / 60);
  const rm = m % 60;
  if(h < 24) return rm > 0 ? h + ' jam ' + rm + ' menit' : h + ' jam';
  const d = Math.floor(h / 24);
  const rh = h % 24;
  if(d < 7) return rh > 0 ? d + ' hari ' + rh + ' jam' : d + ' hari';
  const w = Math.floor(d / 7);
  const rd = d % 7;
  return rd > 0 ? w + ' minggu ' + rd + ' hari' : w + ' minggu';
}

/* Build sub-label "Dibuat → Selesai" */
function buildResolutionSub(t, endAt){
  const created = new Date(getCreatedAt(t));
  const ended = new Date(endAt);
  const fmtShort = (d) => {
    const sameDay = created.toDateString() === ended.toDateString();
    if(sameDay){
      return d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
    }
    return d.toLocaleDateString('id-ID', { day: 'numeric', month: 'short' }) + ' ' +
           d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
  };
  return fmtShort(created) + ' → ' + fmtShort(ended);
}

/* Render resolution-time panel (extracted supaya bisa di-reuse) */
function renderResolutionPanel(t){
  const rtPanel = document.getElementById('resolutionTime');
  if(!rtPanel) return;
  const done = ['resolved','closed'].includes(t.status);
  const endAt = t.resolved_at || t.closed_at;
  const createdAt = getCreatedAt(t);

  if(done && createdAt && endAt){
    const ms = new Date(endAt) - new Date(createdAt);
    if(ms >= 0){
      const duration = fmtResolutionTime(ms);
      const onTime = t.due_at ? (new Date(endAt) <= new Date(t.due_at)) : null;
      document.getElementById('rtDuration').textContent = 'Terselesaikan dalam ' + duration;
      document.getElementById('rtSub').textContent = buildResolutionSub(t, endAt);

      const badge = document.getElementById('rtBadge');
      if(onTime === true){
        badge.className = 'rt-badge ontime';
        badge.textContent = 'On-Time';
        badge.style.display = '';
        rtPanel.style.background = 'linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%)';
        rtPanel.style.borderColor = '#a7f3d0';
        document.querySelector('#resolutionTime .rt-head').style.color = '#047857';
        document.getElementById('rtDuration').style.color = '#065f46';
        document.getElementById('rtSub').style.color = '#059669';
      } else if(onTime === false){
        badge.className = 'rt-badge late';
        badge.textContent = 'SLA Lewat';
        badge.style.display = '';
        rtPanel.style.background = 'linear-gradient(135deg,#fef2f2 0%,#fee2e2 100%)';
        rtPanel.style.borderColor = '#fecaca';
        document.querySelector('#resolutionTime .rt-head').style.color = '#b91c1c';
        document.getElementById('rtDuration').style.color = '#7f1d1d';
        document.getElementById('rtSub').style.color = '#dc2626';
      } else {
        badge.style.display = 'none';
        rtPanel.style.background = 'linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%)';
        rtPanel.style.borderColor = '#a7f3d0';
      }
      rtPanel.classList.add('show');
      return;
    }
  }

  if(done && endAt){
    // Fallback: tanpa created_at
    document.getElementById('rtDuration').textContent = 'Diselesaikan ' + new Date(endAt).toLocaleString('id-ID', {day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
    document.getElementById('rtSub').textContent = 'Durasi tidak tersedia (tanggal pembuatan hilang)';
    const badge = document.getElementById('rtBadge');
    if(badge) badge.style.display = 'none';
    rtPanel.style.background = '#f8fafc';
    rtPanel.style.borderColor = '#e2e8f0';
    document.querySelector('#resolutionTime .rt-head').style.color = '#64748b';
    document.getElementById('rtDuration').style.color = '#334155';
    document.getElementById('rtSub').style.color = '#94a3b8';
    rtPanel.classList.add('show');
  } else {
    rtPanel.classList.remove('show');
  }
}

function renderSLA(t){
  const done=['resolved','closed'].includes(t.status);
  $('slaBadge').textContent=done?(t.status==='closed'?'Ditutup':'Selesai'):'Aktif';
  $('slaBadge').className='sbadge '+(done?'s-res':'s-prog');

  let pct=0, color='#16a34a', remText='—', tgtText='—', dueText='';

  if(done){
    pct=100; color='#16a34a';
    tgtText=(t.sla_hours||24)+'h';
    remText=t.status==='closed'?'Ditutup':'Selesai';
    dueText='';
  } else if(!t.due_at){
    pct=0; color='#16a34a';
    tgtText=(t.sla_hours||24)+'h';
    remText='—';
  } else {
    const cr=new Date(getCreatedAt(t)||Date.now()).getTime(),due=new Date(t.due_at).getTime(),now=Date.now();
    const total=due-cr;
    pct=total>0?Math.min(100,Math.max(0,(now-cr)/total*100)):0;
    if(isNaN(pct))pct=0;
    const rem=due-now,over=rem<0;
    const h=Math.floor(Math.abs(rem)/3600000),m=Math.floor((Math.abs(rem)%3600000)/60000);
    const rs=h>24?`${Math.floor(h/24)}h ${h%24}j`:h>0?`${h}j ${m}m`:`${m} menit`;
    color=over?'#dc2626':pct>80?'#ea580c':pct>60?'#d97706':'#16a34a';
    tgtText=(t.sla_hours||24)+'h';
    remText=over?`⚠ ${rs}`:rs;
    $('slaRem').style.color=color;
    dueText='Due: '+fd(t.due_at);
  }

  $('slaTgt').textContent=tgtText;
  $('slaRem').textContent=remText;
  $('slaRem').style.color=color;
  $('slaDue').textContent=dueText;

  // Render resolution panel (kalau status done)
  renderResolutionPanel(t);

  const safePct=isNaN(pct)?0:Math.round(pct);
  // Render ApexCharts radial gauge
  const gaugeOpts={
    series:[safePct],
    chart:{type:'radialBar',height:130,width:120,sparkline:{enabled:true}},
    plotOptions:{radialBar:{
      startAngle:-135,endAngle:135,
      hollow:{size:'55%'},
      track:{background:'#f0f0f0',strokeWidth:'97%',margin:4},
      dataLabels:{
        name:{show:true,offsetY:16,color:'#9ca3af',fontSize:'9px',fontWeight:700,fontFamily:'Inter',formatter:()=>'SLA'},
        value:{offsetY:-10,color:color,fontSize:'18px',fontWeight:800,fontFamily:'Inter',formatter:v=>v+'%'}
      }
    }},
    fill:{type:'gradient',gradient:{shade:'dark',type:'horizontal',gradientToColors:[color],stops:[0,100],colorStops:[
      {offset:0,color:done?'#22c55e':pct>80?'#f97316':pct>60?'#facc15':'#4ade80',opacity:1},
      {offset:100,color:color,opacity:1}
    ]}},
    stroke:{lineCap:'round'},
    labels:['SLA'],
  };

  if(slaChart){slaChart.updateOptions(gaugeOpts,true,true);}
  else{
    const el=$('slaGaugeChart');
    if(el&&window.ApexCharts){slaChart=new ApexCharts(el,gaugeOpts);slaChart.render();}
  }
}

