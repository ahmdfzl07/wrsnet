  <img id="lbi" src="" alt="">
</div>

<!-- Modal: Update Status -->
<div class="mover" id="mStatus">
  <div class="mbox">
    <div class="mhd">
      <h3><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>Update Status Ticket</h3>
      <button class="mcls" onclick="closeM('mStatus')">×</button>
    </div>
    <div class="mbdy">
      <p style="font-size:12px;color:var(--g500);margin:0 0 14px;">Pilih status baru untuk ticket ini:</p>
      <div class="stgrid" id="statusGrid"></div>
      <div class="fg" style="margin-top:14px;">
        <label class="fl">Catatan Update (opsional)</label>
        <textarea id="statusNote" class="fc" rows="3" placeholder="Catatan untuk update status ini..."></textarea>
      </div>
      <button class="btn btn-prim" style="width:100%;" onclick="submitStatus()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Simpan Status
      </button>
    </div>
  </div>
</div>

<!-- Modal: Assign -->
<div class="mover" id="mAss">
  <div class="mbox" style="max-width:420px;">
    <div class="mhd">
      <h3><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>Tugaskan Teknisi</h3>
      <button class="mcls" onclick="closeM('mAss')">×</button>
    </div>
    <div class="mbdy">
      <div class="fg">
        <label class="fl">Pilih Teknisi *</label>
        <select id="assUid" class="fc"><option value="">-- Pilih Teknisi --</option></select>
      </div>
      <div class="fg">
        <label class="fl">Catatan (opsional)</label>
        <textarea id="assNote" class="fc" rows="2" placeholder="Instruksi atau catatan untuk teknisi..."></textarea>
      </div>
      <button class="btn btn-prim" style="width:100%;" onclick="submitAssign()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>Tugaskan
      </button>
    </div>
  </div>
</div>

<!-- Modal: Edit pelanggan-->
<div class="mover" id="mEditPelanggan">
  <div class="mbox" style="max-width:540px;">
    <div class="mhd">
      <h3><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Edit Detail Pelanggan</h3>
      <button class="mcls" onclick="closeM('mEditPelanggan')">×</button>
    </div>
    <div class="mbdy">
      <div class="frow">
        <div class="fg">
          <label class="fl">No HP *</label>
          <input type="text" id="eNoHp" class="fc" placeholder="no  hp...">
        </div>
        <div class="fg">
          <label class="fl">Email *</label>
          <input type="text" id="eMail" class="fc" placeholder="Email...">
        </div>
      </div>
      <div class="fg">
        <label class="fl">Alamat</label>
        <textarea id="eAlamat" class="fc" rows="4" placeholder="Alamat detail..."></textarea>
      </div>
      <div class="frow">
        <div class="fg">
          <label class="fl">latitude *</label>
          <input type="text" id="eLat" class="fc" readonly>
        </div>
        <div class="fg">
          <label class="fl">longitude *</label>
          <input type="text" id="eLong" class="fc" readonly>
        </div>
      </div>
      <div class="fg">
        <label class="fl">Pilih Lokasi di Map</label>
        <div id="mapEdit" style="height:300px; border-radius:8px;"></div>
      </div>
      <button class="btn btn-prim" style="width:100%;" onclick="submitEditPelanggan()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 0-2-2V5a2 2 0 0 0 2-2h11l5 5v14a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>Simpan
      </button>
    </div>
  </div>
</div>

<!-- Modal: Edit -->
<div class="mover" id="mEdit">
  <div class="mbox" style="max-width:540px;">
    <div class="mhd">
      <h3><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Edit Detail Ticket</h3>
      <button class="mcls" onclick="closeM('mEdit')">×</button>
    </div>
    <div class="mbdy">
      <div class="fg">
        <label class="fl">Judul Ticket *</label>
        <input type="text" id="eTitle" class="fc" placeholder="Judul ticket...">
      </div>
      <div class="frow">
        <div class="fg">
          <label class="fl">Kategori</label>
          <select id="eType" class="fc">
            <option value="gangguan">Gangguan</option><option value="request">Request</option>
            <option value="installation">Instalasi</option><option value="maintenance">Maintenance</option>
          </select>
        </div>
        <div class="fg">
          <label class="fl">Prioritas</label>
          <select id="ePrio" class="fc">
            <option value="low">Rendah</option><option value="medium">Sedang</option>
            <option value="high">Tinggi</option><option value="critical">Critical</option>
          </select>
        </div>
      </div>
      <div class="fg">
        <label class="fl">Deskripsi</label>
        <textarea id="eDesc" class="fc" rows="4" placeholder="Deskripsi detail..."></textarea>
      </div>
      <button class="btn btn-prim" style="width:100%;" onclick="submitEdit()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 0-2-2V5a2 2 0 0 0 2-2h11l5 5v14a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>Simpan
      </button>
    </div>
  </div>
</div>

<!-- Modal asign ODP -->
<div class="modal-overlay" id="infraModal">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle">Tambah Titik Infrastruktur</h2>
      <button class="modal-close" onclick="closeModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body">
      <div style="background:var(--bg-secondary);border-radius:10px;padding:12px 14px;margin-bottom:14px;border:1.5px solid var(--border)">
        <!-- Header row -->
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <div style="display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--text-primary)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Lokasi
          </div>
        </div>

        <!-- Koordinat display -->
        <div id="coordPreviewWrap" style="display:flex;align-items:center;gap:8px">
          <div id="coordDot" style="width:8px;height:8px;border-radius:50%;background:#e2e8f0;flex-shrink:0"></div>
          <span id="coordPreview" style="font-size:12px;color:var(--text-secondary)">Belum dipilih — klik tombol di atas</span>
        </div>

        <!-- Manual input (hidden by default) -->
        <div id="coordManualWrap" style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border)">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <div>
              <label style="font-size:10px;font-weight:600;color:var(--text-secondary);letter-spacing:.05em;text-transform:uppercase;display:block;margin-bottom:4px">Latitude</label>
              <input type="number" id="manualLat" step="0.000001" placeholder="-6.391581" readonly
                style="width:100%;padding:7px 10px;border-radius:7px;border:1.5px solid var(--border);background:var(--bg-card);font-size:12px;font-family:monospace;color:var(--text-primary);outline:none"
                oninput="applyManualCoord()">
            </div>
            <div>
              <label style="font-size:10px;font-weight:600;color:var(--text-secondary);letter-spacing:.05em;text-transform:uppercase;display:block;margin-bottom:4px">Longitude</label>
              <input type="number" id="manualLng" step="0.000001" placeholder="106.457346" readonly
                style="width:100%;padding:7px 10px;border-radius:7px;border:1.5px solid var(--border);background:var(--bg-card);font-size:12px;font-family:monospace;color:var(--text-primary);outline:none"
                oninput="applyManualCoord()">
            </div>
          </div>
        </div>
      </div>
      <div class="tab-panel" id="tab-odp">
        <div class="form-group"><label class="form-label">Nama ODP *</label><input type="text" class="form-control" id="odp-name" placeholder="mis. ODP-BGR-001-A"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Kapasitas Port</label><input type="number" class="form-control" id="odp-capacity" placeholder="8" min="1"></div>
          <div class="form-group"><label class="form-label">Port Terpakai</label><input type="number" class="form-control" id="odp-used" placeholder="0" min="0"></div>
        </div>
        <div class="form-group"><label class="form-label">Parent ODC</label><select class="form-control" id="odp-parent"><option value="">-- Tidak ada --</option></select></div>
        <div class="form-group"><label class="form-label">Alamat</label><input type="text" class="form-control" id="odp-address" placeholder="Alamat lokasi ODP"></div>
        <div class="form-group"><label class="form-label">Status</label><select class="form-control" id="odp-status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="maintenance">Maintenance</option></select></div>
        <div class="form-group"><label class="form-label">Catatan</label><textarea class="form-control" id="odp-notes" rows="2" placeholder="Catatan..."></textarea></div>
        <div class="form-group">
          <label class="form-label">Foto ODP</label>
          <div id="odp-photo-wrap" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
