// Edit pelanggan
let mapEdit, markerEdit;

function initMapEdit(lat, lng) {

  if (mapEdit) {
    mapEdit.remove();
  }

  mapEdit = L.map('mapEdit').setView([lat, lng], 15);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(mapEdit);

  markerEdit = L.marker([lat, lng], { draggable: true }).addTo(mapEdit);

  setCoordinatesEdit(lat, lng);

  markerEdit.on('dragend', function (e) {
    const { lat, lng } = e.target.getLatLng();
    setCoordinatesEdit(lat, lng);
  });

  mapEdit.on('click', function (e) {
    const { lat, lng } = e.latlng;
    markerEdit.setLatLng([lat, lng]);
    setCoordinatesEdit(lat, lng);
  });

  setTimeout(() => {
    mapEdit.invalidateSize();
  }, 300);
}

function setCoordinatesEdit(lat, lng){
  $('eLat').value = lat.toFixed(6);
  $('eLong').value = lng.toFixed(6);
}

function openEditModalPelanggan(){
  if(!tkData) return;

  $('eNoHp').value = tkData.customerRegistration.phone || '';
  $('eMail').value = tkData.customerRegistration.email || '';
  $('eAlamat').value = tkData.customerRegistration.address || '';

  const lat = parseFloat(tkData.customerRegistration.latitude);
  const lng = parseFloat(tkData.customerRegistration.longitude);

  if (isNaN(lat) || isNaN(lng)) {
    alert('Koordinat pelanggan belum tersedia di database!');
    return;
  }

  $('eLat').value = lat;
  $('eLong').value = lng;

  openM('mEditPelanggan');

  setTimeout(() => {
    initMapEdit(lat, lng);
  }, 200);
}
async function submitEditPelanggan(){
  const phone = $('eNoHp').value.trim();
  const email = $('eMail').value.trim();
  const address = $('eAlamat').value.trim();
  const lat = parseFloat($('eLat').value);
  const lng = parseFloat($('eLong').value);

  if(!phone){
    showToast('No HP wajib diisi!','warn');
    return;
  }

  if(!email){
    showToast('Email wajib diisi!','warn');
    return;
  }

  if (isNaN(lat) || isNaN(lng)) {
    showToast('Koordinat belum valid!','warn');
    return;
  }

  try{
