<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Detail Ticket' %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.45.2/dist/apexcharts.min.js"></script>
  <style>
    :root{--nv:#2f6cbb;--nv2:#1e3ecc;}
    /* Header card */
    .ticket-header-card{background:linear-gradient(135deg,var(--nv) 0%,var(--nv2) 100%);color:#fff;padding:28px 36px;border-radius:18px;margin-bottom:20px;box-shadow:0 10px 40px rgba(6,13,154,.3);position:relative;overflow:hidden;}
    .ticket-number{font-size:12px;opacity:.85;font-weight:700;margin-bottom:6px;letter-spacing:.08em;text-transform:uppercase;position:relative;z-index:1;}
    .ticket-title{font-size:26px;font-weight:800;margin-bottom:14px;line-height:1.3;position:relative;z-index:1;letter-spacing:-.3px;}
    .ticket-meta{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-top:4px;position:relative;z-index:1;}
    .meta-item{display:inline-flex;align-items:center;gap:7px;font-size:13px;font-weight:600;padding:6px 14px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:20px;letter-spacing:.01em;color:#fff;}
    /* Layout */
    .detail-grid{display:grid;grid-template-columns:1fr 380px;gap:20px;}
    @media(max-width:1000px){.detail-grid{grid-template-columns:1fr;}}
    /* Cards */
    .card-modern{background:#fff;border-radius:15px;box-shadow:0 5px 20px rgba(0,0,0,.08);border:1px solid #f0f0f0;margin-bottom:20px;}
    .info-section{padding:25px 30px;border-bottom:1px solid #f0f0f0;}
    .info-section:last-child{border-bottom:none;}
    .section-title{font-size:16px;font-weight:700;color:#2d3748;margin-bottom:15px;display:flex;align-items:center;gap:10px;} .section-title svg{color:var(--nv);flex-shrink:0;}
    .info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;}
    .info-item{padding:14px;background:#f7fafc;border-radius:10px;}
    .info-label{font-size:11px;font-weight:700;color:#718096;margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px;}
    .info-value{font-size:14px;font-weight:600;color:#2d3748;word-break:break-word;}
    .info-value a{color:#667eea;text-decoration:none;}
    .desc-box{padding:18px;background:#f7fafc;border-radius:10px;line-height:1.8;color:#4a5568;font-size:14px;}
    /* Map */
    #map{height:500px;border-radius:10px;overflow:hidden;margin-top:15px;box-shadow:0 4px 15px rgba(0,0,0,.1);border:2px solid #e2e8f0;position:relative;}
    .map-layer-control{position:absolute;top:10px;right:10px;z-index:1000;background:white;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.2);overflow:hidden;display:flex;gap:0;}
    .map-layer-btn{padding:6px 12px;border:none;background:white;cursor:pointer;font-size:11px;font-weight:600;color:#4a5568;display:flex;align-items:center;gap:4px;transition:all 0.2s;border-right:1px solid #e2e8f0;}
    .map-layer-btn:last-child{border-right:none;}
    .map-layer-btn:hover{background:#f7fafc;}
    .map-layer-btn.active{background:#2f6cbb;color:white;}
    .map-layer-btn svg{width:14px;height:14px;flex-shrink:0;}
    .map-buttons{display:flex;gap:10px;margin-top:15px;flex-wrap:wrap;}
    /* Timeline */
    .timeline-container{max-height:450px;overflow-y:auto;padding:15px;background:#f7fafc;border-radius:12px;}
    .timeline-item{padding:15px;margin-bottom:12px;background:#fff;border-left:0px solid #2196f3;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,.05);transition:all .25s;}
    .timeline-item:hover{transform:translateX(5px);box-shadow:0 4px 12px rgba(0,0,0,.1);}
    .timeline-item.created{border-left-color:#4caf50;} .timeline-item.assigned,.timeline-item.assignment{border-left-color:#ff9800;}
    .timeline-item.reassigned{border-left-color:#9c27b0;} .timeline-item.status_change,.timeline-item.status_changed{border-left-color:#2196f3;}
    .timeline-item.comment,.timeline-item.photo{border-left-color:#00bcd4;} .timeline-item.system{border-left-color:#9e9e9e;}
    .timeline-foto{max-width:250px;max-height:150px;border-radius:10px;margin-top:12px;cursor:pointer;border:2px solid #e0e0e0;transition:all .25s;}
    .timeline-foto:hover{transform:scale(1.05);box-shadow:0 5px 15px rgba(0,0,0,.2);}
    /* Add comment */
    .comment-box{padding:20px 25px;background:#f7fafc;border-radius:12px;border:2px solid #e2e8f0;}
    .comment-box textarea{width:100%;padding:12px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px;font-family:inherit;resize:vertical;transition:all .25s;background:#fff;box-sizing:border-box;}
    .comment-box textarea:focus{outline:none;border-color:var(--nv);box-shadow:0 0 0 4px rgba(6,13,154,.08);}
    .comment-box label{display:block;margin-bottom:8px;font-weight:700;color:#4a5568;font-size:14px;}
    /* Sidebar */
    .sidebar-card{background:#fff;border-radius:15px;box-shadow:0 5px 20px rgba(0,0,0,.08);padding:25px;margin-bottom:20px;border:1px solid #f0f0f0;}
    .sidebar-title{font-size:16px;font-weight:700;color:#2d3748;margin-bottom:15px;display:flex;align-items:center;gap:10px;} .sidebar-title svg{color:var(--nv);flex-shrink:0;}

    /* Buttons */
    .btn{padding:12px 22px;border-radius:10px;border:none;cursor:pointer;font-weight:700;font-size:14px;transition:all .25s;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 14px rgba(0,0,0,.1);font-family:inherit;text-decoration:none;justify-content:center;width:100%;margin-bottom:10px;} .btn svg{flex-shrink:0;}
    .btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.15);}
    .btn-primary{background:linear-gradient(135deg,var(--nv),var(--nv2));color:#fff;}
    .btn-success{background:linear-gradient(135deg,#4caf50,#8bc34a);color:#fff;}
    .btn-warning{background:linear-gradient(135deg,#ff9800,#ff5722);color:#fff;}
    .btn-danger{background:linear-gradient(135deg,#e22c1f,#c62828);color:#fff;}
    .btn-secondary{background:linear-gradient(135deg,#6c757d,#5a6268);color:#fff;}
    .qa-btn{margin-bottom:10px;}

    /* Lightbox */
    .lb{display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.95);justify-content:center;align-items:center;}
    .lb.show{display:flex;}
    .lb img{max-width:90%;max-height:90%;border-radius:14px;}
    .lb-c{position:absolute;top:24px;right:40px;color:#fff;font-size:44px;cursor:pointer;transition:all .25s;}
    .lb-c:hover{transform:rotate(90deg);}

    /* Leaflet popup */
    .leaflet-popup-content-wrapper{border-radius:12px;padding:0;overflow:hidden;box-shadow:0 8px 25px rgba(0,0,0,.15);border:none;}
    .leaflet-popup-content{margin:0;width:240px!important;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;}
    .popup-header{background:linear-gradient(135deg,var(--nv),var(--nv2));color:#fff;padding:12px 15px;text-align:center;}
    .popup-header h3{margin:0;font-size:15px;font-weight:700;}
    .popup-body{padding:12px 15px;background:#fff;}
    .popup-info-item{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid #f0f0f0;gap:10px;}
    .popup-info-item:last-child{border-bottom:none;}
    .popup-label{font-size:12px;color:#718096;font-weight:500;flex-shrink:0;}
    .popup-value{font-size:12px;color:#2d3748;font-weight:600;text-align:right;word-break:break-word;}
    .popup-value a{color:#667eea;text-decoration:none;}
    .popup-footer{padding:10px 15px;background:#f7fafc;border-top:1px solid #e2e8f0;display:grid;grid-template-columns:1fr 1fr;gap:8px;}
    .popup-footer a{display:flex;align-items:center;justify-content:center;gap:5px;padding:8px;color:#fff;text-decoration:none;border-radius:8px;font-size:12px;font-weight:700;transition:all .25s;}

    /* Pulse markers */
    @keyframes pr{0%,100%{box-shadow:0 0 0 0 rgba(244,67,54,.7);}50%{box-shadow:0 0 0 15px rgba(244,67,54,0);}}
    @keyframes pb{0%,100%{box-shadow:0 0 0 0 rgba(33,150,243,.7);}50%{box-shadow:0 0 0 15px rgba(33,150,243,0);}}
    @keyframes po{0%,100%{box-shadow:0 0 0 0 rgba(255,152,0,.7);}50%{box-shadow:0 0 0 15px rgba(255,152,0,0);}}
    @keyframes pg2{0%,100%{box-shadow:0 0 0 0 rgba(76,175,80,.7);}50%{box-shadow:0 0 0 15px rgba(76,175,80,0);}}
    .pulse-red{animation:pr 2s infinite;} .pulse-blue{animation:pb 2s infinite;}
    .pulse-orange{animation:po 2s infinite;} .pulse-green{animation:pg2 2s infinite;}
    .custom-marker{position:relative;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;border:3px solid #fff;transition:transform .3s;}
    .custom-marker i{color:#fff;font-size:18px;z-index:2;}
    .custom-marker:hover{transform:scale(1.1);}

    /* ── SLA Gauge ──────────────────────────────────────── */
    .sla-gauge-wrap{display:flex;align-items:center;gap:14px;padding:4px 0;}
    #slaGaugeChart{flex-shrink:0;}
    .sla-stats{flex:1;display:flex;flex-direction:column;gap:9px;}
    .sla-stat-row{display:flex;justify-content:space-between;align-items:center;padding:7px 10px;background:#f9fafb;border:1px solid #f3f4f6;border-radius:8px;}
    .sla-stat-lbl{font-size:11px;font-weight:600;color:#6b7280;}
    .sla-stat-val{font-size:13px;font-weight:800;color:#1f2937;}
    .sla-due-row{font-size:10px;color:#9ca3af;text-align:center;margin-top:4px;}

    /* Resolution time banner — muncul saat tiket resolved/closed */
    .resolution-time{
      display:none;
      margin-top:12px;
      padding:12px 14px;
      border-radius:12px;
      background:linear-gradient(135deg,#ecfdf5 0%,#d1fae5 100%);
      border:1px solid #a7f3d0;
      position:relative;
      overflow:hidden;
    }
    .resolution-time.show{display:block;animation:resIn .35s cubic-bezier(.4,0,.2,1);}
    @keyframes resIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
    .resolution-time::before{
      content:'';
      position:absolute;top:-20px;right:-20px;
      width:80px;height:80px;border-radius:50%;
      background:radial-gradient(circle,rgba(16,185,129,.12),transparent 70%);
      pointer-events:none;
    }
    .rt-head{
      display:flex;align-items:center;gap:8px;
      font-size:10.5px;font-weight:700;color:#047857;
      text-transform:uppercase;letter-spacing:.4px;
      margin-bottom:6px;position:relative;
    }
    .rt-head svg{width:13px;height:13px;flex-shrink:0;}
    .rt-duration{
      font-size:16px;font-weight:800;color:#065f46;
      letter-spacing:-.3px;line-height:1.25;
      position:relative;
    }
    .rt-sub{
      font-size:10.5px;color:#059669;
      margin-top:4px;font-weight:500;
      position:relative;
    }
    .rt-badge{
      display:inline-flex;align-items:center;gap:3px;
      margin-left:6px;padding:1px 7px;border-radius:20px;
      font-size:9.5px;font-weight:800;text-transform:uppercase;letter-spacing:.3px;
      vertical-align:middle;
    }
    .rt-badge.ontime{background:#10b981;color:#fff;}
    .rt-badge.late{background:#ef4444;color:#fff;}

    /* ── Status Progress ────────────────────────────────── */
    .sflow{display:flex;flex-direction:column;gap:6px;}
    .sfi{display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:9px;border:1.5px solid #e5e7eb;background:#f9fafb;transition:.2s;cursor:default;}
    .sfi.done{border-color:#bbf7d0;background:#f0fdf4;}
    .sfi.active{border-color:#1d4ed8;background:#dbeafe;box-shadow:0 0 0 3px rgba(29,78,216,.08);}
    .sfi-dot{width:30px;height:30px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;background:#e5e7eb;color:#6b7280;transition:.2s;padding:6px;}
    .sfi-dot svg{width:100%;height:100%;display:block;}
    .sfi.done .sfi-dot{background:linear-gradient(135deg,#15803d,#22c55e);color:#fff;}
    .sfi.active .sfi-dot{background:linear-gradient(135deg,#1e3a8a,#1d4ed8);color:#fff;}
    .sfi-lbl{flex:1;font-size:12px;font-weight:700;color:#4b5563;}
    .sfi-sub{font-size:10px;font-weight:500;color:#9ca3af;}
    .sfi.done .sfi-lbl{color:#15803d;}
    .sfi.active .sfi-lbl{color:#1d4ed8;}
    .sfi-chip{font-size:9px;font-weight:800;padding:2px 7px;border-radius:5px;background:#1d4ed8;color:#fff;letter-spacing:.03em;}

    /* ── Quick Action Buttons ───────────────────────────── */
    .qa-list{display:flex;flex-direction:column;gap:7px;}
    .qab{display:flex;align-items:center;gap:9px;padding:10px 15px;border-radius:9px;border:none;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;transition:.2s;text-decoration:none;box-shadow:0 2px 8px rgba(0,0,0,.07);}
    .qab:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(0,0,0,.12);}
    .qab svg{flex-shrink:0;}
    .qab-status{background:linear-gradient(135deg,#1e3a8a,#1d4ed8);color:#fff;}
    .qab-primary{background:linear-gradient(135deg,#1e40af,#2563eb);color:#fff;}
    .qab-info{background:linear-gradient(135deg,#066f92,#07cafa);color:#fff;}
    .qab-warning{background:linear-gradient(135deg,#92400e,#d97706);color:#fff;}
    .qab-success{background:linear-gradient(135deg,#14532d,#16a34a);color:#fff;}
    .qab-gray{background:#f3f4f6;color:#374151;border:1.5px solid #e5e7eb;box-shadow:none;}

    /* ── Badges ─────────────────────────────────────────── */
    .sbadge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:7px;font-size:11px;font-weight:700;}
    .s-open{background:#fef3c7;color:#92400e;} .s-prog{background:#dbeafe;color:#1e3a8a;}
    .s-pend{background:#ede9fe;color:#4c1d95;} .s-res{background:#dcfce7;color:#14532d;}
    .s-cls{background:#f3f4f6;color:#374151;}

    /* ── Buttons (send comment) ─────────────────────────── */
    .btn-prim{background:linear-gradient(135deg,#1e3a8a,#1d4ed8);color:#fff;box-shadow:0 4px 12px rgba(29,78,216,.25);padding:9px 18px;border-radius:9px;border:none;cursor:pointer;font-size:13px;font-weight:700;font-family:inherit;transition:.2s;display:inline-flex;align-items:center;gap:7px;text-decoration:none;}
    .btn-prim:hover{opacity:.9;transform:translateY(-1px);}
    .btn-sm{padding:6px 13px;font-size:12px;border-radius:8px;}

    /* ── Modals ─────────────────────────────────────────── */
    .mover{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;}
    .mover.show{display:flex;}
    .mbox{background:#fff;border-radius:16px;width:90%;max-width:360px;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:mIn .25s ease-out;max-height:90vh;overflow-y:auto;}
    @keyframes mIn{from{transform:translateY(40px);opacity:0}to{transform:none;opacity:1}}
    .mhd{background:linear-gradient(135deg,#1e3a8a,#1d4ed8);color:#fff;padding:18px 22px;border-radius:16px 16px 0 0;display:flex;justify-content:space-between;align-items:center;}
    .mhd h3{margin:0;font-size:15px;font-weight:700;display:flex;align-items:center;gap:8px;}
    .mcls{width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.2);border:none;color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;line-height:1;}
    .mcls:hover{background:rgba(255,255,255,.35);transform:rotate(90deg);}
    .mbdy{padding:20px 22px;}
    .fg{margin-bottom:14px;}
    .fl{display:block;margin-bottom:6px;font-size:11px;font-weight:700;color:#4b5563;text-transform:uppercase;letter-spacing:.4px;}
    .fc{width:100%;padding:9px 12px;border:1.5px solid #e5e7eb;border-radius:9px;font-size:13px;font-family:inherit;background:#f9fafb;color:#1f2937;transition:.2s;}
    .fc:focus{outline:none;border-color:#1d4ed8;box-shadow:0 0 0 3px rgba(29,78,216,.1);background:#fff;}
    .frow{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
    .stgrid{display:flex;flex-direction:column;gap:6px;}
    .stop{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:9px;border:2px solid #e5e7eb;cursor:pointer;transition:.2s;background:#f9fafb;text-align:left;}
    .stop:hover{border-color:#1d4ed8;background:#dbeafe;}
    .stop.sel{border-color:#1d4ed8;background:#dbeafe;}
    .stop-ico{width:34px;height:34px;flex-shrink:0;display:flex;align-items:center;justify-content:center;border-radius:8px;background:#e5e7eb;padding:7px;color:#6b7280;transition:.2s;}
    .stop-ico svg{width:100%;height:100%;display:block;}
    .stop.sel .stop-ico,.stop:hover .stop-ico{background:#bfdbfe;color:#1d4ed8;}
    .stop-txt{flex:1;}
    .stop-lbl{font-size:13px;font-weight:700;color:#1f2937;}
    .stop-desc{font-size:11px;color:#9ca3af;margin-top:1px;}

    /* Lightbox */
    .lb{display:none;position:fixed;inset:0;z-index:10000;background:rgba(0,0,0,.95);align-items:center;justify-content:center;}
    .lb.show{display:flex;}
    .lb img{max-width:90%;max-height:90%;border-radius:12px;}
    .lbx{position:absolute;top:18px;right:28px;color:#fff;font-size:38px;cursor:pointer;}
    @keyframes spin{to{transform:rotate(360deg)}}
    @media(max-width:768px){.tkt-ttl{font-size:17px;}.frow{grid-template-columns:1fr;}}
    .coord-preview {
      background: var(--bg-secondary); border-radius: 8px; padding: 8px 12px;
      font-size: 12px; color: var(--text-secondary); margin-bottom: 14px;
      display: flex; align-items: center; gap: 6px;
    }
    .coord-preview svg { width: 14px; height: 14px; flex-shrink: 0; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* ── Anti tile-grid ── */
    .leaflet-tile {
      border: none !important;
      outline: none !important;
      margin: 0 !important;
      padding: 0 !important;
      box-shadow: none !important;
    }
    .leaflet-container {
      background: #e8e0d8;
    }
    .odp-modal{
      width: 360px;
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
    }

    .odp-header{
      background: linear-gradient(90deg,#2563eb,#60a5fa);
      color:#fff;
      padding:14px 16px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .odp-title{
      font-weight:600;
      font-size:16px;
    }

    .odp-status{
      font-size:12px;
      opacity:.9;
      display:flex;
      align-items:center;
      gap:6px;
    }

    .dot{
      width:8px;
      height:8px;
      background:#22c55e;
      border-radius:50%;
    }

    .odp-box{
      margin-top:14px;
      font-size:12px;
    }

    .odp-row{
      display:flex;
      justify-content:space-between;
      margin-bottom:6px;
      color:#444;
    }

    .odp-used{
      color:#ef4444;
      font-weight:600;
    }

    .progress-bar{
      height:8px;
      background:#eee;
      border-radius:10px;
      overflow:hidden;
    }

    .progress-fill{
      height:100%;
      width:70%;
      background:#ef4444;
    }

    .odp-image-wrap{
      margin-top:12px;
      border-radius:10px;
      overflow:hidden;
      border:1px solid #eee;
      height:180px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:#fafafa;
    }

    .odp-image-wrap img{
      height:100%;
      width:100%;
      object-fit:contain;
    }

    .odp-notes{
      margin-top:10px;
      font-size:12px;
      color:#666;
      font-style:italic;
    }

    .odp-footer{
      display:flex;
      gap:8px;
    }
  </style>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar') %>
  <div class="main-content">
    <%- include('../partials/topbar') %>

    <main class="page-content" id="mainContent" style="display:none;">

      <!-- Ticket Header Card -->
      <div class="ticket-header-card">
        <div class="ticket-number" id="hNum">Memuat...</div>
        <div class="ticket-title" id="hTitle">—</div>
        <div class="ticket-meta" id="hMeta"></div>
      </div>

      <a href="/tickets" class="btn btn-secondary" style="width:auto;display:inline-flex;margin-bottom:20px;">
