        </div>
        <div class="w-card" style="padding:20px 22px;">
          <div style="margin-bottom:14px"><div class="wc-lbl">Pengeluaran per Kategori</div><div class="wc-ttl" id="cat-title">Bulan Ini</div></div>
          <div id="cat-list"><div style="text-align:center;padding:24px;color:var(--d-muted);font-size:12.5px">Tidak ada data</div></div>
        </div>
      </div>

      <!-- Main layout: form + table -->
      <div class="main-layout a4">

        <!-- ── FORM ── -->
        <div class="form-card">
          <div class="form-title">
            <div class="ft-icon"><svg width="15" height="15" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg></div>
            <span id="form-title-text">Input Transaksi</span>
          </div>

          <!-- Type tabs -->
          <div class="type-tabs">
            <button class="type-tab" data-type="pemasukan" onclick="setType('pemasukan')">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin:0 auto 3px;display:block"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Masuk</button>
            <button class="type-tab" data-type="pengeluaran" onclick="setType('pengeluaran')">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin:0 auto 3px;display:block"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4m0 0l6-6M4 12l6 6"/></svg>
        Keluar</button>
            <button class="type-tab" data-type="hutang" onclick="setType('hutang')">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin:0 auto 3px;display:block"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
        Hutang</button>
            <button class="type-tab" data-type="piutang" onclick="setType('piutang')">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin:0 auto 3px;display:block"><path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
        Piutang</button>
            <button class="type-tab" data-type="modal" onclick="setType('modal')">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin:0 auto 3px;display:block"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H3m14 0h2m-2 0v-3.5a.5.5 0 01.5-.5H21a.5.5 0 01.5.5V21M3 21H1m2 0v-3.5A.5.5 0 012.5 17H3m0 4h2M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 8v-4a1 1 0 011-1h2a1 1 0 011 1v4"/></svg>
        Modal</button>
          </div>

          <input type="hidden" id="form-type" value="pemasukan">
          <input type="hidden" id="form-edit-id" value="">

          <div class="form-group">
            <label class="form-label">Kategori <span>*</span></label>
            <input type="text" id="f-category" class="form-control" placeholder="e.g. Gaji, Operasional, Sewa..." list="cat-suggestions" autocomplete="off">
            <datalist id="cat-suggestions"></datalist>
          </div>

          <div class="form-group">
            <label class="form-label">Deskripsi <span>*</span></label>
