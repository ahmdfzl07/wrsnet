              <label class="form-label">Jumlah (Rp) <span>*</span></label>
              <div class="amount-wrap">
                <span class="amount-prefix">Rp</span>
                <input type="text" id="f-amount" class="form-control" placeholder="0" inputmode="numeric" oninput="formatAmountInput(this)">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Tanggal <span>*</span></label>
              <input type="date" id="f-date" class="form-control">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">No. Referensi / Kwitansi</label>
            <input type="text" id="f-ref" class="form-control" placeholder="INV-001, KWT-2026...">
          </div>

          <!-- Hutang/Piutang fields -->
          <div id="cond-party" class="cond-field">
            <div class="form-group">
              <label class="form-label">Nama Pihak <span>*</span></label>
              <input type="text" id="f-party" class="form-control" placeholder="Nama vendor / pelanggan...">
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Jatuh Tempo</label>
                <input type="date" id="f-due" class="form-control">
              </div>
              <div class="form-group">
                <label class="form-label">Status</label>
                <select id="f-status" class="form-control">
                  <option value="belum_lunas">Belum Lunas</option>
                  <option value="cicilan">Cicilan</option>
                  <option value="lunas">Lunas</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Modal fields -->
          <div id="cond-modal" class="cond-field">
            <div class="form-group">
              <label class="form-label">Sumber Modal</label>
              <input type="text" id="f-source" class="form-control" placeholder="Investor, Pinjaman Bank, Tabungan...">
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Catatan</label>
            <textarea id="f-notes" class="form-control" placeholder="Catatan tambahan..."></textarea>
          </div>

          <button class="btn-submit" id="submit-btn" onclick="submitForm()">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span id="submit-label">Simpan Transaksi</span>
          </button>
          <button id="cancel-edit-btn" onclick="cancelEdit()" style="display:none;width:100%;margin-top:8px;padding:9px;border-radius:10px;border:1.5px solid var(--d-border);background:#fff;color:var(--d-muted);font-size:13px;font-weight:600;cursor:pointer">Batal Edit</button>
        </div>

        <!-- ── TABLE ── -->
        <div>
          <div class="w-card">
            <!-- Filter bar -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:10px">
              <div style="display:flex;align-items:center;gap:8px">
                <div class="wc-lbl" style="margin:0">Daftar Transaksi</div>
                <span id="tbl-count" style="font-size:11px;background:#eef2f9;padding:2px 8px;border-radius:20px;color:var(--d-muted);font-weight:600"></span>
              </div>
              <div class="filter-bar" style="margin:0">
                <input type="text" class="search-input" placeholder="Cari..." id="tbl-search" oninput="debounceSearch()" style="width:160px">
              </div>
            </div>

            <!-- Type filter tabs -->
            <div style="display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap">
              <button class="filter-tab active" data-filter="semua"      onclick="setFilter('semua',this)">Semua</button>
              <button class="filter-tab" data-filter="pemasukan"   onclick="setFilter('pemasukan',this)"><span style="width:7px;height:7px;border-radius:50%;background:#00c896;display:inline-block;margin-right:5px;vertical-align:middle"></span>Pemasukan</button>
              <button class="filter-tab" data-filter="pengeluaran" onclick="setFilter('pengeluaran',this)"><span style="width:7px;height:7px;border-radius:50%;background:#f5365c;display:inline-block;margin-right:5px;vertical-align:middle"></span>Pengeluaran</button>
              <button class="filter-tab" data-filter="hutang"      onclick="setFilter('hutang',this)"><span style="width:7px;height:7px;border-radius:50%;background:#fb8c00;display:inline-block;margin-right:5px;vertical-align:middle"></span>Hutang</button>
              <button class="filter-tab" data-filter="piutang"     onclick="setFilter('piutang',this)"><span style="width:7px;height:7px;border-radius:50%;background:#0096c7;display:inline-block;margin-right:5px;vertical-align:middle"></span>Piutang</button>
              <button class="filter-tab" data-filter="modal"       onclick="setFilter('modal',this)"><span style="width:7px;height:7px;border-radius:50%;background:#1a6ef5;display:inline-block;margin-right:5px;vertical-align:middle"></span>Modal</button>
            </div>

            <div style="overflow-x:auto">
              <table class="keu-table">
                <thead>
                  <tr>
                    <th>Tgl</th>
                    <th>Tipe</th>
                    <th>Kategori / Deskripsi</th>
                    <th class="col-hide">Pihak / Ref</th>
                    <th>Status</th>
                    <th style="text-align:right">Jumlah</th>
                    <th style="width:80px;text-align:center">Aksi</th>
                  </tr>
                </thead>
                <tbody id="keu-tbody">
                  <tr><td colspan="7" style="text-align:center;padding:32px;color:var(--d-muted)">Memuat...</td></tr>
                </tbody>
