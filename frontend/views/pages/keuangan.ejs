    </main>
  </div>
</div>

<!-- Delete confirm modal -->
<div id="del-modal" style="display:none" class="modal-overlay" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal-box">
    <div class="modal-title">
      Konfirmasi Hapus
      <button class="modal-close" onclick="document.getElementById('del-modal').style.display='none'">×</button>
    </div>
    <p style="font-size:13px;color:var(--d-muted);margin-bottom:20px">Yakin ingin menghapus transaksi ini? Data tidak bisa dikembalikan.</p>
    <div style="display:flex;gap:10px;justify-content:flex-end">
      <button onclick="document.getElementById('del-modal').style.display='none'" style="padding:9px 18px;border-radius:10px;border:1.5px solid var(--d-border);background:#fff;color:var(--d-muted);font-size:13px;font-weight:600;cursor:pointer">Batal</button>
      <button id="del-confirm-btn" style="padding:9px 18px;border-radius:10px;border:none;background:linear-gradient(135deg,#f5365c,#c0183a);color:#fff;font-size:13px;font-weight:600;cursor:pointer">Hapus</button>
    </div>
  </div>
</div>

<script>
// ─── State ────────────────────────────────────────────────────
let _type = 'pemasukan';
let _filter = 'semua';
let _page = 1;
let _trendChart;
let _searchTimer;
const LIMIT = 20;

const TYPE_LABEL = {pemasukan:'Pemasukan',pengeluaran:'Pengeluaran',hutang:'Hutang',piutang:'Piutang',modal:'Modal'};
const MONTHS_ID  = ['','Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
const CAT_DEFAULT = {
  pemasukan:   ['Pembayaran Pelanggan','Jasa','Lain-lain'],
  pengeluaran: ['Operasional','Gaji','Sewa','Listrik','Internet','Peralatan','Transportasi','Lain-lain'],
  hutang:      ['Pinjaman Bank','Pinjaman Vendor','Lain-lain'],
  piutang:     ['Tagihan Pelanggan','Deposit','Lain-lain'],
  modal:       ['Modal Awal','Investasi','Lain-lain']
};

function fmtRp(n){ return 'Rp '+new Intl.NumberFormat('id-ID').format(n||0); }
function fmtRpK(n){ n=n||0; if(n>=1000000)return'Rp '+(n/1000000).toFixed(1).replace(/\.0$/,'')+'jt'; if(n>=1000)return'Rp '+Math.round(n/1000)+'rb'; return'Rp '+n; }
function fmtDate(s){ if(!s)return'—'; const d=new Date(s); return isNaN(d)?s:d.toLocaleDateString('id-ID',{day:'2-digit',month:'2-digit',year:'numeric'}); }
function el(id){ return document.getElementById(id); }

function formatAmountInput(inp){
  let v = inp.value.replace(/\D/g,'');
  inp.value = v ? new Intl.NumberFormat('id-ID').format(parseInt(v)) : '';
}

// ─── Init ──────────────────────────────────────────────────────
function init(){
  const now = new Date();
  const yr  = now.getFullYear();
  const years = Array.from({length:6},(_,i)=>yr-i);
  el('filterYear').innerHTML = years.map(y=>`<option value="${y}">${y}</option>`).join('');
  el('filterMonth').value = now.getMonth()+1;
  el('f-date').value = now.toISOString().split('T')[0];
  setType('pemasukan');
  loadAll();
}

// ─── Type selector ────────────────────────────────────────────
function setType(t){
  _type = t;
  el('form-type').value = t;
  document.querySelectorAll('.type-tab').forEach(b=>b.classList.toggle('active',b.dataset.type===t));

  // Conditional fields
  const showParty = ['hutang','piutang'].includes(t);
  const showModal = t === 'modal';
  el('cond-party').classList.toggle('show', showParty);
  el('cond-modal').classList.toggle('show', showModal);

  // Update datalist
  const cats = CAT_DEFAULT[t] || [];
  el('cat-suggestions').innerHTML = cats.map(c=>`<option value="${c}">`).join('');
}

// ─── Filter ───────────────────────────────────────────────────
function setFilter(f, btn){
  _filter = f; _page = 1;
  document.querySelectorAll('.filter-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  loadTable();
}

function debounceSearch(){
  clearTimeout(_searchTimer);
  _searchTimer = setTimeout(()=>{ _page=1; loadTable(); }, 350);
}

// ─── API helpers ──────────────────────────────────────────────
async function api(url, opts={}){
  const token = localStorage.getItem('token');
  const headers = {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'};
  if(token&&token!=='null') headers['Authorization']='Bearer '+token;
  const res = await fetch(url,{...opts,headers,credentials:'include'});
  return res.json();
}

// ─── Load all ─────────────────────────────────────────────────
function loadAll(){
  loadSummary();
  loadTable();
}

// ─── Summary ──────────────────────────────────────────────────
async function loadSummary(){
  const month = el('filterMonth').value;
  const year  = el('filterYear').value;
  try {
    const r = await api(`/api/keuangan/summary?month=${month}&year=${year}`);
    if(!r.success) return;
    const d = r.data;

    // KPI cards
    const maxAmt = Math.max(d.pemasukan, d.pengeluaran, 1);
    el('kpi-masuk').textContent     = fmtRpK(d.pemasukan);
    el('kpi-masuk-sub').textContent = `${MONTHS_ID[+month]} ${year}`;
    (el('kpi-masuk-bar')||{style:{}}).style.width = Math.min(100,d.pemasukan/maxAmt*100)+'%';

    el('kpi-keluar').textContent     = fmtRpK(d.pengeluaran);
    el('kpi-keluar-sub').textContent = `${MONTHS_ID[+month]} ${year}`;
    (el('kpi-keluar-bar')||{style:{}}).style.width = Math.min(100,d.pengeluaran/maxAmt*100)+'%';

    const cf = d.cashflow;
    el('kpi-cashflow').textContent = fmtRpK(Math.abs(cf));
    const cfCard = el('fc-cashflow');
    const cfPill = el('cp-cashflow');
    if(cf >= 0){
      if(cfPill){ cfPill.className='card-pill pill-green'; }
    } else {
      if(cfPill){ cfPill.className='card-pill pill-red'; }
    }

    el('kpi-hutang').textContent     = fmtRpK(d.hutangOutstanding);
    el('kpi-hutang-sub').textContent = `${d.hutangOutstandingCnt} belum lunas`;

    el('kpi-piutang').textContent     = fmtRpK(d.piutangOutstanding);
    el('kpi-piutang-sub').textContent = `${d.piutangOutstandingCnt} belum lunas`;

    // Trend chart
    requestAnimationFrame(()=>renderTrend(d.trend||[]));

    // Category
    el('cat-title').textContent = `${MONTHS_ID[+month]} ${year}`;
    renderCats(d.catRows||[]);
  } catch(e){ console.error('[Keuangan summary]',e.message); }
}

function renderTrend(trend){
  const tEl = el('trendChart');
  if(!tEl){ setTimeout(()=>renderTrend(trend),200); return; }
  if(_trendChart){ try{_trendChart.destroy();}catch(e){} _trendChart=null; }

  if(!trend||!trend.length){
    tEl.innerHTML='<div style="display:flex;align-items:center;justify-content:center;height:260px;color:#94a3b8;font-size:13px;">Belum ada data trend</div>';
    return;
  }
  tEl.innerHTML='';

  const labels = trend.map(function(t){return t.label;});
  const masuk  = trend.map(function(t){return +(t.pemasukan)||0;});
  const keluar = trend.map(function(t){return +(t.pengeluaran)||0;});
  const net    = masuk.map(function(v,i){return v-keluar[i];});

  function axFmt(v){
    if(v>=1000000) return 'Rp '+(v/1000000).toFixed(0)+'jt';
    if(v>=1000)    return 'Rp '+Math.round(v/1000)+'rb';
    return v?('Rp '+v):'0';
  }

  var opts = {
    series:[
      { name:'Pemasukan',   data: masuk  },
      { name:'Pengeluaran', data: keluar },
      { name:'Net',         data: net    }
    ],
    chart:{
      type:'bar',
      height:260,
      stacked:false,
      toolbar:{show:false},
      fontFamily:"DM Sans,sans-serif",
      background:'transparent',
      animations:{enabled:true,easing:'easeinout',speed:700,animateGradually:{enabled:true,delay:80}}
    },
    plotOptions:{
      bar:{
        columnWidth:'60%',
        borderRadius:4,
        dataLabels:{position:'top'}
      }
    },
    colors:['#16a34a','#ef4444','#2563eb'],
    fill:{
      type:['solid','solid','gradient'],
      gradient:{
        type:'vertical',
        shade:'light',
        shadeIntensity:0.4,
        gradientToColors:['#60a5fa'],
        inverseColors:false,
        opacityFrom:0.85,
        opacityTo:0.35,
        stops:[0,100]
      },
      opacity:[1,0.85,1]
    },
    dataLabels:{enabled:false},
    stroke:{show:false},
    grid:{
      borderColor:'#f1f5f9',
      strokeDashArray:4,
      xaxis:{lines:{show:false}},
      yaxis:{lines:{show:true}},
      padding:{top:4,right:4,bottom:0,left:4}
    },
    xaxis:{
      categories:labels,
      axisBorder:{show:false},
      axisTicks:{show:false},
      labels:{style:{colors:'#94a3b8',fontSize:'11.5px',fontWeight:500,fontFamily:'DM Sans,sans-serif'},
              offsetY:2}
    },
    yaxis:{
      labels:{
        style:{colors:'#94a3b8',fontSize:'11px',fontFamily:'DM Sans,sans-serif'},
        formatter:axFmt
      },
      tickAmount:4
    },
    tooltip:{
      theme:'light',
      shared:true,
      intersect:false,
      style:{fontSize:'12px',fontFamily:'DM Sans,sans-serif'},
      y:{
        formatter:function(v,w){
          var name=(w&&w.w&&w.w.config&&w.w.config.series&&w.w.config.series[w.seriesIndex])?w.w.config.series[w.seriesIndex].name:'';
          var prefix=(name==='Net'&&v>=0)?'+':'';
          return prefix+fmtRp(v);
        }
      }
    },
    states:{
      hover:{filter:{type:'darken',value:0.8}},
      active:{filter:{type:'darken',value:0.7}}
    },
    legend:{
      show:false
    }
  };

  _trendChart = new ApexCharts(tEl, opts);
  _trendChart.render();
}

function renderCats(cats){
  const el2 = el('cat-list');
  if(!cats.length){ el2.innerHTML='<div style="text-align:center;padding:24px;color:var(--d-muted);font-size:12.5px">Tidak ada pengeluaran bulan ini</div>'; return; }
  const max = Math.max(1,...cats.map(c=>+c.total));
  el2.innerHTML = cats.map(c=>{
    const pct = Math.round(+c.total/max*100);
    return`<div class="cat-item">
      <span style="font-size:12px;flex:1;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.category}</span>
      <div class="cat-bar-bg"><div class="cat-bar-fill" style="width:${pct}%"></div></div>
      <span style="font-size:11.5px;font-weight:700;font-family:'DM Mono',monospace;min-width:70px;text-align:right">${fmtRpK(+c.total)}</span>
    </div>`;
  }).join('');
}

// ─── Table ────────────────────────────────────────────────────
async function loadTable(){
  const month  = el('filterMonth').value;
  const year   = el('filterYear').value;
  const search = el('tbl-search').value.trim();
  const params = new URLSearchParams({ month, year, page:_page, limit:LIMIT, search });
  if(_filter !== 'semua') params.set('type', _filter);

  try {
    const r = await api('/api/keuangan?'+params.toString());
    if(!r.success) return;
    renderTable(r.data||[], r.total||0);
    renderPagination(r.total||0);
  } catch(e){ console.error('[Keuangan table]',e.message); }
}

function renderTable(rows, total){
  el('tbl-count').textContent = total + ' data';
  const tbody = el('keu-tbody');
  if(!rows.length){
    tbody.innerHTML=`<tr><td colspan="7" style="text-align:center;padding:36px;color:var(--d-muted)">
      <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="margin:0 auto 10px;display:block;opacity:.3"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      <p style="font-size:13px;font-weight:600">Belum ada transaksi</p>
    </td></tr>`;
    return;
  }
  tbody.innerHTML = rows.map(r=>{
    const isDebt = ['hutang','piutang'].includes(r.type);
    const statusHtml = isDebt && r.status
      ? `<span class="status-badge sb-${r.status}">${r.status==='lunas'?'Lunas':r.status==='cicilan'?'↺ Cicilan':'Belum'}</span>`
      : `<span style="color:#d0d8e8;font-size:12px">—</span>`;
    const lunasBtn = isDebt && r.status !== 'lunas'
      ? `<button class="btn-icon btn-lunas" onclick="markLunas(${r.id})" title="Tandai Lunas">✓</button>`
      : '';
    const amtColor = r.type==='pemasukan'||r.type==='modal'?'#007a5e':r.type==='pengeluaran'?'#c0183a':r.type==='piutang'?'#0077b6':'#b45309';
    const amtSign  = r.type==='pemasukan'||r.type==='modal'?'+':r.type==='pengeluaran'?'-':'';
    return`<tr>
      <td style="white-space:nowrap;font-size:11.5px;color:var(--d-muted)">${fmtDate(r.date)}</td>
      <td><span class="type-badge tb-${r.type}">${TYPE_LABEL[r.type]||r.type}</span></td>
      <td>
        <div style="font-weight:600;font-size:12.5px">${r.description||'—'}</div>
        <div style="font-size:11px;color:var(--d-muted)">${r.category||''}</div>
      </td>
      <td class="col-hide">
        <div style="font-size:12px">${r.party_name||r.ref_number||'—'}</div>
        ${r.due_date?`<div style="font-size:10.5px;color:var(--d-muted)">Due: ${fmtDate(r.due_date)}</div>`:''}
      </td>
      <td>${statusHtml}</td>
      <td style="text-align:right;font-family:'DM Mono',monospace;font-weight:700;font-size:13px;color:${amtColor}">
        ${amtSign}${fmtRp(+r.amount)}
      </td>
      <td style="text-align:center">
        <div style="display:flex;gap:4px;justify-content:center;align-items:center">
          ${lunasBtn}
          <button class="btn-icon btn-edit" onclick="editRecord(${r.id})" title="Edit">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          </button>
          <button class="btn-icon btn-del" onclick="confirmDelete(${r.id})" title="Hapus">
            <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function renderPagination(total){
  const pages = Math.ceil(total/LIMIT);
  const pg = el('pagination');
  if(pages<=1){ pg.innerHTML=''; return; }
  let html = `<span class="page-info">${total} data</span>`;
  const start = Math.max(1,_page-2), end = Math.min(pages,_page+2);
  if(start>1) html+=`<button class="page-btn" onclick="goPage(1)">1</button>${start>2?'<span style="color:var(--d-muted)">…</span>':''}`;
  for(let i=start;i<=end;i++) html+=`<button class="page-btn ${i===_page?'active':''}" onclick="goPage(${i})">${i}</button>`;
  if(end<pages) html+=`${end<pages-1?'<span style="color:var(--d-muted)">…</span>':''}<button class="page-btn" onclick="goPage(${pages})">${pages}</button>`;
  pg.innerHTML = html;
}

function goPage(p){ _page=p; loadTable(); }

// ─── Form submit ──────────────────────────────────────────────
async function submitForm(){
  const id  = el('form-edit-id').value;
  const type = el('form-type').value;

  const rawAmt = el('f-amount').value.replace(/\./g,'').replace(/,/g,'');
  const amount = parseFloat(rawAmt)||0;

  const body = {
    type,
    category:    el('f-category').value.trim(),
    description: el('f-description').value.trim(),
    amount,
    date:        el('f-date').value,
    ref_number:  el('f-ref').value.trim()||null,
    notes:       el('f-notes').value.trim()||null,
  };
  if(['hutang','piutang'].includes(type)){
    body.party_name = el('f-party').value.trim()||null;
    body.due_date   = el('f-due').value||null;
    body.status     = el('f-status').value||null;
  }
  if(type==='modal') body.source = el('f-source').value.trim()||null;

  if(!body.category||!body.description||!amount||!body.date){
    App.showToast('Lengkapi semua field wajib','error'); return;
  }

  const btn = el('submit-btn');
  btn.disabled = true;
  el('submit-label').textContent = 'Menyimpan...';

  try {
    const url    = id ? `/api/keuangan/${id}` : '/api/keuangan';
    const method = id ? 'PUT' : 'POST';
    const r = await api(url,{ method, body:JSON.stringify(body) });
    if(!r.success) throw new Error(r.message);

    App.showToast(r.message,'success');
    cancelEdit();
    loadAll();
  } catch(e){
    App.showToast(e.message,'error');
  } finally {
    btn.disabled = false;
    el('submit-label').textContent = id?'Simpan Perubahan':'Simpan Transaksi';
  }
}

// ─── Edit ─────────────────────────────────────────────────────
async function editRecord(id){
  try {
    const token = localStorage.getItem('token');
    const headers = {'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'};
    if(token&&token!=='null') headers['Authorization']='Bearer '+token;
    const res = await fetch(`/api/keuangan/${id}`,{headers,credentials:'include'});
    const r = await res.json();
    if(!r.success||!r.data) throw new Error(r.message||'Data tidak ditemukan');
    const d = r.data;

    el('form-edit-id').value   = d.id;
    el('form-title-text').textContent = 'Edit Transaksi';
    el('submit-label').textContent    = 'Simpan Perubahan';
    el('cancel-edit-btn').style.display = 'block';

    setType(d.type);
    el('f-category').value    = d.category||'';
    el('f-description').value = d.description||'';
    el('f-amount').value      = d.amount ? new Intl.NumberFormat('id-ID').format(+d.amount) : '';
    el('f-date').value        = d.date||'';
    el('f-ref').value         = d.ref_number||'';
    el('f-notes').value       = d.notes||'';
    if(d.party_name) el('f-party').value = d.party_name;
    if(d.due_date)   el('f-due').value   = d.due_date;
    if(d.status)     el('f-status').value= d.status;
    if(d.source)     el('f-source').value= d.source;

    el('form-card') ? el('form-card').scrollIntoView({behavior:'smooth',block:'start'})
                    : window.scrollTo({top:0,behavior:'smooth'});
  } catch(e){ App.showToast(e.message,'error'); }
}

function cancelEdit(){
  el('form-edit-id').value = '';
  el('form-title-text').textContent = 'Input Transaksi';
  el('submit-label').textContent    = 'Simpan Transaksi';
  el('cancel-edit-btn').style.display = 'none';
  ['f-category','f-description','f-amount','f-ref','f-notes','f-party','f-due','f-source'].forEach(id=>{ if(el(id)) el(id).value=''; });
  el('f-status').value = 'belum_lunas';
  el('f-date').value   = new Date().toISOString().split('T')[0];
  setType('pemasukan');
}

// ─── Delete ───────────────────────────────────────────────────
function confirmDelete(id){
  el('del-modal').style.display='flex';
  el('del-confirm-btn').onclick = async ()=>{
    try {
      const r = await api(`/api/keuangan/${id}`,{method:'DELETE'});
      if(!r.success) throw new Error(r.message);
      App.showToast(r.message,'success');
      el('del-modal').style.display='none';
      loadAll();
    } catch(e){ App.showToast(e.message,'error'); }
  };
}

// ─── Mark Lunas ───────────────────────────────────────────────
async function markLunas(id){
  try {
    const r = await api(`/api/keuangan/${id}/lunas`,{method:'PUT'});
    if(!r.success) throw new Error(r.message);
    App.showToast('Ditandai lunas ✓','success');
    loadAll();
  } catch(e){ App.showToast(e.message,'error'); }
}

// ─── Init ─────────────────────────────────────────────────────
// ─── Sync payments ────────────────────────────────────────────
async function syncPayments(){
  const month = el('filterMonth').value;
  const year  = el('filterYear').value;
  const btn   = el('sync-btn');
  btn.disabled = true;
  btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Syncing...';
  try {
    const r = await api(`/api/keuangan/sync-payments?month=${month}&year=${year}`,{method:'POST'});
    if(!r.success) throw new Error(r.message);
    el('sync-status').textContent = `✓ ${r.synced} transaksi disinkronkan`;
    if(typeof App !== 'undefined') App.showToast(r.message,'success');
    loadAll();
    setTimeout(()=>{ el('sync-status').textContent=''; },5000);
  } catch(e){
    if(typeof App !== 'undefined') App.showToast(e.message,'error');
    else alert(e.message);
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg> Sync Bulan Ini';
  }
}

document.addEventListener('DOMContentLoaded', init);
</script>

<script>
(function(){
  const W=72,H=36,MAX=20,hist={},C={'masuk':'#16a34a','keluar':'#dc2626','cashflow':'#2563eb','hutang':'#c2410c','piutang':'#d97706'},IDS={'masuk':'kpi-masuk','keluar':'kpi-keluar','cashflow':'kpi-cashflow','hutang':'kpi-hutang','piutang':'kpi-piutang'};
  Object.keys(C).forEach(k=>hist[k]=[]);
  function sp(v){if(!v||v.length<2)return null;const mn=Math.min(...v),mx=Math.max(...v),r=mx-mn||1;const p=v.map((n,i)=>[(i/(v.length-1))*W,H-((n-mn)/r)*(H-6)-3]);const d=p.reduce((a,[x,y],i)=>{if(!i)return'M'+x.toFixed(1)+','+y.toFixed(1);const[px,py]=p[i-1],cx=(px+x)/2;return a+' C'+cx.toFixed(1)+','+py.toFixed(1)+' '+cx.toFixed(1)+','+y.toFixed(1)+' '+x.toFixed(1)+','+y.toFixed(1);},'');const lp=p[p.length-1],fp=p[0];return{d,fill:d+' L'+lp[0].toFixed(1)+','+H+' L'+fp[0].toFixed(1)+','+H+' Z',dot:lp};}
  function draw(id,v){const s=sp(v);if(!s)return;const f=document.getElementById(id+'-fill'),l=document.getElementById(id+'-line'),d=document.getElementById(id+'-dot');if(f)f.setAttribute('d',s.fill);if(l)l.setAttribute('d',s.d);if(d){d.setAttribute('cx',s.dot[0].toFixed(1));d.setAttribute('cy',s.dot[1].toFixed(1));}}
  function rn(id){const e=document.getElementById(id);return e?parseFloat(e.textContent.replace(/[^\d.]/g,''))||0:0;}
  function upd(){Object.keys(C).forEach(k=>{const v=rn(IDS[k]);hist[k].push(v);if(hist[k].length>MAX)hist[k].shift();draw('sp-'+k,hist[k]);const p=document.getElementById('cp-'+k);if(p)p.textContent=hist[k][hist[k].length-1]||'—';});}
  window._keuUpd=upd;
  Object.values(IDS).forEach(id=>{const e=document.getElementById(id);if(e)new MutationObserver(()=>setTimeout(upd,50)).observe(e,{childList:true,characterData:true,subtree:true});});
  document.addEventListener('DOMContentLoaded',upd);
})();
</script>

<script>
const _KEU_COLORS = {
  'fc-masuk':'#16a34a','fc-keluar':'#dc2626','fc-cashflow':'#2563eb',
  'fc-hutang':'#c2410c','fc-piutang':'#d97706'
};
function keuCardClick(el){
  const was = el.classList.contains('fc-active');
  document.querySelectorAll('.fin-card[id^="fc-"]').forEach(card=>{
    card.classList.remove('fc-active');
    const col=_KEU_COLORS[card.id]||'#64748b';
    const l=card.querySelector('.sp-line'),f=card.querySelector('.sp-fill'),d=card.querySelector('.sp-dot');
    if(l)l.style.stroke=col;if(f)f.style.fill=col;if(d)d.style.fill=col;
  });
  if(!was){
    el.classList.add('fc-active');
    const l=el.querySelector('.sp-line'),f=el.querySelector('.sp-fill'),d=el.querySelector('.sp-dot');
    if(l)l.style.stroke='rgba(255,255,255,.70)';
    if(f)f.style.fill='rgba(255,255,255,.12)';
    if(d)d.style.fill='#fff';
  }
}
document.addEventListener('DOMContentLoaded',function(){
  const def=document.getElementById('fc-masuk');
  if(def){
    const l=def.querySelector('.sp-line'),f=def.querySelector('.sp-fill'),d=def.querySelector('.sp-dot');
    if(l)l.style.stroke='rgba(255,255,255,.70)';
    if(f)f.style.fill='rgba(255,255,255,.12)';
    if(d)d.style.fill='#fff';
  }
});
</script>
