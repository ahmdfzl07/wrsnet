        <div class="fin-card" id="fc-piutang" onclick="keuCardClick(this)">
          <div class="card-lbl">Piutang</div>
          <div class="card-body">
            <div class="card-left">
              <span class="card-val" id="kpi-piutang">–</span>
              <div class="card-meta">
                <span class="card-pill pill-amber" id="cp-piutang">—</span>
                <span class="card-sub" id="kpi-piutang-sub">Outstanding</span>
              </div>
            </div>
            <div class="card-spark">
              <svg id="sp-piutang" viewBox="0 0 72 36" preserveAspectRatio="none">
                <path class="sp-fill" id="sp-piutang-fill" d="" fill="#d97706" opacity=".12"/>
                <path class="sp-line" id="sp-piutang-line" d="" stroke="#d97706"/>
                <circle class="sp-dot" id="sp-piutang-dot" r="2.5" fill="#d97706"/>
