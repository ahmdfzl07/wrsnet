<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>ACC TopUp - WRS NET</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/app.css">

<style>

.table-card{
    background:#fff;
    border-radius:12px;
    padding:20px;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

table{
    width:100%;
    border-collapse:collapse;
}

th,td{
    padding:12px;
    border-bottom:1px solid #eee;
    text-align:left;
    font-size:14px;
}

th{
    background:#2563eb;
    color:white;
}

.btn{
    padding:8px 14px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    color:white;
    font-size:13px;
}

.btn-success{
    background:#16a34a;
}

.btn-danger{
    background:#dc2626;
}

.btn-view{
    background:#2563eb;
    color:white;
    padding:6px 10px;
    border-radius:5px;
    text-decoration:none;
}

.pending{
    color:#d97706;
    font-weight:bold;
}

.approved{
    color:#16a34a;
    font-weight:bold;
}

.rejected{
    color:#dc2626;
    font-weight:bold;
}

.action-group{
    display:flex;
    gap:6px;
}

</style>

</head>

<body>

<div class="app-layout">

    <!-- SIDEBAR -->
    <%- include("../partials/sidebar") %>

    <div class="main-content">

        <!-- TOPBAR -->
        <%- include("../partials/topbar") %>

        <main class="page-content">

            <div class="page-header">
                <div class="page-header-left">
                    <h1>ACC TopUp Agen</h1>
                </div>
            </div>

            <div class="table-card">

                <table>

                    <thead>

                        <tr>
                            <th>No</th>
                            <th>User</th>
                            <th>Nominal</th>
                            <th>Metode</th>
                            <th>Keterangan</th>
                            <th>Bukti</th>
                            <th>Status</th>
                            <th width="180">Aksi</th>
                        </tr>

                    </thead>

                    <tbody>

                    <% if(data && data.length){ %>

                        <% data.forEach(function(item,index){ %>

                        <tr>

                            <td>
                                <%= index+1 %>
                            </td>

                            <td>
                                <%= item.user ? item.user.name : "-" %>
                            </td>

                            <td>
                                Rp <%= Number(item.amount || 0).toLocaleString("id-ID") %>
                            </td>

                            <td>
                                <%= item.method || "-" %>
                            </td>

                            <td>
                                <%= item.note || "-" %>
                            </td>

                            <td>

                                <% if(item.proof){ %>

                                    <a
                                        class="btn-view"
                                        target="_blank"
                                        href="/uploads/topup/<%= item.proof %>">
                                        Lihat
                                    </a>

                                <% }else{ %>

                                    -

                                <% } %>

                            </td>

                            <td>

                                <span class="<%= item.status %>">
                                    <%= item.status %>
                                </span>

                            </td>

                            <td>

                            <% if(item.status=="pending"){ %>

                                <div class="action-group">

                    <form action="/topup/<%= item.id %>/approve" method="POST">
                        <button
                            type="submit"
                            class="btn btn-success">
                            Approve
                        </button>
                    </form>

                    <form action="/topup/<%= item.id %>/reject" method="POST">
                    <button
                        type="submit"
                        class="btn btn-danger">
                        Reject
                    </button>
                </form>

                </div>

                            <% }else{ %>

                                -

                            <% } %>

                            </td>

                        </tr>

                        <% }) %>

                    <% }else{ %>

                        <tr>

                            <td colspan="8" style="text-align:center;padding:30px;">
                                Belum ada data TopUp
                            </td>

                        </tr>

                    <% } %>

                    </tbody>

                </table>

            </div>

        </main>

        <!-- FOOTER -->
        <%- include("../partials/footer") %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/socket.io-client@4.7.2/dist/socket.io.min.js"></script>
<script src="/js/app.js"></script>

</body>
</html>