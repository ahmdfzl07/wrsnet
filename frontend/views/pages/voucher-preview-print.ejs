<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Preview Print Voucher</title>
  <%
    // Default fallback — sama dengan DEFAULTS di voucher-template.ejs
    const def = {
      primary_color:  '#1565C0',
      primary_dark:   '#0D47A1',
      accent_color:   '#2E7D32',
      company_name:   'FLAYNET',
      tagline:        'Voucher Hotspot',
      logo_url:       '',
      label_username: 'USERNAME',
      label_password: 'PASSWORD',
      label_profile:  'PAKET',
      label_duration: 'DURASI',
      label_price:    'HARGA',
      show_wifi:      '1',
      show_price:     '1',
      show_duration:  '1',
      show_profile:   '1',
      show_footer:    '1',
      columns:        '5',
      footer_text:    ''
    };
    const t = Object.assign({}, def, tpl || {});
    function esc(s) {
      return String(s == null ? '' : s)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
    const BLUE   = t.primary_color;
    const BLUE_D = t.primary_dark;
    const GREEN  = t.accent_color;
    const cols   = Math.max(2, Math.min(8, parseInt(t.columns) || 5));
    // 12 sample vouchers
    const samples = [];
    for (let i = 0; i < 12; i++) {
      const pwd = Math.random().toString(36).substring(2, 6);
      samples.push({
        username: 'vc' + Math.random().toString(36).substring(2, 7),
        password: pwd,
        profile:  ['1-Hari','7-Hari','1-Bulan'][i % 3],
        duration: ['24h','7d','30d'][i % 3],
        price:    ['Rp 5.000','Rp 25.000','Rp 80.000'][i % 3],
        active:   true
      });
    }
  %>
  <style>
    @page { size: A4; margin: 8mm 10mm; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { font-family: Arial, Helvetica, sans-serif; background: #fff; -webkit-print-color-adjust: exact; print-color-adjust: exact; font-size: 10px; }

    .toolbar {
      position: sticky; top:0; background:#fff; padding:12px 16px; border-bottom:1px solid #e0e7f3;
      display:flex; gap:10px; align-items:center; z-index:10;
    }
    .toolbar h2 { font-size: 14px; flex: 1; }
    .btn-print {
      padding:8px 16px; background:#1a6ef5; color:#fff; border:none; border-radius:8px;
      font-weight:700; cursor:pointer; font-size:12px;
    }
    .btn-back {
      padding:8px 16px; background:#fff; color:#0d1b3e; border:1.5px solid #e0e7f3;
      border-radius:8px; font-weight:700; cursor:pointer; font-size:12px; text-decoration:none;
    }
    .container { padding: 14px 16px 30px; }

    @media print {
      .toolbar, .no-print { display: none !important; }
      .container { padding: 0; }
    }

    /* Page header */
    .ph { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; padding-bottom:7px; border-bottom:2px solid <%= BLUE %>; }
    .ph-brand { display:flex; align-items:center; gap:7px; }
    .ph-ico { width:28px; height:28px; border-radius:7px; background:<%= BLUE %>; display:flex; align-items:center; justify-content:center; }
    .ph-ico svg { width:14px; height:14px; stroke:#fff; fill:none; stroke-width:2; }
    .ph-name { font-size:15px; font-weight:900; color:<%= BLUE_D %>; letter-spacing:-.5px; }
    .ph-sub  { font-size:7px; color:#888; text-transform:uppercase; letter-spacing:.7px; margin-top:1px; }
    .ph-meta { text-align:right; font-size:7.5px; color:#666; line-height:1.7; }

    .grid { display:grid; grid-template-columns:repeat(<%= cols %>,1fr); gap:5px; }

    .vc { border-radius:7px; overflow:hidden; border:1px solid #dde3ef; background:#fff; break-inside:avoid; page-break-inside:avoid; display:flex; flex-direction:column; }
    .vh { background:<%= BLUE %>; padding:6px 7px 5px; position:relative; overflow:hidden; flex-shrink:0; }
    .vh::after { content:''; position:absolute; bottom:-10px; right:-10px; width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,.08); }
    .vh-row { display:flex; align-items:center; gap:5px; position:relative; z-index:1; }
    .vh-av { width:22px; height:22px; border-radius:50%; background:rgba(255,255,255,.25); border:1px solid rgba(255,255,255,.5); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:8px; font-weight:800; color:#fff; font-family:'Courier New',monospace; letter-spacing:-.5px; }
    .vh-info { flex:1; min-width:0; }
    .vh-brand { font-size:5.5px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:rgba(255,255,255,.65); margin-bottom:1px; }
    .vh-user  { font-size:8px; font-weight:800; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; letter-spacing:-.2px; }
    .vh-prof  { font-size:6px; color:rgba(255,255,255,.7); margin-top:1px; }
    .vh-wifi { position:absolute; top:5px; right:6px; opacity:.25; }
    .vh-wifi svg { width:11px; height:11px; stroke:#fff; fill:none; stroke-width:2; }

    .vb { flex:1; }
    .vr { display:flex; align-items:center; justify-content:space-between; padding:3.5px 7px; border-bottom:1px solid #f0f2f8; }
    .vr:last-child { border-bottom:none; }
    .vl { font-size:6px; font-weight:700; text-transform:uppercase; letter-spacing:.3px; color:#b0bac9; }
    .vv { font-weight:700; color:#111; font-size:8px; text-align:right; max-width:65%; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .vv.pw { font-family:'Courier New',monospace; color:<%= BLUE_D %>; font-size:10px; font-weight:900; letter-spacing:1px; max-width:70%; }
    .vv.gn { color:<%= GREEN %>; }
    .s-on  { background:#e8f5e9; color:<%= GREEN %>;  padding:1px 4px; border-radius:2px; font-size:6px; font-weight:700; }
    .vf { padding:3px 7px; background:#f8fafc; border-top:1px solid #f0f2f8; font-size:5.5px; text-align:center; color:#94a3b8; font-style:italic; line-height:1.3; }
  </style>
</head>
<body>
  <div class="toolbar no-print">
    <a href="/voucher-template" class="btn-back">← Kembali</a>
    <h2>Preview Print Voucher (12 sampel)</h2>
    <button class="btn-print" onclick="window.print()">🖨️ Print</button>
  </div>
  <div class="container">

    <div class="ph">
      <div class="ph-brand">
        <% if (t.logo_url) { %>
          <img src="<%= esc(t.logo_url) %>" alt="Logo" style="width:28px;height:28px;border-radius:7px;object-fit:contain;">
        <% } else { %>
          <div class="ph-ico"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0114.08 0"/><path d="M1.42 9a16 16 0 0121.16 0"/><path d="M8.53 16.11a6 6 0 016.95 0"/><circle cx="12" cy="20" r="1" fill="#fff" stroke="none"/></svg></div>
        <% } %>
        <div>
          <div class="ph-name"><%= esc(t.company_name) %></div>
          <div class="ph-sub"><%= esc(t.tagline) %></div>
        </div>
      </div>
      <div class="ph-meta">
        <strong>SAMPLE PREVIEW</strong><br>
        <%= samples.length %> voucher · <%= cols %> kolom
      </div>
    </div>

    <div class="grid">
      <% samples.forEach(s => { %>
        <div class="vc">
          <div class="vh">
            <div class="vh-row">
              <div class="vh-av"><%= s.username.substring(0,2).toUpperCase() %></div>
              <div class="vh-info">
                <div class="vh-brand"><%= esc(t.company_name) %></div>
                <div class="vh-user"><%= esc(s.username) %></div>
                <% if (t.show_profile === '1') { %><div class="vh-prof"><%= esc(s.profile) %></div><% } %>
              </div>
            </div>
            <% if (t.show_wifi === '1') { %>
              <div class="vh-wifi"><svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="#fff" stroke="none"/></svg></div>
            <% } %>
          </div>
          <div class="vb">
            <div class="vr"><span class="vl"><%= esc(t.label_password) %></span><span class="vv pw"><%= esc(s.password) %></span></div>
            <% if (t.show_duration === '1') { %><div class="vr"><span class="vl"><%= esc(t.label_duration) %></span><span class="vv"><%= esc(s.duration) %></span></div><% } %>
            <% if (t.show_price === '1') { %><div class="vr"><span class="vl"><%= esc(t.label_price) %></span><span class="vv gn"><%= esc(s.price) %></span></div><% } %>
            <div class="vr"><span class="vl">STATUS</span><span class="s-on">AKTIF</span></div>
          </div>
          <% if (t.show_footer === '1' && t.footer_text) { %>
            <div class="vf"><%= esc(t.footer_text) %></div>
          <% } %>
        </div>
      <% }) %>
    </div>

  </div>
</body>
</html>
