  const BUCKET_META = {
    unpaid_all: { emptyMsg: 'Semua invoice sudah dibayar 🎉',
                  emptyTitle: 'Tidak ada tunggakan' },
    due_3days:  { emptyMsg: 'Tidak ada invoice yang akan jatuh tempo dalam 3 hari',
                  emptyTitle: 'Tidak ada invoice mendatang' },
    due_today:  { emptyMsg: 'Tidak ada invoice yang jatuh tempo hari ini',
                  emptyTitle: 'Tidak ada jatuh tempo hari ini' },
    past_due:   { emptyMsg: 'Tidak ada invoice yang lewat jatuh tempo 🎉',
                  emptyTitle: 'Bersih dari tunggakan' },
  };

  function initials(name){
    return String(name||'?').trim().split(/\s+/).filter(Boolean)
      .slice(0,2).map(w=>w[0]).join('').toUpperCase() || '?';
  }
  function daysLabel(days){
    if (days < 0)   return { txt: Math.abs(days)+' hr lalu', cls:'past' };
    if (days === 0) return { txt: 'Hari ini',                cls:'today' };
    if (days === 1) return { txt: 'Besok',                   cls:'upcoming' };
    return { txt: days+' hr lagi', cls:'upcoming' };
  }

  // Track invoice IDs yang sudah berhasil dikirim WA reminder pada session ini
  // supaya tombolnya berubah jadi "Terkirim" dan tidak bisa diklik ganda
  const _waSent = new Set();
  // Track invoice yang sudah dimark paid agar tidak muncul lagi di list lokal
  const _markedPaid = new Set();
  // Set untuk track checkbox selections (per invoice_id)
  const _selectedInv = new Set();

  // ─── Last reminder badge helper ───
  function lastReminderLabel(at) {
    if (!at) return '';
    const d = new Date(at);
    if (isNaN(d.getTime())) return '';
    const now = Date.now();
    const diff = Math.max(0, now - d.getTime());
    const s = Math.floor(diff / 1000);
    let txt;
    if (s < 60)      txt = 'baru saja';
    else if (s < 3600)   txt = Math.floor(s / 60) + ' mnt lalu';
    else if (s < 86400)  txt = Math.floor(s / 3600) + ' jam lalu';
    else if (s < 604800) txt = Math.floor(s / 86400) + ' hr lalu';
    else                 txt = d.toLocaleDateString('id-ID',{day:'2-digit',month:'short'});
    return txt;
  }

