  <!-- Mark Paid Modal -->
  <div class="qm-overlay" id="mpOverlay" onclick="closeMP(event)">
    <div class="qm-modal" onclick="event.stopPropagation();">
      <div class="qm-head">
        <div class="qm-head-icon" style="background:linear-gradient(135deg,#059669,#16a34a);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="qm-head-body">
          <h3>Tandai Lunas Manual</h3>
          <div class="qm-head-sub" id="mpSub">—</div>
        </div>
        <button type="button" class="qm-close" onclick="closeMP()" aria-label="Tutup">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <form id="mpForm" class="qm-body" onsubmit="return false;">
        <div class="qm-row">
          <div class="qm-field">
            <label>Metode</label>
            <select id="mpMethod">
              <option value="cash">Cash</option>
              <option value="transfer" selected>Transfer</option>
              <option value="qris">QRIS</option>
              <option value="other">Lainnya</option>
            </select>
          </div>
          <div class="qm-field">
            <label>Tanggal Bayar</label>
            <input type="date" id="mpDate"/>
          </div>
        </div>
        <div class="qm-field">
          <label>Nomor Referensi</label>
          <input type="text" id="mpRef" placeholder="opsional, mis. ID transfer"/>
        </div>
        <div class="qm-field">
          <label>Catatan</label>
          <textarea id="mpNotes" rows="2" placeholder="opsional"></textarea>
        </div>
        <div class="qm-actions">
          <button type="button" class="qm-btn ghost" onclick="closeMP()">Batal</button>
          <button type="button" class="qm-btn primary" id="mpSubmit" onclick="submitMP()">
            <span id="mpSubmitTxt">Tandai Lunas</span>
          </button>
        </div>
      </form>
    </div>
  </div>

<script>
(function(){
  // ═══════ UTILITIES ═══════════════════════════════════════════
  const fmtRp  = n => 'Rp ' + Number(n||0).toLocaleString('id-ID');
  function fmtRpCompact(n){
    n = Number(n||0); const abs = Math.abs(n);
    if (abs >= 1e9) return 'Rp ' + (n/1e9).toFixed(1).replace('.',',') + ' M';
    if (abs >= 1e6) return 'Rp ' + (n/1e6).toFixed(1).replace('.',',') + ' Jt';
    if (abs >= 1e3) return 'Rp ' + Math.round(n/1e3) + 'rb';
    return 'Rp ' + n.toLocaleString('id-ID');
  }
  const fmtNum = n => Number(n||0).toLocaleString('id-ID');
  function fmtDate(s){
    if(!s) return '–';
    const d = new Date(s); if (isNaN(d)) return '–';
    return d.toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'});
  }
  function escHtml(s){
    return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }
  function pad2(n){return String(n).padStart(2,'0');}

  async function api(url){
    try {
      const r = await fetch(url, { credentials:'same-origin' });
      if (!r.ok) throw new Error(r.status);
      return await r.json();
    } catch (e) { return null; }
  }

  // Subtitle = today's date
  try {
    const now = new Date();
    const opts = { weekday:'long', day:'numeric', month:'long', year:'numeric' };
    document.getElementById('finSub').textContent =
      now.toLocaleDateString('id-ID', opts) + ' · ringkasan keuangan ISP Anda';
  } catch(_) {}

  // ═══════ STATE & SHARED FETCH ════════════════════════════════
  const state = {
    income: null, expense: null,
    paymentsRevenue: null, paymentsCount: null,
    paymentsGrowthAmt: null, paymentsGrowthTx: null,
    paymentsOverdueCount: 0, paymentsOverdueAmount: 0,
    keuanganTrend: [],
    catRows: [],
  };

  // ─── 1. Keuangan summary (untuk trend chart + income/expense + budget) ───
  // API: /api/keuangan/summary returns:
  //   data.pemasukan, data.pengeluaran, data.trend[6], data.catRows
  async function loadKeuangan(){
    const j = await api('/api/keuangan/summary');
    if (!j || !j.success) {
      // Fallback: kosong tapi tidak error
      state.income = 0; state.expense = 0; state.keuanganTrend = []; state.catRows = [];
      return;
    }
    const d = j.data || {};
    state.income         = parseFloat(d.pemasukan   || 0);
    state.expense        = parseFloat(d.pengeluaran || 0);
    state.keuanganTrend  = Array.isArray(d.trend) ? d.trend : [];
    state.catRows        = Array.isArray(d.catRows) ? d.catRows : [];
  }

  // ─── 2. Payments stats (untuk fallback income & growth) ───
  // API: /api/payments/stats returns total_amount, total_tx, growth_amt
  async function loadPayments(){
    const j = await api('/api/payments/stats');
    if (!j || !j.success) return;
    const d = j.data || {};
    state.paymentsRevenue    = parseFloat(d.total_amount || 0);
    state.paymentsCount      = parseInt(d.total_tx || 0);
    state.paymentsGrowthAmt  = (d.growth_amt === null || d.growth_amt === undefined) ? null : parseFloat(d.growth_amt);
    state.paymentsGrowthTx   = (d.growth_tx  === null || d.growth_tx  === undefined) ? null : parseFloat(d.growth_tx);
    state.paymentsOverdueCount  = parseInt(d.overdue_count || 0);
    state.paymentsOverdueAmount = parseFloat(d.overdue_amount || 0);
  }

  // ─── 3. Customers stats (untuk balance card — total recurring monthly revenue) ───
  async function loadCustomers(){
    const j = await api('/api/customers/stats');
    if (!j || !j.success) return null;
    return j.data || {};
  }

  // ─── 4. Recent transactions (unified: income + expense) ───
  // API: /api/billing/recent-transactions?type=all|income|expense
  async function loadTransactions(filter){
    const t = filter || 'all';
    const j = await api('/api/billing/recent-transactions?type=' + t + '&limit=8');
    if (!j || !j.success) return null;
    return j.data?.items || [];
  }

  // ─── 5. Collection stats (paid vs unpaid this month) ───
  // API: /api/billing/collection-stats
  async function loadCollection(){
    const j = await api('/api/billing/collection-stats');
    if (!j || !j.success) return null;
    return j.data || {};
  }

  // ─── 6. Payment method stats (channels) ───
  // Reuse /api/payments/stats — already has method_stats array
  // Already fetched in loadPayments(); we just need to expose it
  async function loadChannels(){
    const j = await api('/api/payments/stats');
    if (!j || !j.success) return null;
    return Array.isArray(j.data?.method_stats) ? j.data.method_stats : [];
  }

  // ─── 7. Due-date customer lists (lazy — only when modal opens) ───
  // API: /api/billing/due-date-lists
  // Cached supaya tidak fetch ulang saat user buka modal berbeda
  let _dueListsCache = null;
  async function loadDueLists(force){
    if (_dueListsCache && !force) return _dueListsCache;
    const j = await api('/api/billing/due-date-lists?limit=50');
    if (!j || !j.success) return null;
    _dueListsCache = j.data;
    return j.data;
  }

  // ─── 8. Daily transactions (income vs expense) ───
  // API: /api/billing/daily-transactions?days=N
  async function loadDailyTx(days){
    const j = await api('/api/billing/daily-transactions?days=' + (days || 7));
    if (!j || !j.success) return null;
    return j.data;
  }

  // ─── 9. Auto insights ───
  async function loadInsights(){
    const j = await api('/api/finance/insights');
    if (!j || !j.success) return null;
    return j.data || [];
  }

  // ─── 10. Activity log (mini) ───
  async function loadActivity(){
    const j = await api('/api/finance/activity?limit=8');
    if (!j || !j.success) return null;
    return j.data || [];
  }

  // ─── 11. Auto-reminder config ───
  async function loadReminderConfig(){
    const j = await api('/api/finance/reminder-config');
    if (!j || !j.success) return null;
    return j.data || { enabled:false, rules:[] };
  }

  // ═══════ RENDERERS ═══════════════════════════════════════════

  function renderKPI(){
    // Use Keuangan income/expense kalau ada datanya, fallback ke payment revenue
    const inc = (state.income > 0) ? state.income : (state.paymentsRevenue || 0);
    const exp = state.expense || 0;

    document.getElementById('kIncome').textContent  = fmtRp(inc);
    document.getElementById('kExpense').textContent = fmtRp(exp);

    // Delta vs prev month (dari payments.growth_amt — only applies to income)
    const deltaIncEl = document.getElementById('kIncomeDelta');
    if (state.paymentsGrowthAmt !== null) {
      const g = state.paymentsGrowthAmt;
      const cls  = g > 0 ? 'up' : (g < 0 ? 'down' : 'flat');
      const sign = g > 0 ? '▲' : (g < 0 ? '▼' : '—');
      deltaIncEl.innerHTML = `<span class="kpi-delta ${cls}">${sign} ${Math.abs(g)}%</span><span class="since" style="margin-left:6px;font-size:11.5px;color:#94a3b8;font-weight:500;">vs bulan lalu</span>`;
    } else {
      deltaIncEl.innerHTML = '<span class="kpi-delta flat"><span class="since">Tidak ada data perbandingan</span></span>';
    }

    // Expense — kalau ada multi-month trend bisa dihitung growth manual
    const deltaExpEl = document.getElementById('kExpenseDelta');
    if (state.keuanganTrend.length >= 2) {
      const cur = state.keuanganTrend[state.keuanganTrend.length-1].pengeluaran || 0;
      const prv = state.keuanganTrend[state.keuanganTrend.length-2].pengeluaran || 0;
      if (prv > 0) {
        const g = Math.round((cur - prv) / prv * 100);
        // Untuk expense: naik = bad (down style), turun = good (up style)
        const cls  = g > 0 ? 'down' : (g < 0 ? 'up' : 'flat');
        const sign = g > 0 ? '▲' : (g < 0 ? '▼' : '—');
        deltaExpEl.innerHTML = `<span class="kpi-delta ${cls}">${sign} ${Math.abs(g)}%</span><span class="since" style="margin-left:6px;font-size:11.5px;color:#94a3b8;font-weight:500;">vs bulan lalu</span>`;
      } else if (cur > 0) {
        deltaExpEl.innerHTML = '<span class="kpi-delta flat"><span class="since">Bulan lalu tidak ada pengeluaran</span></span>';
      } else {
        deltaExpEl.innerHTML = '<span class="kpi-delta flat"><span class="since">Belum ada pengeluaran</span></span>';
      }
    } else {
      deltaExpEl.innerHTML = '<span class="kpi-delta flat"><span class="since">Tidak ada data perbandingan</span></span>';
    }
  }

  function renderBalance(custStats){
    // Saldo Tersedia = Net Cash Flow Bulan Ini (Pemasukan - Pengeluaran)
    // Fallback: kalau Keuangan kosong, pakai pembayaran masuk
    const inc = (state.income > 0) ? state.income : (state.paymentsRevenue || 0);
    const exp = state.expense || 0;
    const net = inc - exp;
    document.getElementById('balValue').textContent = fmtRp(net);

    // ─── Mini stats: Pelanggan Aktif ───
    if (custStats) {
      const active = custStats.active || 0;
      const total  = custStats.total  || 0;
      document.getElementById('mActive').textContent    = fmtNum(active);
      document.getElementById('mActiveSub').textContent =
        total > 0 ? `dari ${fmtNum(total)} total` : 'aktif';
    } else {
      document.getElementById('mActive').textContent = '0';
      document.getElementById('mActiveSub').textContent = 'aktif';
    }

    // ─── Mini stats: Overdue (dari payments.overdue_count) ───
    const ov = state.paymentsOverdueCount || 0;
    const ovAmt = state.paymentsOverdueAmount || 0;
    document.getElementById('mOverdue').textContent = fmtNum(ov);
    document.getElementById('mOverdueSub').textContent =
      ovAmt > 0 ? `Rp ${fmtRpCompact(ovAmt).replace('Rp ','')}` : 'invoice';
  }

  // ─── CHART: SVG area + line ───
  let cfMonths = 6;
  function renderCashFlow(){
    const svg = document.getElementById('cfChart');
    const tip = document.getElementById('cfTip');
    const W = 800, H = 260, P = { t: 20, r: 20, b: 36, l: 56 };
    const trend = state.keuanganTrend.slice(-cfMonths);

    if (!trend.length) {
      svg.innerHTML = `<text x="${W/2}" y="${H/2}" text-anchor="middle" font-size="13" fill="#94a3b8" font-family="Plus Jakarta Sans">Belum ada data arus kas untuk ditampilkan</text>`;
      return;
    }

    const inMax  = Math.max(...trend.map(t => t.pemasukan   || 0));
    const outMax = Math.max(...trend.map(t => t.pengeluaran || 0));
    const yMax   = Math.max(inMax, outMax, 1);     // hindari pembagi 0
    const stepX  = (W - P.l - P.r) / Math.max(trend.length - 1, 1);

    function x(i){ return P.l + stepX * i; }
    function y(v){ return P.t + (H - P.t - P.b) * (1 - (v / yMax)); }

    // ── Y-axis ticks (4 levels) ──
    const yTicks = 4;
    let gridSvg = '';
    let yLabels = '';
    for (let i = 0; i <= yTicks; i++) {
      const v = yMax * (1 - i / yTicks);
      const yy = P.t + (H - P.t - P.b) * (i / yTicks);
      gridSvg += `<line x1="${P.l}" y1="${yy}" x2="${W - P.r}" y2="${yy}" stroke="#eef2f8" stroke-width="1"/>`;
      yLabels += `<text x="${P.l - 8}" y="${yy + 3}" text-anchor="end" font-size="10" fill="#94a3b8" font-family="Plus Jakarta Sans">${fmtRpCompact(v).replace('Rp ','')}</text>`;
    }

    // ── X-axis labels ──
    let xLabels = '';
    trend.forEach((t, i) => {
      xLabels += `<text x="${x(i)}" y="${H - P.b + 18}" text-anchor="middle" font-size="11" fill="#7587a6" font-family="Plus Jakarta Sans" font-weight="500">${escHtml(t.label || '')}</text>`;
    });

    // ── Income area + line ──
    let incPath = `M ${x(0)} ${y(trend[0].pemasukan || 0)}`;
    for (let i = 1; i < trend.length; i++) {
      // Smooth curve: pakai cubic bezier antar titik
      const cp1x = x(i-1) + stepX * 0.5;
      const cp1y = y(trend[i-1].pemasukan || 0);
      const cp2x = x(i) - stepX * 0.5;
      const cp2y = y(trend[i].pemasukan || 0);
      incPath += ` C ${cp1x} ${cp1y}, ${cp2x} ${cp2y}, ${x(i)} ${y(trend[i].pemasukan || 0)}`;
    }
    const incArea = incPath + ` L ${x(trend.length-1)} ${H - P.b} L ${x(0)} ${H - P.b} Z`;

    // ── Expense area + line ──
    let expPath = `M ${x(0)} ${y(trend[0].pengeluaran || 0)}`;
    for (let i = 1; i < trend.length; i++) {
      const cp1x = x(i-1) + stepX * 0.5;
      const cp1y = y(trend[i-1].pengeluaran || 0);
      const cp2x = x(i) - stepX * 0.5;
      const cp2y = y(trend[i].pengeluaran || 0);
      expPath += ` C ${cp1x} ${cp1y}, ${cp2x} ${cp2y}, ${x(i)} ${y(trend[i].pengeluaran || 0)}`;
    }
    const expArea = expPath + ` L ${x(trend.length-1)} ${H - P.b} L ${x(0)} ${H - P.b} Z`;

    // ── Dots & invisible hover targets ──
    let dots = '', hovers = '';
    trend.forEach((t, i) => {
      dots += `<circle cx="${x(i)}" cy="${y(t.pemasukan || 0)}"   r="4" fill="#1d4ed8" stroke="#fff" stroke-width="2"/>`;
      dots += `<circle cx="${x(i)}" cy="${y(t.pengeluaran || 0)}" r="4" fill="#e11d48" stroke="#fff" stroke-width="2"/>`;
      hovers += `<rect class="cf-hover" data-i="${i}" x="${x(i) - stepX/2}" y="${P.t}" width="${stepX}" height="${H - P.t - P.b}" fill="transparent" style="cursor:pointer;"/>`;
    });

    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    svg.innerHTML = `
      <defs>
        <linearGradient id="grad-in" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%"  stop-color="#1d4ed8" stop-opacity=".28"/>
          <stop offset="100%" stop-color="#1d4ed8" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="grad-out" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%"  stop-color="#e11d48" stop-opacity=".22"/>
          <stop offset="100%" stop-color="#e11d48" stop-opacity="0"/>
        </linearGradient>
      </defs>
      ${gridSvg}
      ${yLabels}
      ${xLabels}
      <path d="${incArea}" fill="url(#grad-in)"/>
      <path d="${expArea}" fill="url(#grad-out)"/>
      <path d="${incPath}" fill="none" stroke="#1d4ed8" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="${expPath}" fill="none" stroke="#e11d48" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      ${dots}
      ${hovers}
    `;

    // Tooltip on hover
    const wrap = svg.closest('.cf-wrap');
    svg.querySelectorAll('.cf-hover').forEach(rect => {
      rect.addEventListener('mouseenter', () => {
        const i = parseInt(rect.getAttribute('data-i'));
        const t = trend[i];
        tip.innerHTML = `
          <div class="ti-month">${escHtml(t.label || '')}</div>
          <div class="ti-row"><span class="dot" style="background:#60a5fa;"></span>Pemasukan: <strong style="margin-left:auto;">${fmtRp(t.pemasukan||0)}</strong></div>
          <div class="ti-row"><span class="dot" style="background:#fb7185;"></span>Pengeluaran: <strong style="margin-left:auto;">${fmtRp(t.pengeluaran||0)}</strong></div>
        `;
        // Position tip — convert SVG coordinate to client px
        const wrect = wrap.getBoundingClientRect();
        const srect = svg.getBoundingClientRect();
        const xPct = (x(i) / W);
        const yPct = (y(Math.max(t.pemasukan||0, t.pengeluaran||0)) / H);
        tip.style.left = (srect.left - wrect.left + srect.width * xPct) + 'px';
        tip.style.top  = (srect.top  - wrect.top  + srect.height * yPct) + 'px';
        tip.classList.add('show');
      });
      rect.addEventListener('mouseleave', () => tip.classList.remove('show'));
    });
  }

  // Range pill switcher
  document.querySelectorAll('#cfRange button').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#cfRange button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cfMonths = parseInt(btn.getAttribute('data-r'));
      renderCashFlow();
    });
  });

  // ─── BUDGET donut ───
  function renderBudget(){
    const wrap = document.getElementById('budgetWrap');
    const rows = state.catRows.slice(0, 6);  // top 6 categories

    if (!rows.length || rows.every(r => !parseFloat(r.total))) {
      wrap.innerHTML = `
        <div class="empty" style="flex:1;">
          <div class="ic" style="background:rgba(16,185,129,.10);color:#16a34a;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div class="t">Belum ada pengeluaran</div>
          <div>Catat pengeluaran di menu Keuangan.</div>
        </div>
      `;
      return;
    }

    const total = rows.reduce((s,r) => s + parseFloat(r.total||0), 0);
    const palette = ['#1d4ed8','#1a6ef5','#3b82f6','#60a5fa','#93c5fd','#1e40af'];

    // ── Build SVG donut (circle stroke arcs) ──
    const R = 60, CX = 80, CY = 80, SW = 18;
    const C = 2 * Math.PI * R;
    let offset = 0;
    let arcs = '';
    rows.forEach((r, i) => {
      const val = parseFloat(r.total||0);
      const pct = val / total;
      const len = pct * C;
      arcs += `<circle cx="${CX}" cy="${CY}" r="${R}"
                fill="none"
                stroke="${palette[i % palette.length]}"
                stroke-width="${SW}"
                stroke-dasharray="${len} ${C - len}"
                stroke-dashoffset="${-offset}"
                style="transition:stroke-dasharray .4s;"/>`;
      offset += len;
    });

    // Legend
    let legend = '';
    rows.forEach((r, i) => {
      const val = parseFloat(r.total||0);
      const pct = total > 0 ? Math.round(val/total*100) : 0;
      const cat = r.category || 'Lainnya';
      legend += `
        <div class="dl-item">
          <span class="dot" style="background:${palette[i % palette.length]};"></span>
          <span class="name" title="${escHtml(cat)}">${escHtml(cat)}</span>
          <span class="amt">${pct}%</span>
        </div>`;
    });

    wrap.innerHTML = `
      <div class="donut">
        <svg viewBox="0 0 160 160">
          <circle cx="${CX}" cy="${CY}" r="${R}" fill="none" stroke="#f1f5f9" stroke-width="${SW}"/>
          ${arcs}
        </svg>
        <div class="donut-center">
          <div class="lbl">Total</div>
          <div class="val">${fmtRpCompact(total)}</div>
        </div>
      </div>
      <div class="donut-legend">${legend}</div>
    `;
  }

  // ═══════ DAILY TRANSACTIONS CHART (ApexCharts) ═════════════════
  let _dtxDays = 7;
  let _dtxApex = null;     // ApexCharts instance (untuk update tanpa rebuild)

  async function renderDailyTx(days){
    document.getElementById('dtxRangeLabel').textContent = days + ' hari terakhir';

    // Show loading state pada strip
    ['dtxSumIn','dtxSumOut','dtxSumNet'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.innerHTML = '<span class="skel" style="width:90px;height:14px;"></span>';
    });
    document.getElementById('dtxCntIn').textContent  = '—';
    document.getElementById('dtxCntOut').textContent = '—';

    const data = await loadDailyTx(days);
    if (!data || !Array.isArray(data.days)) {
      // Show error in chart area
      if (_dtxApex) { try { _dtxApex.destroy(); } catch(_){} _dtxApex = null; }
      document.getElementById('dtxChart').innerHTML =
        '<div class="empty" style="padding:60px 14px;"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg></div><div class="t">Gagal memuat data</div><div>Coba refresh halaman.</div></div>';
      return;
    }
    const rows   = data.days;
    const totals = data.totals || {};

    // Strip totals
    document.getElementById('dtxSumIn').textContent  = fmtRp(totals.income  || 0);
    document.getElementById('dtxSumOut').textContent = fmtRp(totals.expense || 0);
    document.getElementById('dtxSumNet').textContent = fmtRp(totals.net     || 0);
    document.getElementById('dtxCntIn').textContent  = fmtNum(totals.income_count  || 0) + ' tx';
    document.getElementById('dtxCntOut').textContent = fmtNum(totals.expense_count || 0) + ' tx';

    // ─── Build ApexCharts series ───
