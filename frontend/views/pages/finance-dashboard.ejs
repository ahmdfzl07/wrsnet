                <div class="mini-sub" id="mOverdueSub">invoice</div>
              </div>
            </div>

            <!-- ─── BUDGET / Kategori Pengeluaran ─── -->
            <div class="card budget-card">
              <div class="card-head">
                <div>
                  <h3>Kategori Pengeluaran</h3>
                  <div class="h-sub">Top kategori bulan ini</div>
                </div>
                <a href="/keuangan" class="link">
                  Detail
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
              </div>
              <div class="donut-wrap" id="budgetWrap">
                <div class="empty" style="flex:1;">
                  <div class="ic"><div class="skel" style="width:24px;height:24px;border-radius:50%;"></div></div>
                  <div class="t">Memuat data…</div>
                </div>
              </div>
            </div>

            <!-- ─── QUICK LINKS ─── -->
            <div class="card quick-card">
              <div class="card-head">
                <div>
                  <h3>Akses Cepat</h3>
                </div>
              </div>
              <div class="quick-list">
                <a href="/customers" class="qa-item">
                  <span class="qa-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
                  Pelanggan
                  <span class="qa-arrow">→</span>
                </a>
                <a href="/packages" class="qa-item">
                  <span class="qa-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"/></svg></span>
                  Paket Layanan
                  <span class="qa-arrow">→</span>
                </a>
                <a href="/keuangan" class="qa-item">
                  <span class="qa-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 100 4h4a2 2 0 110 4H8"/><path d="M12 18V6"/></svg></span>
                  Keuangan
                  <span class="qa-arrow">→</span>
                </a>
                <a href="/laporan" class="qa-item">
                  <span class="qa-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg></span>
                  Laporan
                  <span class="qa-arrow">→</span>
                </a>
              </div>
            </div>

            <!-- ─── Mini Activity Log ─── -->
            <div class="card act-card">
              <div class="card-head">
                <div>
