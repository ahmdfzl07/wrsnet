          </div>
          <div class="t">Belum ada aktivitas</div>
          <div>Aktivitas tim akan muncul di sini.</div>
        </div>`;
      return;
    }
    body.innerHTML = items.slice(0,8).map(a => {
      const ic = ACT_ICONS[a.action] || ACT_ICONS.default;
      const moduleClass = (a.module || 'billing').toLowerCase();
      const who = a.user?.name || 'Sistem';
      return `
