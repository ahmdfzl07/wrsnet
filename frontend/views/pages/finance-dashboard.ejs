  function renderChannels(methods){
    const wrap = document.getElementById('channelWrap');
    if (!methods || !methods.length) {
      wrap.innerHTML = `
        <div class="empty">
          <div class="ic" style="background:rgba(99,102,241,.10);color:#4f46e5;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M2 12h20"/></svg>
          </div>
          <div class="t">Belum ada pembayaran</div>
          <div>Channel pembayaran akan tampil setelah ada transaksi.</div>
        </div>
      `;
      return;
    }

    // Sort by total desc (sudah di-sort dari server, tapi defensive)
    methods = methods.slice().sort((a,b) => (b.total||0) - (a.total||0));
    const grandTotal = methods.reduce((s,m) => s + parseFloat(m.total||0), 0);
    const grandCount = methods.reduce((s,m) => s + parseInt(m.count||0), 0);

    let html = '<div class="ch-list">';
    methods.forEach(m => {
      const method = String(m.method || 'other').toLowerCase();
      const label  = m.label || method.charAt(0).toUpperCase() + method.slice(1);
      const color  = m.color || CH_COLORS[method] || '#6b7280';
      const total  = parseFloat(m.total || 0);
      const count  = parseInt(m.count || 0);
      const pct    = grandTotal > 0 ? (total / grandTotal) * 100 : 0;
      const icon   = CH_ICONS[method] || CH_ICONS.other;

      html += `
        <div class="ch-row">
          <div class="ch-icon" style="background:${color};">${icon}</div>
          <div class="ch-body">
            <div class="ch-top-row">
              <span class="ch-name">${escHtml(label)}</span>
              <span class="ch-amt">${fmtRp(total)}</span>
            </div>
            <div class="ch-bar">
              <div class="ch-fill" style="width:${Math.max(pct, pct > 0 ? 3 : 0)}%;background:${color};"></div>
            </div>
            <div class="ch-meta">
              <span class="pct">${pct.toFixed(1)}%</span>
              <span>${fmtNum(count)} transaksi</span>
            </div>
          </div>
        </div>
      `;
    });
    html += '</div>';

    // Total strip
    html += `
      <div class="ch-total">
        <span class="ch-total-lbl">Total: <strong style="color:#475569;">${fmtNum(grandCount)}</strong> transaksi via <strong style="color:#475569;">${methods.length}</strong> channel</span>
        <span class="ch-total-val">${fmtRp(grandTotal)}</span>
      </div>
    `;

    wrap.innerHTML = html;
  }

  // ═══════ TOAST NOTIFICATIONS ═══════════════════════════════════
  function showToast(type, title, msg, dur){
    const stack = document.getElementById('toastStack');
    if (!stack) return;
    const icons = {
      success: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
      error:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>',
      info:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
    };
    const el = document.createElement('div');
    el.className = 'toast ' + (type || 'info');
    el.innerHTML = `
      <div class="toast-icon">${icons[type] || icons.info}</div>
      <div class="toast-body">
        <div class="toast-title">${escHtml(title || '')}</div>
        <div class="toast-msg">${escHtml(msg || '')}</div>
      </div>`;
    stack.appendChild(el);
    requestAnimationFrame(() => el.classList.add('show'));
    setTimeout(() => {
      el.classList.remove('show');
      setTimeout(() => el.remove(), 320);
    }, dur || 4000);
  }

