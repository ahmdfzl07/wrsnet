                      <div class="skel" style="width:200px;height:12px;"></div>
                      <div class="skel" style="width:170px;height:12px;"></div>
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <!-- ─── Cash Flow ─── -->
            <div class="card">
              <div class="card-head">
                <div>
                  <h3>Arus Kas (Cash Flow)</h3>
