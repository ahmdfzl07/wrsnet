  // ─── Bind row-level action handlers ───
  function bindRowActions(body){
    // WA send
    body.querySelectorAll('.cl-wa-btn[data-inv]').forEach(btn => {
      btn.addEventListener('click', () => sendWAReminder(btn));
    });
    // Checkbox
    body.querySelectorAll('.cl-check').forEach(cb => {
      cb.addEventListener('change', () => {
        const id  = parseInt(cb.getAttribute('data-inv'));
        const row = cb.closest('.cl-row');
        if (cb.checked) {
          _selectedInv.add(id);
          row.classList.add('selected');
        } else {
          _selectedInv.delete(id);
          row.classList.remove('selected');
        }
        updateBulkBar();
      });
    });
    // Overflow popover toggle
    body.querySelectorAll('.cl-more').forEach(btn => {
      btn.addEventListener('click', (ev) => {
        ev.stopPropagation();
        const pop = btn.parentElement.querySelector('.cl-popover');
        // Close other popovers first
        body.querySelectorAll('.cl-popover.show').forEach(p => { if (p !== pop) p.classList.remove('show'); });
        pop.classList.toggle('show');
      });
    });
    // Popover items
    body.querySelectorAll('.cl-popover-item').forEach(item => {
      item.addEventListener('click', (ev) => {
        ev.stopPropagation();
        const act = item.getAttribute('data-act');
        // close popover
        item.closest('.cl-popover').classList.remove('show');
        if (act === 'mark-paid') {
          openMP({
            id:        parseInt(item.getAttribute('data-inv')),
            name:      item.getAttribute('data-name'),
            invoiceNo: item.getAttribute('data-inv-no'),
            amount:    parseFloat(item.getAttribute('data-amt') || 0),
          });
        } else if (act === 'copy-phone') {
          copyToClipboard(item.getAttribute('data-phone'));
        } else if (act === 'open-wa') {
          openWAManual(item.getAttribute('data-phone'));
        }
      });
    });
  }

  // Close popovers on outside click
  document.addEventListener('click', () => {
    document.querySelectorAll('.cl-popover.show').forEach(p => p.classList.remove('show'));
  });

  // ─── Bulk action bar ───
  function updateBulkBar(){
    const bar = document.getElementById('bulkBar');
    const cntEl = document.getElementById('bulkBarCnt');
    const sendCntEl = document.getElementById('bulkSendCnt');
    const n = _selectedInv.size;
    if (n === 0) { bar.style.display = 'none'; return; }
    cntEl.textContent = n;
    sendCntEl.textContent = n;
    bar.style.display = 'flex';
  }
  document.getElementById('bulkClearBtn')?.addEventListener('click', () => {
    _selectedInv.clear();
    if (_dueListsCache) renderCustomerList(_currentBucket, _dueListsCache);
  });
  document.getElementById('bulkSendBtn')?.addEventListener('click', () => {
    if (_selectedInv.size === 0) return;
    runBulkReminder(Array.from(_selectedInv));
  });

  // ─── Copy phone & open WA helpers ───
  async function copyToClipboard(text){
    if (!text) return;
    try {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(text);
      } else {
        // Fallback: textarea hack
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
      showToast('success', 'Tersalin', text);
    } catch (e) {
      showToast('error', 'Gagal menyalin', e.message || 'Coba salin manual.');
    }
  }
  function openWAManual(phone){
    if (!phone) return;
    // Bersihkan format → digit saja, prefix 62
    let p = String(phone).replace(/\D/g, '');
    if (p.startsWith('0')) p = '62' + p.slice(1);
    if (!p.startsWith('62')) p = '62' + p;
    window.open('https://wa.me/' + p, '_blank', 'noopener');
  }

  // Update tab badges
  function renderTabCounts(lists){
    if (!lists) return;
    const setBadge = (id, n) => {
      const el = document.getElementById(id);
      if (!el) return;
      const v = fmtNum(n || 0);
      el.textContent = v;
    };
    setBadge('tabUnpaidAll', (lists.unpaid_all || []).length);
    setBadge('tab3Days',     (lists.due_3days  || []).length);
    setBadge('tabToday',     (lists.due_today  || []).length);
    setBadge('tabPast',      (lists.past_due   || []).length);
  }

  // Tab switcher
  let _currentBucket = 'unpaid_all';
  document.querySelectorAll('.cl-tab[data-bucket]').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.cl-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      _currentBucket = tab.getAttribute('data-bucket');
      if (_dueListsCache) renderCustomerList(_currentBucket, _dueListsCache);
    });
  });

  // Send WA reminder for one invoice
  async function sendWAReminder(btn){
    const invId = btn.getAttribute('data-inv');
    const name  = btn.getAttribute('data-name') || 'pelanggan';
    if (!invId) return;

    // Set loading state
    btn.disabled = true;
    btn.innerHTML = `
      <svg class="spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
      Mengirim…`;

    try {
      const r = await fetch('/api/billing/invoices/' + encodeURIComponent(invId) + '/reminder', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type':'application/json' },
      });
      let j = null;
      try { j = await r.json(); } catch(_) {}

      if (r.ok && j && j.success) {
        _waSent.add(parseInt(invId));
        btn.classList.add('sent');
        btn.innerHTML = 'Terkirim';
        showToast('success', 'WA reminder terkirim', `Reminder berhasil dikirim ke ${name}.`);
      } else {
        const msg = (j && j.message) || 'Gagal mengirim WA reminder.';
        // Restore button
        btn.disabled = false;
        btn.innerHTML = `
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2zm0 18.15a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.26 8.26 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24s8.24 3.7 8.24 8.24-3.7 8.24-8.24 8.24z"/></svg>
          Kirim WA`;
        showToast('error', 'Gagal mengirim', msg);
      }
    } catch (e) {
      btn.disabled = false;
      btn.innerHTML = `
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2zm0 18.15a8.23 8.23 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.26 8.26 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24s8.24 3.7 8.24 8.24-3.7 8.24-8.24 8.24z"/></svg>
        Kirim WA`;
      showToast('error', 'Gagal mengirim', e.message || 'Jaringan bermasalah.');
    }
  }

  // ─── TRANSACTIONS table ───
  // Items dari /api/billing/recent-transactions:
  //   { type:'income'|'expense', date, amount, label, description, ref, method }
  let _txFilter = 'all';

  function renderTransactions(rows){
    const tb = document.getElementById('txBody');
    if (!rows) {
      tb.innerHTML = `<tr><td colspan="4">
        <div class="empty">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg></div>
          <div class="t">Gagal memuat transaksi</div>
          <div>Coba refresh halaman.</div>
        </div>
      </td></tr>`;
      return;
    }
    if (!rows.length) {
      const emptyMsg = {
        all:     ['Belum ada transaksi', 'Transaksi akan muncul setelah ada pembayaran atau pengeluaran.'],
        income:  ['Belum ada pembayaran masuk', 'Pemasukan dari customer akan muncul di sini.'],
        expense: ['Belum ada pengeluaran', 'Catat pengeluaran di menu Keuangan.'],
      }[_txFilter] || ['Belum ada transaksi', ''];
      tb.innerHTML = `<tr><td colspan="4">
        <div class="empty">
          <div class="ic" style="background:rgba(99,102,241,.10);color:#4f46e5;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="t">${escHtml(emptyMsg[0])}</div>
          <div>${escHtml(emptyMsg[1])}</div>
        </div>
      </td></tr>`;
      return;
    }

    tb.innerHTML = rows.slice(0, 8).map(it => {
      const isIncome = it.type === 'income';
      const sign     = isIncome ? '+' : '−';
      const cls      = isIncome ? 'in'  : 'out';
      const ref      = it.ref || it.description || '';
      const dt       = it.date;
      // Arrow icon — income up-right, expense down-left
      const iconSvg = isIncome
        ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>'
        : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="7" x2="7" y2="17"/><polyline points="17 17 7 17 7 7"/></svg>';

      // Description: untuk income → nama customer; untuk expense → kategori/keterangan
      // Detail kecil di bawah → invoice_number / category
      const mainLabel = it.label || '—';
      const subLabel  = isIncome
        ? (it.method && it.method !== '-' ? it.method.toUpperCase() : '')
        : (it.description && it.description !== it.label ? it.description : '');

      return `<tr>
        <td>
          <div class="tx-desc">
            <span class="tx-icon ${cls}">${iconSvg}</span>
            <div style="display:flex;flex-direction:column;line-height:1.25;min-width:0;">
              <span style="font-weight:700;color:#0d1b3e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px;">${escHtml(mainLabel)}</span>
              ${subLabel ? `<span style="font-size:11px;color:#94a3b8;font-weight:500;">${escHtml(subLabel)}</span>` : ''}
            </div>
          </div>
        </td>
        <td><span class="tx-id">${escHtml(ref)}</span></td>
        <td class="right"><span class="tx-amt ${cls}">${sign}${fmtRp(it.amount || 0)}</span></td>
        <td><span class="tx-date">${escHtml(fmtDate(dt))}</span></td>
      </tr>`;
    }).join('');
  }

  // Show skeleton sebelum fetch baru
  function txShowLoading(){
    document.getElementById('txBody').innerHTML = `<tr><td colspan="4">
      <div class="empty">
        <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
          <div class="skel" style="width:200px;height:14px;"></div>
          <div class="skel" style="width:140px;height:12px;"></div>
        </div>
      </div>
    </td></tr>`;
  }

  // Filter switcher
  document.querySelectorAll('#txFilter button').forEach(btn => {
    btn.addEventListener('click', async () => {
      document.querySelectorAll('#txFilter button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      _txFilter = btn.getAttribute('data-f') || 'all';
      txShowLoading();
      const rows = await loadTransactions(_txFilter);
      renderTransactions(rows);
    });
  });

  // ═══════ ENTRANCE ANIMATIONS ═══════════════════════════════════
  // Auto-tag setiap .card di main + rail dengan .fin-anim sebelum init,
  // lalu IntersectionObserver akan add .in-view saat scroll ke viewport.
  // Stagger delay diberikan per-element (main column lebih cepat,
  // rail column slightly behind supaya kesannya kolom utama muncul dulu).
  (function setupEntranceAnims(){
    if (!('IntersectionObserver' in window)) {
      // Fallback: langsung tampilkan kalau IO tidak didukung
      document.querySelectorAll('.fin-anim').forEach(el => el.classList.add('in-view'));
      return;
    }

    // Tag semua card di area main dengan stagger delay menanjak
    const mainCards = document.querySelectorAll('.fin-main > .card');
    mainCards.forEach((el, i) => {
      if (!el.classList.contains('fin-anim')) {
        el.classList.add('fin-anim');
        el.style.setProperty('--anim-delay', (80 + i * 90) + 'ms');
      }
    });

    // Tag semua card di rail (slide dari kanan untuk membedakan)
    const railCards = document.querySelectorAll('.fin-rail > .card, .fin-rail > .bal-card');
    railCards.forEach((el, i) => {
      if (!el.classList.contains('fin-anim')) {
        el.classList.add('fin-anim');
        // Balance card pakai scale-in karena hero card; sisanya slide-right
        if (el.classList.contains('bal-card')) {
          el.classList.add('scale-in');
        } else {
          el.classList.add('slide-right');
        }
        el.style.setProperty('--anim-delay', (120 + i * 100) + 'ms');
      }
    });

    // Tag mini-row (Pelanggan + Overdue di rail) — animate as group
    const miniRow = document.querySelector('.fin-rail .mini-row');
    if (miniRow && !miniRow.classList.contains('fin-anim')) {
      miniRow.classList.add('fin-anim', 'slide-right');
      miniRow.style.setProperty('--anim-delay', '220ms');
    }

    // IntersectionObserver — trigger .in-view sekali (unobserve setelah trigger)
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          io.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      // rootMargin negatif bawah supaya element animate sedikit SEBELUM
      // benar-benar terlihat penuh (terasa lebih "responsif")
      rootMargin: '0px 0px -8% 0px',
      threshold: 0.05,
    });

    // Observe semua .fin-anim
    document.querySelectorAll('.fin-anim').forEach(el => io.observe(el));
  })();

  // ═══════ QUICK EXPENSE MODAL ═══════════════════════════════════
  function openQE(){
    document.getElementById('qeForm').reset();
    document.getElementById('qeDate').value = new Date().toISOString().slice(0,10);
    document.getElementById('qeOverlay').classList.add('show');
    document.body.style.overflow = 'hidden';
    setTimeout(() => document.getElementById('qeAmount').focus(), 250);
  }
  window.closeQE = function(ev){
    if (ev && ev.target !== ev.currentTarget) return;
    document.getElementById('qeOverlay').classList.remove('show');
    document.body.style.overflow = '';
  };
  window.submitQE = async function(){
    const btn  = document.getElementById('qeSubmit');
    const txt  = document.getElementById('qeSubmitTxt');
    const amount   = parseFloat(document.getElementById('qeAmount').value);
    const category = document.getElementById('qeCategory').value.trim();
    const partyName = document.getElementById('qePartyName').value.trim();
    const date      = document.getElementById('qeDate').value;
    const notes     = document.getElementById('qeNotes').value.trim();

    if (!amount || amount <= 0) { showToast('error','Jumlah tidak valid','Masukkan nominal lebih dari 0.'); return; }
    if (!category)               { showToast('error','Kategori kosong','Pilih atau ketik kategori pengeluaran.'); return; }

    btn.disabled = true;
    txt.textContent = 'Menyimpan…';
    try {
      const r = await fetch('/api/finance/quick-expense', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({
          amount, category,
          party_name: partyName || null,
          description: notes || null,
          date: date || null,
        }),
      });
      const j = await r.json().catch(() => null);
      if (r.ok && j && j.success) {
        showToast('success', 'Pengeluaran tercatat',
          'Rp ' + amount.toLocaleString('id-ID') + ' • ' + category);
        window.closeQE();
        // Refresh data: KPI, daily tx, activity, recent tx
        try {
          await Promise.all([loadKeuangan(), loadPayments()]);
          renderKPI();
          renderDailyTx(_dtxDays);
        } catch(_){}
        loadActivity().then(renderActivity);
        loadTransactions(_txFilter).then(renderTransactions);
      } else {
        showToast('error', 'Gagal menyimpan', (j && j.message) || 'Coba lagi.');
      }
    } catch (e) {
      showToast('error', 'Gagal menyimpan', e.message || 'Jaringan bermasalah.');
    } finally {
      btn.disabled = false;
      txt.textContent = 'Simpan';
    }
  };
  document.getElementById('fabExpense').addEventListener('click', openQE);

  // ═══════ MARK PAID MODAL ═══════════════════════════════════════
  let _mpContext = null;
  function openMP(ctx){
    _mpContext = ctx;
    document.getElementById('mpForm').reset();
    document.getElementById('mpDate').value = new Date().toISOString().slice(0,10);
    document.getElementById('mpMethod').value = 'transfer';
    document.getElementById('mpSub').textContent =
      `${ctx.invoiceNo || ''} • ${ctx.name || '—'} • Rp ${(ctx.amount||0).toLocaleString('id-ID')}`;
    document.getElementById('mpOverlay').classList.add('show');
    document.body.style.overflow = 'hidden';
  }
  window.closeMP = function(ev){
    if (ev && ev.target !== ev.currentTarget) return;
    document.getElementById('mpOverlay').classList.remove('show');
    document.body.style.overflow = '';
    _mpContext = null;
  };
  window.submitMP = async function(){
    if (!_mpContext) return;
    const btn = document.getElementById('mpSubmit');
    const txt = document.getElementById('mpSubmitTxt');
    const method = document.getElementById('mpMethod').value;
    const date   = document.getElementById('mpDate').value;
    const ref    = document.getElementById('mpRef').value.trim();
    const notes  = document.getElementById('mpNotes').value.trim();
    const ctx    = _mpContext;

    btn.disabled = true;
    txt.textContent = 'Memproses…';
    try {
      const r = await fetch('/api/billing/invoices/' + encodeURIComponent(ctx.id) + '/mark-paid', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({
          method,
          payment_date: date || null,
          reference_number: ref || null,
          notes: notes || null,
        }),
      });
      const j = await r.json().catch(() => null);
      if (r.ok && j && j.success) {
        _markedPaid.add(ctx.id);
        showToast('success', 'Berhasil dilunaskan', `Invoice ${ctx.invoiceNo} • ${ctx.name}`);
        window.closeMP();
        // Refresh: re-render customer list, refresh collection stats, KPI, recent tx
        if (_dueListsCache) renderCustomerList(_currentBucket, _dueListsCache);
        loadCollection().then(renderCollection);
        loadPayments().then(() => renderKPI());
        loadActivity().then(renderActivity);
        loadTransactions(_txFilter).then(renderTransactions);
      } else {
        showToast('error', 'Gagal menandai lunas', (j && j.message) || 'Coba lagi.');
      }
    } catch (e) {
      showToast('error', 'Gagal menandai lunas', e.message || 'Jaringan bermasalah.');
    } finally {
      btn.disabled = false;
      txt.textContent = 'Tandai Lunas';
    }
  };

  // ═══════ BULK SEND WA ═══════════════════════════════════════════
  async function runBulkReminder(invoiceIds){
    const overlay = document.getElementById('bulkOverlay');
    const title   = document.getElementById('bulkTitle');
    const sub     = document.getElementById('bulkSub');
    const fill    = document.getElementById('bulkFill');
    const pctText = document.getElementById('bulkPctText');
    const counter = document.getElementById('bulkCounter');
    const log     = document.getElementById('bulkLog');
    const closeBtn= document.getElementById('bulkCloseBtn');
    const doneBtn = document.getElementById('bulkDoneBtn');

    log.innerHTML = '';
    fill.style.width = '0%';
    pctText.textContent = '0%';
    counter.textContent = '0 / ' + invoiceIds.length;
    title.textContent = 'Mengirim WA Massal';
    sub.textContent = invoiceIds.length + ' invoice diproses';
    closeBtn.style.display = 'none';
    doneBtn.style.display = 'none';
    overlay.classList.add('show');
    document.body.style.overflow = 'hidden';

    try {
      const r = await fetch('/api/billing/bulk-reminder', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ invoice_ids: invoiceIds }),
      });
      const j = await r.json().catch(() => null);

      if (!r.ok || !j || !j.success) {
        title.textContent = 'Gagal mengirim';
        sub.textContent = (j && j.message) || 'Server error';
        closeBtn.style.display = '';
        doneBtn.style.display = '';
        return;
      }

      // Simulasi animasi progress karena server return sekaligus
      // (alasan: implementasi SSE/WebSocket akan terlalu kompleks untuk
      // volume kecil; bulk dibatasi 100 invoice di server)
      const results = (j.data && j.data.results) || [];
      const total = results.length;
      const stepMs = Math.min(120, Math.max(40, Math.floor(2000 / Math.max(total,1))));

      for (let i = 0; i < total; i++) {
        const res = results[i];
        const row = document.createElement('div');
        row.className = 'bulk-log-row ' + (res.ok ? 'ok' : 'err');
        row.innerHTML = `
          <span class="bulk-log-icon">
            ${res.ok
              ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>'
              : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'}
          </span>
          <span class="bulk-log-name">${escHtml(res.customer_name || ('Invoice #' + res.id))}</span>
          <span style="font-size:10.5px;opacity:.7;">${escHtml(res.invoice_number || '')}</span>
          ${res.ok ? '' : `<span style="font-size:10.5px;color:#991b1b;">${escHtml(res.error || 'gagal')}</span>`}
        `;
        log.appendChild(row);
        log.scrollTop = log.scrollHeight;

        if (res.ok) _waSent.add(res.id);

        const pct = Math.round(((i+1) / total) * 100);
        fill.style.width = pct + '%';
        pctText.textContent = pct + '%';
        counter.textContent = (i+1) + ' / ' + total;
        await new Promise(r => setTimeout(r, stepMs));
      }

      const okCount  = j.data.ok_count || 0;
      const failCount = j.data.fail_count || 0;
      title.textContent = `Selesai: ${okCount} berhasil, ${failCount} gagal`;
      sub.textContent = 'Tutup untuk kembali ke dashboard';
      closeBtn.style.display = '';
      doneBtn.style.display = '';

      // Clear selection & refresh list + activity
      _selectedInv.clear();
      if (_dueListsCache) renderCustomerList(_currentBucket, _dueListsCache);
      loadActivity().then(renderActivity);
    } catch (e) {
      title.textContent = 'Gagal mengirim';
      sub.textContent = e.message || 'Jaringan bermasalah.';
      closeBtn.style.display = '';
      doneBtn.style.display = '';
    }
  }
  window.closeBulk = function(ev){
    if (ev && ev.target !== ev.currentTarget) return;
    document.getElementById('bulkOverlay').classList.remove('show');
    document.body.style.overflow = '';
  };

  // ESC closes any open modal
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      ['qeOverlay','mpOverlay','bulkOverlay'].forEach(id => {
        const ov = document.getElementById(id);
        if (ov && ov.classList.contains('show')) {
          ov.classList.remove('show');
          document.body.style.overflow = '';
        }
      });
    }
  });

  // ═══════ MAIN INIT ═══════════════════════════════════════════
  (async function init(){
    // Run in parallel — but render KPI hanya setelah dua fetch utama selesai
    const [_, txRows, custStats, collectionData, channels, dueLists, insights, activity] = await Promise.all([
      // gabung keuangan + payments (race tidak masalah, state di-set masing2)
      Promise.all([loadKeuangan(), loadPayments()]),
      loadTransactions('all'),
      loadCustomers(),
      loadCollection(),
      loadChannels(),
      loadDueLists(),
      loadInsights(),
      loadActivity(),
    ]);

    renderKPI();
    renderBalance(custStats);
    renderCollection(collectionData);
    renderChannels(channels);
    renderCashFlow();
    renderBudget();
    renderTransactions(txRows);
    renderDailyTx(_dtxDays);
    renderInsights(insights);
    renderActivity(activity);

    // Customer list section — default tab: unpaid_all
    renderTabCounts(dueLists);
    renderCustomerList(_currentBucket, dueLists);

    // Setup auto-reminder toggle (independent of other data)
    setupReminderToggle();
  })();

})();
</script>
