                <div class="mini-sub" id="mActiveSub">aktif</div>
              </div>

              <div class="mini">
                <div class="mini-head">
                  <span class="mini-icon" style="background:rgba(245,158,11,.12);color:#d97706;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4"/><circle cx="12" cy="17" r=".5"/></svg>
                  </span>
                  <span class="mini-lbl">Overdue</span>
                </div>
