  // ─── COLLECTION RATE ───
  function renderCollection(d){
    if (!d) d = {};
    const total_inv     = parseInt(d.total_invoices    || 0);
    const total_billed  = parseFloat(d.total_billed    || 0);
    const paid_count    = parseInt(d.paid_count        || 0);
    const collected     = parseFloat(d.total_collected || 0);
    const unpaid_count  = parseInt(d.unpaid_count      || 0);
    const outstanding   = parseFloat(d.total_outstanding || 0);
    const paid_cust     = parseInt(d.paid_customers    || 0);
    const unpaid_cust   = parseInt(d.unpaid_customers  || 0);
    const rate          = parseFloat(d.collection_rate_amt || d.collection_rate || 0);

    // ── Circular progress ring ──
    const R = 58;
    const C = 2 * Math.PI * R;
    const fillLen = (Math.min(rate, 100) / 100) * C;
    const ring = document.getElementById('crRing');
    if (ring) {
      // Animate dari 0 ke target
      ring.setAttribute('stroke-dasharray', `0 ${C}`);
      // Trigger reflow lalu animate (CSS transition stroke-dasharray tidak jalan
      // di semua browser, jadi pakai requestAnimationFrame fade-in)
      let start = null;
      const dur = 900;
      function step(ts){
        if (!start) start = ts;
        const t = Math.min((ts - start) / dur, 1);
        const eased = 1 - Math.pow(1 - t, 3);  // easeOutCubic
        const cur = fillLen * eased;
        ring.setAttribute('stroke-dasharray', `${cur} ${C - cur}`);
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    // ── Center text ──
    document.getElementById('crValue').textContent = rate.toFixed(1);

    // ── Breakdown ──
    document.getElementById('cbPaidCnt').textContent   = fmtNum(paid_count);
    document.getElementById('cbPaidAmt').textContent   = fmtRp(collected);
    document.getElementById('cbPaidCust').textContent  = fmtNum(paid_cust) + ' pelanggan sudah membayar';
    document.getElementById('cbUnpaidCnt').textContent = fmtNum(unpaid_count);
    document.getElementById('cbUnpaidAmt').textContent = fmtRp(outstanding);
    document.getElementById('cbUnpaidCust').textContent = fmtNum(unpaid_cust) + ' pelanggan belum membayar';

    // ── Bar fills (proportional to amount) ──
    const totalAmt = collected + outstanding;
    let paidPct   = totalAmt > 0 ? (collected   / totalAmt) * 100 : 0;
    let unpaidPct = totalAmt > 0 ? (outstanding / totalAmt) * 100 : 0;
    // Minimum visible width supaya bar tetap kelihatan kalau pct sangat kecil
    if (paidPct   > 0 && paidPct   < 4) paidPct   = 4;
    if (unpaidPct > 0 && unpaidPct < 4) unpaidPct = 4;
    // Delay supaya animasi width terlihat
    setTimeout(() => {
      document.getElementById('cbPaidFill').style.width   = paidPct + '%';
      document.getElementById('cbUnpaidFill').style.width = unpaidPct + '%';
    }, 80);

    // ── Footer strip ──
    document.getElementById('crTotalBilled').textContent = fmtRp(total_billed);
    document.getElementById('crTotalInv').textContent    = fmtNum(total_inv);

    // ── DUE-DATE BUCKETS ──
    const dd3Count  = parseInt(d.due_3days_count     || 0);
    const dd3Cust   = parseInt(d.due_3days_customers || 0);
    const dd3Amt    = parseFloat(d.due_3days_amount  || 0);
    const ddTCount  = parseInt(d.due_today_count     || 0);
    const ddTCust   = parseInt(d.due_today_customers || 0);
    const ddTAmt    = parseFloat(d.due_today_amount  || 0);
    const ddPCount  = parseInt(d.past_due_count      || 0);
    const ddPCust   = parseInt(d.past_due_customers  || 0);
    const ddPAmt    = parseFloat(d.past_due_amount   || 0);

    function setDD(prefix, cnt, cust, amt){
      const v = document.getElementById(prefix + 'Count');
      const c = document.getElementById(prefix + 'Cust');
      const a = document.getElementById(prefix + 'Amt');
      if (v) v.textContent = fmtNum(cnt) + (cnt === 1 ? ' invoice' : ' invoice');
      if (c) c.textContent = fmtNum(cust) + ' pelanggan';
      if (a) a.textContent = amt > 0 ? fmtRp(amt) : 'Rp 0';
    }
    setDD('dd3', dd3Count, dd3Cust, dd3Amt);
    setDD('ddT', ddTCount, ddTCust, ddTAmt);
    setDD('ddP', ddPCount, ddPCust, ddPAmt);

    // ── Edge case: tidak ada invoice bulan ini ──
    if (total_inv === 0) {
      const wrap = document.querySelector('.collect-card .collect-wrap');
      if (wrap) {
        wrap.innerHTML = `
          <div class="empty" style="grid-column:1/-1;">
            <div class="ic" style="background:rgba(99,102,241,.10);color:#4f46e5;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2.5"/><path d="M1 10h22"/></svg>
            </div>
            <div class="t">Belum ada invoice bulan ini</div>
            <div>Generate tagihan bulanan untuk mulai tracking collection.</div>
          </div>
        `;
      }
      document.getElementById('crStrip').style.display = 'none';
    }
  }

