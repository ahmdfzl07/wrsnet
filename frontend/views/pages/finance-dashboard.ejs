                    <span class="rem-track">
                      <span class="rem-thumb"></span>
                    </span>
                    <span class="rem-lbl">
                      <span class="rem-dot"></span>
                      <span id="remLblText">Reminder otomatis</span>
                    </span>
                  </label>
                  <a href="/billing" class="link">
