              <span class="sep">·</span>
              <span>${escHtml(timeAgo(a.created_at))}</span>
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  // ═══════ AUTO-REMINDER TOGGLE ═══════════════════════════════════
  async function setupReminderToggle(){
    const wrap = document.getElementById('remToggleWrap');
    const cb   = document.getElementById('remToggle');
    const lblText = document.getElementById('remLblText');
    if (!cb) return;

    const cfg = await loadReminderConfig();
    if (!cfg) {
      lblText.textContent = 'Reminder otomatis (tidak tersedia)';
      wrap.classList.add('disabled');
      return;
    }
    cb.checked  = !!cfg.enabled;
    cb.disabled = false;
    wrap.classList.remove('disabled');
    lblText.textContent = 'Reminder otomatis ' + (cfg.enabled ? 'ON' : 'OFF');

    cb.addEventListener('change', async () => {
      const want = cb.checked;
      cb.disabled = true;
      wrap.classList.add('disabled');
      try {
        const r = await fetch('/api/finance/reminder-config', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type':'application/json' },
          body: JSON.stringify({ enabled: want })
        });
        const j = await r.json().catch(() => null);
        if (r.ok && j && j.success) {
          lblText.textContent = 'Reminder otomatis ' + (want ? 'ON' : 'OFF');
          showToast('success',
            want ? 'Reminder otomatis aktif' : 'Reminder otomatis nonaktif',
            want
              ? 'Sistem akan kirim reminder WA sesuai jadwal di /wa/reminder.'
              : 'Reminder hanya akan terkirim manual dari dashboard ini.'
          );
        } else {
          cb.checked = !want;   // revert
          showToast('error', 'Gagal mengubah', (j && j.message) || 'Coba lagi.');
        }
      } catch (e) {
        cb.checked = !want;
        showToast('error', 'Gagal mengubah', e.message || 'Jaringan bermasalah.');
      } finally {
        cb.disabled = false;
        wrap.classList.remove('disabled');
      }
    });
  }

