  };
  // Fallback color (server-side METHOD_COLOR map)
  const CH_COLORS = {
    cash:'#16a34a', transfer:'#1d4ed8', qris:'#d97706',
    dana:'#0ea5e9', ovo:'#7c3aed',     gopay:'#16a34a',
