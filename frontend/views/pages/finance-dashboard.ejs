                  <span>Belum Bayar</span>
                  <span class="cl-tab-cnt" id="tabUnpaidAll">—</span>
                </button>
                <button type="button" class="cl-tab" data-bucket="due_3days" role="tab">
                  <span class="cl-tab-dot" style="background:#1d4ed8;"></span>
                  <span>3 Hari Kedepan</span>
                  <span class="cl-tab-cnt" id="tab3Days">—</span>
                </button>
                <button type="button" class="cl-tab" data-bucket="due_today" role="tab">
                  <span class="cl-tab-dot" style="background:#d97706;"></span>
                  <span>Jatuh Tempo Hari Ini</span>
                  <span class="cl-tab-cnt" id="tabToday">—</span>
                </button>
                <button type="button" class="cl-tab" data-bucket="past_due" role="tab">
                  <span class="cl-tab-dot" style="background:#e11d48;"></span>
                  <span>Lewat Jatuh Tempo</span>
                  <span class="cl-tab-cnt" id="tabPast">—</span>
                </button>
              </div>

              <!-- Bulk action bar — muncul saat ada checkbox yang dipilih -->
              <div class="bulk-bar" id="bulkBar" style="display:none;">
                <div class="bulk-bar-info">
                  <span class="bulk-bar-cnt" id="bulkBarCnt">0</span>
                  invoice dipilih
                </div>
                <div class="bulk-bar-actions">
                  <button type="button" class="bulk-bar-btn ghost" id="bulkClearBtn">
                    Batal pilihan
                  </button>
                  <button type="button" class="bulk-bar-btn primary" id="bulkSendBtn">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2z"/></svg>
                    Kirim WA ke <span id="bulkSendCnt">0</span> terpilih
                  </button>
                </div>
              </div>

              <!-- List body -->
              <div id="clBody" class="cl-body">
                <div class="empty" style="padding:38px 14px;">
                  <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
                    <div class="skel" style="width:200px;height:14px;"></div>
                    <div class="skel" style="width:140px;height:12px;"></div>
                    <div class="skel" style="width:170px;height:12px;"></div>
                  </div>
                </div>
              </div>

              <!-- Footer summary -->
              <div class="cl-foot" id="clFoot" style="display:none;">
                <span id="clFootMeta">—</span>
              </div>
            </div>

            <!-- ─── Recent Transactions ─── -->
            <div class="card">
              <div class="card-head">
                <div>
                  <h3>Transaksi Terbaru</h3>
                  <div class="h-sub">Pemasukan customer &amp; pengeluaran operasional terbaru</div>
                </div>
                <a href="/payments" class="link">
                  Lihat semua
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
              </div>

              <!-- Filter pills -->
              <div class="range-pills tx-filter" id="txFilter">
                <button data-f="all"     class="active" type="button">
                  <span class="tx-fdot" style="background:linear-gradient(135deg,#0b3d8c 50%,#7dd3fc 50%);"></span>
                  Semua
                </button>
                <button data-f="income"  type="button">
                  <span class="tx-fdot" style="background:#0b3d8c;"></span>
                  Pemasukan
                </button>
                <button data-f="expense" type="button">
                  <span class="tx-fdot" style="background:#7dd3fc;"></span>
                  Pengeluaran
                </button>
              </div>

              <div style="overflow-x:auto;margin:0 -8px;">
                <table class="tx-table">
                  <thead>
                    <tr>
                      <th style="width:42%;">Deskripsi</th>
                      <th>Referensi</th>
                      <th class="right">Jumlah</th>
                      <th>Tanggal</th>
