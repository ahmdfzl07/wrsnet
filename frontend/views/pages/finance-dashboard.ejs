                  <div class="h-sub">Audit ringan transaksi tim</div>
                </div>
              </div>
              <div id="actBody" class="act-list">
                <div class="empty" style="padding:24px 14px;">
                  <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                    <div class="skel" style="width:160px;height:12px;"></div>
                    <div class="skel" style="width:120px;height:11px;"></div>
                  </div>
                </div>
              </div>
            </div>

          </div><!-- /.fin-rail -->

        </div><!-- /.fin-grid -->
      </div><!-- /.fin -->

      </main>
    </div>
  </div>

  <!-- Toast notifications -->
  <div class="toast-stack" id="toastStack"></div>

  <!-- Quick Expense FAB (floating action button) -->
  <button type="button" class="fab-expense" id="fabExpense" title="Catat Pengeluaran" aria-label="Catat Pengeluaran">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    <span>Catat Pengeluaran</span>
  </button>

  <!-- Quick Expense Modal -->
  <div class="qm-overlay" id="qeOverlay" onclick="closeQE(event)">
    <div class="qm-modal" onclick="event.stopPropagation();">
      <div class="qm-head">
        <div class="qm-head-icon" style="background:linear-gradient(135deg,#0b3d8c,#1d4ed8);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
        </div>
        <div class="qm-head-body">
          <h3>Catat Pengeluaran</h3>
          <div class="qm-head-sub">Tambah cepat tanpa pindah halaman</div>
        </div>
        <button type="button" class="qm-close" onclick="closeQE()" aria-label="Tutup">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
      </div>
      <form id="qeForm" class="qm-body" onsubmit="return false;">
        <div class="qm-field">
          <label>Jumlah (Rp) <span class="req">*</span></label>
          <input type="number" id="qeAmount" required min="1" placeholder="contoh: 150000" inputmode="numeric"/>
        </div>
        <div class="qm-field">
          <label>Kategori <span class="req">*</span></label>
          <input type="text" id="qeCategory" list="qeCatList" required placeholder="Pilih atau ketik kategori"/>
          <datalist id="qeCatList">
            <option value="Gaji Teknisi"/>
            <option value="Sewa Kantor"/>
            <option value="Internet Backbone"/>
            <option value="Listrik"/>
            <option value="Peralatan"/>
            <option value="Konsumsi"/>
            <option value="Transportasi"/>
            <option value="Maintenance"/>
            <option value="Lainnya"/>
          </datalist>
        </div>
        <div class="qm-row">
          <div class="qm-field">
            <label>Vendor / Pihak</label>
            <input type="text" id="qePartyName" placeholder="opsional"/>
          </div>
          <div class="qm-field">
            <label>Tanggal</label>
            <input type="date" id="qeDate"/>
          </div>
        </div>
        <div class="qm-field">
          <label>Keterangan</label>
          <textarea id="qeNotes" rows="2" placeholder="opsional"></textarea>
        </div>
        <div class="qm-actions">
          <button type="button" class="qm-btn ghost" onclick="closeQE()">Batal</button>
          <button type="button" class="qm-btn primary" id="qeSubmit" onclick="submitQE()">
            <span id="qeSubmitTxt">Simpan</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Bulk Send WA Modal (progress) -->
  <div class="qm-overlay" id="bulkOverlay" onclick="closeBulk(event)">
    <div class="qm-modal" onclick="event.stopPropagation();">
      <div class="qm-head">
        <div class="qm-head-icon" style="background:#25d366;">
          <svg viewBox="0 0 24 24" fill="currentColor" style="color:#fff;"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.87 9.87 0 0 0 12.04 2z"/></svg>
        </div>
        <div class="qm-head-body">
