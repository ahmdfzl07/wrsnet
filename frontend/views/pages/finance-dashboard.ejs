                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M7 17 17 7"/><polyline points="7 7 17 7 17 17"/></svg>
                </a>
                <a href="/billing" class="bal-btn ghost">
                  Tagihan
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M17 7 7 17"/><polyline points="17 17 7 17 7 7"/></svg>
                </a>
              </div>
            </div>

