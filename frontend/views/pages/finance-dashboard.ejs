<!DOCTYPE html>
<html lang="id" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= appName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script src="https://cdn.jsdelivr.net/npm/apexcharts@3.45.2/dist/apexcharts.min.js"></script>
  <style>
    /* ═══════════════════════════════════════════════════════════════
       FINANCE DASHBOARD v2 — Fundex-inspired
       Clean, modern, brand-blue gradient
       ═══════════════════════════════════════════════════════════════ */

    .fin{font-family:'Plus Jakarta Sans','DM Sans',system-ui,sans-serif;letter-spacing:-.005em;max-width:1480px;margin:0 auto;}
    .fin,.fin *{font-feature-settings:'cv11','ss01';}

    /* ═══════════════════════════════════════════════════════════ */
    /* ENTRANCE ANIMATIONS                                          */
    /* Setiap elemen dengan class .fin-anim awalnya invisible &      */
    /* translated; saat masuk viewport (via IntersectionObserver)    */
    /* dapat class .in-view → animate ease-out ke posisi normal.     */
    /* Stagger pakai inline style --anim-delay.                      */
    /* ═══════════════════════════════════════════════════════════ */
    @media (prefers-reduced-motion: no-preference) {
      .fin-anim{
        opacity:0;
        transform:translateY(18px);
        transition:opacity .65s cubic-bezier(.22,.61,.36,1),
                   transform .65s cubic-bezier(.22,.61,.36,1);
        transition-delay:var(--anim-delay, 0ms);
        will-change:opacity, transform;
      }
      .fin-anim.fade-only{transform:none;}
      .fin-anim.slide-left{transform:translateX(-22px);}
      .fin-anim.slide-right{transform:translateX(22px);}
      .fin-anim.scale-in{transform:scale(.96);}
      .fin-anim.in-view{
        opacity:1;
        transform:translate(0,0) scale(1);
      }
      /* Pulse highlight saat KPI value pertama kali muncul */
      @keyframes fin-pop{
        0%{transform:scale(.92);opacity:0;}
        60%{transform:scale(1.02);opacity:1;}
        100%{transform:scale(1);opacity:1;}
      }
      .fin-anim.in-view .kpi-value,
      .fin-anim.in-view .bal-value{
        animation:fin-pop .55s cubic-bezier(.22,.61,.36,1) backwards;
        animation-delay:calc(var(--anim-delay, 0ms) + 200ms);
      }
    }
    /* Respect user preference: kalau prefers-reduced-motion, langsung tampil */
    @media (prefers-reduced-motion: reduce) {
      .fin-anim{opacity:1;transform:none;}
    }

    /* Reveal animation untuk row tabel (tx-table) & customer list (cl-list)
       saat di-populate via JS — agar tidak instant pop */
    @media (prefers-reduced-motion: no-preference) {
      @keyframes fin-row-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .tx-table tbody tr,
      .cl-list .cl-row,
      .ch-list .ch-row,
      .donut-legend .dl-item {
        animation: fin-row-in .42s cubic-bezier(.22,.61,.36,1) backwards;
      }
      .tx-table tbody tr:nth-child(1),
      .cl-list .cl-row:nth-child(1),
      .ch-list .ch-row:nth-child(1),
      .donut-legend .dl-item:nth-child(1)   { animation-delay: 30ms; }
      .tx-table tbody tr:nth-child(2),
      .cl-list .cl-row:nth-child(2),
      .ch-list .ch-row:nth-child(2),
      .donut-legend .dl-item:nth-child(2)   { animation-delay: 70ms; }
      .tx-table tbody tr:nth-child(3),
      .cl-list .cl-row:nth-child(3),
      .ch-list .ch-row:nth-child(3),
      .donut-legend .dl-item:nth-child(3)   { animation-delay: 110ms; }
      .tx-table tbody tr:nth-child(4),
      .cl-list .cl-row:nth-child(4),
      .ch-list .ch-row:nth-child(4),
      .donut-legend .dl-item:nth-child(4)   { animation-delay: 150ms; }
      .tx-table tbody tr:nth-child(5),
      .cl-list .cl-row:nth-child(5),
      .ch-list .ch-row:nth-child(5),
      .donut-legend .dl-item:nth-child(5)   { animation-delay: 190ms; }
      .tx-table tbody tr:nth-child(6),
      .cl-list .cl-row:nth-child(6),
      .ch-list .ch-row:nth-child(6),
      .donut-legend .dl-item:nth-child(6)   { animation-delay: 230ms; }
      .tx-table tbody tr:nth-child(n+7),
      .cl-list .cl-row:nth-child(n+7),
      .ch-list .ch-row:nth-child(n+7),
      .donut-legend .dl-item:nth-child(n+7) { animation-delay: 270ms; }

      /* Smooth fade for KPI value text updates */
      .kpi-val, .kpi-sub,
      .dtx-strip-val,
      .cb-amt,
      .cb-cnt,
      .dd-val,
      .mini-val {
        transition: color .3s ease;
      }

      /* Bar fills slow & smooth (collection rate + channels) */
      .cb-fill, .ch-fill, .dl-item, .dtx-strip-cnt {
        transition: width .8s cubic-bezier(.22,.61,.36,1),
                    opacity .3s ease;
      }
    }

    /* ── Page header ─────────────────────────────────────────── */
    .fin-head{margin-bottom:22px;}
    .fin-head h1{
      font-size:26px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.028em;margin:0 0 4px;
    }
    .fin-head .sub{font-size:13.5px;color:#7587a6;font-weight:500;}

    /* ── 2-column grid: main + sidebar (right rail) ─────────── */
    .fin-grid{display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start;}
    @media (max-width:1180px){.fin-grid{grid-template-columns:1fr;}}

    /* ── Main column ─────────────────────────────────────────── */
    .fin-main{display:flex;flex-direction:column;gap:18px;min-width:0;}

    /* ── Right rail (balance + budget + my card) ─────────────── */
    .fin-rail{display:flex;flex-direction:column;gap:18px;}

    /* ─── KPI mini cards (Income / Expense) ─────────────────── */
    .kpi-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
    @media (max-width:520px){.kpi-row{grid-template-columns:1fr;}}

    .kpi{
      position:relative;background:#fff;
      border:1px solid #ecf0f9;border-radius:18px;
      padding:18px 20px;
      transition:transform .25s cubic-bezier(.2,.8,.2,1),
                 box-shadow .25s cubic-bezier(.2,.8,.2,1),
                 border-color .2s;
      overflow:hidden;
    }
    .kpi:hover{
      transform:translateY(-2px);
      box-shadow:0 18px 36px -20px rgba(15,30,90,.18);
      border-color:#dde6ff;
    }
    .kpi-head{display:flex;align-items:center;gap:10px;margin-bottom:14px;}
    .kpi-iwrap{
      width:34px;height:34px;border-radius:10px;
      display:flex;align-items:center;justify-content:center;flex-shrink:0;
    }
    .kpi-iwrap svg{width:17px;height:17px;}
    .kpi.tone-in  .kpi-iwrap{background:rgba(16,185,129,.12);color:#059669;}
    .kpi.tone-out .kpi-iwrap{background:rgba(244,63,94,.12);color:#e11d48;}
    .kpi-lbl{font-size:13px;font-weight:600;color:#475569;}
    .kpi-val{
      font-size:26px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.03em;line-height:1.1;
      font-variant-numeric:tabular-nums;
      margin-bottom:6px;
    }
    .kpi-delta{
      display:inline-flex;align-items:center;gap:4px;
      font-size:11.5px;font-weight:700;
    }
    .kpi-delta svg{width:11px;height:11px;}
    .kpi-delta.up{color:#16a34a;}
    .kpi-delta.down{color:#dc2626;}
    .kpi-delta.flat{color:#64748b;}
    .kpi-delta .since{color:#94a3b8;font-weight:500;margin-left:3px;}

    /* ═══════════════════════════════════════════════════════════ */
    /* DAILY TRANSACTIONS CHART                                     */
    /* ═══════════════════════════════════════════════════════════ */
    .dtx-card{position:relative;overflow:hidden;}

    /* Summary strip (3 mini-stats) */
    .dtx-strip{
      display:grid;grid-template-columns:repeat(3,1fr);gap:10px;
      margin-bottom:18px;
    }
    @media (max-width:560px){.dtx-strip{grid-template-columns:1fr;}}
    .dtx-strip-item{
      position:relative;
      display:flex;align-items:center;gap:11px;
      padding:11px 14px;border-radius:12px;
      background:#fafbff;border:1px solid #ecf0f9;
      overflow:hidden;
    }
    .dtx-strip-item .dtx-dot{
      width:9px;height:9px;border-radius:50%;flex-shrink:0;
    }
    /* Pemasukan: biru tua (navy). Pengeluaran: biru muda tosca (sky/cyan). Net: ungu/violet */
    .dtx-strip-item.dtx-in  .dtx-dot{background:#0b3d8c;}
    .dtx-strip-item.dtx-out .dtx-dot{background:#7dd3fc;}
    .dtx-strip-item.dtx-net .dtx-dot{background:#1d4ed8;}
    .dtx-strip-body{flex:1;min-width:0;line-height:1.2;}
    .dtx-strip-lbl{font-size:10.5px;font-weight:700;color:#7587a6;letter-spacing:.05em;text-transform:uppercase;}
    .dtx-strip-val{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-size:15px;font-weight:800;color:#0d1b3e;letter-spacing:-.018em;
      font-variant-numeric:tabular-nums;margin-top:2px;
    }
    .dtx-strip-cnt{
      font-size:11px;font-weight:700;color:#475569;
      background:#fff;padding:3px 9px;border-radius:99px;
      border:1px solid #e6ebf5;
      font-variant-numeric:tabular-nums;flex-shrink:0;
    }

    /* Chart canvas (ApexCharts) */
    .dtx-wrap{position:relative;width:100%;min-height:280px;}
    .dtx-wrap #dtxChart{min-height:280px;}

    /* ApexCharts tooltip override agar konsisten dengan theme */
    .dtx-wrap .apexcharts-tooltip{
      background:#0d1b3e !important;
      border:none !important;
      box-shadow:0 14px 28px -14px rgba(13,30,80,.55) !important;
      border-radius:10px !important;
      font-family:'Plus Jakarta Sans',sans-serif !important;
    }
    .dtx-wrap .apexcharts-tooltip-title{
      background:#0d1b3e !important;
      border-bottom:1px solid rgba(255,255,255,.15) !important;
      color:#fff !important;
      font-weight:700 !important;
      font-size:11.5px !important;
      letter-spacing:.04em;
      padding:8px 12px !important;
    }
    .dtx-wrap .apexcharts-tooltip-series-group{
      padding:4px 12px !important;
      color:#fff !important;
    }
    .dtx-wrap .apexcharts-tooltip-series-group.apexcharts-active{
      padding:4px 12px !important;
    }
    .dtx-wrap .apexcharts-tooltip-text-y-label,
    .dtx-wrap .apexcharts-tooltip-text-y-value{
      color:#fff !important;
      font-size:12px !important;
    }
    .dtx-wrap .apexcharts-tooltip-text-y-value{font-weight:700 !important;}
    .dtx-wrap .apexcharts-xaxistooltip,
    .dtx-wrap .apexcharts-yaxistooltip{display:none !important;}

    /* ─── Due-date card ──────────────────────────────────────── */
    .duedate-card{position:relative;overflow:hidden;}
    .dd-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
    @media (max-width:760px){.dd-grid{grid-template-columns:1fr;}}

    .dd-item{
      position:relative;
      display:flex;align-items:center;gap:14px;
      padding:16px 18px;border-radius:14px;
      background:#fafbff;border:1px solid #ecf0f9;
      transition:all .25s cubic-bezier(.2,.8,.2,1);
      overflow:hidden;
      cursor:pointer;
    }
    .dd-item:hover{
      transform:translateY(-2px);
      box-shadow:0 14px 28px -16px rgba(15,30,90,.20);
      border-color:#dde6ff;
    }
    .dd-icon{
      width:42px;height:42px;border-radius:12px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      background:currentColor;
    }
    .dd-icon svg{width:20px;height:20px;color:#fff;}
    .dd-body{flex:1;min-width:0;color:#0d1b3e;}
    .dd-lbl{
      font-size:11.5px;font-weight:700;letter-spacing:.04em;
      text-transform:uppercase;color:#64748b;margin-bottom:4px;
    }
    .dd-val{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-size:22px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.025em;line-height:1.05;
      font-variant-numeric:tabular-nums;margin-bottom:4px;
    }
    .dd-sub{
      font-size:11px;color:#7587a6;font-weight:500;
      display:flex;align-items:center;gap:6px;flex-wrap:wrap;
    }
    .dd-sub .dd-sep{color:#cbd5e1;}

    /* Tone variants */
    .dd-soon  { color:#1d4ed8; }
    .dd-today { color:#d97706; }
    .dd-past  { color:#e11d48; }

    .dd-soon  .dd-icon{background:linear-gradient(135deg,#1d4ed8,#3b82f6);box-shadow:0 8px 20px -8px rgba(29,78,216,.45);}
    .dd-today .dd-icon{background:linear-gradient(135deg,#d97706,#f59e0b);box-shadow:0 8px 20px -8px rgba(217,119,6,.45);}
    .dd-past  .dd-icon{background:linear-gradient(135deg,#e11d48,#f43f5e);box-shadow:0 8px 20px -8px rgba(225,29,72,.45);}

    /* Make breakdown items clickable (hint hover) */
    .cb-clickable{cursor:pointer;transition:background .15s;border-radius:10px;margin:-6px;padding:6px;}
    .cb-clickable:hover{background:#fff8e6;}

    /* ═══════════════════════════════════════════════════════════ */
    /* CUSTOMER LIST INLINE SECTION                                 */
    /* ═══════════════════════════════════════════════════════════ */
    .cl-card{}

    /* Template source info banner */
    .cl-tpl-info{
      display:flex;align-items:center;gap:10px;
      padding:10px 14px;margin-bottom:14px;
      background:linear-gradient(135deg,rgba(29,78,216,.05),rgba(29,78,216,.02));
      border:1px solid rgba(29,78,216,.12);
      border-radius:11px;
      font-size:12px;color:#475569;line-height:1.45;
    }
    .cl-tpl-info > svg{
      width:16px;height:16px;color:#1d4ed8;flex-shrink:0;
    }
    .cl-tpl-text{flex:1;min-width:0;}
    .cl-tpl-text code{
      font-family:ui-monospace,SFMono-Regular,Menlo,monospace;
      font-size:11px;background:rgba(29,78,216,.10);color:#1d4ed8;
      padding:1px 6px;border-radius:5px;font-weight:600;
      margin:0 1px;white-space:nowrap;
    }
    .cl-tpl-link{
      display:inline-flex;align-items:center;gap:5px;flex-shrink:0;
      font-size:12px;font-weight:600;color:#1d4ed8;
      padding:5px 11px;border-radius:8px;
      background:#fff;border:1px solid rgba(29,78,216,.20);
      text-decoration:none;transition:all .15s;
    }
    .cl-tpl-link:hover{background:rgba(29,78,216,.06);border-color:#1d4ed8;}
    .cl-tpl-link svg{width:12px;height:12px;}
    @media (max-width:640px){
      .cl-tpl-info{flex-wrap:wrap;}
      .cl-tpl-link{width:100%;justify-content:center;}
    }

    /* Tabs */
    .cl-tabs{
      display:flex;gap:4px;margin-bottom:14px;
      background:#f3f5fb;border-radius:12px;padding:4px;
      overflow-x:auto;scrollbar-width:none;
    }
    .cl-tabs::-webkit-scrollbar{display:none;}
    .cl-tab{
      display:inline-flex;align-items:center;gap:7px;
      padding:8px 14px;border-radius:9px;
      font-size:12.5px;font-weight:600;
      color:#64748b;background:transparent;border:none;cursor:pointer;
      transition:all .15s;font-family:inherit;white-space:nowrap;flex-shrink:0;
    }
    .cl-tab:hover{color:#1d4ed8;}
    .cl-tab.active{
      background:#fff;color:#0d1b3e;
      box-shadow:0 1px 3px rgba(13,30,80,.10);
    }
    .cl-tab-dot{
      width:7px;height:7px;border-radius:50%;flex-shrink:0;
    }
    .cl-tab-cnt{
      font-size:11px;font-weight:700;
      background:#e2e8f0;color:#475569;
      padding:2px 7px;border-radius:99px;
      min-width:22px;text-align:center;
      font-variant-numeric:tabular-nums;
    }
    .cl-tab.active .cl-tab-cnt{background:#dbeafe;color:#1d4ed8;}

    /* List body */
    .cl-body{margin:0 -8px;}
    .cl-list{display:flex;flex-direction:column;}
    .cl-row{
      display:grid;
      /* checkbox | avatar | info (flex grow) | amount | days | WA btn | more */
      grid-template-columns:20px 36px minmax(0,1fr) auto auto auto auto;
      gap:10px;align-items:center;
      padding:12px;border-radius:11px;
      transition:background .12s;
    }
    .cl-row:hover{background:#fafbff;}
    .cl-row + .cl-row{border-top:1px solid #f5f7fb;}

    .cl-avatar{
      width:36px;height:36px;border-radius:11px;flex-shrink:0;
      background:linear-gradient(135deg,#dbeafe,#e0e7ff);
      color:#1d4ed8;font-size:12.5px;font-weight:800;
      display:flex;align-items:center;justify-content:center;letter-spacing:-.01em;
    }
    .cl-info{min-width:0;display:flex;flex-direction:column;line-height:1.3;}
    .cl-name{
      font-size:13.5px;font-weight:700;color:#0d1b3e;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    }
    .cl-meta{
      font-size:11.5px;color:#7587a6;font-weight:500;
      font-variant-numeric:tabular-nums;
      display:flex;gap:6px;flex-wrap:wrap;align-items:center;
    }
    .cl-meta .sep{color:#cbd5e1;}
    .cl-amt{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-size:13.5px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.012em;font-variant-numeric:tabular-nums;
      text-align:right;min-width:90px;white-space:nowrap;
    }
    .cl-days{
      display:inline-flex;align-items:center;gap:3px;
      font-size:10.5px;font-weight:700;
      padding:3px 8px;border-radius:99px;
      font-variant-numeric:tabular-nums;flex-shrink:0;
      min-width:78px;justify-content:center;white-space:nowrap;
    }
    .cl-days.upcoming{background:rgba(29,78,216,.10);color:#1d4ed8;}
    .cl-days.today   {background:rgba(217,119,6,.12);color:#b45309;}
    .cl-days.past    {background:rgba(225,29,72,.12);color:#b91c1c;}

    /* WA action button */
    .cl-wa-btn{
      display:inline-flex;align-items:center;gap:6px;
      padding:8px 13px;border-radius:9px;
      background:#25d366;color:#fff;
      font-size:12px;font-weight:700;
      border:none;cursor:pointer;font-family:inherit;
      transition:all .15s;flex-shrink:0;white-space:nowrap;
      box-shadow:0 4px 10px -4px rgba(37,211,102,.5);
    }
    .cl-wa-btn:hover{
      background:#1eb555;transform:translateY(-1px);
      box-shadow:0 8px 16px -6px rgba(37,211,102,.55);
    }
    .cl-wa-btn:active{transform:translateY(0);}
    .cl-wa-btn:disabled{
      opacity:.6;cursor:wait;transform:none;
      background:#9ca3af;box-shadow:none;
    }
    .cl-wa-btn svg{width:13px;height:13px;flex-shrink:0;}
    .cl-wa-btn .spin{animation:cl-spin 1s linear infinite;}
    .cl-wa-btn.sent{background:#16a34a;}
    .cl-wa-btn.sent::before{
      content:'';width:7px;height:7px;border-radius:50%;background:#fff;
    }
    @keyframes cl-spin{to{transform:rotate(360deg);}}

    /* Footer */
    .cl-foot{
      display:flex;align-items:center;justify-content:space-between;
      gap:10px;padding:14px 0 0;margin-top:8px;
      border-top:1px dashed #ecf0f9;
      font-size:12px;color:#7587a6;font-weight:500;
    }
    .cl-foot strong{color:#0d1b3e;font-weight:700;}

    /* Tablet: kompresi tampilan — sembunyikan amount min-width & days min-width
       supaya 7 kolom muat di area sempit (rail mode atau viewport ~1000-1200px) */
    @media (max-width:1100px){
      .cl-row{
        grid-template-columns:20px 36px minmax(0,1fr) auto auto auto;
        grid-template-rows:auto auto;
        column-gap:10px;row-gap:8px;
      }
      .cl-wa-btn{
        grid-column:3/-1;grid-row:2;
        justify-self:end;justify-content:center;
      }
    }

    /* Mobile: stack semua → 2 baris bersih */
    @media (max-width:680px){
      .cl-row{
        grid-template-columns:20px 36px minmax(0,1fr) auto;
        grid-template-rows:auto auto auto;
        column-gap:10px;row-gap:8px;
        padding:10px;
      }
      .cl-avatar{width:32px;height:32px;}
      .cl-name{font-size:13px;}
      .cl-meta{font-size:11px;}
      .cl-amt{
        grid-column:3/4;grid-row:2;
        text-align:left;font-size:13px;min-width:auto;
      }
      .cl-days{
        grid-column:4/5;grid-row:2;
        justify-self:end;
      }
      .cl-wa-btn{
        grid-column:1/-1;grid-row:3;
        justify-content:center;width:100%;
      }
      .cl-more-wrap{
        grid-column:4/5;grid-row:1;
        justify-self:end;
      }
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* INSIGHT BANNER                                               */
    /* ═══════════════════════════════════════════════════════════ */
    .ins-wrap{
      display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
      gap:10px;margin-bottom:20px;
    }
    .ins-card{
      display:flex;align-items:flex-start;gap:11px;
      padding:13px 14px;border-radius:13px;
      background:#fff;border:1px solid #ecf0f9;
      transition:all .2s;
      position:relative;overflow:hidden;
    }
    .ins-card:hover{border-color:#dde6ff;box-shadow:0 14px 28px -16px rgba(15,30,90,.18);}
    .ins-card.has-action{cursor:pointer;}
    .ins-icon{
      width:34px;height:34px;border-radius:10px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .ins-icon svg{width:17px;height:17px;}
    .ins-card.danger  .ins-icon{background:rgba(225,29,72,.12);color:#dc2626;}
    .ins-card.warning .ins-icon{background:rgba(217,119,6,.12);color:#d97706;}
    .ins-card.info    .ins-icon{background:rgba(29,78,216,.10);color:#1d4ed8;}
    .ins-card.success .ins-icon{background:rgba(22,163,74,.12);color:#16a34a;}
    .ins-card.danger  {border-left:3px solid #e11d48;}
    .ins-card.warning {border-left:3px solid #f59e0b;}
    .ins-card.info    {border-left:3px solid #1d4ed8;}
    .ins-card.success {border-left:3px solid #16a34a;}
    .ins-body{flex:1;min-width:0;line-height:1.4;}
    .ins-title{
      font-size:13px;font-weight:700;color:#0d1b3e;
      letter-spacing:-.01em;margin-bottom:3px;
    }
    .ins-msg{font-size:11.5px;color:#475569;}
    .ins-action{
      display:inline-flex;align-items:center;gap:4px;
      font-size:11px;font-weight:700;color:#1d4ed8;
      margin-top:6px;
    }
    .ins-action svg{width:11px;height:11px;}

    /* ═══════════════════════════════════════════════════════════ */
    /* CUSTOMER LIST — auto-reminder toggle in head                 */
    /* ═══════════════════════════════════════════════════════════ */
    .cl-head-actions{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}

    .rem-toggle{
      display:inline-flex;align-items:center;gap:10px;cursor:pointer;
      padding:6px 12px 6px 6px;border-radius:99px;
      background:#f3f5fb;border:1px solid #e6ebf5;
      transition:all .15s;user-select:none;
    }
    .rem-toggle:hover{border-color:#cbd5e1;}
    .rem-toggle.disabled{opacity:.55;cursor:wait;}
    .rem-toggle input{position:absolute;opacity:0;pointer-events:none;}
    .rem-track{
      width:32px;height:18px;border-radius:99px;
      background:#cbd5e1;position:relative;
      transition:background .25s;flex-shrink:0;
    }
    .rem-thumb{
      position:absolute;top:2px;left:2px;
      width:14px;height:14px;border-radius:50%;
      background:#fff;
      box-shadow:0 1px 3px rgba(0,0,0,.20);
      transition:transform .25s cubic-bezier(.2,.8,.2,1);
    }
    .rem-toggle input:checked + .rem-track{background:#16a34a;}
    .rem-toggle input:checked + .rem-track .rem-thumb{transform:translateX(14px);}
    .rem-lbl{
      display:inline-flex;align-items:center;gap:6px;
      font-size:11.5px;font-weight:600;color:#475569;
      letter-spacing:.01em;
    }
    .rem-dot{
      width:7px;height:7px;border-radius:50%;background:#9ca3af;
      flex-shrink:0;transition:background .2s;
    }
    .rem-toggle input:checked ~ .rem-lbl .rem-dot{
      background:#16a34a;
      box-shadow:0 0 0 3px rgba(22,163,74,.20);
    }
    .rem-toggle input:checked ~ .rem-lbl{color:#16a34a;}

    /* ═══════════════════════════════════════════════════════════ */
    /* BULK ACTION BAR                                              */
    /* ═══════════════════════════════════════════════════════════ */
    .bulk-bar{
      display:flex;align-items:center;justify-content:space-between;
      gap:10px;margin-bottom:14px;
      padding:10px 14px;border-radius:11px;
      background:linear-gradient(135deg,rgba(11,61,140,.06),rgba(29,78,216,.04));
      border:1px solid rgba(29,78,216,.15);
      animation:bulk-bar-in .3s cubic-bezier(.22,.61,.36,1);
    }
    @keyframes bulk-bar-in{
      from{opacity:0;transform:translateY(-8px);}
      to  {opacity:1;transform:translateY(0);}
    }
    .bulk-bar-info{
      font-size:12.5px;color:#1d4ed8;font-weight:600;
    }
    .bulk-bar-cnt{
      display:inline-block;
      font-weight:800;font-size:14px;
      background:#1d4ed8;color:#fff;
      min-width:22px;text-align:center;
      padding:1px 7px;border-radius:6px;margin-right:3px;
      font-variant-numeric:tabular-nums;
    }
    .bulk-bar-actions{display:flex;gap:8px;flex-wrap:wrap;}
    .bulk-bar-btn{
      display:inline-flex;align-items:center;gap:6px;
      padding:8px 14px;border-radius:9px;
      font-size:12px;font-weight:700;
      border:none;cursor:pointer;font-family:inherit;
      transition:all .15s;
    }
    .bulk-bar-btn svg{width:13px;height:13px;flex-shrink:0;}
    .bulk-bar-btn.ghost{
      background:#fff;color:#475569;border:1px solid #e6ebf5;
    }
    .bulk-bar-btn.ghost:hover{background:#f3f5fb;border-color:#cbd5e1;}
    .bulk-bar-btn.primary{
      background:#25d366;color:#fff;
      box-shadow:0 6px 14px -6px rgba(37,211,102,.5);
    }
    .bulk-bar-btn.primary:hover{
      background:#1eb555;transform:translateY(-1px);
      box-shadow:0 10px 18px -8px rgba(37,211,102,.55);
    }
    .bulk-bar-btn:disabled{opacity:.6;cursor:wait;transform:none;}

    /* Row: checkbox + overflow menu */
    .cl-check{
      width:18px;height:18px;flex-shrink:0;cursor:pointer;
      accent-color:#1d4ed8;
    }
    .cl-row.selected{background:#f0f7ff !important;}
    .cl-row.selected:hover{background:#e0f0ff !important;}

    /* Last reminder badge */
    .cl-last-rem{
      font-size:10.5px;font-weight:600;color:#16a34a;
      display:inline-flex;align-items:center;gap:3px;
      background:rgba(22,163,74,.10);padding:2px 7px;border-radius:6px;
      margin-left:4px;
    }
    .cl-last-rem svg{width:10px;height:10px;}

    /* Overflow menu button */
    .cl-more-wrap{position:relative;flex-shrink:0;}
    .cl-more{
      width:30px;height:30px;border-radius:8px;
      background:transparent;border:1px solid #ecf0f9;
      color:#64748b;cursor:pointer;flex-shrink:0;
      display:inline-flex;align-items:center;justify-content:center;
      transition:all .15s;
    }
    .cl-more:hover{background:#f3f5fb;color:#0d1b3e;border-color:#cbd5e1;}
    .cl-more svg{width:15px;height:15px;}

    .cl-popover{
      position:absolute;top:calc(100% + 6px);right:0;
      min-width:200px;
      background:#fff;border:1px solid #ecf0f9;border-radius:11px;
      box-shadow:0 18px 38px -14px rgba(13,30,80,.30);
      padding:5px;z-index:50;
      display:none;
    }
    .cl-popover.show{display:block;}
    .cl-popover-item{
      display:flex;align-items:center;gap:10px;
      width:100%;padding:9px 11px;border-radius:8px;
      background:transparent;border:none;cursor:pointer;
      font-size:12.5px;font-weight:600;color:#0d1b3e;
      font-family:inherit;text-align:left;
      transition:background .12s;
    }
    .cl-popover-item:hover{background:#f3f5fb;}
    .cl-popover-item svg{width:14px;height:14px;color:#64748b;flex-shrink:0;}
    .cl-popover-item.danger{color:#dc2626;}
    .cl-popover-item.danger svg{color:#dc2626;}

    /* ═══════════════════════════════════════════════════════════ */
    /* QUICK EXPENSE FAB                                            */
    /* ═══════════════════════════════════════════════════════════ */
    .fab-expense{
      position:fixed;bottom:24px;right:24px;
      display:inline-flex;align-items:center;gap:8px;
      padding:14px 22px 14px 16px;
      border-radius:99px;border:none;cursor:pointer;
      background:linear-gradient(135deg,#0b3d8c,#1d4ed8);color:#fff;
      font-family:inherit;font-size:13px;font-weight:700;
      box-shadow:0 14px 30px -10px rgba(11,61,140,.55);
      transition:all .25s cubic-bezier(.2,.8,.2,1);
      z-index:90;
    }
    .fab-expense:hover{
      transform:translateY(-2px);
      box-shadow:0 20px 36px -10px rgba(11,61,140,.6);
    }
    .fab-expense:active{transform:translateY(0);}
    .fab-expense svg{width:18px;height:18px;flex-shrink:0;}
    @media (max-width:560px){
      .fab-expense{
        padding:14px;
        bottom:16px;right:16px;
      }
      .fab-expense span{display:none;}
    }

    /* ═══════════════════════════════════════════════════════════ */
    /* QUICK EXPENSE / BULK / MARK-PAID MODAL (shared)              */
    /* ═══════════════════════════════════════════════════════════ */
    .qm-overlay{
      position:fixed;inset:0;
      background:rgba(13,30,80,.45);
      backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
      display:none;align-items:center;justify-content:center;
      z-index:1000;padding:20px;
      opacity:0;transition:opacity .2s;
    }
    .qm-overlay.show{display:flex;opacity:1;}
    .qm-modal{
      background:#fff;border-radius:18px;
      max-width:480px;width:100%;max-height:88vh;
      box-shadow:0 30px 80px -20px rgba(13,30,80,.45);
      display:flex;flex-direction:column;
      transform:translateY(16px);opacity:0;
      transition:transform .25s cubic-bezier(.2,.8,.2,1),opacity .2s;
      overflow:hidden;
    }
    .qm-overlay.show .qm-modal{transform:translateY(0);opacity:1;}
    .qm-head{
      display:flex;align-items:center;gap:13px;
      padding:18px 20px;border-bottom:1px solid #ecf0f9;
    }
    .qm-head-icon{
      width:38px;height:38px;border-radius:11px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .qm-head-icon svg{width:18px;height:18px;color:#fff;}
    .qm-head-body{flex:1;min-width:0;}
    .qm-head-body h3{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-size:15.5px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.022em;margin:0 0 1px;
    }
    .qm-head-sub{font-size:11.5px;color:#7587a6;font-weight:500;}
    .qm-close{
      width:30px;height:30px;border-radius:8px;flex-shrink:0;
      background:#f3f5fb;color:#64748b;
      border:none;cursor:pointer;
      display:flex;align-items:center;justify-content:center;
      transition:all .15s;
    }
    .qm-close:hover{background:#e2e8f0;color:#0d1b3e;}
    .qm-close svg{width:14px;height:14px;}
    .qm-body{
      flex:1;overflow-y:auto;
      padding:18px 20px;
      display:flex;flex-direction:column;gap:12px;
    }
    .qm-field{display:flex;flex-direction:column;gap:5px;}
    .qm-field label{
      font-size:11.5px;font-weight:700;color:#475569;
      letter-spacing:.02em;text-transform:uppercase;
    }
    .qm-field label .req{color:#dc2626;}
    .qm-field input,
    .qm-field select,
    .qm-field textarea{
      padding:10px 12px;border-radius:9px;
      border:1px solid #e2e8f0;background:#fff;
      font-family:inherit;font-size:13px;color:#0d1b3e;
      transition:border-color .15s,box-shadow .15s;
    }
    .qm-field input:focus,
    .qm-field select:focus,
    .qm-field textarea:focus{
      outline:none;border-color:#1d4ed8;
      box-shadow:0 0 0 3px rgba(29,78,216,.12);
    }
    .qm-field textarea{resize:vertical;min-height:60px;font-family:inherit;}
    .qm-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    @media (max-width:480px){.qm-row{grid-template-columns:1fr;}}
    .qm-actions{
      display:flex;gap:8px;justify-content:flex-end;
      padding:14px 20px;border-top:1px solid #ecf0f9;background:#fafbff;
    }
    .qm-btn{
      padding:10px 18px;border-radius:9px;
      font-size:12.5px;font-weight:700;font-family:inherit;
      border:none;cursor:pointer;transition:all .15s;
      display:inline-flex;align-items:center;gap:6px;
    }
    .qm-btn.ghost{
      background:#fff;color:#475569;border:1px solid #e2e8f0;
    }
    .qm-btn.ghost:hover{background:#f3f5fb;}
    .qm-btn.primary{
      background:linear-gradient(135deg,#0b3d8c,#1d4ed8);color:#fff;
      box-shadow:0 6px 14px -6px rgba(11,61,140,.4);
    }
    .qm-btn.primary:hover{
      transform:translateY(-1px);
      box-shadow:0 10px 18px -6px rgba(11,61,140,.5);
    }
    .qm-btn:disabled{opacity:.6;cursor:wait;transform:none;}

    /* Bulk progress UI */
    .bulk-progress-wrap{margin-bottom:14px;}
    .bulk-progress{
      width:100%;height:8px;background:#e6ebf5;
      border-radius:99px;overflow:hidden;
    }
    .bulk-progress-fill{
      height:100%;border-radius:99px;
      background:linear-gradient(90deg,#25d366,#16a34a);
      transition:width .3s cubic-bezier(.2,.8,.2,1);
    }
    .bulk-progress-text{
      display:flex;justify-content:space-between;
      font-size:11.5px;color:#475569;font-weight:600;
      margin-top:6px;font-variant-numeric:tabular-nums;
    }
    .bulk-log{
      max-height:220px;overflow-y:auto;
      background:#fafbff;border:1px solid #ecf0f9;border-radius:10px;
      padding:8px;
      display:flex;flex-direction:column;gap:4px;
    }
    .bulk-log-row{
      display:flex;align-items:center;gap:8px;
      padding:6px 9px;border-radius:7px;
      font-size:11.5px;color:#0d1b3e;
    }
    .bulk-log-row.ok{background:rgba(22,163,74,.06);}
    .bulk-log-row.err{background:rgba(225,29,72,.06);color:#991b1b;}
    .bulk-log-icon{
      width:16px;height:16px;border-radius:50%;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .bulk-log-icon svg{width:9px;height:9px;}
    .bulk-log-row.ok .bulk-log-icon{background:#16a34a;color:#fff;}
    .bulk-log-row.err .bulk-log-icon{background:#dc2626;color:#fff;}
    .bulk-log-name{font-weight:700;flex:1;}

    /* ═══════════════════════════════════════════════════════════ */
    /* ACTIVITY LOG CARD                                            */
    /* ═══════════════════════════════════════════════════════════ */
    .act-card{}
    .act-list{display:flex;flex-direction:column;gap:1px;}
    .act-item{
      display:flex;align-items:flex-start;gap:10px;
      padding:9px 8px;border-radius:9px;
      transition:background .12s;
    }
    .act-item + .act-item{border-top:1px dashed #f1f5f9;}
    .act-icon{
      width:26px;height:26px;border-radius:8px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      margin-top:1px;
    }
    .act-icon svg{width:12px;height:12px;}
    .act-icon.billing  {background:rgba(29,78,216,.10);color:#1d4ed8;}
    .act-icon.payment  {background:rgba(22,163,74,.10);color:#16a34a;}
    .act-icon.keuangan {background:rgba(125,211,252,.20);color:#0284c7;}
    .act-icon.customer {background:rgba(217,119,6,.10);color:#d97706;}
    .act-body{flex:1;min-width:0;line-height:1.4;}
    .act-desc{
      font-size:12px;color:#0d1b3e;font-weight:500;
      word-wrap:break-word;
    }
    .act-meta{
      font-size:10.5px;color:#7587a6;font-weight:500;margin-top:2px;
      display:flex;gap:5px;align-items:center;flex-wrap:wrap;
    }
    .act-meta .who{font-weight:700;color:#475569;}
    .act-meta .sep{color:#cbd5e1;}

    /* ═══ Toast notification ═══ */
    .toast-stack{
      position:fixed;bottom:24px;right:24px;z-index:1100;
      display:flex;flex-direction:column;gap:10px;
      max-width:380px;pointer-events:none;
    }
    .toast{
      display:flex;align-items:flex-start;gap:11px;
      padding:13px 16px;border-radius:13px;
      background:#fff;border:1px solid #ecf0f9;
      box-shadow:0 16px 40px -12px rgba(13,30,80,.25);
      font-size:13px;color:#0d1b3e;font-weight:500;
      transform:translateX(110%);opacity:0;
      transition:all .3s cubic-bezier(.2,.8,.2,1);
      pointer-events:auto;
    }
    .toast.show{transform:translateX(0);opacity:1;}
    .toast-icon{
      width:30px;height:30px;border-radius:9px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .toast-icon svg{width:15px;height:15px;}
    .toast.success .toast-icon{background:rgba(16,185,129,.12);color:#059669;}
    .toast.error   .toast-icon{background:rgba(239,68,68,.12);color:#dc2626;}
    .toast.info    .toast-icon{background:rgba(29,78,216,.10);color:#1d4ed8;}
    .toast-body{flex:1;line-height:1.4;min-width:0;}
    .toast-title{font-weight:700;color:#0d1b3e;margin-bottom:1px;}
    .toast-msg{font-size:12px;color:#475569;word-wrap:break-word;}

    /* ─── Collection rate + Channel row ───────────────────── */
    .collection-row{display:grid;grid-template-columns:1.15fr 1fr;gap:14px;}
    @media (max-width:980px){.collection-row{grid-template-columns:1fr;}}

    /* Collection card */
    .collect-card{}
    .collect-wrap{
      display:grid;grid-template-columns:160px 1fr;gap:24px;
      align-items:center;
    }
    @media (max-width:520px){
      .collect-wrap{grid-template-columns:1fr;gap:18px;justify-items:center;}
    }
    .cr-progress{position:relative;width:160px;height:160px;flex-shrink:0;}
    .cr-svg{width:100%;height:100%;display:block;}
    .cr-center{
      position:absolute;inset:0;display:flex;flex-direction:column;
      align-items:center;justify-content:center;pointer-events:none;
    }
    .cr-val{
      font-size:32px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.035em;line-height:1;
      font-variant-numeric:tabular-nums;
    }
    .cr-val::after{content:'%';font-size:18px;font-weight:700;color:#7587a6;margin-left:2px;}
    .cr-lbl{font-size:11px;font-weight:600;color:#7587a6;letter-spacing:.05em;text-transform:uppercase;margin-top:6px;}

    .cr-breakdown{display:flex;flex-direction:column;gap:14px;min-width:0;width:100%;}
    .cb-item{}
    .cb-top{display:flex;align-items:center;gap:8px;margin-bottom:4px;}
    .cb-dot{width:8px;height:8px;border-radius:3px;flex-shrink:0;}
    .cb-lbl{font-size:12px;font-weight:600;color:#475569;flex:1;}
    .cb-cnt{
      font-size:11.5px;font-weight:700;color:#64748b;
      background:#f1f5f9;padding:2px 8px;border-radius:6px;
      font-variant-numeric:tabular-nums;
    }
    .cb-amt{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-size:17px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.02em;line-height:1.2;
      font-variant-numeric:tabular-nums;margin-bottom:6px;
    }
    .cb-bar{
      width:100%;height:6px;background:#f1f5f9;
      border-radius:99px;overflow:hidden;
    }
    .cb-fill{
      height:100%;border-radius:99px;
      transition:width .6s cubic-bezier(.2,.8,.2,1);
    }
    .cb-meta{font-size:11px;color:#94a3b8;font-weight:500;margin-top:5px;}

    .cr-strip{
      display:flex;align-items:center;gap:8px;flex-wrap:wrap;
      margin-top:18px;padding-top:14px;border-top:1px dashed #ecf0f9;
      font-size:12px;color:#7587a6;font-weight:500;
    }
    .cr-strip strong{color:#0d1b3e;font-weight:700;font-variant-numeric:tabular-nums;}

    /* Channel card */
    .channel-card{display:flex;flex-direction:column;}
    .ch-list{display:flex;flex-direction:column;gap:12px;}
    .ch-row{display:flex;align-items:center;gap:12px;}
    .ch-icon{
      width:36px;height:36px;border-radius:11px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
      font-size:11px;font-weight:800;letter-spacing:-.01em;color:#fff;
    }
    .ch-icon svg{width:17px;height:17px;}
    .ch-body{flex:1;min-width:0;}
    .ch-top-row{display:flex;align-items:center;gap:6px;margin-bottom:5px;}
    .ch-name{font-size:13px;font-weight:600;color:#0d1b3e;flex:1;}
    .ch-amt{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-size:13px;font-weight:700;color:#0d1b3e;
      font-variant-numeric:tabular-nums;letter-spacing:-.012em;
    }
    .ch-bar{height:6px;background:#f1f5f9;border-radius:99px;overflow:hidden;}
    .ch-fill{
      height:100%;border-radius:99px;
      transition:width .6s cubic-bezier(.2,.8,.2,1);
    }
    .ch-meta{display:flex;align-items:center;gap:8px;font-size:11px;color:#7587a6;font-weight:500;margin-top:4px;}
    .ch-meta .pct{
      font-weight:700;color:#475569;
      background:#f1f5f9;padding:1px 7px;border-radius:5px;
      font-variant-numeric:tabular-nums;
    }
    .ch-total{
      display:flex;align-items:center;justify-content:space-between;
      margin-top:16px;padding-top:14px;border-top:1px dashed #ecf0f9;
      font-size:12.5px;
    }
    .ch-total-lbl{color:#64748b;font-weight:500;}
    .ch-total-val{
      font-family:'Plus Jakarta Sans',sans-serif;
      font-weight:800;color:#0d1b3e;letter-spacing:-.018em;
      font-variant-numeric:tabular-nums;font-size:15px;
    }

    /* ─── Card primitive ─────────────────────────────────────── */
    .card{
      background:#fff;border:1px solid #ecf0f9;border-radius:18px;
      padding:22px 24px;
    }
    .card-head{
      display:flex;align-items:center;justify-content:space-between;
      gap:10px;margin-bottom:18px;flex-wrap:wrap;
    }
    .card-head h3{
      font-size:16px;font-weight:700;color:#0d1b3e;
      letter-spacing:-.02em;margin:0;
    }
    .card-head .h-sub{font-size:12px;color:#94a3b8;font-weight:500;margin-top:2px;}
    .card-head .link{
      font-size:12.5px;font-weight:600;color:#1d4ed8;
      display:inline-flex;align-items:center;gap:5px;
      padding:7px 12px;border-radius:9px;
      background:rgba(29,78,216,.06);transition:all .15s;
    }
    .card-head .link:hover{background:rgba(29,78,216,.12);}
    .card-head .link svg{width:13px;height:13px;}

    /* ─── Range pills ────────────────────────────────────────── */
    .range-pills{
      display:inline-flex;background:#f3f5fb;
      border-radius:10px;padding:3px;gap:2px;
    }
    .range-pills button{
      font-size:11.5px;font-weight:600;
      padding:6px 12px;border-radius:8px;
      color:#64748b;background:transparent;transition:all .15s;
      font-family:inherit;cursor:pointer;border:none;
    }
    .range-pills button:hover{color:#1d4ed8;}
    .range-pills button.active{
      background:#fff;color:#0d1b3e;
      box-shadow:0 1px 3px rgba(13,30,80,.08);
    }

    /* ─── Cash Flow chart ────────────────────────────────────── */
    .cf-wrap{position:relative;width:100%;}
    .cf-svg{display:block;width:100%;height:260px;}
    .cf-legend{
      display:flex;gap:18px;font-size:12px;color:#475569;
      margin-bottom:14px;
    }
    .cf-legend .dot{
      width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:6px;
    }
    .cf-legend .income .dot{background:#1d4ed8;}
    .cf-legend .expense .dot{background:#e11d48;}

    /* Chart tooltip */
    .cf-tip{
      position:absolute;pointer-events:none;
      background:#0d1b3e;color:#fff;font-size:11.5px;
      padding:10px 12px;border-radius:10px;
      white-space:nowrap;font-weight:500;
      box-shadow:0 14px 28px -14px rgba(13,30,80,.55);
      transform:translate(-50%,-105%);opacity:0;transition:opacity .15s;
      z-index:5;
    }
    .cf-tip.show{opacity:1;}
    .cf-tip .ti-month{font-weight:700;color:#fff;margin-bottom:4px;font-size:11px;letter-spacing:.04em;text-transform:uppercase;}
    .cf-tip .ti-row{display:flex;align-items:center;gap:6px;margin-top:3px;}
    .cf-tip .ti-row .dot{width:6px;height:6px;border-radius:50%;}

    /* ─── Recent transactions table ──────────────────────────── */
    .tx-table{width:100%;border-collapse:separate;border-spacing:0;font-size:13px;}
    .tx-table thead th{
      font-size:10.5px;font-weight:700;color:#7587a6;
      letter-spacing:.08em;text-transform:uppercase;
      padding:10px 12px 12px;text-align:left;
      border-bottom:1px solid #ecf0f9;
    }
    .tx-table thead th.right{text-align:right;}
    .tx-table tbody td{
      padding:14px 12px;color:#1e293b;
      border-bottom:1px solid #f5f7fb;vertical-align:middle;
    }
    .tx-table tbody tr:last-child td{border-bottom:0;}
    .tx-table tbody tr{transition:background .12s;}
    .tx-table tbody tr:hover{background:#fafbff;}

    .tx-desc{display:flex;align-items:center;gap:11px;font-weight:600;color:#0d1b3e;}
    .tx-icon{
      width:32px;height:32px;border-radius:10px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;
    }
    .tx-icon svg{width:15px;height:15px;}
    .tx-icon.in {background:rgba(11,61,140,.12);color:#0b3d8c;}
    .tx-icon.out{background:rgba(125,211,252,.20);color:#0284c7;}

    /* Tx filter pills */
    .tx-filter{margin-bottom:14px;}
    .tx-filter button{display:inline-flex;align-items:center;gap:6px;}
    .tx-fdot{
      width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0;
    }
    .tx-icon.neu{background:rgba(99,102,241,.12);color:#4f46e5;}

    .tx-id{font-size:12px;color:#7587a6;font-weight:500;font-variant-numeric:tabular-nums;}
    .tx-amt{
      font-weight:700;color:#0d1b3e;
      font-variant-numeric:tabular-nums;letter-spacing:-.012em;
    }
    .tx-amt.in{color:#0b3d8c;}
    .tx-amt.out{color:#0284c7;}
    .tx-date{font-size:12.5px;color:#475569;font-variant-numeric:tabular-nums;}

    /* ─── BALANCE CARD (right rail, brand gradient) ──────────── */
    .bal-card{
      position:relative;overflow:hidden;
      background:linear-gradient(135deg,#1a3a8c 0%,#1d4ed8 50%,#1a6ef5 100%);
      border-radius:20px;padding:24px;color:#fff;
      box-shadow:0 22px 50px -22px rgba(29,78,216,.55);
    }
    .bal-card::before{
      content:'';position:absolute;top:-90px;right:-70px;
      width:280px;height:280px;border-radius:50%;
      background:radial-gradient(circle,rgba(56,189,248,.35),transparent 65%);
      pointer-events:none;
    }
    .bal-card::after{
      content:'';position:absolute;bottom:-140px;left:-50px;
      width:260px;height:260px;border-radius:50%;
      background:radial-gradient(circle,rgba(99,102,241,.30),transparent 65%);
      pointer-events:none;
    }
    .bal-top{display:flex;align-items:center;justify-content:space-between;position:relative;}
    .bal-top h4{font-size:14.5px;font-weight:600;color:rgba(255,255,255,.92);letter-spacing:-.01em;margin:0;}
    .bal-cur{
      display:inline-flex;align-items:center;gap:6px;
      background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.18);
      backdrop-filter:blur(10px);
      padding:5px 10px;border-radius:999px;
      font-size:11px;font-weight:700;color:#fff;letter-spacing:.05em;
    }
    .bal-cur::before{content:'🇮🇩';font-size:13px;}
    .bal-avail{
      display:inline-flex;align-items:center;gap:7px;
      font-size:11.5px;color:rgba(255,255,255,.78);font-weight:500;
      margin:18px 0 6px;position:relative;
    }
    .bal-avail svg{width:13px;height:13px;opacity:.85;}
    .bal-value{
      font-size:32px;font-weight:800;color:#fff;
      letter-spacing:-.03em;line-height:1.1;
      font-variant-numeric:tabular-nums;position:relative;margin-bottom:20px;
    }
    .bal-actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;position:relative;}
    .bal-btn{
      display:inline-flex;align-items:center;justify-content:center;gap:6px;
      padding:11px 14px;border-radius:11px;
      font-size:12.5px;font-weight:600;
      background:rgba(255,255,255,.96);color:#0d1b3e;
      border:none;cursor:pointer;font-family:inherit;
      transition:all .15s;text-decoration:none;
    }
    .bal-btn:hover{transform:translateY(-1px);box-shadow:0 8px 16px -8px rgba(0,0,0,.3);}
    .bal-btn svg{width:13px;height:13px;}
    .bal-btn.ghost{
      background:rgba(255,255,255,.14);color:#fff;
      border:1px solid rgba(255,255,255,.20);backdrop-filter:blur(8px);
    }
    .bal-btn.ghost:hover{background:rgba(255,255,255,.22);}

    /* ─── Mini stats row (di rail) ───────────────────────────── */
    .mini-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
    .mini{
      background:#fff;border:1px solid #ecf0f9;border-radius:14px;
      padding:14px 16px;transition:all .2s;
    }
    .mini:hover{border-color:#dde6ff;box-shadow:0 10px 22px -14px rgba(15,30,90,.18);}
    .mini-head{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
    .mini-icon{
      width:28px;height:28px;border-radius:9px;
      display:flex;align-items:center;justify-content:center;flex-shrink:0;
    }
    .mini-icon svg{width:14px;height:14px;}
    .mini-lbl{font-size:11.5px;font-weight:600;color:#64748b;letter-spacing:.01em;}
    .mini-val{
      font-size:22px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.025em;line-height:1.05;font-variant-numeric:tabular-nums;
    }
    .mini-sub{font-size:11px;color:#7587a6;font-weight:500;margin-top:3px;}

    /* ─── Quick Links card ───────────────────────────────────── */
    .quick-card{padding:20px;}
    .quick-list{display:flex;flex-direction:column;gap:6px;}
    .qa-item{
      display:flex;align-items:center;gap:11px;
      padding:11px 12px;border-radius:11px;
      color:#0d1b3e;font-size:13px;font-weight:600;
      transition:all .18s;text-decoration:none;
    }
    .qa-item:hover{background:#f3f6fc;color:#1d4ed8;transform:translateX(2px);}
    .qa-icon{
      width:30px;height:30px;border-radius:9px;
      display:flex;align-items:center;justify-content:center;
      flex-shrink:0;background:rgba(29,78,216,.10);color:#1d4ed8;
    }
    .qa-icon svg{width:14px;height:14px;}
    .qa-arrow{margin-left:auto;color:#cbd5e1;font-weight:700;transition:all .15s;}
    .qa-item:hover .qa-arrow{color:#1d4ed8;transform:translateX(2px);}

    /* ─── Budget donut card ──────────────────────────────────── */
    .budget-card{}
    .donut-wrap{
      display:flex;align-items:center;gap:18px;flex-wrap:wrap;
      justify-content:center;
    }
    .donut{position:relative;width:160px;height:160px;flex-shrink:0;}
    .donut svg{transform:rotate(-90deg);width:100%;height:100%;}
    .donut-center{
      position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
      text-align:center;
    }
    .donut-center .lbl{font-size:10.5px;font-weight:700;color:#7587a6;letter-spacing:.05em;text-transform:uppercase;}
    .donut-center .val{
      font-size:18px;font-weight:800;color:#0d1b3e;
      letter-spacing:-.025em;line-height:1.1;margin-top:2px;
      font-variant-numeric:tabular-nums;
    }
    .donut-legend{flex:1;display:flex;flex-direction:column;gap:8px;min-width:120px;}
    .dl-item{display:flex;align-items:center;gap:8px;font-size:12px;}
    .dl-item .dot{width:8px;height:8px;border-radius:3px;flex-shrink:0;}
    .dl-item .name{flex:1;color:#475569;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .dl-item .amt{font-weight:700;color:#0d1b3e;font-variant-numeric:tabular-nums;}

    /* ─── Empty / loading states ────────────────────────────── */
    .empty{
      padding:32px 14px;text-align:center;color:#94a3b8;font-size:12.5px;
    }
    .empty .ic{
      width:44px;height:44px;border-radius:13px;
      background:#f5f7fb;color:#cbd5e1;
      display:flex;align-items:center;justify-content:center;
      margin:0 auto 10px;
    }
    .empty .ic svg{width:20px;height:20px;}
    .empty .t{font-size:13px;font-weight:600;color:#475569;margin-bottom:2px;}

    .skel{
      background:linear-gradient(90deg,#f1f5f9 25%,#e6ecf5 50%,#f1f5f9 75%);
      background-size:200% 100%;animation:shimmer 1.5s linear infinite;
      border-radius:6px;display:inline-block;
    }
    .skel-dark{
      background:linear-gradient(90deg,rgba(255,255,255,.10) 25%,rgba(255,255,255,.18) 50%,rgba(255,255,255,.10) 75%);
      background-size:200% 100%;animation:shimmer 1.5s linear infinite;
      border-radius:6px;display:inline-block;
    }
    @keyframes shimmer{0%{background-position:200% 0;}100%{background-position:-200% 0;}}

    /* ─── Mobile tweaks ──────────────────────────────────────── */
    @media (max-width:768px){
      .fin-head h1{font-size:22px;}
      .card{padding:18px;border-radius:16px;}
      .kpi-val{font-size:22px;}
      .bal-value{font-size:26px;}
      .donut-wrap{justify-content:center;}
    }
  </style>
</head>
<body>
  <div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
      <%- include('../partials/topbar') %>
      <main class="page-content">

      <div class="fin">

        <!-- ─── PAGE HEADER ─── -->
        <header class="fin-head fin-anim fade-only">
          <h1>Dashboard Overview</h1>
          <div class="sub" id="finSub">Pantau arus kas, tagihan, dan performa keuangan — semua di satu tempat.</div>
        </header>

        <!-- ─── INSIGHT BANNER ─── -->
        <div class="ins-wrap fin-anim fade-only" id="insWrap" style="--anim-delay:60ms;display:none;">
          <!-- diisi oleh JS — sembunyi kalau tidak ada insight -->
        </div>

        <!-- ─── MAIN GRID ─── -->
        <div class="fin-grid">

          <!-- ═══════════════════════════════════════════════════ -->
          <!-- LEFT / MAIN COLUMN                                    -->
          <!-- ═══════════════════════════════════════════════════ -->
          <div class="fin-main">

            <!-- ─── KPI row: Pemasukan / Pengeluaran ─── -->
            <div class="kpi-row">
              <div class="kpi tone-in fin-anim" style="--anim-delay:80ms;">
                <div class="kpi-head">
                  <span class="kpi-iwrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                  </span>
                  <span class="kpi-lbl">Pemasukan Bulan Ini</span>
                </div>
                <div class="kpi-val" id="kIncome"><span class="skel" style="width:140px;height:24px;"></span></div>
                <div id="kIncomeDelta">
                  <span class="kpi-delta flat"><span class="since">memuat data…</span></span>
                </div>
              </div>

              <div class="kpi tone-out fin-anim" style="--anim-delay:180ms;">
                <div class="kpi-head">
                  <span class="kpi-iwrap">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="7" x2="17" y2="17"/><polyline points="7 17 17 17 17 7"/></svg>
                  </span>
                  <span class="kpi-lbl">Pengeluaran Bulan Ini</span>
                </div>
                <div class="kpi-val" id="kExpense"><span class="skel" style="width:140px;height:24px;"></span></div>
                <div id="kExpenseDelta">
                  <span class="kpi-delta flat"><span class="since">memuat data…</span></span>
                </div>
              </div>
            </div>

            <!-- ─── Daily Transactions Chart ─── -->
            <div class="card dtx-card">
              <div class="card-head">
                <div>
                  <h3>Transaksi Harian</h3>
                  <div class="h-sub">Pembayaran masuk &amp; pengeluaran <span id="dtxRangeLabel">7 hari terakhir</span></div>
                </div>
                <div class="range-pills" id="dtxRange">
                  <button data-d="7"  class="active" type="button">7 Hari</button>
                  <button data-d="14"                type="button">14 Hari</button>
                  <button data-d="30"                type="button">30 Hari</button>
                </div>
              </div>

              <!-- Mini summary strip -->
              <div class="dtx-strip">
                <div class="dtx-strip-item dtx-in">
                  <span class="dtx-dot"></span>
                  <div class="dtx-strip-body">
                    <div class="dtx-strip-lbl">Pemasukan</div>
                    <div class="dtx-strip-val" id="dtxSumIn"><span class="skel" style="width:90px;height:14px;"></span></div>
                  </div>
                  <div class="dtx-strip-cnt" id="dtxCntIn">—</div>
                </div>
                <div class="dtx-strip-item dtx-out">
                  <span class="dtx-dot"></span>
                  <div class="dtx-strip-body">
                    <div class="dtx-strip-lbl">Pengeluaran</div>
                    <div class="dtx-strip-val" id="dtxSumOut"><span class="skel" style="width:90px;height:14px;"></span></div>
                  </div>
                  <div class="dtx-strip-cnt" id="dtxCntOut">—</div>
                </div>
                <div class="dtx-strip-item dtx-net">
                  <span class="dtx-dot"></span>
                  <div class="dtx-strip-body">
                    <div class="dtx-strip-lbl">Net</div>
                    <div class="dtx-strip-val" id="dtxSumNet"><span class="skel" style="width:90px;height:14px;"></span></div>
                  </div>
                </div>
              </div>

              <!-- Chart -->
              <div class="dtx-wrap">
                <div id="dtxChart"></div>
              </div>
            </div>

            <!-- ─── Pelanggan Akan Jatuh Tempo ─── -->
            <div class="card duedate-card">
              <div class="card-head">
                <div>
                  <h3>Pelanggan Akan Jatuh Tempo</h3>
                  <div class="h-sub">Pengingat penagihan berdasarkan tanggal jatuh tempo</div>
                </div>
                <a href="/billing" class="link">
                  Tindak lanjuti
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                </a>
              </div>

              <div class="dd-grid">
                <!-- 3 Hari Kedepan -->
                <div class="dd-item dd-soon">
                  <div class="dd-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M12 14l2 2 4-4"/></svg>
                  </div>
                  <div class="dd-body">
                    <div class="dd-lbl">3 Hari Kedepan</div>
                    <div class="dd-val" id="dd3Count"><span class="skel" style="width:38px;height:22px;"></span></div>
                    <div class="dd-sub">
                      <span id="dd3Cust">— pelanggan</span>
                      <span class="dd-sep">·</span>
                      <span id="dd3Amt">—</span>
                    </div>
                  </div>
                </div>

                <!-- Jatuh Tempo Hari Ini -->
                <div class="dd-item dd-today">
                  <div class="dd-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </div>
                  <div class="dd-body">
                    <div class="dd-lbl">Jatuh Tempo Hari Ini</div>
                    <div class="dd-val" id="ddTCount"><span class="skel" style="width:38px;height:22px;"></span></div>
                    <div class="dd-sub">
                      <span id="ddTCust">— pelanggan</span>
                      <span class="dd-sep">·</span>
                      <span id="ddTAmt">—</span>
                    </div>
                  </div>
                </div>

                <!-- Lewat Jatuh Tempo -->
                <div class="dd-item dd-past">
                  <div class="dd-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><circle cx="12" cy="17" r=".5"/></svg>
                  </div>
                  <div class="dd-body">
                    <div class="dd-lbl">Lewat Jatuh Tempo</div>
                    <div class="dd-val" id="ddPCount"><span class="skel" style="width:38px;height:22px;"></span></div>
                    <div class="dd-sub">
                      <span id="ddPCust">— pelanggan</span>
                      <span class="dd-sep">·</span>
                      <span id="ddPAmt">—</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ─── Collection Rate + Payment Channels ─── -->
            <div class="collection-row">

              <!-- Collection Rate (with circular progress) -->
              <div class="card collect-card">
                <div class="card-head">
                  <div>
                    <h3>Collection Rate</h3>
                    <div class="h-sub">Performa pengumpulan tagihan bulan ini</div>
                  </div>
                </div>

                <div class="collect-wrap">
                  <!-- Circular Progress -->
                  <div class="cr-progress">
                    <svg viewBox="0 0 140 140" class="cr-svg">
                      <defs>
                        <linearGradient id="crGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                          <stop offset="0%"   stop-color="#1d4ed8"/>
                          <stop offset="50%"  stop-color="#1a6ef5"/>
                          <stop offset="100%" stop-color="#3b82f6"/>
                        </linearGradient>
                      </defs>
                      <!-- Background ring -->
                      <circle cx="70" cy="70" r="58" fill="none" stroke="#eef2f8" stroke-width="12"/>
                      <!-- Progress ring -->
                      <circle id="crRing" cx="70" cy="70" r="58" fill="none"
                              stroke="url(#crGrad)" stroke-width="12" stroke-linecap="round"
                              transform="rotate(-90 70 70)"
                              stroke-dasharray="0 364.4" />
                    </svg>
                    <div class="cr-center">
                      <div class="cr-val" id="crValue">—</div>
                      <div class="cr-lbl">Collection Rate</div>
                    </div>
                  </div>

                  <!-- Breakdown -->
                  <div class="cr-breakdown">
                    <div class="cb-item">
                      <div class="cb-top">
                        <span class="cb-dot" style="background:#16a34a;"></span>
                        <span class="cb-lbl">Sudah Bayar</span>
                        <span class="cb-cnt" id="cbPaidCnt">—</span>
                      </div>
                      <div class="cb-amt" id="cbPaidAmt">—</div>
                      <div class="cb-bar">
                        <div class="cb-fill" id="cbPaidFill" style="width:0%;background:#16a34a;"></div>
                      </div>
                      <div class="cb-meta" id="cbPaidCust">— pelanggan</div>
                    </div>

                    <div class="cb-item">
                      <div class="cb-top">
                        <span class="cb-dot" style="background:#f59e0b;"></span>
                        <span class="cb-lbl">Belum Bayar</span>
                        <span class="cb-cnt" id="cbUnpaidCnt">—</span>
                      </div>
                      <div class="cb-amt" id="cbUnpaidAmt">—</div>
                      <div class="cb-bar">
                        <div class="cb-fill" id="cbUnpaidFill" style="width:0%;background:#f59e0b;"></div>
                      </div>
                      <div class="cb-meta" id="cbUnpaidCust">— pelanggan</div>
                    </div>
                  </div>
                </div>

                <!-- Total billed strip -->
