                      <stop offset="100%" stop-color="#1d4ed8" stop-opacity="0"/>
                    </linearGradient>
                    <linearGradient id="grad-out" x1="0" x2="0" y1="0" y2="1">
                      <stop offset="0%"  stop-color="#e11d48" stop-opacity=".22"/>
                      <stop offset="100%" stop-color="#e11d48" stop-opacity="0"/>
                    </linearGradient>
