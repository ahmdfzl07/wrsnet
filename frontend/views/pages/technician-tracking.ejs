<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= typeof title !== 'undefined' ? title : 'Field Tracking' %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <style>
    /* ═══════════════════════════════════════════════════
       THEME — identik dengan gps-tracking.ejs
    ══════════════════════════════════════════════════ */
    :root {
      --f-bg:             #f4f6f9;
      --f-card:           #ffffff;
      --f-primary:        #2563eb;
      --f-primary-light:  #dbeafe;
      --f-primary-dark:   #1d4ed8;
      --f-primary-darker: #1e40af;
      --f-gradient:       linear-gradient(135deg, #2563eb, #1d4ed8);
      --f-accent:         #f59e0b;
      --f-accent-light:   #fef3c7;
      --f-danger:         #ef4444;
      --f-danger-light:   #fee2e2;
      --f-success:        #10b981;
      --f-success-light:  #d1fae5;
      --f-text:           #1e293b;
      --f-text2:          #64748b;
      --f-text3:          #94a3b8;
      --f-border:         #e2e8f0;
      --f-border2:        #f1f5f9;
      --f-shadow:         0 1px 3px rgba(0,0,0,0.06);
      --f-shadow-lg:      0 8px 25px rgba(0,0,0,0.08);
      --f-radius:         12px;
    }

    /* ═══════════════════════════════════════════════════
       LAYOUT — sama persis dengan pola gps-tracking.ejs:
       main-content padding 0, page mengisi sisa tinggi
    ══════════════════════════════════════════════════ */
    /* standalone — no main-content wrapper */

    .tt-page {
      background: var(--f-bg);
      display: grid;
      grid-template-columns: 300px 1fr 320px;
      grid-template-rows: auto 1fr;
      height: 100%;
      max-height: 100%;
      overflow: hidden;
      flex: 1;
      min-height: 0;
    }

    /* ═══ INNER TOPBAR (span 3 kolom) ═══ */
    .tt-topbar {
      grid-column: 1 / 4;
      grid-row: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 12px 20px;
      background: var(--f-card);
      border-bottom: 1px solid var(--f-border);
      z-index: 5;
    }

    .ttb-left  { display:flex; align-items:center; gap:10px; }
    .ttb-right { display:flex; align-items:center; gap:8px; }

    .ttb-title {
      font-size: 16px; font-weight: 700; color: var(--f-text);
      display: flex; align-items: center; gap: 8px;
    }
    .ttb-title svg { color: var(--f-primary); }

    .status-pill {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 12px; border-radius: 20px;
      font-size: 12px; font-weight: 700;
    }
    .status-pill.active   { background:var(--f-success-light); color:#065f46; }
    .status-pill.inactive { background:var(--f-border2); color:var(--f-text2); }

    .pulse-dot {
      width:7px; height:7px; border-radius:50%;
      background:currentColor; animation:pulse-k 2s infinite;
    }
    @keyframes pulse-k {
      0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)}
    }

    .btn-f {
      display:inline-flex; align-items:center; gap:6px;
      padding:7px 14px; border-radius:6px;
      font-size:13px; font-weight:600; cursor:pointer;
      transition:all .15s; border:1px solid var(--f-border);
      background:var(--f-card); color:var(--f-text); font-family:inherit;
    }
    .btn-f:hover { background:#f8fafc; border-color:#cbd5e1; }
    .btn-f.active  { background:var(--f-primary); color:white; border-color:var(--f-primary); }
    .btn-f.primary {
      background:var(--f-gradient); color:white;
      border-color:transparent; box-shadow:0 2px 8px rgba(37,99,235,.3);
    }
    .btn-f.primary:hover { box-shadow:0 4px 14px rgba(37,99,235,.4); }

    /* ═══ COL 1: TICKET SIDEBAR ═══ */
    .tt-sidebar {
      grid-column:1; grid-row:2;
      background:var(--f-card); border-right:1px solid var(--f-border);
      display:flex; flex-direction:column; overflow:hidden; min-height:0;
    }

    .ts-head {
      padding:13px 16px; border-bottom:1px solid var(--f-border);
      display:flex; align-items:center; justify-content:space-between; flex-shrink:0;
    }
    .ts-title { font-size:12px; font-weight:700; color:var(--f-text); text-transform:uppercase; letter-spacing:.5px; }
    .ts-badge { background:var(--f-primary-light); color:var(--f-primary); font-size:11px; font-weight:700; padding:2px 8px; border-radius:10px; }

    .ts-search { padding:10px 14px; border-bottom:1px solid var(--f-border2); flex-shrink:0; position:relative; }
    .ts-search input {
      width:100%; padding:7px 10px 7px 30px;
      border:1px solid var(--f-border); border-radius:6px;
      font-size:13px; font-family:inherit; color:var(--f-text);
      background:var(--f-bg); transition:all .2s;
    }
    .ts-search input:focus { outline:none; border-color:var(--f-primary); box-shadow:0 0 0 3px rgba(37,99,235,.12); background:white; }
    .ts-search svg { position:absolute; left:23px; top:50%; transform:translateY(-50%); color:var(--f-text3); pointer-events:none; }

    .ts-list { flex:1; overflow-y:auto; min-height:0; }
    .ts-list::-webkit-scrollbar { width:3px; }
    .ts-list::-webkit-scrollbar-thumb { background:var(--f-border); border-radius:2px; }

    .ticket-item { padding:13px 16px; border-bottom:1px solid var(--f-border2); cursor:pointer; transition:background .12s; }
    .ticket-item:hover { background:#f8fafc; }
    .ticket-item.selected { background:var(--f-primary-light); border-left:3px solid var(--f-primary); }
    .ticket-item.locked   { opacity:.5; pointer-events:none; }

    .ti-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:5px; }
    .ti-num  { font-size:13px; font-weight:700; color:var(--f-text); }
    .ti-priority { font-size:10px; font-weight:700; padding:2px 8px; border-radius:4px; text-transform:uppercase; letter-spacing:.3px; }
    .pri-critical { background:#fce7f3; color:#9d174d; }
    .pri-high     { background:var(--f-danger-light); color:#991b1b; }
    .pri-medium   { background:var(--f-accent-light); color:#92400e; }
    .pri-low      { background:var(--f-primary-light); color:var(--f-primary-darker); }

    .ti-title { font-size:12.5px; color:var(--f-text); font-weight:500; margin-bottom:5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .ti-meta  { display:flex; align-items:center; gap:5px; font-size:11.5px; color:var(--f-text2); }
    .ti-meta svg { color:var(--f-text3); flex-shrink:0; }

    .empty-s { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 20px; color:var(--f-text3); gap:10px; }
    .empty-s p     { font-size:13px; font-weight:500; color:var(--f-text2); text-align:center; }
    .empty-s small { font-size:12px; color:var(--f-text3); text-align:center; }

    /* ═══ COL 2: MAP ═══ */
    .tt-map {
      grid-column:2; grid-row:2;
      position:relative; overflow:hidden; min-height:0;
    }
    #tt-map-leaf { position:absolute; inset:0; z-index:1; }

    /* Map controls (kanan atas) */
    .map-ctrl {
      position:absolute; top:12px; right:12px; z-index:1000;
      display:flex; flex-direction:column; gap:4px;
    }
    .mc-btn {
      width:34px; height:34px; background:white;
      border:1px solid var(--f-border); border-radius:6px;
      display:flex; align-items:center; justify-content:center;
      cursor:pointer; transition:all .15s; color:var(--f-text2); box-shadow:var(--f-shadow);
    }
    .mc-btn:hover  { background:#f8fafc; color:var(--f-primary); }
    .mc-btn.active { background:var(--f-primary); color:white; border-color:var(--f-primary); }
    .mc-sep { width:28px; height:1px; background:var(--f-border); margin:2px auto; }

    /* GPS accuracy badge (kiri bawah) */
    .map-acc {
      position:absolute; bottom:14px; left:14px; z-index:1000;
      background:white; border:1px solid var(--f-border); border-radius:8px;
      padding:8px 13px; font-size:12px; font-weight:600; color:var(--f-text2);
      display:none; align-items:center; gap:8px; box-shadow:var(--f-shadow-lg);
    }
    .map-acc svg { color:var(--f-primary); }

    /* Overlay saat belum ada GPS */
    .map-nogps {
      position:absolute; inset:0; z-index:500;
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      background:rgba(244,246,249,.88); gap:12px;
    }
    .map-nogps svg { opacity:.3; }
    .map-nogps p     { font-size:14px; font-weight:600; color:var(--f-text2); }
    .map-nogps small { font-size:12px; color:var(--f-text3); }

    /* Leaflet popup */
    .leaflet-popup-content-wrapper { padding:0; border-radius:10px; box-shadow:0 8px 30px rgba(0,0,0,.15); overflow:hidden; border:none; }
    .leaflet-popup-content { margin:0; font-family:'DM Sans',sans-serif; min-width:210px; }
    .leaflet-popup-tip { background:white; }
    .leaflet-control-zoom { display:none !important; }
    .pp-head { background:var(--f-gradient); padding:12px 14px; color:white; }
    .pp-name { font-size:14px; font-weight:700; }
    .pp-sub  { font-size:11px; opacity:.85; margin-top:2px; }
    .pp-body { padding:10px 14px; }
    .pp-row  { display:flex; justify-content:space-between; padding:5px 0; font-size:12px; border-bottom:1px solid var(--f-border2); }
    .pp-row:last-child { border-bottom:none; }
    .pp-rk { color:var(--f-text2); }
    .pp-rv { font-weight:600; color:var(--f-text); font-family:monospace; font-size:11.5px; }

    /* ═══ COL 3: INFO PANEL ═══ */
    .tt-info {
      grid-column:3; grid-row:2;
      background:var(--f-card); border-left:1px solid var(--f-border);
      display:flex; flex-direction:column; overflow:hidden; min-height:0;
    }
    .ti-head { padding:14px 16px; border-bottom:1px solid var(--f-border); font-size:13px; font-weight:700; color:var(--f-text); flex-shrink:0; }
    .ti-body { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; padding:14px 16px; display:flex; flex-direction:column; gap:12px; min-height:0; }
    .ti-body::-webkit-scrollbar { width:3px; }
    .ti-body::-webkit-scrollbar-thumb { background:var(--f-border); border-radius:2px; }

    /* Stat row */
    .stat-row { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
    .stat-card { background:var(--f-bg); border:1px solid var(--f-border); border-radius:8px; padding:12px 10px; text-align:center; }
    .sc-val { font-size:20px; font-weight:800; color:var(--f-text); line-height:1.1; }
    .sc-lbl { font-size:11px; font-weight:600; color:var(--f-text2); margin-top:3px; }

    /* Active ticket */
    .atc { background:var(--f-card); border:1px solid var(--f-border); border-radius:var(--f-radius); overflow:hidden; display:none; }
    .atc.show { display:block; }
    .atc-hd { background:var(--f-gradient); padding:12px 14px; display:flex; align-items:center; gap:10px; }
    .atc-icon { width:36px; height:36px; border-radius:8px; background:rgba(255,255,255,.2); border:1.5px solid rgba(255,255,255,.3); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .atc-meta { flex:1; min-width:0; }
    .atc-num { font-size:14px; font-weight:700; color:white; }
    .atc-sub { font-size:11px; color:rgba(255,255,255,.8); margin-top:1px; }
    .live-badge { display:flex; align-items:center; gap:5px; font-size:11px; font-weight:700; color:white; background:rgba(255,255,255,.2); padding:3px 8px; border-radius:10px; white-space:nowrap; }
    .live-dot   { width:6px; height:6px; border-radius:50%; background:#4ade80; animation:pulse-k 1.5s infinite; }
    .atc-bd { padding:12px 14px; }
    .atc-row { display:flex; align-items:flex-start; gap:8px; padding:7px 0; border-bottom:1px solid var(--f-border2); font-size:13px; }
    .atc-row:last-child { border-bottom:none; }
    .atc-lbl { color:var(--f-text2); font-weight:500; width:80px; flex-shrink:0; }
    .atc-val { color:var(--f-text); font-weight:600; flex:1; }

    /* GPS section */
    .gps-sec { background:var(--f-card); border:1px solid var(--f-border); border-radius:var(--f-radius); overflow:hidden; }
    .gps-hd  { display:flex; align-items:center; justify-content:space-between; padding:11px 14px; border-bottom:1px solid var(--f-border); }
    .gps-title { font-size:13px; font-weight:700; color:var(--f-text); display:flex; align-items:center; gap:7px; }
    .gps-title svg { color:var(--f-primary); }
    .gps-live { display:none; align-items:center; gap:5px; font-size:11px; font-weight:700; color:var(--f-success); }
    .gps-live-dot { width:6px; height:6px; border-radius:50%; background:var(--f-success); animation:pulse-k 1.5s infinite; }
    .gps-row { display:flex; align-items:center; justify-content:space-between; padding:9px 14px; border-bottom:1px solid var(--f-border2); font-size:12.5px; }
    .gps-row:last-child { border-bottom:none; }
    .gps-lbl { display:flex; align-items:center; gap:7px; color:var(--f-text2); font-weight:500; }
    .gps-lbl svg { color:var(--f-text3); flex-shrink:0; }
    .gps-val { color:var(--f-text); font-weight:600; font-family:monospace; font-size:12px; }

    /* Error alert */
    .err-alert { display:none; align-items:center; gap:10px; padding:10px 14px; background:var(--f-danger-light); color:#991b1b; border:1px solid #fca5a5; border-radius:8px; font-size:12.5px; font-weight:600; }
    .err-alert.show { display:flex; animation:shake .5s; }
    @keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-8px)} 60%{transform:translateX(8px)} }

    /* Hint */
    .act-hint { display:flex; align-items:center; gap:7px; font-size:12px; color:var(--f-text2); padding:9px 12px; background:var(--f-border2); border-radius:7px; }
    .act-hint svg { flex-shrink:0; color:var(--f-text3); }

    /* Action button */
    .act-btn { width:100%; padding:13px 18px; border:none; border-radius:8px; font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:9px; font-family:inherit; transition:all .2s; }
    .act-btn.start { background:var(--f-gradient); color:white; box-shadow:0 3px 12px rgba(37,99,235,.35); }
    .act-btn.start:hover:not(:disabled) { box-shadow:0 5px 18px rgba(37,99,235,.45); }
    .act-btn.stop  { background:linear-gradient(135deg,var(--f-danger),#dc2626); color:white; box-shadow:0 3px 12px rgba(239,68,68,.35); }
    .act-btn.stop:hover:not(:disabled)  { box-shadow:0 5px 18px rgba(239,68,68,.45); }
    .act-btn:disabled { opacity:.55; cursor:not-allowed; box-shadow:none; }

    /* Spinner */
    .spin { width:16px; height:16px; border:2.5px solid rgba(255,255,255,.3); border-top-color:white; border-radius:50%; animation:sp .7s linear infinite; flex-shrink:0; }
    @keyframes sp { to { transform:rotate(360deg); } }

    /* ═══════════════════════════════════════════════════
       MODAL — Stop Tracking Confirmation
    ══════════════════════════════════════════════════ */
    .modal-overlay {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(15, 23, 42, 0.55);
      backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
      display: none; align-items: center; justify-content: center;
      padding: 20px;
      opacity: 0; transition: opacity .25s ease;
    }
    .modal-overlay.show { display: flex; opacity: 1; }
    .modal-overlay.fade-out { opacity: 0; }

    .modal-card {
      background: white; border-radius: 20px;
      width: 100%; max-width: 380px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.18);
      overflow: hidden;
      transform: scale(0.9) translateY(20px);
      transition: transform .3s cubic-bezier(0.34,1.56,0.64,1);
    }
    .modal-overlay.show .modal-card {
      transform: scale(1) translateY(0);
    }

    .modal-icon-area {
      padding: 28px 24px 8px;
      display: flex; flex-direction: column; align-items: center;
    }
    .modal-icon-circle {
      width: 64px; height: 64px; border-radius: 50%;
      background: var(--f-danger-light);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
    }
    .modal-icon-circle svg { color: var(--f-danger); }

    .modal-title {
      font-size: 18px; font-weight: 800; color: var(--f-text);
      text-align: center; margin-bottom: 6px;
    }
    .modal-desc {
      font-size: 13px; color: var(--f-text2);
      text-align: center; line-height: 1.5;
      max-width: 280px;
    }

    /* Session summary inside modal */
    .modal-summary {
      margin: 16px 24px 0;
      background: var(--f-bg); border: 1px solid var(--f-border);
      border-radius: 12px; overflow: hidden;
    }
    .ms-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 14px; font-size: 12.5px;
      border-bottom: 1px solid var(--f-border2);
    }
    .ms-row:last-child { border-bottom: none; }
    .ms-lbl { color: var(--f-text2); font-weight: 500; display: flex; align-items: center; gap: 6px; }
    .ms-lbl svg { width: 14px; height: 14px; color: var(--f-text3); }
    .ms-val { font-weight: 700; color: var(--f-text); font-family: 'DM Sans', monospace; }

    /* Notes textarea */
    .modal-notes {
      margin: 12px 24px 0;
    }
    .modal-notes label {
      font-size: 12px; font-weight: 600; color: var(--f-text2);
      display: block; margin-bottom: 6px;
    }
    .modal-notes textarea {
      width: 100%; padding: 10px 12px;
      border: 1px solid var(--f-border); border-radius: 8px;
      font-family: inherit; font-size: 13px; color: var(--f-text);
      resize: none; background: var(--f-bg);
      transition: all .2s;
    }
    .modal-notes textarea:focus {
      outline: none; border-color: var(--f-primary);
      box-shadow: 0 0 0 3px rgba(37,99,235,.1);
      background: white;
    }

    /* Modal buttons */
    .modal-actions {
      display: flex; gap: 10px; padding: 20px 24px 24px;
    }
    .modal-btn {
      flex: 1; padding: 12px 16px; border-radius: 10px;
      font-size: 14px; font-weight: 700; cursor: pointer;
      border: none; font-family: inherit;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      transition: all .15s;
    }
    .modal-btn.cancel {
      background: var(--f-bg); color: var(--f-text);
      border: 1px solid var(--f-border);
    }
    .modal-btn.cancel:hover { background: #f1f5f9; }
    .modal-btn.confirm-stop {
      background: linear-gradient(135deg, var(--f-danger), #dc2626);
      color: white;
      box-shadow: 0 3px 12px rgba(239,68,68,.3);
    }
    .modal-btn.confirm-stop:hover { box-shadow: 0 5px 18px rgba(239,68,68,.45); }
    .modal-btn:disabled { opacity: .5; cursor: not-allowed; }
    .modal-btn .spin { width: 16px; height: 16px; border-width: 2.5px; }

    /* ═══════════════════════════════════════════════════
       MOBILE — Bottom tab bar + single-panel view
    ══════════════════════════════════════════════════ */
    .mob-tab-bar { display:none; }

    @media (max-width:1100px) {
      .tt-page { grid-template-columns: 260px 1fr 300px; }
    }

    @media (max-width:900px) {
      .tt-page { grid-template-columns: 240px 1fr 280px; }
    }

    @media (max-width:768px) {
      .tt-page {
        grid-template-columns: 1fr;
        grid-template-rows: auto auto 1fr;
        height: 100vh;
        max-height: 100vh;
      }

      .tt-topbar { grid-column:1; grid-row:1; padding:10px 14px; flex-wrap:wrap; gap:6px; }
      .btn-f .hm { display:none; }

      .mob-tab-bar {
        display:flex;
        grid-column:1; grid-row:2;
        background:var(--f-card);
        border-bottom:1px solid var(--f-border);
      }
      .mob-tab {
        flex:1; padding:9px 8px;
        display:flex; flex-direction:column; align-items:center; gap:3px;
        cursor:pointer; font-size:10px; font-weight:600; color:var(--f-text3);
        border-bottom:2px solid transparent; transition:all .15s;
      }
      .mob-tab svg { width:18px; height:18px; }
      .mob-tab.active { color:var(--f-primary); border-bottom-color:var(--f-primary); }

      .tt-sidebar, .tt-map, .tt-info {
        grid-column:1; grid-row:3;
        display:none;
      }
      .tt-sidebar.mob-on, .tt-map.mob-on, .tt-info.mob-on { display:flex; }
      .tt-map.mob-on { display:block; }
      .tt-map { min-height:300px; }
      .tt-info { border-left:none; border-top:1px solid var(--f-border); }

      /* Fix: seluruh info panel jadi satu blok scrollable di mobile */
      .tt-info.mob-on {
        display: block !important;
        overflow-y: auto !important;
        -webkit-overflow-scrolling: touch;
        /* override overflow:hidden dari base */
        overflow: auto !important;
      }

      /* ti-head tetap terlihat di atas saat scroll */
      .tt-info.mob-on .ti-head {
        position: sticky;
        top: 0;
        background: var(--f-card);
        z-index: 2;
      }

      /* ti-body: hilangkan nested scroll, biarkan parent yg scroll */
      .tt-info.mob-on .ti-body {
        overflow: visible !important;
        flex: none;
        padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px));
      }

      /* Fix: atc-bd row wrap agar teks panjang tidak terpotong */
      .atc-row {
        flex-wrap: wrap;
      }
      .atc-lbl {
        width: 72px;
        font-size: 12px;
      }
      .atc-val {
        flex: 1;
        min-width: 0;
        word-break: break-word;
        font-size: 12.5px;
      }

      /* map-acc di atas bottom nav baru (56px) */
      .map-acc {
        position: fixed !important;
        bottom: calc(64px + env(safe-area-inset-bottom, 0px)) !important;
        left: 14px !important;
        z-index: 499 !important;
        font-size: 11px;
        padding: 6px 10px !important;
      }
    }

    /* ══════════════════════════════════════════════════
       STANDALONE TECHNICIAN LAYOUT
    ══════════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; font-family: 'DM Sans', sans-serif; }

    .tt-app { display: flex; height: 100vh; }

    /* ── Sidebar — identik dengan technician-dashboard ── */
    .tt-sidebar-nav {
      width: 260px; flex-shrink: 0;
      background: #fff; border-right: 1px solid #e2e8f0;
      display: flex; flex-direction: column;
      height: 100vh; position: sticky; top: 0; z-index: 200;
    }

    /* Brand */
    .sb-brand {
      display: flex; align-items: center; gap: 10px;
      padding: 20px 20px 16px; border-bottom: 1px solid #e2e8f0; flex-shrink: 0;
    }
    .sb-logo {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, #3b82f6, #38bdf8);
      display: flex; align-items: center; justify-content: center;
    }
    .sb-logo svg { width: 18px; height: 18px; color: #fff; }
    .sb-brand-text { line-height: 1.2; }
    .sb-brand-text .n { font-size: 15px; font-weight: 700; color: #0f172a; letter-spacing: -.2px; }
    .sb-brand-text .s { font-size: 10.5px; color: #94a3b8; font-weight: 500; margin-top: 1px; }

    /* Nav */
    .sb-menu { flex: 1; overflow-y: auto; padding: 8px 0; display: flex; flex-direction: column; }
    .sb-label {
      font-size: 10px; font-weight: 700; color: #94a3b8;
      text-transform: uppercase; letter-spacing: 1.2px;
      padding: 10px 24px 4px; display: block;
    }
    .sb-item {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 12px; margin: 1px 8px; border-radius: 8px;
      color: #64748b; font-size: 13.5px; font-weight: 500;
      text-decoration: none; transition: all .15s; cursor: pointer;
    }
    .sb-item svg { width: 18px; height: 18px; flex-shrink: 0; stroke-width: 1.8; }
    .sb-item:hover { background: #f1f5f9; color: #0f172a; }
    .sb-item.active { background: #eff6ff; color: #2563eb; font-weight: 600; }
    .sb-item.active svg { color: #2563eb; }

    /* Profile footer */
    .sb-user {
      padding: 12px 16px 16px; border-top: 1px solid #e2e8f0;
      display: flex; align-items: center; gap: 10px; flex-shrink: 0;
    }
    .sb-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #2563eb, #38bdf8);
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 800; font-size: 13px; flex-shrink: 0;
      box-shadow: 0 0 0 2.5px #2563eb, 0 3px 10px rgba(37,99,235,.35);
    }
    .sb-u-info { min-width: 0; flex: 1; }
    .sb-u-name { font-size: 12.5px; font-weight: 700; color: #0d1b3e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sb-u-role { font-size: 10.5px; color: #94a3b8; margin-top: 1px; text-transform: capitalize; }
    .sb-logout {
      width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;
      border-radius: 8px; color: #94a3b8; transition: all .15s; flex-shrink: 0; text-decoration: none;
      background: none; border: none; cursor: pointer;
    }
    .sb-logout:hover { background: rgba(245,54,92,.12); color: #ef4444; }

    /* ── Main area ──────────────────────────────────── */
    .tt-main {
      flex: 1; min-width: 0;
      display: flex; flex-direction: column;
      height: 100vh; overflow: hidden;
    }

    /* ── Suppress any injected admin elements ───────── */
    .topbar, .bottom-nav, .sidebar:not(.tt-sidebar-nav) { display: none !important; }

    /* ── Mobile: hide sidebar ────────────────────────── */
    @media (max-width: 768px) {
      .tt-sidebar-nav { display: none; }
      .tt-main { height: 100vh; }
    }

    /* ══════════════════════════════════════════════════
       MOBILE HEADER & BOTTOM NAV (identik dashboard)
    ══════════════════════════════════════════════════ */
    .m-header{
      display:none;
      background:linear-gradient(160deg,#1e40af 0%,#2563eb 55%,#0284c7 100%);
      padding:18px 18px 26px;color:#fff;position:relative;overflow:hidden;
      flex-shrink:0;
    }
    .m-header::after{content:'';position:absolute;top:-40px;right:-30px;width:160px;height:160px;background:radial-gradient(circle,rgba(6,182,212,.35),transparent 70%);border-radius:50%;}
    .m-hdr-row{display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;}
    .m-hi{font-size:12.5px;color:rgba(255,255,255,.8);font-weight:500;}
    .m-name{font-size:20px;font-weight:800;margin-top:2px;letter-spacing:-.3px;}
    .m-hdr-btns{display:flex;gap:8px;}
    .m-hbtn{width:38px;height:38px;border-radius:12px;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;color:#fff;position:relative;cursor:pointer;}
    .m-hbtn svg{width:18px;height:18px;}

    .tt-btm-nav{
      display:none;position:fixed;bottom:0;left:0;right:0;
      background:#fff;border-top:1px solid #e2e8f0;
      padding:8px 12px calc(14px + env(safe-area-inset-bottom,0px));
      z-index:400;box-shadow:0 -4px 20px rgba(0,0,0,.05);
    }
    .tt-btm-inner{display:flex;justify-content:space-around;max-width:480px;margin:0 auto;position:relative;}
    .tt-bn{
      display:flex;flex-direction:column;align-items:center;gap:3px;
      padding:6px 10px;border-radius:10px;color:#94a3b8;
      font-size:10.5px;font-weight:700;transition:all .18s;
      flex:1;text-decoration:none;cursor:pointer;background:none;border:none;font-family:inherit;
    }
    .tt-bn svg{width:20px;height:20px;}
    .tt-bn.active{color:#2563eb;}
    .tt-bn.active svg{color:#2563eb;}
    .tt-bn-fab{
      position:absolute;top:-24px;left:50%;transform:translateX(-50%);
      width:54px;height:54px;border-radius:50%;
      background:linear-gradient(135deg,#2563eb,#1d4ed8);
      color:#fff;display:flex;align-items:center;justify-content:center;
      box-shadow:0 10px 24px rgba(37,99,235,.45);border:4px solid #fff;
      text-decoration:none;
    }
    .tt-bn-fab svg{width:22px;height:22px;}
    /* GPS item — tidak pakai .active, background selalu transparan */
    .tt-bn.tt-bn-gps { background: none !important; color: #2563eb; }
    .tt-bn.tt-bn-gps:hover { background: none !important; }
    /* FAB circle — selalu gradient biru, SVG selalu putih */
    .tt-bn-fab { background: linear-gradient(135deg,#2563eb,#1d4ed8) !important; }
    .tt-bn-fab svg { color: #fff !important; stroke: #fff !important; }

    @media(max-width:768px){
      .tt-sidebar-nav{display:none;}
      .m-header{display:block;}
      .tt-btm-nav{display:block;}
      .tt-main{height:100vh;}
      /* tt-page di mobile: full height minus header minus bottom nav */
      .tt-page{
        height:calc(100vh - 90px - 72px) !important;
        max-height:calc(100vh - 90px - 72px) !important;
      }
    }
  </style>
</head>
<body>

<div class="tt-app">

  <!-- ═══════════════════════════════════════════════
       SIDEBAR TEKNISI (desktop ≥ 769px)
  ════════════════════════════════════════════════ -->
  <aside class="tt-sidebar-nav">
    <div class="sb-brand">
      <div class="sb-logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </div>
      <div class="sb-brand-text">
        <div class="n">DIGSnet</div>
        <div class="s">Technician Portal</div>
      </div>
    </div>

    <div class="sb-menu">
      <div class="sb-label">Menu</div>
      <a class="sb-item" href="/technician">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Overview
      </a>
      <a class="sb-item" href="/technician?tab=tickets">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4h-4z"/></svg>
        Tiket
      </a>
      <a class="sb-item" href="/technician?tab=workorders">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-4"/><rect x="9" y="2" width="6" height="13" rx="2"/></svg>
        Work Order
      </a>
      <a class="sb-item active" href="/technician-tracking">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        GPS Tracking
      </a>
      <div class="sb-label">Akun</div>
      <a class="sb-item" href="/technician?tab=profile">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profil &amp; Statistik
      </a>
    </div>

    <div class="sb-user">
      <div class="sb-avatar" id="sbAvatar">T</div>
      <div class="sb-u-info">
        <div class="sb-u-name" id="sbUserName"><%= user?.name || user?.username || 'Teknisi' %></div>
        <div class="sb-u-role"><%= (user?.role?.name || user?.role || 'Teknisi') %></div>
      </div>
      <button class="sb-logout" onclick="fetch('/api/auth/logout',{method:'POST'}).finally(()=>location.href='/login')" title="Logout" aria-label="Logout">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </button>
    </div>
  </aside>

  <!-- ═══════════════════════════════════════════════
       MAIN AREA
  ════════════════════════════════════════════════ -->
  <div class="tt-main">

    <!-- Mobile header gradient (≤768px) — identik dashboard -->
    <div class="m-header">
      <div class="m-hdr-row">
        <div>
          <div class="m-hi">Halo,</div>
          <div class="m-name" id="mHeaderName">Teknisi</div>
        </div>
        <div class="m-hdr-btns">
          <button class="m-hbtn" onclick="fetch('/api/auth/logout',{method:'POST'}).finally(()=>location.href='/login')" aria-label="Logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </button>
        </div>
      </div>
    </div>

  <div class="tt-page">

    <!-- ═══ INNER TOPBAR ═══ -->
    <div class="tt-topbar">
      <div class="ttb-left">
        <div class="ttb-title">
          Tickets Tracking GPS System
        </div>
      </div>
      <div class="ttb-right">
        <div id="topbar-status">
          <span class="status-pill inactive">
            <span class="pulse-dot"></span>
            Tidak Aktif
          </span>
        </div>
        <button class="btn-f" onclick="loadMyTickets()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
            <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
          </svg>
          <span class="hm">Refresh</span>
        </button>
        <button class="btn-f" id="btn-sat-top" onclick="toggleSat()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
          </svg>
          <span class="hm">Street</span>
        </button>
        <button class="btn-f primary" onclick="centerMap()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="3 11 22 2 13 21 11 13 3 11"/>
          </svg>
          <span class="hm">Lokasi Saya</span>
        </button>
      </div>
    </div>

    <!-- ═══ MOBILE TAB BAR ═══ -->
    <div class="mob-tab-bar">
      <div class="mob-tab" id="mtab-map" onclick="mobSwitch('map')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
          <line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>
        </svg>
        Peta
      </div>
      <div class="mob-tab" id="mtab-tickets" onclick="mobSwitch('tickets')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
        Tickets
      </div>
      <div class="mob-tab" id="mtab-info" onclick="mobSwitch('info')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
        </svg>
        Info GPS
      </div>
    </div>

    <!-- ═══ COL 1: TICKET SIDEBAR ═══ -->
    <div class="tt-sidebar" id="tt-sidebar">
      <div class="ts-head">
        <span class="ts-title">Ticket Saya</span>
        <span class="ts-badge" id="ticket-count">0</span>
      </div>
      <div class="ts-search">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" id="search-ticket" placeholder="Cari ticket..." oninput="filterTickets(this.value)">
      </div>
      <div class="ts-list" id="ticket-list">
        <div class="empty-s">
          <div class="spin" style="border-color:var(--f-border);border-top-color:var(--f-primary);width:20px;height:20px;border-width:2px;"></div>
          <p>Memuat ticket...</p>
        </div>
      </div>
    </div>

    <!-- ═══ COL 2: MAP ═══ -->
    <div class="tt-map" id="tt-map">
      <div id="tt-map-leaf"></div>

      <div class="map-ctrl">
        <button class="mc-btn" onclick="leafMap.zoomIn()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <button class="mc-btn" onclick="leafMap.zoomOut()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </button>
        <button class="mc-btn" onclick="centerMap()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v4m0 12v4m10-10h-4M6 12H2"/></svg>
        </button>
        <div class="mc-sep"></div>
        <button class="mc-btn" id="btn-sat-map" onclick="toggleSat()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        </button>
      </div>

      <div class="map-acc" id="map-acc">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="1"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/></svg>
        Akurasi: <strong id="map-acc-val">—</strong>
      </div>

      <div class="map-nogps" id="map-nogps">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        <p>Lokasi belum tersedia</p>
        <small>Mulai tracking untuk melihat posisi Anda di peta</small>
      </div>
    </div>

    <!-- ═══ COL 3: INFO PANEL ═══ -->
    <div class="tt-info" id="tt-info">
      <div class="ti-head">Status &amp; Informasi</div>
      <div class="ti-body">

        <div class="err-alert" id="err-alert">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
          <span id="err-msg"></span>
        </div>

        <div id="stats-row" style="display:none;">
          <div class="stat-row">
            <div class="stat-card"><div class="sc-val" id="s-dur">0m</div><div class="sc-lbl">Durasi</div></div>
            <div class="stat-card"><div class="sc-val" id="s-dist">0m</div><div class="sc-lbl">Jarak</div></div>
            <div class="stat-card"><div class="sc-val" id="s-pts">0</div><div class="sc-lbl">Points</div></div>
          </div>
        </div>

        <div class="atc" id="atc">
          <div class="atc-hd">
            <div class="atc-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
            <div class="atc-meta">
              <div class="atc-num" id="atc-num">—</div>
              <div class="atc-sub">Ticket aktif saat ini</div>
            </div>
            <div class="live-badge"><span class="live-dot"></span> LIVE</div>
          </div>
          <div class="atc-bd">
            <div class="atc-row"><span class="atc-lbl">Judul</span>    <span class="atc-val" id="atc-title">—</span></div>
            <div class="atc-row"><span class="atc-lbl">Customer</span> <span class="atc-val" id="atc-cust">—</span></div>
            <div class="atc-row"><span class="atc-lbl">Prioritas</span><span class="atc-val" id="atc-prio">—</span></div>
            <div class="atc-row"><span class="atc-lbl">Mulai</span>    <span class="atc-val" id="atc-start">—</span></div>
          </div>
        </div>

        <div class="gps-sec">
          <div class="gps-hd">
