<%# Load app.js SEBELUM socket dan script halaman — ini yang mendefinisikan App global %>
<script src="/js/app.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/socket.io/socket.io.js"></script>

<script>
/* ═══════════════════════════════════════════════════════
   STATE
════════════════════════════════════════════════════════ */
let sess=null, selTicket=null, watchId=null, itvl=null;
let curLoc=null, socket=null;
let tickets=[], filtered=[];
let leafMap=null, marker=null, circle=null;
let trailPts=[], currentLayer='street';
let streetLayer=null, satLayer=null, labelLayer=null;

/* Trail layers */
let trailShadow=null;      // garis bayangan (lebar, transparan)
let trailMain=null;         // garis utama
let trailArrows=[];         // panah arah di sepanjang rute
let trailStartMarker=null;  // marker titik awal
let trailDots=[];           // dot kecil di setiap titik GPS

const CENTER = [-6.2088, 106.8456];

/* ═══════════════════════════════════════════════════════
   MAP — tile layers identik dengan gps-tracking.ejs
════════════════════════════════════════════════════════ */
function initMap() {
  leafMap = L.map('tt-map-leaf', { center:CENTER, zoom:13, zoomControl:false });

  // CartoDB Voyager (sama dengan gps-tracking.ejs)
  streetLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution:'&copy; <a href="https://carto.com/">CARTO</a>',
    subdomains:'abcd', maxZoom:19
  });

  // ESRI Satellite
  satLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
    attribution:'Tiles &copy; Esri', maxZoom:19
  });

  // Label overlay di atas satellite
  labelLayer = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Transportation/MapServer/tile/{z}/{y}/{x}', {
    attribution:'', maxZoom:19, opacity:1
  });

  streetLayer.addTo(leafMap);
}

function toggleSat() {
  const lblTopbar = document.getElementById('btn-sat-top').querySelector('.hm');
  if (currentLayer === 'street') {
    leafMap.removeLayer(streetLayer);
    leafMap.addLayer(satLayer);
    leafMap.addLayer(labelLayer);
    currentLayer = 'satellite';
    if (lblTopbar) lblTopbar.textContent = 'Street';
    ['btn-sat-top','btn-sat-map'].forEach(id => document.getElementById(id)?.classList.add('active'));
  } else {
    leafMap.removeLayer(satLayer);
    leafMap.removeLayer(labelLayer);
    leafMap.addLayer(streetLayer);
    currentLayer = 'street';
    if (lblTopbar) lblTopbar.textContent = 'Satellite';
    ['btn-sat-top','btn-sat-map'].forEach(id => document.getElementById(id)?.classList.remove('active'));
  }
}

function centerMap() {
  if (curLoc) leafMap.setView([curLoc.latitude, curLoc.longitude], 17);
  else leafMap.setView(CENTER, 13);
}

function setMapPos(lat, lng, acc) {
  const ll = [lat, lng];
  document.getElementById('map-nogps').style.display = 'none';
  const accEl = document.getElementById('map-acc');
  accEl.style.display = 'flex';
  document.getElementById('map-acc-val').textContent = Math.round(acc) + ' m';

  // ── Marker icon dengan arah heading ──
  const heading = curLoc?.heading;
  const hasHeading = heading !== null && heading !== undefined && !isNaN(heading);
  const rotation = hasHeading ? heading : 0;

  const iconHtml = `<div style="
    width:40px;height:40px;border-radius:50%;
    background:linear-gradient(135deg,#2563eb,#1d4ed8);
    border:3px solid white;box-shadow:0 3px 16px rgba(37,99,235,.5);
    display:flex;align-items:center;justify-content:center;position:relative;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="white" style="transform:rotate(${rotation}deg);transition:transform .5s ease">
      <path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/>
    </svg>
  </div>`;

  const icon = L.divIcon({ html:iconHtml, className:'', iconSize:[40,40], iconAnchor:[20,20], popupAnchor:[0,-24] });

  if (!marker) {
    marker = L.marker(ll, { icon }).addTo(leafMap);
    leafMap.setView(ll, 16);
  } else {
    marker.setIcon(icon);
    // Smooth marker movement
    animateMarker(marker, marker.getLatLng(), L.latLng(ll), 600);
  }

  // ── Accuracy circle ──
  if (!circle) {
    circle = L.circle(ll, { radius:acc, color:'#2563eb', fillColor:'#2563eb', fillOpacity:.06, weight:1.5, dashArray:'4,4' }).addTo(leafMap);
  } else {
    circle.setLatLng(ll).setRadius(acc);
  }

  // ── Trail / Route ──
  if (sess) {
    // Jangan tambah titik terlalu dekat (< 3m) untuk menghindari clutter
    if (trailPts.length > 0) {
      const last = trailPts[trailPts.length - 1];
      const dist = haversine(last[0], last[1], lat, lng);
      if (dist < 3) {
        // Terlalu dekat — update marker saja, jangan tambah trail point
        return;
      }
    }

    trailPts.push(ll);

    // Gambar ulang trail
    drawTrail();
  }

  // ── Popup ──
  const t = selTicket || sess?.ticket;
  marker.bindPopup(`
    <div class="pp-head">
      <div class="pp-name">Lokasi Saya</div>
      <div class="pp-sub">${t ? t.ticket_number+' — '+(t.title||'') : 'Tracking aktif'}</div>
    </div>
    <div class="pp-body">
      <div class="pp-row"><span class="pp-rk">Latitude</span>  <span class="pp-rv">${lat.toFixed(6)}</span></div>
      <div class="pp-row"><span class="pp-rk">Longitude</span> <span class="pp-rv">${lng.toFixed(6)}</span></div>
      <div class="pp-row"><span class="pp-rk">Akurasi</span>   <span class="pp-rv">${Math.round(acc)} m</span></div>
      <div class="pp-row"><span class="pp-rk">Update</span>    <span class="pp-rv">${new Date().toLocaleTimeString('id-ID')}</span></div>
    </div>`);
}

/**
 * Animasi smooth marker movement (seperti di Gojek/Grab)
 */
function animateMarker(mkr, from, to, duration) {
  const start = performance.now();
  const fromLat = from.lat, fromLng = from.lng;
  const dLat = to.lat - fromLat, dLng = to.lng - fromLng;

  function step(now) {
    const elapsed = now - start;
    const t = Math.min(elapsed / duration, 1);
    // Easing: ease-out cubic
    const ease = 1 - Math.pow(1 - t, 3);
    mkr.setLatLng([fromLat + dLat * ease, fromLng + dLng * ease]);
    if (t < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

/**
 * Gambar trail rute — multi-layer seperti Google Maps / Gojek
 * Layer 1: Shadow (lebar, transparan) — memberikan kedalaman
 * Layer 2: Main line (solid, biru)
 * Layer 3: Arrow decorators — menunjukkan arah perjalanan
 * Layer 4: Start marker (titik hijau)
 */
function drawTrail() {
  if (trailPts.length < 2) return;

  // Smooth the trail points — simple moving average untuk 3 titik
  const smoothed = smoothTrail(trailPts);

  // ── Layer 1: Shadow ──
  if (trailShadow) leafMap.removeLayer(trailShadow);
  trailShadow = L.polyline(smoothed, {
    color: '#1e40af',
    weight: 8,
    opacity: 0.15,
    lineCap: 'round',
    lineJoin: 'round'
  }).addTo(leafMap);

  // ── Layer 2: Main trail ──
  if (trailMain) leafMap.removeLayer(trailMain);
  trailMain = L.polyline(smoothed, {
    color: '#3b82f6',
    weight: 4,
    opacity: 0.9,
    lineCap: 'round',
    lineJoin: 'round'
  }).addTo(leafMap);

  // ── Layer 3: Direction arrows setiap ~50m ──
  clearArrows();
  let accumDist = 0;
  for (let i = 1; i < smoothed.length; i++) {
    const prev = smoothed[i-1], curr = smoothed[i];
    const segDist = haversine(prev[0], prev[1], curr[0], curr[1]);
    accumDist += segDist;

    if (accumDist >= 50) {  // Panah setiap ~50 meter
      accumDist = 0;
      const midLat = (prev[0] + curr[0]) / 2;
      const midLng = (prev[1] + curr[1]) / 2;
      const angle = bearing(prev[0], prev[1], curr[0], curr[1]);

      const arrowIcon = L.divIcon({
        html: `<div style="
          width:16px;height:16px;
          display:flex;align-items:center;justify-content:center;
          transform:rotate(${angle}deg);
        "><svg width="12" height="12" viewBox="0 0 24 24" fill="#1d4ed8" opacity="0.7"><path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/></svg></div>`,
        className: '',
        iconSize: [16, 16],
        iconAnchor: [8, 8]
      });

      const arrowMarker = L.marker([midLat, midLng], {
        icon: arrowIcon,
        interactive: false
      }).addTo(leafMap);
      trailArrows.push(arrowMarker);
    }
  }

  // ── Layer 4: Start marker (titik hijau) ──
  if (!trailStartMarker && trailPts.length > 0) {
    const startIcon = L.divIcon({
      html: `<div style="
        width:14px;height:14px;border-radius:50%;
        background:#10b981;border:2.5px solid white;
        box-shadow:0 2px 6px rgba(16,185,129,.4);
      "></div>`,
      className: '',
      iconSize: [14, 14],
      iconAnchor: [7, 7]
    });
    trailStartMarker = L.marker(trailPts[0], { icon: startIcon, interactive: false }).addTo(leafMap);
  }
}

/**
 * Smooth trail — simple 3-point moving average
 * Menghilangkan zig-zag kecil dari noise GPS
 */
function smoothTrail(pts) {
  if (pts.length <= 3) return pts;
  const result = [pts[0]]; // keep first point exact
  for (let i = 1; i < pts.length - 1; i++) {
    const prev = pts[i-1], curr = pts[i], next = pts[i+1];
    result.push([
      (prev[0] + curr[0] + next[0]) / 3,
      (prev[1] + curr[1] + next[1]) / 3
    ]);
  }
  result.push(pts[pts.length - 1]); // keep last point exact
  return result;
}

/**
 * Bearing (derajat) dari titik A ke titik B
 */
function bearing(lat1, lng1, lat2, lng2) {
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const y = Math.sin(dLng) * Math.cos(lat2 * Math.PI / 180);
  const x = Math.cos(lat1 * Math.PI / 180) * Math.sin(lat2 * Math.PI / 180) -
            Math.sin(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.cos(dLng);
  return ((Math.atan2(y, x) * 180 / Math.PI) + 360) % 360;
}

/**
 * Clear arrow markers
 */
function clearArrows() {
  trailArrows.forEach(a => leafMap.removeLayer(a));
  trailArrows = [];
}

/**
 * Clear all trail layers
 */
function clearTrail() {
  if (trailShadow) { leafMap.removeLayer(trailShadow); trailShadow = null; }
  if (trailMain) { leafMap.removeLayer(trailMain); trailMain = null; }
  if (trailStartMarker) { leafMap.removeLayer(trailStartMarker); trailStartMarker = null; }
  clearArrows();
  trailPts = [];
}

/* ═══════════════════════════════════════════════════════
   INIT
════════════════════════════════════════════════════════ */
async function init() {
  initMap();
  if (window.innerWidth <= 768) mobSwitch('map');
  try {
    await checkSession();
    await loadMyTickets();
    initSocket();
  } catch(e) { showErr('Gagal memuat: ' + e.message); }
}

/* ═══════════════════════════════════════════════════════
   SESSION CHECK
════════════════════════════════════════════════════════ */
async function checkSession() {
  const token = localStorage.getItem('token');
  if (!token) return;
  try {
    const r = await fetch('/api/tracking/my-session', { headers:{'Authorization':'Bearer '+token} });
    const d = await r.json();
    if (d.success && d.data) {
      sess=d.data; selTicket=d.data.ticket;
      uiActive(); startWatch();
    }
  } catch(e) { console.warn('Session check:', e); }
}

/* ═══════════════════════════════════════════════════════
   LOAD TICKETS
════════════════════════════════════════════════════════ */
async function loadMyTickets() {
  const token = localStorage.getItem('token');
  const user  = JSON.parse(localStorage.getItem('user') || '{}');
  if (!token) { showErr('Silakan login terlebih dahulu'); return; }
  try {
    const r = await fetch('/api/tickets?assigned_to='+user.id, { headers:{'Authorization':'Bearer '+token} });
    const d = await r.json();
    if (d.success && d.data) {
      tickets  = d.data.filter(t => ['assigned','in_progress','open'].includes(t.status));
      filtered = [...tickets];
      renderTickets();
    } else throw new Error(d.message || 'Gagal memuat ticket');
  } catch(e) {
    document.getElementById('ticket-list').innerHTML = `
      <div class="empty-s">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.35"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <p>Gagal memuat ticket</p><small>${e.message}</small>
      </div>`;
  }
}

function filterTickets(q) {
  const v = q.toLowerCase().trim();
  filtered = v
    ? tickets.filter(t =>
        (t.ticket_number||'').toLowerCase().includes(v) ||
        (t.title||'').toLowerCase().includes(v) ||
        (t.customer?.name||'').toLowerCase().includes(v))
    : [...tickets];
  renderTickets();
}

/* ═══════════════════════════════════════════════════════
   RENDER TICKETS
════════════════════════════════════════════════════════ */
function renderTickets() {
  const el = document.getElementById('ticket-list');
  document.getElementById('ticket-count').textContent = tickets.length;
  if (!filtered.length) {
    el.innerHTML = `
      <div class="empty-s">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:.35">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
        </svg>
        <p>Tidak ada ticket</p><small>Belum ada ticket yang di-assign ke Anda</small>
      </div>`;
    return;
  }
  const PL={critical:'Critical',high:'Tinggi',medium:'Sedang',low:'Rendah'};
  const PC={critical:'pri-critical',high:'pri-high',medium:'pri-medium',low:'pri-low'};
  el.innerHTML = filtered.map(t => {
    const sel=selTicket?.id===t.id, locked=sess&&!sel;
    return `
      <div class="ticket-item ${sel?'selected':''} ${locked?'locked':''}"
           onclick="${locked?'':('pickTicket('+t.id+')')}">
        <div class="ti-head">
          <span class="ti-num">${t.ticket_number}</span>
          <span class="ti-priority ${PC[t.priority]||'pri-low'}">${PL[t.priority]||t.priority}</span>
        </div>
        <div class="ti-title">${t.title||'Tanpa judul'}</div>
        <div class="ti-meta">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          ${t.customer?.name||'Tidak ada customer'}
        </div>
      </div>`;
  }).join('');
}

function pickTicket(id) {
  if (sess) { showErr('Tidak bisa ganti ticket saat tracking aktif'); return; }
  selTicket = tickets.find(t => t.id===id);
  renderTickets(); setHint();
  if (window.innerWidth <= 768) mobSwitch('map');
}

/* ═══════════════════════════════════════════════════════
   TRACKING
════════════════════════════════════════════════════════ */
async function toggleTracking() {
  if (sess) await stopTracking(); else await startTracking();
}

async function startTracking() {
  if (!selTicket) { showErr('Pilih ticket terlebih dahulu'); return; }
  try {
    setBtnLoad(true);
    // Gunakan best-of-N sampling untuk posisi awal yang lebih akurat
    const pos   = await getAccuratePos(4, 10000);
    curLoc = { latitude:pos.coords.latitude, longitude:pos.coords.longitude, accuracy:pos.coords.accuracy };
    const bat   = await getBat();
    const token = localStorage.getItem('token');
    const r = await fetch('/api/tracking/start', {
      method:'POST',
      headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
      body: JSON.stringify({ ticket_id:selTicket.id, latitude:curLoc.latitude, longitude:curLoc.longitude, accuracy:curLoc.accuracy, battery_level:bat })
    });
    const d = await r.json();
    if (!r.ok || !d.success) throw new Error(d.message||'HTTP '+r.status);
    sess=d.data; trailPts=[[curLoc.latitude,curLoc.longitude]];
    uiActive(); startWatch();
    setMapPos(curLoc.latitude, curLoc.longitude, curLoc.accuracy);
  } catch(e) {
    let m=e.message;
    if (m.includes('denied')||m.includes('PERMISSION')) m='GPS permission ditolak. Izinkan akses lokasi.';
    else if (m.includes('401')) m='Token expired. Silakan login kembali.';
    showErr(m);
  } finally { setBtnLoad(false); }
}

async function stopTracking() {
  if (!sess) return;
  // Show modal instead of confirm()
  openStopModal();
}

function openStopModal() {
  const t = selTicket || sess?.ticket;
  document.getElementById('md-ticket').textContent = t?.ticket_number || '—';
  document.getElementById('md-dur').textContent = fmtDur(sess.total_duration || 0);
  document.getElementById('md-dist').textContent = fmtDist(sess.total_distance || 0);
  document.getElementById('md-pts').textContent = sess.points_count || 0;
  document.getElementById('md-notes').value = '';

  const overlay = document.getElementById('stop-modal');
  overlay.classList.remove('fade-out');
  overlay.classList.add('show');
}

function closeStopModal() {
  const overlay = document.getElementById('stop-modal');
  overlay.classList.add('fade-out');
  setTimeout(() => { overlay.classList.remove('show', 'fade-out'); }, 250);
}

async function confirmStop() {
  const btn = document.getElementById('md-confirm');
  btn.disabled = true;
  btn.innerHTML = '<div class="spin"></div> Menghentikan...';

  try {
    // Gunakan posisi terakhir yang sudah ada dari watchPosition — JANGAN request GPS baru
    // Ini menghindari timeout 15 detik yang membuat proses stop lama
    let lat, lng;
    if (curLoc) {
      lat = curLoc.latitude;
      lng = curLoc.longitude;
    } else {
      // Fallback: coba ambil posisi cepat dengan maximumAge tinggi (boleh cache)
      try {
        const pos = await new Promise((res, rej) => {
          navigator.geolocation.getCurrentPosition(res, rej, {
            enableHighAccuracy: false,
            timeout: 5000,
            maximumAge: 60000  // boleh pakai cache hingga 1 menit
          });
        });
        lat = pos.coords.latitude;
        lng = pos.coords.longitude;
      } catch(e) {
        // Kalau tetap gagal, pakai posisi start session
        lat = sess.start_latitude || 0;
        lng = sess.start_longitude || 0;
      }
    }

    const token = localStorage.getItem('token');
    const notes = document.getElementById('md-notes').value.trim();
    const r = await fetch('/api/tracking/stop', {
      method: 'POST',
      headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
      body: JSON.stringify({
        session_id: sess.session_id,
        latitude: lat,
        longitude: lng,
        notes: notes || null
      })
    });
    const d = await r.json();
    if (!d.success) throw new Error(d.message);
    stopWatch(); sess = null;
    clearTrail();
    closeStopModal();
    uiInactive();
  } catch (e) {
    showErr(e.message);
    closeStopModal();
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg> Stop Tracking';
  }
}

/* ═══════════════════════════════════════════════════════
   GPS — High Accuracy Engine
   Target: 5-10 meter accuracy
════════════════════════════════════════════════════════ */

/**
 * Quick position — untuk stop tracking & fallback
 * Boleh pakai cache, tidak perlu akurat banget
 */
function getPos() {
  return new Promise((res,rej) => {
    if (!navigator.geolocation) { rej(new Error('Geolocation tidak didukung')); return; }
    navigator.geolocation.getCurrentPosition(res, err => {
      rej(new Error(['','GPS permission ditolak','Posisi GPS tidak tersedia','GPS timeout'][err.code]||err.message));
    }, {
      enableHighAccuracy: true,
      timeout: 8000,
      maximumAge: 30000   // boleh cache 30 detik untuk kecepatan
    });
  });
}

/**
 * Best-of-N sampling — untuk START tracking
 * Ambil beberapa sample, pilih yang terbaik.
 * Berhenti segera jika akurasi <= 10m.
 */
function getAccuratePos(maxSamples, timeoutMs) {
  maxSamples = maxSamples || 5;
  timeoutMs  = timeoutMs  || 12000;
  return new Promise((resolve, reject) => {
    if (!navigator.geolocation) { reject(new Error('Geolocation tidak didukung')); return; }
    let best = null;
    let count = 0;
    let settled = false;

    const done = (result) => {
      if (settled) return;
      settled = true;
      navigator.geolocation.clearWatch(wid);
      clearTimeout(fallback);
      if (result) resolve(result);
      else reject(new Error('GPS timeout'));
    };

    const wid = navigator.geolocation.watchPosition(
      pos => {
        count++;
        console.log(`GPS sample #${count}: accuracy=${pos.coords.accuracy.toFixed(1)}m`);

        if (!best || pos.coords.accuracy < best.coords.accuracy) {
          best = pos;
        }
        // Target tercapai — langsung selesai
        if (pos.coords.accuracy <= 10) {
          done(best);
          return;
        }
        // Sudah cukup sample — ambil yang terbaik
        if (count >= maxSamples) {
          done(best);
        }
      },
      err => {
        console.warn('GPS sample error:', err.message);
        // Jika sudah punya data bagus, pakai itu
        done(best);
      },
      {
        enableHighAccuracy: true,
        timeout: Math.min(timeoutMs, 10000),
        maximumAge: 0   // paksa posisi fresh untuk start
      }
    );

    // Hard timeout
    const fallback = setTimeout(() => {
      console.warn('GPS sampling timeout, best accuracy:', best?.coords.accuracy);
      done(best);
    }, timeoutMs);
  });
}

/**
 * Continuous watch — untuk tracking berjalan
 * Strategi high-accuracy:
 * 1. maximumAge: 0 — selalu minta posisi segar, TIDAK pakai cache
 * 2. Filter noise: abaikan spike akurasi buruk
 * 3. Minimum distance filter: abaikan update < 2m (noise statis)
 */
function startWatch() {
  if (watchId) return;
  document.getElementById('gps-live').style.display = 'flex';
  let lastGood = null;      // posisi terakhir yang lolos filter
  let warmupCount = 0;      // hitung beberapa reading pertama untuk warm-up

  watchId = navigator.geolocation.watchPosition(p => {
    const acc = p.coords.accuracy;
    const lat = p.coords.latitude;
    const lng = p.coords.longitude;
    warmupCount++;

    // WARM-UP: 3 reading pertama selalu diterima agar GPS lock cepat
    if (warmupCount <= 3) {
      curLoc = { latitude:lat, longitude:lng, accuracy:acc, speed:p.coords.speed, heading:p.coords.heading };
      lastGood = { latitude:lat, longitude:lng, accuracy:acc };
      updateGps();
      setMapPos(lat, lng, acc);
      return;
    }

    // FILTER 1: Buang reading dengan akurasi > 50m jika sudah punya yg < 20m
    if (lastGood && lastGood.accuracy < 20 && acc > 50) {
      console.log(`GPS filtered: acc ${acc.toFixed(0)}m too bad (had ${lastGood.accuracy.toFixed(0)}m)`);
      return;
    }

    // FILTER 2: Buang jika akurasi > 4x lebih buruk dari terakhir
    if (lastGood && lastGood.accuracy < 15 && acc > lastGood.accuracy * 4) {
      console.log(`GPS filtered: acc spike ${acc.toFixed(0)}m vs ${lastGood.accuracy.toFixed(0)}m`);
      return;
    }

    // FILTER 3: Minimum distance — abaikan gerakan < 2m (noise statis saat diam)
    if (lastGood && acc < 25) {
      const dist = haversine(lastGood.latitude, lastGood.longitude, lat, lng);
      if (dist < 2 && acc >= lastGood.accuracy) {
        // Posisi hampir sama, akurasi tidak lebih baik — skip
        return;
      }
    }

    // Lolos filter — update
    curLoc = { latitude:lat, longitude:lng, accuracy:acc, speed:p.coords.speed, heading:p.coords.heading };
    lastGood = { latitude:lat, longitude:lng, accuracy:acc };
    updateGps();
    setMapPos(lat, lng, acc);
  }, e => {
    console.warn('GPS watch error:', e.message);
    // Jangan showErr untuk setiap watch error — terlalu noisy
  }, {
    enableHighAccuracy: true,
    timeout: 15000,
    maximumAge: 0   // KUNCI akurasi tinggi: JANGAN pakai cache, selalu posisi segar
  });

  // Kirim update ke server setiap 15 detik (lebih sering = tracking lebih akurat)
  itvl = setInterval(sendUpdate, 15000);
}

/**
 * Haversine distance antara 2 koordinat (meter)
 */
function haversine(lat1, lon1, lat2, lon2) {
  const R = 6371000;
  const dLat = (lat2-lat1) * Math.PI/180;
  const dLon = (lon2-lon1) * Math.PI/180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

function stopWatch() {
  if (watchId) { navigator.geolocation.clearWatch(watchId); watchId=null; }
  if (itvl)   { clearInterval(itvl); itvl=null; }
  document.getElementById('gps-live').style.display = 'none';
}

async function sendUpdate() {
  if (!sess||!curLoc) return;
  // Jangan kirim jika akurasi terlalu buruk
  if (curLoc.accuracy > 100) {
    console.warn('GPS accuracy too low (' + Math.round(curLoc.accuracy) + 'm), skipping update');
    return;
  }
  try {
    const bat=await getBat(), token=localStorage.getItem('token');
    const r = await fetch('/api/tracking/update', {
      method:'POST',
      headers:{'Authorization':'Bearer '+token,'Content-Type':'application/json'},
      body: JSON.stringify({ session_id:sess.session_id, latitude:curLoc.latitude, longitude:curLoc.longitude, accuracy:curLoc.accuracy, speed:curLoc.speed, heading:curLoc.heading, battery_level:bat })
    });
    const d = await r.json();
    if (d.success&&d.data.session) { sess=d.data.session; updateStats(); }
  } catch(e) { console.warn('Update err:',e); }
}

async function getBat() {
  try { if('getBattery' in navigator){ const b=await navigator.getBattery(); return Math.round(b.level*100); } } catch(e){}
  return null;
}

/* ═══════════════════════════════════════════════════════
   UI
════════════════════════════════════════════════════════ */
function uiActive() {
  const _actPill = '<span class="status-pill active" style="font-size:10px;padding:3px 8px;"><span class="pulse-dot"></span> Aktif</span>';
  document.getElementById('topbar-status').innerHTML = '<span class="status-pill active"><span class="pulse-dot"></span> Tracking Aktif</span>';
  const _mobP = document.getElementById('mob-status-pill'); if(_mobP) _mobP.innerHTML = _actPill;
  const btn=document.getElementById('act-btn');
  btn.className='act-btn stop';
  btn.innerHTML=`<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg><span id="btn-txt">Stop Tracking</span>`;
  document.getElementById('stats-row').style.display='block';
  updateStats();
  const t=selTicket||sess?.ticket;
  if (t) {
    const PM={critical:'Critical',high:'Tinggi',medium:'Sedang',low:'Rendah'};
    document.getElementById('atc').classList.add('show');
    document.getElementById('atc-num').textContent   = t.ticket_number||'—';
    document.getElementById('atc-title').textContent = t.title||'—';
    document.getElementById('atc-cust').textContent  = t.customer?.name||'—';
    document.getElementById('atc-prio').textContent  = PM[t.priority]||t.priority||'—';
  }
  if (sess?.started_at) {
    document.getElementById('atc-start').textContent =
      new Date(sess.started_at).toLocaleString('id-ID',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
  }
  setHint(); renderTickets();
}

function uiInactive() {
  const _inactPill = '<span class="status-pill inactive" style="font-size:10px;padding:3px 8px;"><span class="pulse-dot"></span> Tidak Aktif</span>';
  document.getElementById('topbar-status').innerHTML = '<span class="status-pill inactive"><span class="pulse-dot"></span> Tidak Aktif</span>';
  const _mobP2 = document.getElementById('mob-status-pill'); if(_mobP2) _mobP2.innerHTML = _inactPill;
  const btn=document.getElementById('act-btn');
  btn.className='act-btn start';
  btn.innerHTML=`<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg><span id="btn-txt">Mulai Tracking</span>`;
  document.getElementById('stats-row').style.display='none';
  document.getElementById('atc').classList.remove('show');
  ['g-lat','g-lng','g-acc','g-bat','g-upd'].forEach(id=>{const e=document.getElementById(id);if(e)e.textContent='—';});
  document.getElementById('map-nogps').style.display='flex';
  document.getElementById('map-acc').style.display='none';
  setHint(); renderTickets();
}

function updateStats() {
  if (!sess) return;
  document.getElementById('s-dur').textContent  = fmtDur(sess.total_duration||0);
  document.getElementById('s-dist').textContent = fmtDist(sess.total_distance||0);
  document.getElementById('s-pts').textContent  = sess.points_count||0;
}

function updateGps() {
  if (!curLoc) return;
  document.getElementById('g-lat').textContent = curLoc.latitude.toFixed(6);
  document.getElementById('g-lng').textContent = curLoc.longitude.toFixed(6);
  document.getElementById('g-acc').textContent = Math.round(curLoc.accuracy)+' m';
  document.getElementById('g-upd').textContent = new Date().toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
  getBat().then(b=>{if(b!==null)document.getElementById('g-bat').textContent=b+'%';});
}

function setHint() {
  const el=document.getElementById('act-hint');
  if (sess)
    el.innerHTML=`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--f-danger)" stroke-width="2" style="flex-shrink:0"><polygon points="5 3 19 12 5 21 5 3"/></svg>Tracking sedang berjalan`;
  else if (selTicket)
    el.innerHTML=`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--f-success)" stroke-width="2.5" style="flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg>Ticket <strong>${selTicket.ticket_number}</strong> dipilih`;
  else
    el.innerHTML=`<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>Pilih ticket dari daftar kiri lalu klik Mulai Tracking`;
}

function setBtnLoad(on) {
  const btn=document.getElementById('act-btn');
  btn.disabled=on;
  if(on) btn.innerHTML='<div class="spin"></div><span>Loading...</span>';
}

function showErr(msg) {
  const el=document.getElementById('err-alert');
  document.getElementById('err-msg').textContent=msg;
  el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),5000);
}

/* ═══════════════════════════════════════════════════════
   MOBILE TAB SWITCH
════════════════════════════════════════════════════════ */
function mobSwitch(tab) {
  ['map','tickets','info'].forEach(t=>{
    document.getElementById('mtab-'+t)?.classList.toggle('active',t===tab);
    const panel = document.getElementById('tt-'+(t==='tickets'?'sidebar':t));
    if (panel) panel.classList.toggle('mob-on', t===tab);
  });
  // Hide/show map-acc badge depending on active tab (karena fixed di mobile)
  const accEl = document.getElementById('map-acc');
  if (accEl) accEl.style.display = (tab === 'map' && curLoc) ? 'flex' : 'none';
  setTimeout(()=>{ if(leafMap) leafMap.invalidateSize(); }, 160);
}

/* ═══════════════════════════════════════════════════════
   SOCKET — kirim token agar tidak "Authentication required"
════════════════════════════════════════════════════════ */
function initSocket() {
  try {
    if (typeof io === 'undefined') return;
    const token = localStorage.getItem('token');
    socket = io({
      reconnection: true,
      reconnectionDelay: 1000,
      reconnectionAttempts: 5,
      // Kirim token saat handshake, sama dengan gps-tracking.ejs
      auth: { token: token || '' }
    });
    socket.on('connect', () => console.log('Socket connected'));
    socket.on('connect_error', e => console.warn('Socket err:', e.message));
    socket.on('technician:location:update', d => {
      if (sess && d.session_id === sess.session_id) {
        if (d.stats) { sess.total_distance=d.stats.total_distance; sess.total_duration=d.stats.total_duration; sess.points_count=d.stats.points_count; updateStats(); }
        if (d.location) { curLoc={latitude:d.location.latitude,longitude:d.location.longitude,accuracy:curLoc?.accuracy||10}; updateGps(); setMapPos(curLoc.latitude,curLoc.longitude,curLoc.accuracy); }
      }
    });
  } catch(e) { console.warn('Socket init failed:', e); }
}

/* ═══════════════════════════════════════════════════════
   HELPERS
════════════════════════════════════════════════════════ */
function fmtDur(s)  { const h=Math.floor(s/3600),m=Math.floor((s%3600)/60); return h?h+'j '+m+'m':m+'m'; }
function fmtDist(m) { return m<1000?Math.round(m)+' m':(m/1000).toFixed(1)+' km'; }

setInterval(async()=>{ if(sess){const b=await getBat();if(b!==null)document.getElementById('g-bat').textContent=b+'%';}},60000);

document.addEventListener('DOMContentLoaded', init);
</script>
