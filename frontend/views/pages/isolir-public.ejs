<%
  pageConfig = pageConfig || {};
  const cfg = {
    title:     pageConfig.title     || 'Layanan Anda Sedang Diisolir',
    subtitle:  pageConfig.subtitle  || 'Akses internet diblokir karena ada tagihan yang belum dibayar. Silakan login portal untuk melihat detail tagihan dan melakukan pembayaran.',
    color:     (pageConfig.color || '#2563eb').trim(),
    footer:    pageConfig.footer    || '',
    help_text: pageConfig.help_text || '',
  };
  function _shade(hex, p) {
    let h = String(hex || '#2563eb').replace('#','');
    if (h.length === 3) h = h.split('').map(c => c+c).join('');
    const n = parseInt(h, 16);
    const r = Math.max(0, Math.min(255, ((n>>16) & 0xff) + Math.round(255 * p)));
    const g = Math.max(0, Math.min(255, ((n>>8)  & 0xff) + Math.round(255 * p)));
    const b = Math.max(0, Math.min(255, ( n      & 0xff) + Math.round(255 * p)));
    return '#' + [r,g,b].map(v => v.toString(16).padStart(2,'0')).join('');
  }
  const cDark  = _shade(cfg.color, -0.20);
  const cSoft  = _shade(cfg.color,  0.46);
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
  <meta name="theme-color" content="<%= cDark %>">
  <meta name="robots" content="noindex,nofollow">
  <title><%= cfg.title %> · <%= appName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --brand:       <%= cfg.color %>;
      --brand-dark:  <%= cDark %>;
      --brand-soft:  <%= cSoft %>;
      --brand-sky:   #0ea5e9;
      --bg:          #fafafb;
      --surface:     #ffffff;
      --surface-2:   #f8f9fb;
      --border:      #e8eaef;
      --border-soft: #f0f1f4;
      --text:        #0a0e1a;
      --text-mute:   #5b6478;
      --text-soft:   #9aa3b8;
      --danger:      #e11d48;
      --danger-soft: #fff1f3;
      --warning:     #d97706;
      --warning-soft:#fffbeb;
      --success:     #059669;
      --shadow-sm:   0 1px 3px rgba(10,14,26,0.05), 0 2px 8px rgba(10,14,26,0.03);
      --shadow-md:   0 4px 16px rgba(10,14,26,0.06), 0 1px 3px rgba(10,14,26,0.04);
      --shadow-lg:   0 12px 40px rgba(10,14,26,0.08), 0 4px 12px rgba(10,14,26,0.04);
    }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
      font-feature-settings: 'cv11', 'ss01', 'ss03';
      overflow-x: hidden;
    }
    .mono { font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace; }

    /* ── Animated background ── */
    .bg-decor { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .blob { position: absolute; border-radius: 50%; filter: blur(80px); will-change: transform; }
    .blob-1 {
      width: 480px; height: 480px; background: var(--brand);
      top: -180px; right: -120px; opacity: 0.32;
      animation: drift1 22s ease-in-out infinite;
    }
    .blob-2 {
      width: 360px; height: 360px; background: var(--brand-soft);
      bottom: -100px; left: -120px; opacity: 0.5;
      animation: drift2 26s ease-in-out infinite;
    }
    .blob-3 {
      width: 280px; height: 280px; background: var(--brand-sky);
      top: 40%; left: 50%; opacity: 0.14;
      transform: translate(-50%, -50%);
      animation: drift3 30s ease-in-out infinite;
    }
    @keyframes drift1 { 0%,100% { transform: translate(0,0); } 33% { transform: translate(-40px,30px) scale(1.08); } 66% { transform: translate(20px,-20px) scale(0.95); } }
    @keyframes drift2 { 0%,100% { transform: translate(0,0); } 40% { transform: translate(40px,-30px) scale(1.1); } 75% { transform: translate(-20px,25px) scale(0.92); } }
    @keyframes drift3 { 0%,100% { transform: translate(-50%,-50%); } 50% { transform: translate(-40%,-55%) scale(1.15); } }

    /* ── Layout ── */
    .page {
      position: relative; z-index: 1;
      max-width: 720px; margin: 0 auto;
      padding: 28px 24px 56px;
    }
    @media (max-width: 640px) { .page { padding: 18px 14px 36px; } }

    /* ── Top bar ── */
    .topbar {
      display: flex; align-items: center; justify-content: space-between;
      gap: 10px; margin-bottom: 36px;
      opacity: 0; animation: fadeDown .6s .05s cubic-bezier(.16,1,.3,1) forwards;
    }
    @media (max-width: 640px) { .topbar { margin-bottom: 24px; } }
    .brand-mark {
      display: inline-flex; align-items: center; gap: 12px;
      font-weight: 600; font-size: 14.5px; color: var(--text);
      letter-spacing: -0.005em; min-width: 0;
    }
    .brand-mark img { height: 32px; width: auto; max-width: 140px; display: block; }
    .brand-mark .logo-dot {
      width: 36px; height: 36px; background: var(--text);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 700; font-size: 16px;
      letter-spacing: -0.03em; flex-shrink: 0;
    }
    .brand-mark span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    @media (max-width: 480px) {
      .brand-mark { font-size: 13px; }
      .brand-mark .logo-dot { width: 32px; height: 32px; font-size: 14px; }
      .brand-mark img { height: 26px; max-width: 100px; }
    }

    .status-pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(225,29,72,0.2);
      color: var(--danger); padding: 7px 14px 7px 12px;
      border-radius: 99px; font-size: 12px; font-weight: 500;
      letter-spacing: -0.005em; position: relative; overflow: hidden; flex-shrink: 0;
    }
    @media (max-width: 480px) {
      .status-pill { padding: 6px 10px 6px 9px; font-size: 11px; }
    }
    .status-pill::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(90deg, transparent, rgba(225,29,72,0.07), transparent);
      transform: translateX(-100%); animation: shimmer 3s ease-in-out infinite;
    }
    @keyframes shimmer { 0% { transform: translateX(-100%); } 40%,100% { transform: translateX(100%); } }
    .pulse-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--danger); position: relative; flex-shrink: 0;
    }
    .pulse-dot::after {
      content: ''; position: absolute; inset: -3px;
      border-radius: 50%; background: var(--danger);
      opacity: 0.4; animation: pulseDot 1.8s ease-out infinite;
    }
    @keyframes pulseDot { 0% { transform: scale(0.8); opacity: 0.5; } 100% { transform: scale(2.4); opacity: 0; } }

    /* ── Hero card (combined, since no split needed now) ── */
    .hero-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 36px 32px;
      box-shadow: var(--shadow-lg);
      position: relative;
      overflow: hidden;
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp .7s .15s cubic-bezier(.16,1,.3,1) forwards;
    }
    @media (max-width: 640px) { .hero-card { padding: 28px 22px; border-radius: 20px; } }
    .hero-card::before {
      content: ''; position: absolute;
      top: -50%; right: -25%;
      width: 380px; height: 380px;
      background: radial-gradient(circle, var(--brand-soft) 0%, transparent 65%);
      pointer-events: none; opacity: 0.6;
    }
    .hero-card::after {
      content: ''; position: absolute; inset: 0;
      border-radius: 24px; border: 1px solid rgba(255,255,255,0.6);
      pointer-events: none;
    }
    .hero-icon-wrap {
      position: relative;
      width: 56px; height: 56px;
      background: var(--danger-soft);
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 20px;
      border: 1px solid rgba(225, 29, 72, 0.15);
    }
    .hero-icon-wrap svg { width: 28px; height: 28px; stroke: var(--danger); }
    .hero-icon-wrap::after {
      content: '';
      position: absolute; inset: -4px;
      border-radius: 18px;
      border: 2px solid var(--danger);
      opacity: 0.2;
      animation: ringPulse 2.4s ease-in-out infinite;
    }
    @keyframes ringPulse {
      0%,100% { transform: scale(1); opacity: 0.2; }
      50%     { transform: scale(1.08); opacity: 0.05; }
    }
    .eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 12px 6px 10px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border); border-radius: 99px;
      font-size: 12px; font-weight: 500; color: var(--text-mute);
      letter-spacing: -0.005em; width: max-content;
      margin-bottom: 18px; position: relative;
    }
    .eyebrow .ico { width: 14px; height: 14px; stroke: var(--brand); }
    .hero-card h1 {
      font-size: 36px; line-height: 1.1; font-weight: 700;
      letter-spacing: -0.035em; margin: 0 0 16px;
      color: var(--text); position: relative; max-width: 540px;
    }
    @media (max-width: 640px) { .hero-card h1 { font-size: 28px; } }
    @media (max-width: 480px) { .hero-card h1 { font-size: 24px; margin-bottom: 12px; } }
    .hero-card .desc {
      font-size: 15.5px; line-height: 1.65;
      color: var(--text-mute); margin: 0;
      position: relative; max-width: 540px; font-weight: 400;
    }
    @media (max-width: 640px) { .hero-card .desc { font-size: 14px; } }

    /* ── Section card ── */
    .section-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px; overflow: hidden;
      margin-bottom: 16px; box-shadow: var(--shadow-sm);
      opacity: 0; animation: fadeUp .6s .35s cubic-bezier(.16,1,.3,1) forwards;
    }
    @media (max-width: 640px) { .section-card { border-radius: 16px; } }
    .section-head {
      padding: 18px 22px 14px;
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      border-bottom: 1px solid var(--border-soft);
    }
    @media (max-width: 640px) { .section-head { padding: 16px 18px 12px; } }
    .section-head h2 {
      font-size: 14.5px; font-weight: 600; margin: 0;
      letter-spacing: -0.01em; color: var(--text);
      display: flex; align-items: center; gap: 10px;
    }
    .section-head h2 svg { width: 18px; height: 18px; stroke: var(--text-mute); }
    .count-pill {
      background: var(--surface-2); color: var(--text-mute);
      font-size: 11.5px; font-weight: 600;
      padding: 3px 10px; border-radius: 99px;
      letter-spacing: -0.005em; border: 1px solid var(--border);
    }

    /* ── Bank rows ── */
    .bank-list { padding: 4px 0; }
    .bank-row {
      display: flex; align-items: center; gap: 14px;
      padding: 14px 22px; border-bottom: 1px solid var(--border-soft);
      transition: background .15s ease;
    }
    @media (max-width: 640px) { .bank-row { padding: 12px 18px; gap: 12px; } }
    .bank-row:last-child { border-bottom: none; }
    .bank-row:hover { background: var(--surface-2); }
    .bank-logo {
      width: 42px; height: 42px; border-radius: 10px;
      background: var(--surface-2); border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; overflow: hidden;
      font-size: 13px; font-weight: 700; color: var(--text-mute);
      letter-spacing: -0.01em;
    }
    .bank-logo img { width: 100%; height: 100%; object-fit: contain; }
    .bank-info { flex: 1; min-width: 0; }
    .bank-name {
      font-size: 13.5px; font-weight: 600; color: var(--text);
      margin-bottom: 2px; letter-spacing: -0.005em;
      display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
    }
    .bank-type-tag {
      font-size: 9.5px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em;
      padding: 1px 6px; border-radius: 4px;
      background: var(--surface-2); color: var(--text-soft);
      border: 1px solid var(--border);
    }
    .bank-type-tag.ewallet { background: #fef3c7; color: #92400e; border-color: #fde68a; }
    .bank-type-tag.qris { background: #ede9fe; color: #5b21b6; border-color: #ddd6fe; }
    .bank-account {
      font-family: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
      font-size: 13.5px; font-weight: 600; color: var(--text);
      letter-spacing: 0.02em;
    }
    @media (max-width: 480px) { .bank-account { font-size: 12.5px; } }
    .bank-owner { font-size: 11.5px; color: var(--text-mute); margin-top: 2px; }
    .bank-copy {
      background: var(--surface); border: 1px solid var(--border);
      color: var(--text-mute); border-radius: 8px;
      padding: 7px 11px; font-size: 12px; font-weight: 600;
      font-family: inherit; cursor: pointer;
      transition: all .2s ease;
      display: inline-flex; align-items: center; gap: 6px; flex-shrink: 0;
    }
    .bank-copy:hover {
      background: var(--brand-soft); border-color: var(--brand); color: var(--brand-dark);
    }
    .bank-copy.copied {
      background: #ecfdf5; border-color: #a7f3d0; color: var(--success);
    }
    .bank-copy svg { width: 13px; height: 13px; stroke: currentColor; }
    @media (max-width: 480px) {
      .bank-copy { padding: 6px 9px; font-size: 11px; }
      .bank-copy .label-text { display: none; }
    }

    /* ── QRIS dedicated card ── */
    .qris-card {
      padding: 24px 22px;
      border-top: 1px solid var(--border-soft);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      background: linear-gradient(180deg, transparent 0%, var(--surface-2) 100%);
    }
    .qris-card:first-child { border-top: none; }
    @media (max-width: 640px) { .qris-card { padding: 20px 16px; gap: 12px; } }

    .qris-head {
      display: flex; align-items: center; gap: 10px;
      font-size: 13.5px; font-weight: 600; color: var(--text);
      letter-spacing: -0.005em;
    }
    .qris-head .qris-badge {
      font-size: 9.5px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em;
      padding: 2px 7px; border-radius: 5px;
      background: #ede9fe; color: #5b21b6;
      border: 1px solid #ddd6fe;
    }

    .qris-img-wrap {
      position: relative;
      background: #fff;
      padding: 12px;
      border-radius: 16px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
      max-width: 260px;
      width: 100%;
      cursor: zoom-in;
      transition: transform .25s cubic-bezier(.16,1,.3,1), box-shadow .25s ease;
    }
    .qris-img-wrap:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
    .qris-img-wrap::after {
      content: '';
      position: absolute;
      top: 8px; right: 8px;
      width: 26px; height: 26px;
      background: rgba(255,255,255,0.95);
      border: 1px solid var(--border);
      border-radius: 7px;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%235b6478' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='15 3 21 3 21 9'/><polyline points='9 21 3 21 3 15'/><line x1='21' y1='3' x2='14' y2='10'/><line x1='3' y1='21' x2='10' y2='14'/></svg>");
      background-repeat: no-repeat;
      background-position: center;
      opacity: 0;
      transition: opacity .2s ease;
    }
    .qris-img-wrap:hover::after { opacity: 1; }
    .qris-img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 8px;
    }
    .qris-placeholder {
      width: 100%;
      aspect-ratio: 1;
      max-width: 220px;
      background: var(--surface-2);
      border: 1px dashed var(--border);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-soft);
      font-size: 12px;
      padding: 20px;
      text-align: center;
      line-height: 1.5;
    }

    .qris-owner {
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
      text-align: center;
    }
    .qris-hint {
      font-size: 12px;
      color: var(--text-mute);
      text-align: center;
      max-width: 320px;
      line-height: 1.55;
    }
    .qris-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .qris-action-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text-mute);
      border-radius: 8px;
      padding: 7px 12px;
      font-size: 12px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: all .2s ease;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }
    .qris-action-btn:hover {
      background: var(--brand-soft);
      border-color: var(--brand);
      color: var(--brand-dark);
    }
    .qris-action-btn svg { width: 13px; height: 13px; stroke: currentColor; }

    /* ── QRIS lightbox (klik gambar = fullscreen) ── */
    .qris-lightbox {
      position: fixed;
      inset: 0;
      background: rgba(10, 14, 26, 0.85);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
      animation: fadeIn .25s ease;
    }
    .qris-lightbox.show { display: flex; }
    .qris-lightbox-img {
      max-width: min(440px, 90vw);
      max-height: 85vh;
      width: auto;
      height: auto;
      border-radius: 16px;
      background: #fff;
      padding: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      animation: zoomIn .3s cubic-bezier(.16,1,.3,1);
    }
    .qris-lightbox-close {
      position: absolute;
      top: 20px;
      right: 20px;
      width: 40px;
      height: 40px;
      background: rgba(255,255,255,0.15);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #fff;
      transition: background .2s ease;
    }
    .qris-lightbox-close:hover { background: rgba(255,255,255,0.25); }
    .qris-lightbox-close svg { width: 20px; height: 20px; stroke: currentColor; }
    @keyframes zoomIn {
      from { opacity: 0; transform: scale(0.9); }
      to   { opacity: 1; transform: scale(1); }
    }

    /* ── Help card ── */
    .help-card {
      background: var(--warning-soft);
      border: 1px solid #fde68a; border-radius: 14px;
      padding: 14px 16px;
      font-size: 13.5px; color: #78350f; line-height: 1.6;
      margin-bottom: 16px;
      display: flex; gap: 12px; align-items: flex-start;
      opacity: 0; animation: fadeUp .6s .45s cubic-bezier(.16,1,.3,1) forwards;
    }
    .help-card svg {
      width: 18px; height: 18px; stroke: var(--warning);
      flex-shrink: 0; margin-top: 1px;
    }

    /* ── CTAs ── */
    .actions {
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
      margin-bottom: 32px;
      opacity: 0; animation: fadeUp .6s .5s cubic-bezier(.16,1,.3,1) forwards;
    }
    @media (max-width: 560px) { .actions { grid-template-columns: 1fr; } }
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 9px; padding: 15px 22px;
      border-radius: 14px; font-family: inherit;
      font-size: 14.5px; font-weight: 600; letter-spacing: -0.01em;
      text-decoration: none; cursor: pointer;
      border: 1px solid transparent;
      transition: all .25s cubic-bezier(.16,1,.3,1);
      white-space: nowrap; position: relative; overflow: hidden;
      min-height: 50px;
    }
    @media (max-width: 480px) { .btn { padding: 14px 18px; font-size: 14px; min-height: 48px; border-radius: 12px; } }
    .btn svg {
      width: 17px; height: 17px; stroke: currentColor;
      flex-shrink: 0; transition: transform .25s cubic-bezier(.16,1,.3,1);
    }
    .btn-primary {
      background: var(--text); color: #fff;
      box-shadow: 0 1px 2px rgba(10,14,26,0.12), 0 4px 12px rgba(10,14,26,0.08);
    }
    .btn-primary::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, transparent 50%);
      pointer-events: none;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(10,14,26,0.15), 0 8px 24px rgba(10,14,26,0.12);
    }
    .btn-primary:hover svg:last-child { transform: translateX(2px); }
    .btn-primary:active { transform: translateY(0); }
    .btn-secondary {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      color: var(--text); border-color: var(--border);
    }
    .btn-secondary:hover {
      background: var(--surface); border-color: #cdd2dc;
      transform: translateY(-2px); box-shadow: var(--shadow-sm);
    }
    .btn-secondary:hover svg { transform: scale(1.08); }
    .btn-secondary:active { transform: translateY(0); }

    /* ── Footer ── */
    .footer {
      margin-top: 32px; padding-top: 24px;
      border-top: 1px solid var(--border-soft);
      text-align: center; font-size: 12.5px;
      color: var(--text-soft); line-height: 1.6;
      opacity: 0; animation: fadeIn .8s .6s ease forwards;
    }
    .footer .custom-footer {
      color: var(--text-mute); margin-bottom: 12px;
      font-size: 13.5px; line-height: 1.65;
    }
    @media (max-width: 480px) { .footer .custom-footer { font-size: 12.5px; } }
    .footer .ip-tag {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      border: 1px solid var(--border);
      padding: 3px 9px; border-radius: 6px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11.5px; color: var(--text-mute); letter-spacing: -0.01em;
    }
    .footer .ip-tag::before {
      content: ''; width: 5px; height: 5px;
      background: var(--success); border-radius: 50%;
    }
    .footer .copyright { margin-top: 8px; font-size: 12px; }

    /* ── Toast ── */
    .toast {
      position: fixed; bottom: 24px; left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--text); color: #fff;
      padding: 11px 18px; border-radius: 12px;
      font-size: 13.5px; font-weight: 500;
      box-shadow: var(--shadow-lg);
      opacity: 0; transition: all .35s cubic-bezier(.16,1,.3,1);
      pointer-events: none; z-index: 1000;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast svg { width: 16px; height: 16px; stroke: #34d399; }

    /* ── Animations ── */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeDown { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      .blob { animation: none; }
    }
  </style>
</head>
<body>

  <div class="bg-decor" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>

  <div class="page">

    <!-- ── TOP BAR ── -->
    <div class="topbar">
      <div class="brand-mark">
        <% if (brand.logo_url) { %>
          <img src="<%= brand.logo_url %>" alt="<%= brand.company_name || brand.app_name %>">
        <% } else { %>
          <div class="logo-dot"><%= ((brand.company_name || brand.app_name || 'I')[0] || 'I').toUpperCase() %></div>
          <span><%= brand.company_name || brand.app_name || 'ISP' %></span>
        <% } %>
      </div>
      <div class="status-pill">
        <span class="pulse-dot"></span>
        Layanan diisolir
      </div>
    </div>

    <!-- ── HERO ── -->
    <div class="hero-card">
      <div class="hero-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <span class="eyebrow">
        <svg class="ico" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        Pemberitahuan
      </span>
      <h1><%= cfg.title %></h1>
      <p class="desc"><%= cfg.subtitle %></p>
    </div>

    <!-- ── BANK ACCOUNTS (loaded via JS) ── -->
    <div class="section-card" id="banksSection" style="display:none;">
      <div class="section-head">
        <h2>
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="6" width="18" height="13" rx="2"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
            <line x1="7" y1="15" x2="9" y2="15"/>
          </svg>
          Metode Pembayaran
        </h2>
        <span class="count-pill" id="banksCount"></span>
      </div>
      <div class="bank-list" id="banksList"></div>
    </div>

    <!-- ── HELP TEXT ── -->
    <% if (cfg.help_text) { %>
      <div class="help-card">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
          <line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <div><%- cfg.help_text.replace(/\n/g,'<br>') %></div>
      </div>
    <% } %>

    <!-- ── ACTIONS ── -->
    <div class="actions">
      <a href="/portal/login" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        Masuk ke Portal
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <% if (brand.company_whatsapp) {
        let waNum = String(brand.company_whatsapp).replace(/[^0-9]/g,'');
        if (waNum.startsWith('0')) waNum = '62' + waNum.slice(1);
        const waMsg = encodeURIComponent('Halo, saya butuh bantuan terkait isolir layanan internet saya.');
      %>
        <a href="https://wa.me/<%= waNum %>?text=<%= waMsg %>" class="btn btn-secondary" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          Hubungi Admin
        </a>
      <% } else { %>
        <a href="/portal/login" class="btn btn-secondary">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
          Pusat Bantuan
        </a>
      <% } %>
    </div>

    <!-- ── FOOTER ── -->
    <div class="footer">
      <% if (cfg.footer) { %>
        <div class="custom-footer"><%- cfg.footer.replace(/\n/g,'<br>') %></div>
      <% } %>
      <% if (clientIp) { %>
        Diakses dari <span class="ip-tag"><%= clientIp %></span>
      <% } %>
      <div class="copyright">
        © <%= new Date().getFullYear() %> <%= brand.company_name || brand.app_name || 'ISP NetOps' %>
      </div>
    </div>

  </div>

  <!-- Toast -->
  <div class="toast" id="toast" role="status" aria-live="polite">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    <span id="toastText">Tersalin</span>
  </div>

<script>
(function() {
  'use strict';

  // ── Toast helper ──
  const toast = document.getElementById('toast');
  const toastText = document.getElementById('toastText');
  let toastTimer = null;
  function showToast(message) {
    if (!toast) return;
    toastText.textContent = message;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 2200);
  }

  // ── Copy clipboard ──
  function copyText(text) {
    if (navigator.clipboard && window.isSecureContext) {
      return navigator.clipboard.writeText(text);
    }
    return new Promise((resolve, reject) => {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.left = '-9999px';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); document.body.removeChild(ta); resolve(); }
      catch (e) { document.body.removeChild(ta); reject(e); }
    });
  }

  document.addEventListener('click', function(e) {
    const btn = e.target.closest('[data-copy]');
    if (!btn) return;
    const val = btn.getAttribute('data-copy');
    const label = btn.getAttribute('data-copy-label') || 'Tersalin';
    copyText(val).then(() => {
      btn.classList.add('copied');
      showToast(label + ': ' + val);
      setTimeout(() => btn.classList.remove('copied'), 1800);
    }).catch(() => showToast('Gagal menyalin'));
  });

  // ── Load bank accounts ──
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]);
  }
  function bankLogo(account) {
    if (account.logo_url) return '<img src="' + escapeHtml(account.logo_url) + '" alt="">';
    const provider = (account.provider || '').toUpperCase().slice(0, 4);
    return escapeHtml(provider || 'BANK');
  }
  function bankTypeTag(type) {
    if (type === 'ewallet') return '<span class="bank-type-tag ewallet">E-Wallet</span>';
    if (type === 'qris')    return '<span class="bank-type-tag qris">QRIS</span>';
    return '';
  }

  fetch('/p/isolir/payment-accounts', { cache: 'no-store' })
    .then(r => r.json())
    .then(data => {
      const list = (data && data.accounts) || [];
      if (!list.length) return;
      const section = document.getElementById('banksSection');
      const container = document.getElementById('banksList');
      const count = document.getElementById('banksCount');
      count.textContent = list.length + ' metode';

      // Pisahkan QRIS dari bank/ewallet — render khusus dengan QR image besar
      const banks = list.filter(a => a.type !== 'qris');
      const qrises = list.filter(a => a.type === 'qris');

      // Render bank/ewallet rows
      const bankHtml = banks.map(acc => {
        const provider = (acc.provider || '').toUpperCase();
        return (
          '<div class="bank-row">' +
            '<div class="bank-logo">' + bankLogo(acc) + '</div>' +
            '<div class="bank-info">' +
              '<div class="bank-name">' + escapeHtml(provider) + bankTypeTag(acc.type) + '</div>' +
              '<div class="bank-account">' + escapeHtml(acc.account_number) + '</div>' +
              (acc.account_owner ? '<div class="bank-owner">a.n. ' + escapeHtml(acc.account_owner) + '</div>' : '') +
            '</div>' +
            '<button type="button" class="bank-copy" data-copy="' + escapeHtml(acc.account_number) + '" data-copy-label="Nomor rekening">' +
              '<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<rect x="9" y="9" width="13" height="13" rx="2"/>' +
                '<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>' +
              '</svg>' +
              '<span class="label-text">Salin</span>' +
            '</button>' +
          '</div>'
        );
      }).join('');

      // Render QRIS sebagai card dedicated (kalau ada)
      const qrisHtml = qrises.map(q => {
        const owner = q.account_owner || '';
        const imgUrl = q.logo_url || '';
        const imgBlock = imgUrl
          ? '<div class="qris-img-wrap" data-qris-zoom="' + escapeHtml(imgUrl) + '">' +
              '<img src="' + escapeHtml(imgUrl) + '" alt="QRIS" class="qris-img" loading="lazy">' +
            '</div>'
          : '<div class="qris-placeholder">QR code belum di-upload<br>oleh admin</div>';

        const actions = imgUrl
          ? '<div class="qris-actions">' +
              '<a href="' + escapeHtml(imgUrl) + '" download class="qris-action-btn">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                  '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>' +
                  '<polyline points="7 10 12 15 17 10"/>' +
                  '<line x1="12" y1="15" x2="12" y2="3"/>' +
                '</svg>' +
                'Simpan QR' +
              '</a>' +
            '</div>'
          : '';

        return (
          '<div class="qris-card">' +
            '<div class="qris-head">' +
              '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<rect x="3" y="3" width="7" height="7"/>' +
                '<rect x="14" y="3" width="7" height="7"/>' +
                '<rect x="3" y="14" width="7" height="7"/>' +
                '<path d="M14 14h2M14 17h5M14 20h3M17 14h4"/>' +
              '</svg>' +
              'QRIS' +
              '<span class="qris-badge">Scan & Bayar</span>' +
            '</div>' +
            imgBlock +
            (owner ? '<div class="qris-owner">a.n. ' + escapeHtml(owner) + '</div>' : '') +
            '<div class="qris-hint">Scan QR di atas pakai GoPay, OVO, DANA, ShopeePay, atau m-banking apa pun.</div>' +
            actions +
          '</div>'
        );
      }).join('');

      container.innerHTML = bankHtml + qrisHtml;
      section.style.display = 'block';
      section.style.animation = 'fadeUp .5s .35s cubic-bezier(.16,1,.3,1) forwards';
    })
    .catch(() => { /* silent — section stays hidden */ });

  // ── QRIS lightbox: klik gambar QR = tampil fullscreen ──
  document.addEventListener('click', function(e) {
    const wrap = e.target.closest('[data-qris-zoom]');
    if (wrap) {
      const url = wrap.getAttribute('data-qris-zoom');
      openQrisLightbox(url);
      return;
    }
    if (e.target.closest('.qris-lightbox-close') || e.target.classList?.contains('qris-lightbox')) {
      closeQrisLightbox();
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeQrisLightbox();
  });

  function openQrisLightbox(url) {
    let lb = document.getElementById('qrisLightbox');
    if (!lb) {
      lb = document.createElement('div');
      lb.id = 'qrisLightbox';
      lb.className = 'qris-lightbox';
      lb.innerHTML =
        '<button type="button" class="qris-lightbox-close" aria-label="Tutup">' +
          '<svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
            '<line x1="18" y1="6" x2="6" y2="18"/>' +
            '<line x1="6" y1="6" x2="18" y2="18"/>' +
          '</svg>' +
        '</button>' +
        '<img class="qris-lightbox-img" alt="QRIS fullscreen">';
      document.body.appendChild(lb);
    }
    const img = lb.querySelector('.qris-lightbox-img');
    img.src = url;
    lb.classList.add('show');
    document.body.style.overflow = 'hidden';
  }
  function closeQrisLightbox() {
    const lb = document.getElementById('qrisLightbox');
    if (lb) {
      lb.classList.remove('show');
      document.body.style.overflow = '';
    }
  }

})();
</script>
</body>
</html>
