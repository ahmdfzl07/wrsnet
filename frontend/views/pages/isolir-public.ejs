<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover">
  <meta name="theme-color" content="#0047cc">
  <meta name="robots" content="noindex,nofollow">
  <title><%= title %> - <%= appName %></title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    :root {
      --bg:        #eef2f9;
      --bg-soft:   #f8faff;
      --card:      #ffffff;
      --border:    #e0e7f3;
      --text:      #0d1b3e;
      --muted:     #6b7fa8;
      --blue:      #1a6ef5;
      --blue-d:    #0047cc;
      --red:       #f5365c;
      --red-soft:  #fee2e2;
      --green:     #00c896;
      --amber:     #f59e0b;
    }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      min-height: 100dvh;
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
    }

    /* ── Hero / Header ── */
    .hero {
      background: linear-gradient(135deg, #1a6ef5 0%, #0047cc 100%);
      color: #fff;
      padding: 32px 20px 56px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(800px 300px at 100% 0%, rgba(255,255,255,.10), transparent 60%),
        radial-gradient(600px 280px at 0% 100%, rgba(255,255,255,.08), transparent 60%);
      pointer-events: none;
    }
    .hero-inner {
      max-width: 560px;
      margin: 0 auto;
      position: relative;
    }
    .hero-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 22px;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: .3px;
      opacity: .85;
    }
    .hero-brand img {
      width: 28px; height: 28px;
      object-fit: contain;
      border-radius: 6px;
      background: rgba(255,255,255,.15);
      padding: 3px;
    }
    .hero-icon {
      width: 64px; height: 64px;
      border-radius: 16px;
      background: rgba(255,255,255,.15);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
      border: 1px solid rgba(255,255,255,.18);
    }
    .hero-icon svg { width: 32px; height: 32px; }
    .hero h1 {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: -.6px;
      margin: 0 0 8px;
      line-height: 1.2;
    }
    .hero p {
      margin: 0;
      font-size: 14.5px;
      opacity: .9;
      max-width: 460px;
      line-height: 1.55;
    }

    /* ── Card layout ── */
    .container {
      max-width: 560px;
      margin: -36px auto 0;
      padding: 0 14px 40px;
      position: relative;
    }
    .card {
      background: var(--card);
      border-radius: 18px;
      box-shadow: 0 4px 24px rgba(15,23,42,.08);
      border: 1px solid var(--border);
      overflow: hidden;
      margin-bottom: 14px;
    }
    .card-head {
      padding: 16px 20px;
      border-bottom: 1px solid #f0f4ff;
      background: linear-gradient(135deg, #f8faff, #f0f4ff);
      display: flex; align-items: center; justify-content: space-between;
    }
    .card-head h2 {
      margin: 0;
      font-size: 13.5px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: .1px;
    }
    .card-body { padding: 18px 20px; }

    /* ── Customer info ── */
    .cust-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    @media (max-width: 380px) {
      .cust-grid { grid-template-columns: 1fr; }
    }
    .cust-field {
      display: flex; flex-direction: column; gap: 3px;
    }
    .cust-label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: .07em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .cust-value {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      word-break: break-word;
    }
    .cust-value.mono {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 13px;
    }
    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px;
      border-radius: 100px;
      background: var(--red-soft);
      color: #dc2626;
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: .1px;
      width: fit-content;
    }
    .status-pill::before {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #dc2626;
      box-shadow: 0 0 0 3px #fecaca;
      animation: pulse 1.6s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 3px #fecaca; }
      50%      { box-shadow: 0 0 0 5px transparent; }
    }

    /* ── Total tagihan banner ── */
    .total-banner {
      background: linear-gradient(135deg, #fef3c7, #fde68a);
      border: 1.5px solid #fbbf24;
      border-radius: 14px;
      padding: 16px 18px;
      margin-bottom: 14px;
      display: flex; align-items: center; gap: 14px;
    }
    .total-banner-icon {
      width: 44px; height: 44px;
      border-radius: 11px;
      background: #fff;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 1px 4px rgba(180,83,9,.12);
    }
    .total-banner-text { flex: 1; min-width: 0; }
    .total-banner-label {
      font-size: 11.5px;
      font-weight: 600;
      color: #92400e;
      margin-bottom: 2px;
    }
    .total-banner-amount {
      font-size: 22px;
      font-weight: 800;
      color: #78350f;
      letter-spacing: -.5px;
      line-height: 1.1;
    }

    /* ── Invoice list ── */
    .inv-list { padding: 0; }
    .inv-row {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 20px;
      border-bottom: 1px solid #f0f4ff;
    }
    .inv-row:last-child { border-bottom: none; }
    .inv-info { flex: 1; min-width: 0; }
    .inv-num {
      font-family: 'DM Mono', ui-monospace, monospace;
      font-size: 12px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 2px;
    }
    .inv-due {
      font-size: 11.5px;
      color: var(--muted);
    }
    .inv-due.overdue { color: #dc2626; font-weight: 600; }
    .inv-amount {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -.2px;
      flex-shrink: 0;
      font-family: 'DM Mono', ui-monospace, monospace;
    }

    /* ── CTA buttons ── */
    .cta-stack {
      display: flex; flex-direction: column; gap: 10px;
    }
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      padding: 14px 18px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 700;
      font-family: inherit;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: transform .12s, box-shadow .15s, opacity .15s;
      -webkit-tap-highlight-color: transparent;
    }
    .btn:active { transform: scale(.98); }
    .btn-primary {
      background: linear-gradient(135deg, #1a6ef5, #0047cc);
      color: #fff;
      box-shadow: 0 4px 14px rgba(26,110,245,.35);
    }
    .btn-primary:hover { box-shadow: 0 6px 18px rgba(26,110,245,.45); }
    .btn-success {
      background: linear-gradient(135deg, #16a34a, #15803d);
      color: #fff;
      box-shadow: 0 4px 14px rgba(22,163,74,.35);
    }
    .btn-success:hover { box-shadow: 0 6px 18px rgba(22,163,74,.45); }
    .btn-ghost {
      background: #f4f8ff;
      color: var(--text);
      border: 1.5px solid var(--border);
    }
    .btn-ghost:hover { background: #eef2f9; }

    /* ── Footer ── */
    .footer {
      text-align: center;
      padding: 18px 20px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.6;
    }
    .footer .ip-tag {
      display: inline-block;
      font-family: 'DM Mono', monospace;
      background: #fff;
      padding: 2px 7px;
      border-radius: 5px;
      font-size: 11px;
      color: #475569;
      border: 1px solid var(--border);
    }

    /* ── Empty / Not Found state ── */
    .nf-state {
      text-align: center;
      padding: 36px 20px;
    }
    .nf-icon {
      width: 64px; height: 64px;
      margin: 0 auto 14px;
      border-radius: 16px;
      background: #f1f5f9;
      display: flex; align-items: center; justify-content: center;
    }
    .nf-icon svg { width: 30px; height: 30px; color: var(--muted); }
    .nf-title {
      font-size: 16px; font-weight: 700;
      color: var(--text); margin: 0 0 6px;
    }
    .nf-sub {
      font-size: 13px;
      color: var(--muted);
      margin: 0 auto;
      max-width: 360px;
    }

    /* ── Animations ── */
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .anim-1 { animation: slideUp .4s .05s ease both; }
    .anim-2 { animation: slideUp .4s .15s ease both; }
    .anim-3 { animation: slideUp .4s .25s ease both; }
    .anim-4 { animation: slideUp .4s .35s ease both; }
  </style>
</head>
<body>

<!-- ═══════════ HERO ═══════════ -->
<div class="hero">
  <div class="hero-inner">
    <div class="hero-brand">
      <% if (brand.logo_url) { %>
        <img src="<%= brand.logo_url %>" alt="">
      <% } %>
      <span><%= brand.company_name || brand.app_name || 'ISP NetOps' %></span>
    </div>
    <div class="hero-icon">
      <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
    </div>
    <h1>Layanan Anda Sedang Diisolir</h1>
    <p>Akses internet Anda diblokir karena ada tagihan yang belum dibayar. Selesaikan pembayaran untuk mengaktifkan kembali layanan Anda.</p>
  </div>
</div>

<div class="container">

<% if (customer) { %>

  <!-- ═══════════ CUSTOMER INFO ═══════════ -->
  <div class="card anim-1">
    <div class="card-head">
      <h2>Informasi Pelanggan</h2>
      <span class="status-pill">Diisolir</span>
    </div>
    <div class="card-body">
      <div class="cust-grid">
        <div class="cust-field">
          <span class="cust-label">Nama</span>
          <span class="cust-value"><%= customer.name %></span>
        </div>
        <div class="cust-field">
          <span class="cust-label">ID Pelanggan</span>
          <span class="cust-value mono"><%= customer.customer_id %></span>
        </div>
        <% if (customer.package_name) { %>
        <div class="cust-field">
          <span class="cust-label">Paket</span>
          <span class="cust-value"><%= customer.package_name %></span>
        </div>
        <% } %>
        <% if (customer.static_ip) { %>
        <div class="cust-field">
          <span class="cust-label">IP Anda</span>
          <span class="cust-value mono"><%= customer.static_ip %></span>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ═══════════ TAGIHAN ═══════════ -->
  <% if (invoices && invoices.length > 0) {
       const totalDue = invoices.reduce((s, i) => s + parseFloat(i.amount || 0), 0);
       const fmtIDR = n => 'Rp ' + Number(n||0).toLocaleString('id-ID');
       const fmtDate = d => {
         if(!d) return '-';
         const dt = new Date(d);
         const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Ags','Sep','Okt','Nov','Des'];
         return dt.getDate() + ' ' + months[dt.getMonth()] + ' ' + dt.getFullYear();
       };
       const today = new Date();
       today.setHours(0,0,0,0);
  %>

  <div class="total-banner anim-2">
    <div class="total-banner-icon">
      <svg width="22" height="22" fill="none" stroke="#d97706" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <div class="total-banner-text">
      <div class="total-banner-label">Total tunggakan (<%= invoices.length %> tagihan)</div>
      <div class="total-banner-amount"><%= fmtIDR(totalDue) %></div>
    </div>
  </div>

  <div class="card anim-3">
    <div class="card-head">
      <h2>Rincian Tagihan</h2>
    </div>
    <div class="inv-list">
      <% invoices.forEach((inv) => {
        const due = inv.due_date ? new Date(inv.due_date) : null;
        const isOverdue = due && due < today;
      %>
      <div class="inv-row">
        <div class="inv-info">
          <div class="inv-num"><%= inv.invoice_number || ('#' + inv.id) %></div>
          <div class="inv-due <%= isOverdue ? 'overdue' : '' %>">
            Jatuh tempo: <%= fmtDate(inv.due_date) %>
            <% if (isOverdue) { %> · Telat<% } %>
          </div>
        </div>
        <div class="inv-amount"><%= fmtIDR(inv.amount) %></div>
      </div>
      <% }); %>
    </div>
  </div>

  <% } %>

  <!-- ═══════════ ACTIONS ═══════════ -->
  <div class="cta-stack anim-4">
    <a href="/portal/login" class="btn btn-primary">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-2M7 12h14m0 0l-3-3m3 3l-3 3"/>
      </svg>
      Masuk ke Portal Pelanggan
    </a>

    <% if (brand.company_whatsapp) {
         const waNum = String(brand.company_whatsapp).replace(/[^\d]/g,'').replace(/^0/,'62');
         const waMsg = encodeURIComponent(`Halo, saya ${customer.name} (ID: ${customer.customer_id}) ingin konfirmasi pembayaran tagihan internet.`);
    %>
    <a href="https://wa.me/<%= waNum %>?text=<%= waMsg %>" class="btn btn-success" target="_blank" rel="noopener">
      <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Hubungi WhatsApp Admin
    </a>
    <% } %>
  </div>

<% } else { %>

  <!-- ═══════════ NOT FOUND (IP tidak ter-mapping ke customer) ═══════════ -->
  <div class="card anim-1">
    <div class="nf-state">
      <div class="nf-icon">
        <svg fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h3 class="nf-title">Akses Anda Sedang Diisolir</h3>
      <p class="nf-sub">
        Sistem tidak dapat mengidentifikasi akun Anda secara otomatis dari IP ini.
        Silakan hubungi admin untuk informasi lebih lanjut atau masuk ke portal pelanggan.
      </p>
    </div>
  </div>

  <div class="cta-stack anim-2">
    <a href="/portal/login" class="btn btn-primary">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
      </svg>
      Masuk ke Portal Pelanggan
    </a>
    <% if (brand.company_whatsapp) {
         const waNum = String(brand.company_whatsapp).replace(/[^\d]/g,'').replace(/^0/,'62');
    %>
    <a href="https://wa.me/<%= waNum %>" class="btn btn-success" target="_blank" rel="noopener">
      Hubungi Admin via WhatsApp
    </a>
    <% } %>
  </div>

<% } %>

  <div class="footer">
    <% if (clientIp) { %>
      Diakses dari IP <span class="ip-tag"><%= clientIp %></span><br>
    <% } %>
    © <%= new Date().getFullYear() %> <%= brand.company_name || brand.app_name || 'ISP NetOps' %>
  </div>

</div>

</body>
</html>
