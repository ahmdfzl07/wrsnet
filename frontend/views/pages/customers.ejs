      <div style="font-size:10.5px;font-weight:600;color:#059669;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Valid</div>
      <div style="font-size:22px;font-weight:600;color:#065f46;line-height:1;">${s.valid}</div>
    </div>
    <div style="padding:14px 16px;background:#fff;border:1px solid #fecaca;border-radius:10px;">
      <div style="font-size:10.5px;font-weight:600;color:#dc2626;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Error</div>
      <div style="font-size:22px;font-weight:600;color:#991b1b;line-height:1;">${s.invalid}</div>
    </div>
    <div style="padding:14px 16px;background:#fff;border:1px solid #bfdbfe;border-radius:10px;">
      <div style="font-size:10.5px;font-weight:600;color:#1d4ed8;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Buat baru / update</div>
      <div style="font-size:18px;font-weight:600;color:#1e3a8a;line-height:1;">${s.toCreate} <span style="color:#94a3b8;font-weight:400;">/</span> ${s.toUpdate}</div>
      ${autoSubtitle}
    </div>
  `;

  // Render rows
  const tbody = document.getElementById('importPreviewRows');
