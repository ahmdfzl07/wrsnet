<script>
/* ── Extra stat update from loadCustomerStats ── */
const _origStats = window.loadCustomerStats;

/* applyFilter — set dropdown + reload */
window.applyFilter = function(status) {
  const sel = document.getElementById('filterStatus');
  if (sel) sel.value = status;
  window._custPage = 1;
  if (typeof loadCustomers === 'function') loadCustomers();
};

/* custCardClick — active state + filter sync */
window.custCardClick = function(el) {
  const COLORS = { total:'#2563eb', overdue:'#c2410c', duesoon:'#d97706', revenue:'#16a34a' };
  const FILTER  = { total:'', overdue:'overdue', duesoon:'due_soon', revenue:'' };
  const key = el.id.replace('xc-','');
  const was = el.classList.contains('fc-active');

  document.querySelectorAll('.fin-card[data-filter]').forEach(card => {
    card.classList.remove('fc-active');
    const k   = card.id.replace('xc-','');
    const col = COLORS[k] || '#64748b';
    const l = card.querySelector('.sp-line'), f = card.querySelector('.sp-fill'), d = card.querySelector('.sp-dot');
    if(l) l.style.stroke = col;
    if(f) f.style.fill   = col;
    if(d) d.style.fill   = col;
  });

  if (!was) {
    el.classList.add('fc-active');
    const l = el.querySelector('.sp-line'), f = el.querySelector('.sp-fill'), d = el.querySelector('.sp-dot');
    if(l) l.style.stroke = 'rgba(255,255,255,.70)';
    if(f) f.style.fill   = 'rgba(255,255,255,.12)';
    if(d) d.style.fill   = '#fff';
  }

  const sel = document.getElementById('filterStatus');
  if (sel) sel.value = was ? '' : (FILTER[key] || '');
  window._custPage = 1;
  if (typeof loadCustomers === 'function') loadCustomers();
};

