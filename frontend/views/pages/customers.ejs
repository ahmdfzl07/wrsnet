<script>
// ── Import / Export Customer Logic ─────────────────────────────────
let _importToken = null;
let _importValidCount = 0;

// Pindahkan dropdown ke body root saat halaman siap, supaya 100% lepas
// dari stacking context parent manapun.

(function ensureMenuAtBodyRoot() {
  const move = () => {
    const menu = document.getElementById('importExportMenu');
    if (menu && menu.parentElement !== document.body) {
      document.body.appendChild(menu);
    }
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', move);
  } else {
    move();
  }
})();

// Toggle dropdown — posisi dynamic relative ke tombol
function toggleImpExpMenu(e) {
  if (e) { e.stopPropagation(); e.preventDefault(); }
  const menu = document.getElementById('importExportMenu');
  const btn = document.getElementById('importExportToggleBtn');
  if (!menu || !btn) return;

  if (menu.classList.contains('show')) {
    menu.classList.remove('show');
    return;
  }

  // Hitung posisi: di bawah tombol, align kanan
  const rect = btn.getBoundingClientRect();
  const menuWidth = 280; // sesuai min-width
  let left = rect.right - menuWidth; // align kanan tombol
  let top = rect.bottom + 8;

  // Pastikan tidak keluar viewport kiri
  if (left < 8) left = 8;
  // Kalau menu tidak muat ke bawah, tampilkan ke atas
  if (top + 280 > window.innerHeight) {
    top = rect.top - 280 - 8;
    if (top < 8) top = 8;
  }

  menu.style.top  = top + 'px';
  menu.style.left = left + 'px';
  menu.classList.add('show');
}

// Tutup saat klik di luar
document.addEventListener('click', (e) => {
  const menu = document.getElementById('importExportMenu');
  const btn = document.getElementById('importExportToggleBtn');
  if (!menu || !menu.classList.contains('show')) return;
  // Klik di dalam menu atau tombol → biarkan
  if (menu.contains(e.target) || (btn && btn.contains(e.target))) return;
  menu.classList.remove('show');
});

// Tutup saat scroll halaman atau resize (supaya tidak nyangkut di posisi lama)
let _impExpClosing;
window.addEventListener('scroll', () => {
  const menu = document.getElementById('importExportMenu');
  if (menu && menu.classList.contains('show')) menu.classList.remove('show');
}, true);
window.addEventListener('resize', () => {
  const menu = document.getElementById('importExportMenu');
  if (menu && menu.classList.contains('show')) menu.classList.remove('show');
});

// Tutup dengan Escape
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    const menu = document.getElementById('importExportMenu');
    if (menu) menu.classList.remove('show');
  }
});

function exportCustomers() {
  document.getElementById('importExportMenu').classList.remove('show');
  // Trigger download via iframe (supaya tidak meninggalkan halaman)
  const token = document.cookie.match(/token=([^;]+)/)?.[1] || localStorage.getItem('token') || '';
  // Pakai window.open dengan auth — tapi browser tidak set Authorization untuk navigation.
  // Solusi: pakai fetch + blob download.
  App.showToast('Sedang menyiapkan file...', 'info');
  fetch('/api/customers/export', {
    headers: token ? { 'Authorization': 'Bearer ' + token } : {},
    credentials: 'include',
  }).then(res => {
    if (!res.ok) throw new Error('HTTP ' + res.status);
    return res.blob();
  }).then(blob => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `customers-export-${new Date().toISOString().slice(0,10)}.xlsx`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
    App.showToast('Export berhasil!', 'success');
  }).catch(err => {
    App.showToast('Export gagal: ' + err.message, 'error');
  });
}

function downloadTemplate() {
  document.getElementById('importExportMenu').classList.remove('show');
  const token = document.cookie.match(/token=([^;]+)/)?.[1] || localStorage.getItem('token') || '';
  App.showToast('Generating template...', 'info');
  fetch('/api/customers/import-template', {
    headers: token ? { 'Authorization': 'Bearer ' + token } : {},
    credentials: 'include',
  }).then(res => {
    if (!res.ok) throw new Error('HTTP ' + res.status);
    return res.blob();
  }).then(blob => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'customers-import-template.xlsx';
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  }).catch(err => {
    App.showToast('Gagal download template: ' + err.message, 'error');
  });
}

function openImportModal() {
  document.getElementById('importExportMenu').classList.remove('show');
  document.getElementById('importModal').style.display = 'flex';
  importBackToStep1();
}

function closeImportModal() {
  document.getElementById('importModal').style.display = 'none';
  _importToken = null;
}

function importBackToStep1() {
  document.getElementById('importStep1').style.display = 'block';
  document.getElementById('importStep2').style.display = 'none';
  document.getElementById('importStep3').style.display = 'none';
  document.getElementById('importBackBtn').style.display = 'none';
  document.getElementById('importConfirmBtn').style.display = 'none';
  document.getElementById('importCancelBtn').textContent = 'Batal';
  document.getElementById('importModalSubtitle').textContent = 'Upload file .xlsx — preview dulu sebelum import.';
  document.getElementById('importFileInput').value = '';
  _importToken = null;
}

function handleImportDrop(e) {
  e.preventDefault();
  e.currentTarget.style.borderColor = '';
  e.currentTarget.style.background = '#f8faff';
  const file = e.dataTransfer.files[0];
  if (file) handleImportFile(file);
}

async function handleImportFile(file) {
  if (!file) return;
  const ext = (file.name.split('.').pop() || '').toLowerCase();
  if (!['xlsx', 'xls'].includes(ext)) {
    App.showToast('Hanya format .xlsx atau .xls yang didukung', 'error');
    return;
  }
  if (file.size > 5 * 1024 * 1024) {
    App.showToast('File terlalu besar. Maksimal 5 MB', 'error');
    return;
  }

  // Show loading
  document.getElementById('importDropArea').innerHTML = `
    <div style="padding:20px;">
      <svg class="spinner" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1a6ef5" stroke-width="2">
        <circle cx="12" cy="12" r="10" stroke-opacity=".25"/>
        <path d="M22 12a10 10 0 0 1-10 10" stroke-linecap="round">
          <animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="1s" repeatCount="indefinite"/>
        </path>
      </svg>
      <div style="font-size:14px;font-weight:600;color:var(--d-text);margin-top:10px;">Membaca file...</div>
      <div style="font-size:12px;color:var(--d-muted);">${file.name}</div>
    </div>
  `;

  const form = new FormData();
  form.append('file', file);

  try {
    const token = document.cookie.match(/token=([^;]+)/)?.[1] || localStorage.getItem('token') || '';
    const res = await fetch('/api/customers/import-preview', {
      method: 'POST',
      headers: token ? { 'Authorization': 'Bearer ' + token } : {},
      body: form,
    });
    const d = await res.json();
    if (!d.success) {
      App.showToast(d.message || 'Gagal parse file', 'error');
      importBackToStep1();
      return;
    }
    showImportPreview(d);
  } catch (err) {
    App.showToast('Error: ' + err.message, 'error');
    importBackToStep1();
  }
}

