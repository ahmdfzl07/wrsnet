    const statusBadge = r.valid 
      ? `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:#ecfdf5;color:#047857;border-radius:6px;font-size:11px;font-weight:600;">
           <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
           Valid
         </span>`
      : `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;background:#fef2f2;color:#b91c1c;border-radius:6px;font-size:11px;font-weight:600;">
           <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
           Error
         </span>`;
    let actionBadge;
    if (r.action === 'create_auto') {
      actionBadge = `<span style="display:inline-flex;align-items:center;gap:4px;color:#475569;font-weight:600;font-size:12.5px;" title="ID akan di-generate otomatis">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Auto
      </span>`;
    } else if (r.action === 'create') {
      actionBadge = `<span style="display:inline-flex;align-items:center;gap:4px;color:#059669;font-weight:600;font-size:12.5px;">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Baru
      </span>`;
    } else {
      actionBadge = `<span style="display:inline-flex;align-items:center;gap:4px;color:#0284c7;font-weight:600;font-size:12.5px;">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M5 9a8 8 0 0114-3M19 15a8 8 0 01-14 3"/></svg>
        Update
      </span>`;
    }
    // Tampilkan placeholder untuk ID yang akan auto-generate
    const customerIdDisplay = r.action === 'create_auto'
      ? `<span style="color:#94a3b8;font-style:italic;font-family:inherit;">akan dibuat</span>`
      : `<span style="font-family:'DM Mono',monospace;color:#0f172a;">${escapeHtml(r.data.customer_id || '')}</span>`;
    const notes = [
      ...(r.errors || []).map(e => `<div style="display:flex;gap:4px;align-items:flex-start;color:#dc2626;font-size:11.5px;">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:3px;"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4M12 16h.01"/></svg>
        <span>${escapeHtml(e)}</span></div>`),
      ...(r.warnings || []).map(w => `<div style="display:flex;gap:4px;align-items:flex-start;color:#d97706;font-size:11.5px;">
        <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:3px;"><path stroke-linecap="round" stroke-linejoin="round" d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/></svg>
        <span>${escapeHtml(w)}</span></div>`),
    ].join('') || '<span style="color:#cbd5e1;font-size:12px;">—</span>';
    return `<tr style="border-bottom:1px solid #f1f5f9;${!r.valid ? 'background:#fef2f2;' : ''}">
      <td style="padding:9px 12px;color:#94a3b8;font-size:12px;">${r.rowNumber}</td>
      <td style="padding:9px 12px;">${statusBadge}</td>
      <td style="padding:9px 12px;font-size:12.5px;">${customerIdDisplay}</td>
      <td style="padding:9px 12px;color:#0f172a;font-size:12.5px;">${escapeHtml(r.data.name || '')}</td>
      <td style="padding:9px 12px;color:#64748b;font-size:12px;">${escapeHtml(r.data.phone || '')}</td>
      <td style="padding:9px 12px;color:#64748b;font-size:12px;">${escapeHtml(r.data.package_name || '')}</td>
      <td style="padding:9px 12px;">${actionBadge}</td>
      <td style="padding:9px 12px;">${notes}</td>
    </tr>`;
  }).join('');
}

async function confirmImport() {
  if (!_importToken) {
    App.showToast('Sesi import sudah expired. Silakan upload ulang.', 'error');
    return;
  }
  const mode = document.getElementById('importMode').value;
  const btn = document.getElementById('importConfirmBtn');
  btn.disabled = true;
  btn.textContent = 'Mengimport...';

  try {
    const res = await App.api('/customers/import-confirm', {
      method: 'POST',
      body: JSON.stringify({ importToken: _importToken, mode }),
    });
    if (res.success) {
      showImportResult(res.summary, res.errors, res.generatedIds);
    } else {
      App.showToast(res.message || 'Import gagal', 'error');
      btn.disabled = false;
      btn.textContent = `Import ${_importValidCount} Baris`;
    }
  } catch (err) {
    App.showToast('Error: ' + err.message, 'error');
    btn.disabled = false;
    btn.textContent = `Import ${_importValidCount} Baris`;
  }
}

function showImportResult(summary, errors, generatedIds) {
  document.getElementById('importStep2').style.display = 'none';
  document.getElementById('importStep3').style.display = 'block';
  document.getElementById('importBackBtn').style.display = 'none';
  document.getElementById('importConfirmBtn').style.display = 'none';
  document.getElementById('importCancelBtn').textContent = 'Tutup';
  document.getElementById('importModalSubtitle').textContent = 'Import selesai.';

  const errorListHtml = (errors && errors.length > 0)
    ? `<div style="margin-top:18px;padding:14px;background:#fff;border:1px solid #fecaca;border-radius:10px;text-align:left;max-height:180px;overflow:auto;">
        <div style="display:flex;align-items:center;gap:6px;font-weight:600;color:#b91c1c;margin-bottom:8px;font-size:12.5px;">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4M12 16h.01"/></svg>
          Beberapa baris gagal:
        </div>
        ${errors.map(e => `<div style="font-size:11.5px;color:#7f1d1d;padding:2px 0;">
          <code style="background:#fef2f2;padding:1px 5px;border-radius:4px;font-family:'DM Mono',monospace;">${escapeHtml(e.customer_id)}</code>
          <span style="margin-left:6px;color:#991b1b;">${escapeHtml(e.message)}</span>
        </div>`).join('')}
      </div>`
    : '';

  // List ID auto-generate (kalau ada)
  const generatedListHtml = (generatedIds && generatedIds.length > 0)
    ? `<div style="margin-top:18px;padding:14px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;text-align:left;max-height:200px;overflow:auto;">
        <div style="display:flex;align-items:center;gap:6px;font-weight:600;color:#0f172a;margin-bottom:8px;font-size:12.5px;">
          <svg width="14" height="14" fill="none" stroke="#475569" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          ID auto-generate (${generatedIds.length}):
        </div>
        ${generatedIds.map(g => `<div style="font-size:12px;display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f8fafc;">
          <span style="color:#475569;">${escapeHtml(g.name)}</span>
          <code style="font-weight:600;color:#0f172a;background:#f1f5f9;padding:1px 6px;border-radius:4px;font-family:'DM Mono',monospace;font-size:11.5px;">${escapeHtml(g.customer_id)}</code>
        </div>`).join('')}
      </div>`
    : '';

  // Card auto-generate (hanya kalau ada)
  const autoCard = (summary.createdAuto && summary.createdAuto > 0)
    ? `<div style="padding:14px 16px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;">
        <div style="font-size:10.5px;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">ID otomatis</div>
        <div style="font-size:22px;font-weight:600;color:#0f172a;line-height:1;">${summary.createdAuto}</div>
      </div>`
    : '';

  // Hitung jumlah card untuk grid layout
  const cardCount = 4 + (autoCard ? 1 : 0);

  document.getElementById('importResultContent').innerHTML = `
    <div style="width:64px;height:64px;border-radius:50%;background:#ecfdf5;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
      <svg width="30" height="30" fill="none" stroke="#059669" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h3 style="margin:0 0 4px;font-size:18px;font-weight:600;color:#0f172a;letter-spacing:-.01em;">Import selesai</h3>
    <p style="margin:0 0 22px;color:#64748b;font-size:13px;">Berikut ringkasan hasil import:</p>
    <div style="display:grid;grid-template-columns:repeat(${cardCount},1fr);gap:10px;max-width:640px;margin:0 auto;">
      <div style="padding:14px 16px;background:#fff;border:1px solid #d1fae5;border-radius:10px;">
        <div style="font-size:10.5px;font-weight:600;color:#059669;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Berhasil dibuat</div>
        <div style="font-size:22px;font-weight:600;color:#065f46;line-height:1;">${summary.created}</div>
      </div>
      ${autoCard}
      <div style="padding:14px 16px;background:#fff;border:1px solid #bfdbfe;border-radius:10px;">
        <div style="font-size:10.5px;font-weight:600;color:#1d4ed8;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Diupdate</div>
        <div style="font-size:22px;font-weight:600;color:#1e3a8a;line-height:1;">${summary.updated}</div>
      </div>
      <div style="padding:14px 16px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;">
        <div style="font-size:10.5px;font-weight:600;color:#64748b;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Dilewati</div>
        <div style="font-size:22px;font-weight:600;color:#334155;line-height:1;">${summary.skipped}</div>
      </div>
      <div style="padding:14px 16px;background:#fff;border:1px solid #fecaca;border-radius:10px;">
        <div style="font-size:10.5px;font-weight:600;color:#dc2626;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px;">Gagal</div>
        <div style="font-size:22px;font-weight:600;color:#991b1b;line-height:1;">${summary.failed}</div>
      </div>
    </div>
    ${generatedListHtml}
    ${errorListHtml}
    <div style="margin-top:22px;">
      <button onclick="closeImportModal();location.reload();" class="btn-fin btn-primary-fin">Selesai &amp; refresh halaman</button>
    </div>
  `;
}

function escapeHtml(s) {
  return String(s == null ? '' : s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

